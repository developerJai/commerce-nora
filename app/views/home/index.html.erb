<!-- Section: Trending Now - Hot Items -->
<%= render "home/sections/trending" %>

<% if @homepage_settings&.promo_banner_enabled? %>
<!-- Promotional Banner -->
<section class="py-6 sm:py-8 md:py-12">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="bg-gradient-to-r from-rose-800 to-rose-900 rounded-xl sm:rounded-2xl p-5 sm:p-8 md:p-10 text-center sm:text-left relative overflow-hidden">
      <!-- Decorative -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-amber-500/10 rounded-full -translate-y-1/2 translate-x-1/4"></div>
      
      <div class="relative sm:flex items-center justify-between">
        <div class="mb-4 sm:mb-0">
          <p class="text-rose-200 text-xs sm:text-sm font-medium mb-1"><%= @homepage_settings.promo_banner_title %></p>
          <h3 class="text-xl sm:text-2xl md:text-3xl font-serif font-semibold text-white mb-2"><%= @homepage_settings.promo_banner_heading %></h3>
          <% if @homepage_settings.promo_code_display.present? %>
            <p class="text-rose-100 text-xs sm:text-sm">Use code <span class="font-mono bg-white/20 px-2 py-0.5 rounded text-white font-semibold"><%= @homepage_settings.promo_banner_code %></span></p>
          <% end %>
        </div>
        <%= link_to @homepage_settings.promo_banner_cta_text, @homepage_settings.promo_banner_cta_link, class: 'inline-block px-5 sm:px-6 py-2.5 sm:py-3 bg-white text-rose-900 text-sm sm:text-base font-medium rounded-full hover:bg-rose-50 transition' %>
      </div>
    </div>
  </div>
</section>
<% end %>

