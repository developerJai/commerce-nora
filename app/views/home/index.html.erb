<% content_for(:title) { "Fine Jewellery" } %>
<% content_for(:hide_header_search) { true } %>

<!-- Hero Section -->
<section class="bg-gradient-to-b from-rose-50 to-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-16">
    <div class="text-center">
      <p class="text-rose-700 text-sm font-medium tracking-widest uppercase mb-2">Timeless Elegance</p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-serif font-semibold text-stone-900 mb-4">
        Discover Exquisite Jewellery
      </h1>
      <p class="text-stone-600 mb-8 max-w-md mx-auto">
        Handcrafted with love, designed to celebrate life's precious moments
      </p>
      
      <!-- Search Bar -->
      <div class="max-w-lg mx-auto" data-controller="search-autocomplete">
        <%= form_with url: search_path, method: :get, class: 'relative' do |f| %>
          <div class="relative">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="search" name="q" value="<%= params[:q] %>" 
                   placeholder="Search rings, earrings, necklaces..." 
                   class="w-full h-12 sm:h-14 pl-12 pr-28 text-stone-800 bg-white rounded-full border border-stone-200 shadow-sm focus:ring-2 focus:ring-rose-400 focus:border-transparent placeholder:text-stone-400 text-sm"
                   autocomplete="off"
                   data-search-autocomplete-target="input"
                   data-action="input->search-autocomplete#search focus->search-autocomplete#search">
            <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 h-8 sm:h-10 px-5 sm:px-6 bg-rose-800 hover:bg-rose-900 text-white text-sm font-medium rounded-full transition">
              Search
            </button>
          </div>
          
          <div data-search-autocomplete-target="results" 
               class="absolute top-full left-0 right-0 mt-2 bg-white rounded-xl shadow-xl border border-stone-200 overflow-hidden hidden z-50 text-left max-h-[60vh] overflow-y-auto">
          </div>
        <% end %>
      </div>

      <!-- Category Pills -->
      <div class="mt-8 flex flex-wrap justify-center gap-2 sm:gap-3">
        <% Category.active.root.ordered.limit(6).each do |category| %>
          <%= link_to category.name, category_path(category.slug), 
              class: 'px-4 py-2 bg-white text-stone-600 text-sm rounded-full border border-stone-200 hover:border-rose-300 hover:text-rose-800 transition shadow-sm' %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- Banner Carousel -->
<% if @banners.any? %>
<section class="py-4 sm:py-6" data-controller="carousel">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="relative rounded-2xl overflow-hidden">
      <% @banners.each_with_index do |banner, index| %>
        <div class="relative h-44 sm:h-64 md:h-80 <%= index > 0 ? 'hidden' : '' %>" data-carousel-target="slide">
          <% if banner.image.attached? %>
            <%= image_tag banner.image, class: 'w-full h-full object-cover' %>
          <% else %>
            <%= image_tag asset_path('storefront/home/discount-banner.png'), class: 'w-full h-full object-cover' %>
            <%# <div class="w-full h-full bg-gradient-to-r from-rose-100 to-amber-50"></div> %>
          <% end %>
          <div class="absolute inset-0 bg-gradient-to-r from-stone-900/60 via-stone-900/30 to-transparent flex items-center">
            <div class="px-6 sm:px-10 md:px-16">
              <h2 class="text-xl sm:text-3xl md:text-4xl font-serif font-semibold text-white mb-2"><%= banner.title %></h2>
              <% if banner.subtitle.present? %>
                <p class="text-sm sm:text-base text-white/90 mb-4 max-w-md"><%= banner.subtitle %></p>
              <% end %>
              <% if banner.link_url.present? %>
                <%= link_to 'Shop Now', banner.link_url, class: 'inline-block px-6 py-2.5 bg-white text-stone-900 text-sm font-medium rounded-full hover:bg-rose-50 transition' %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- Homepage Collections -->
<% @homepage_collections.each do |collection| %>
  <% if collection.items.any? %>
    <%= render 'home/homepage_collection', collection: collection %>
  <% end %>
<% end %>

<!-- Shop by Category -->
<section class="py-8 sm:py-12">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="text-center mb-6 sm:mb-8">
      <h2 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900">Shop by Category</h2>
    </div>
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4 sm:gap-6">
      <% Category.active.root.ordered.limit(6).each do |category| %>
        <%= link_to category_path(category.slug), class: 'group text-center' do %>
          <div class="aspect-square bg-gradient-to-br from-rose-50 to-amber-50 rounded-full flex items-center justify-center mb-3 group-hover:from-rose-100 group-hover:to-amber-100 transition mx-auto w-16 h-16 sm:w-20 sm:h-20">
            <svg class="w-7 h-7 sm:w-9 sm:h-9 text-rose-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
            </svg>
          </div>
          <p class="text-xs sm:text-sm font-medium text-stone-700 group-hover:text-rose-800 transition"><%= category.name %></p>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<!-- Bestsellers -->
<section class="py-8 sm:py-12 bg-white">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900">Bestsellers</h2>
        <p class="text-sm text-stone-500 mt-1 hidden sm:block">Most loved by our customers</p>
      </div>
      <%= link_to 'View All', products_path, class: 'text-rose-700 hover:text-rose-900 text-sm font-medium' %>
    </div>
    
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-4">
      <% @featured_products.each do |product| %>
        <%= render 'shared/product_card', product: product %>
      <% end %>
    </div>
  </div>
</section>

<!-- Promotional Banner -->
<section class="py-8 sm:py-12">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="bg-gradient-to-r from-rose-800 to-rose-900 rounded-2xl p-6 sm:p-10 text-center sm:text-left relative overflow-hidden">
      <!-- Decorative -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-amber-500/10 rounded-full -translate-y-1/2 translate-x-1/4"></div>
      
      <div class="relative sm:flex items-center justify-between">
        <div class="mb-4 sm:mb-0">
          <p class="text-rose-200 text-sm font-medium mb-1">First Order Offer</p>
          <h3 class="text-2xl sm:text-3xl font-serif font-semibold text-white mb-2">Get 10% Off</h3>
          <p class="text-rose-100 text-sm">Use code <span class="font-mono bg-white/20 px-2 py-0.5 rounded text-white font-semibold">WELCOME10</span></p>
        </div>
        <%= link_to 'Shop Now', products_path, class: 'inline-block px-6 py-3 bg-white text-rose-900 font-medium rounded-full hover:bg-rose-50 transition' %>
      </div>
    </div>
  </div>
</section>

<!-- New Arrivals -->
<% if @new_arrivals.any? %>
<section class="py-8 sm:py-12 bg-white">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900">New Arrivals</h2>
        <p class="text-sm text-stone-500 mt-1 hidden sm:block">Fresh designs just for you</p>
      </div>
      <%= link_to 'View All', products_path(sort: 'newest'), class: 'text-rose-700 hover:text-rose-900 text-sm font-medium' %>
    </div>
    
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-4">
      <% @new_arrivals.each do |product| %>
        <%= render 'shared/product_card', product: product %>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- Why Choose Us -->
