<% content_for(:title) { "Buy Fashion Jewellery, Gifts & Ethnic Wear Online" } %>
<% content_for(:native_title) { "Best Deals | Noralooks" } %>
<% content_for(:meta_description) { "Buy fashion jewellery, fashion jewellery, ethnic wear, traditional clothes & gifts online at Noralooks. Best prices on necklaces, earrings, bangles, jhumkas, kundan sets & more. Free shipping above #{format_price(free_delivery_threshold)}, quality checked, 24-hour dispatch. Shop now!" } %>
<% content_for(:meta_keywords) { ["buy fashion jewellery online", "buy fashion jewellery online India", "fashion jewellery shop", "ethnic wear online shopping", "traditional wear shopping", "imitation jewellery online", "costume jewellery India", "online gift shopping India", "jewellery store India", "affordable jewellery online", "women's jewellery online", "necklace set online India", "earrings online shopping", "bangles online", "jhumka earrings online", "kundan jewellery online", "oxidized jewellery online", "gifts for women online", "ethnic clothes online", "traditional Indian clothes", "saree online", "kurti online shopping"] } %>
<% content_for(:hide_header_search) { true } %>

<% content_for(:head) do %>
  <!-- Structured Data - Organization Schema -->
  <% home_store_setting = StoreSetting.instance %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Noralooks",
    "url": "<%= root_url %>",
    "logo": "<%= og_image_url %>",
    "description": "Buy fashion jewellery, fashion jewellery, ethnic wear, traditional clothes and gifts online at best prices in India",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "IN"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "Customer Service",
      "availableLanguage": ["English", "Hindi"]
    },
    "sameAs": [<%= home_store_setting.social_media_links.values.map { |url| "\"#{j url}\"" }.join(", ") %>]
  }
  </script>

  <!-- Structured Data - WebSite Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Noralooks",
    "url": "<%= root_url %>",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "<%= search_url %>?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <!-- Structured Data - Online Store Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Store",
    "name": "Noralooks",
    "image": "<%= og_image_url %>",
    "description": "Buy fashion jewellery, fashion jewellery, ethnic wear, traditional clothes and gifts online at best prices in India. Free shipping, quality checked, 24-hour dispatch.",
    "priceRange": "₹₹",
    "url": "<%= root_url %>",
    "telephone": "",
    "currenciesAccepted": "INR",
    "paymentAccepted": "UPI, Credit Card, Debit Card, Net Banking, COD",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Fashion Jewellery, Ethnic Wear & Gifts",
      "itemListElement": [
        {
          "@type": "OfferCatalog",
          "name": "Fashion Jewellery",
          "description": "Buy necklaces, earrings, bangles, jhumkas, kundan sets, oxidized jewellery online",
          "itemListElement": []
        },
        {
          "@type": "OfferCatalog",
          "name": "Ethnic Wear & Traditional Clothes",
          "description": "Shop sarees, kurtis, salwar suits and traditional Indian wear online",
          "itemListElement": []
        },
        {
          "@type": "OfferCatalog",
          "name": "Gifts",
          "description": "Unique gifts for women, birthday gifts, anniversary gifts, wedding gifts online",
          "itemListElement": []
        }
      ]
    }
  }
  </script>

  <!-- FAQPage Schema for common search queries -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Where can I buy fashion jewellery online in India?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can buy fashion jewellery online at Noralooks (www.noralooks.com). We offer a wide collection of necklaces, earrings, bangles, jhumkas, kundan sets, oxidized jewellery and more at affordable prices with free shipping above ₹499."
        }
      },
      {
        "@type": "Question",
        "name": "Is the jewellery quality checked before shipping?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, every product at Noralooks is quality checked and inspected before dispatch. We ensure 100% certified quality with all orders dispatched within 24 hours."
        }
      },
      {
        "@type": "Question",
        "name": "Do you offer free shipping on fashion jewellery?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, Noralooks offers free shipping on all orders above ₹499. Orders are dispatched within 24 hours and delivered in 3-5 business days across India."
        }
      },
      {
        "@type": "Question",
        "name": "Can I exchange or return jewellery purchased online?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, Noralooks offers easy exchange and return policies on most products. Check the individual product page for specific exchange and return days available."
        }
      }
    ]
  }
  </script>
<% end %>

<style>
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes shimmer-gold {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  @keyframes gentle-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out both;
  }
  .animate-shimmer-gold {
    background: linear-gradient(90deg, transparent 0%, rgba(217,175,105,0.15) 50%, transparent 100%);
    background-size: 200% 100%;
    animation: shimmer-gold 4s ease-in-out infinite;
  }
  .animate-gentle-float {
    animation: gentle-float 6s ease-in-out infinite;
  }
  .gold-divider {
    background: linear-gradient(90deg, transparent, #d4a853, transparent);
  }
  @keyframes wave-flow-1 {
    0%   { transform: translateX(0); }
    50%  { transform: translateX(-16%); }
    100% { transform: translateX(0); }
  }
  @keyframes wave-flow-2 {
    0%   { transform: translateX(0); }
    50%  { transform: translateX(12%); }
    100% { transform: translateX(0); }
  }
  .wave-1 { animation: wave-flow-1 10s ease-in-out infinite; }
  .wave-2 { animation: wave-flow-2 14s ease-in-out infinite; }
</style>


<!-- ═══════════════════════════════════════════════════════════ -->
<!-- HERO SECTION                                               -->
<!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative" style="background: linear-gradient(to bottom, #2B1B0E, #0F0F0F);">
  <!-- Base overlay for contrast -->
  <div class="absolute inset-0 pointer-events-none" style="background: rgba(15,15,15,0.75);"></div>
  <!-- Decorative overlays (clipped to section bounds) -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <!-- Subtle texture overlay -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, #d4a853 1px, transparent 0); background-size: 40px 40px;"></div>
    <!-- Gold ambient glow - top center, responsive for mobile -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] sm:w-[800px] md:w-[1000px] h-[420px] sm:h-[500px] md:h-[600px] bg-amber-600/[0.10] rounded-full blur-3xl"></div>
    <!-- Content-area warm halo - centered on logo + text block, responsive -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-[55%] w-[350px] sm:w-[600px] md:w-[750px] h-[300px] sm:h-[420px] md:h-[480px] bg-amber-400/[0.06] rounded-full blur-[90px]"></div>
    <!-- Rose accent glow - bottom right -->
    <div class="absolute bottom-0 right-0 w-[400px] h-[200px] bg-rose-800/[0.05] rounded-full blur-3xl"></div>
    <!-- Warm glow - left -->
    <div class="absolute top-1/2 left-0 w-[300px] h-[300px] bg-amber-700/[0.04] rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-4 sm:pt-10 sm:pb-8 md:pt-14 md:pb-10">
    <div class="text-center max-w-3xl mx-auto">
      <!-- Logo Mark -->
      <div class="mb-3 sm:mb-5">
        <%= image_tag asset_path('storefront/logo/nora-bag-trans.png'), class: 'w-40 h-40 sm:w-28 sm:h-32 md:w-36 md:h-36 mx-auto rounded-2xl sm:rounded-3xl shadow-2xl shadow-amber-900/40', alt: 'Noralooks' %>
      </div>

      <!-- Tagline -->
      <p class="inline-flex items-center gap-2.5 text-amber-400/80 text-[10px] sm:text-xs font-medium tracking-[0.3em] uppercase mb-4 sm:mb-5">
        <span class="w-6 sm:w-10 h-px bg-gradient-to-r from-transparent to-amber-500/50"></span>
        Timeless Elegance
        <span class="w-6 sm:w-10 h-px bg-gradient-to-l from-transparent to-amber-500/50"></span>
      </p>

      <!-- Heading with gold highlight -->
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-serif font-semibold mb-4 sm:mb-6 leading-tight tracking-tight">
        <span style="color: #F5F5F5;">Discover</span>
        <br class="sm:hidden">
        <span style="color: #D4AF37;"> <%= @hero_heading_highlight %></span>
      </h1>

      <!-- Subtext - warmer tone -->
      <p class="text-sm sm:text-base md:text-lg text-stone-400/90 mb-8 sm:mb-10 max-w-xl mx-auto leading-relaxed">
        Exquisite fashion jewellery, thoughtful gifts, and beautiful ethnic wear for every occasion
      </p>

      <!-- Search Bar - Desktop -->
      <div class="hidden sm:block max-w-xl mx-auto" data-controller="search-autocomplete">
        <%= form_with url: products_path, method: :get, class: 'relative', data: { turbo_frame: '_top' } do |f| %>
          <div class="relative group">
            <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5 text-stone-400 group-focus-within:text-amber-500 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="search" name="q" value="<%= params[:q] %>"
                   placeholder="<%= @search_placeholder %>"
                   class="w-full h-14 pl-13 pr-32 text-stone-800 bg-white/95 backdrop-blur-sm rounded-full border border-white/20 shadow-xl shadow-black/25 focus:bg-white focus:ring-2 focus:ring-amber-400/50 focus:border-transparent placeholder:text-stone-400 text-sm transition-all"
                   autocomplete="off"
                   data-search-autocomplete-target="input"
                   data-action="input->search-autocomplete#search focus->search-autocomplete#search keydown.enter->search-autocomplete#submitForm">
            <button type="button" data-search-autocomplete-target="clearButton" data-action="click->search-autocomplete#clearInput" class="hidden absolute right-28 top-1/2 -translate-y-1/2 p-1 text-stone-400 hover:text-stone-600">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            <button type="submit" class="absolute right-1.5 top-1/2 -translate-y-1/2 h-11 px-6 text-white text-sm font-medium rounded-full transition shadow-lg" style="background-color: #B8962E;" onmouseover="this.style.backgroundColor='#A6872A'" onmouseout="this.style.backgroundColor='#B8962E'">
              Search
            </button>
          </div>
          <div data-search-autocomplete-target="results"
               class="absolute top-full left-0 right-0 mt-2 bg-white rounded-xl shadow-2xl border border-stone-200 overflow-hidden hidden z-50 text-left max-h-[60vh] overflow-y-auto">
          </div>
        <% end %>
      </div>

      <!-- Search Bar - Mobile (opens fullscreen overlay) -->
      <div class="sm:hidden mx-auto relative z-10" data-controller="mobile-search-trigger">
        <button type="button"
                data-action="click->mobile-search-trigger#intercept"
                class="w-full h-11 pl-10 pr-10 text-left text-stone-400 bg-white/95 rounded-full border border-white/20 shadow-lg shadow-black/25 text-base cursor-pointer relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          Search jewellery, gifts...
        </button>
      </div>

      <!-- Category Pills -->
      <div class="mt-6 sm:mt-10 -mx-4 sm:mx-0">
        <div class="flex md:flex-wrap md:justify-center gap-2 sm:gap-2.5 overflow-x-auto md:overflow-x-visible hide-scrollbar px-4 sm:px-0 pb-2 md:pb-0">
          <% Category.storefront_hero_categories.each do |category| %>
            <%= link_to category.name, category_path(category.slug),
                class: 'px-4 sm:px-5 py-2 sm:py-2.5 bg-amber-500/[0.06] text-stone-300 text-xs sm:text-sm rounded-full border border-amber-500/[0.15] hover:bg-amber-500/[0.12] hover:text-amber-200 hover:border-amber-400/30 transition-all whitespace-nowrap flex-shrink-0' %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

</section>
<!-- Hero wave transition: dark bg with wavy light edge at bottom -->
<div class="relative h-20 sm:h-28 md:h-36 bg-[#0F0F0F] overflow-hidden">
  <!-- Animated wavy bottom edge -->
  <svg class="absolute bottom-0 left-0 w-[200%] h-full wave-1" viewBox="0 0 2880 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path fill="#fafaf9" d="M0,60 C240,30 480,80 720,50 C960,20 1200,70 1440,45 C1680,20 1920,75 2160,48 C2400,21 2640,68 2880,40 L2880,120 L0,120 Z"/>
  </svg>
  <svg class="absolute bottom-0 left-0 w-[200%] h-full wave-2 opacity-50" viewBox="0 0 2880 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path fill="#fafaf9" d="M0,70 C300,40 540,85 780,55 C1020,25 1260,78 1500,50 C1740,22 1980,72 2220,45 C2460,18 2700,65 2880,50 L2880,120 L0,120 Z"/>
  </svg>
</div>


<!-- ═══════════════════════════════════════════════════════════ -->
<!-- BANNER CAROUSEL                                            -->
<!-- ═══════════════════════════════════════════════════════════ -->
<% if @banners.any? %>
<section class="py-4 sm:py-6 md:py-8 bg-stone-50" data-controller="carousel">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="relative rounded-2xl sm:rounded-3xl overflow-hidden shadow-lg shadow-stone-300/50">
      <% @banners.each_with_index do |banner, index| %>
        <div class="relative h-44 sm:h-60 md:h-72 lg:h-96 <%= index > 0 ? 'hidden' : '' %>" data-carousel-target="slide">
          <% if banner.image.attached? %>
            <%= image_tag banner.image, class: 'w-full h-full object-cover' %>
          <% else %>
            <%= image_tag asset_path('storefront/home/discount-banner.png'), class: 'w-full h-full object-cover' %>
          <% end %>
          <div class="absolute inset-0 bg-gradient-to-r from-stone-900/70 via-stone-900/30 to-transparent flex items-center">
            <div class="px-5 sm:px-10 md:px-14 lg:px-20 max-w-lg">
              <h2 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-white mb-1.5 sm:mb-3 leading-tight"><%= banner.title %></h2>
              <% if banner.subtitle.present? %>
                <p class="text-xs sm:text-sm md:text-base text-white/80 mb-3 sm:mb-5 leading-relaxed"><%= banner.subtitle %></p>
              <% end %>
              <% if banner.link_url.present? %>
                <%= link_to banner.link_url, class: 'inline-flex items-center gap-2 px-5 sm:px-7 py-2 sm:py-3 bg-white text-stone-900 text-xs sm:text-sm font-medium rounded-full hover:bg-amber-50 transition group' do %>
                  Shop Now
                  <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>


