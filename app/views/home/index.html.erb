<% content_for(:title) { "Home" } %>
<% content_for(:hide_header_search) { true } %>

<!-- Hero Section - Clean & Light -->
<section class="bg-gradient-to-b from-teal-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-16">
    <div class="text-center">
      <h1 class="text-2xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-3 sm:mb-4">
        Find What You Love
      </h1>
      <p class="text-sm sm:text-lg text-gray-600 mb-6 sm:mb-8 max-w-lg mx-auto">
        Discover quality products with fast delivery
      </p>
      
      <!-- Search Bar -->
      <div class="max-w-xl mx-auto" data-controller="search-autocomplete">
        <%= form_with url: search_path, method: :get, class: 'relative' do |f| %>
          <div class="relative">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="search" name="q" value="<%= params[:q] %>" 
                   placeholder="Search for products..." 
                   class="w-full h-12 sm:h-14 pl-12 pr-24 text-gray-900 bg-white rounded-full border border-gray-200 shadow-sm focus:ring-2 focus:ring-teal-500 focus:border-transparent placeholder:text-gray-400 text-sm sm:text-base"
                   autocomplete="off"
                   data-search-autocomplete-target="input"
                   data-action="input->search-autocomplete#search focus->search-autocomplete#search">
            <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 h-8 sm:h-10 px-4 sm:px-6 bg-teal-500 hover:bg-teal-600 text-white text-sm font-medium rounded-full transition">
              Search
            </button>
          </div>
          
          <div data-search-autocomplete-target="results" 
               class="absolute top-full left-0 right-0 mt-2 bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden hidden z-50 text-left max-h-[60vh] overflow-y-auto">
          </div>
        <% end %>
      </div>

      <!-- Category Pills -->
      <div class="mt-6 sm:mt-8 flex flex-wrap justify-center gap-2">
        <% Category.active.root.ordered.limit(6).each do |category| %>
          <%= link_to category.name, category_path(category.slug), 
              class: 'px-4 py-2 bg-white text-gray-600 text-sm rounded-full border border-gray-200 hover:border-teal-300 hover:text-teal-600 transition shadow-sm' %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- Banner Carousel -->
<% if @banners.any? %>
<section class="py-4 sm:py-6" data-controller="carousel">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="relative rounded-2xl overflow-hidden shadow-sm">
      <% @banners.each_with_index do |banner, index| %>
        <div class="relative h-40 sm:h-56 md:h-72 <%= index > 0 ? 'hidden' : '' %>" data-carousel-target="slide">
          <% if banner.image.attached? %>
            <%= image_tag banner.image, class: 'w-full h-full object-cover' %>
          <% else %>
            <div class="w-full h-full bg-gradient-to-r from-teal-100 to-cyan-100"></div>
          <% end %>
          <div class="absolute inset-0 bg-gradient-to-r from-black/50 to-transparent flex items-center">
            <div class="px-6 sm:px-10 md:px-16">
              <h2 class="text-lg sm:text-2xl md:text-3xl font-bold text-white mb-2"><%= banner.title %></h2>
              <% if banner.subtitle.present? %>
                <p class="text-sm sm:text-base text-white/90 mb-3 sm:mb-4 max-w-md line-clamp-2"><%= banner.subtitle %></p>
              <% end %>
              <% if banner.link_url.present? %>
                <%= link_to 'Shop Now', banner.link_url, class: 'inline-block px-5 py-2 bg-white text-gray-900 text-sm font-medium rounded-full hover:bg-gray-100 transition' %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- Categories Grid -->
<section class="py-6 sm:py-10">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <h2 class="text-lg sm:text-xl font-bold text-gray-900 mb-4 sm:mb-6">Shop by Category</h2>
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3 sm:gap-4">
      <% Category.active.root.ordered.limit(6).each do |category| %>
        <%= link_to category_path(category.slug), class: 'group' do %>
          <div class="aspect-square bg-gray-100 rounded-2xl flex items-center justify-center group-hover:bg-teal-50 transition">
            <svg class="w-8 h-8 sm:w-10 sm:h-10 text-gray-400 group-hover:text-teal-500 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
          </div>
          <p class="mt-2 text-xs sm:text-sm font-medium text-gray-700 text-center"><%= category.name %></p>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<!-- Today's Deals -->
<section class="py-6 sm:py-10 bg-white">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-4 sm:mb-6">
      <div class="flex items-center gap-2">
        <h2 class="text-lg sm:text-xl font-bold text-gray-900">Today's Deals</h2>
        <span class="px-2 py-0.5 bg-rose-100 text-rose-600 text-xs font-medium rounded-full">Hot</span>
      </div>
      <%= link_to 'View all', products_path, class: 'text-teal-600 hover:text-teal-700 text-sm font-medium' %>
    </div>
    
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-4">
      <% @featured_products.each do |product| %>
        <%= render 'shared/product_card', product: product %>
      <% end %>
    </div>
  </div>
</section>

<!-- Promo Banner -->
<section class="py-6 sm:py-10">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="bg-gradient-to-r from-teal-500 to-cyan-500 rounded-2xl p-6 sm:p-10 text-center sm:text-left">
      <div class="sm:flex items-center justify-between">
        <div class="mb-4 sm:mb-0">
          <p class="text-teal-100 text-sm font-medium mb-1">Limited Time Offer</p>
          <h3 class="text-2xl sm:text-3xl font-bold text-white mb-2">Get 10% Off Your First Order</h3>
          <p class="text-teal-100">Use code <span class="font-mono bg-white/20 px-2 py-0.5 rounded text-white font-bold">WELCOME10</span> at checkout</p>
        </div>
        <%= link_to 'Shop Now', products_path, class: 'inline-block px-6 py-3 bg-white text-teal-600 font-semibold rounded-full hover:bg-gray-100 transition shadow-sm' %>
      </div>
    </div>
  </div>
</section>

<!-- New Arrivals -->
<% if @new_arrivals.any? %>
<section class="py-6 sm:py-10 bg-white">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-4 sm:mb-6">
      <h2 class="text-lg sm:text-xl font-bold text-gray-900">New Arrivals</h2>
      <%= link_to 'View all', products_path(sort: 'newest'), class: 'text-teal-600 hover:text-teal-700 text-sm font-medium' %>
    </div>
    
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-4">
      <% @new_arrivals.each do |product| %>
        <%= render 'shared/product_card', product: product %>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- Features -->
<section class="py-8 sm:py-12 border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8">
      <div class="text-center">
        <div class="w-12 h-12 mx-auto mb-3 bg-teal-100 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
          </svg>
        </div>
        <h3 class="font-medium text-gray-900 text-sm mb-1">Free Shipping</h3>
        <p class="text-gray-500 text-xs">On orders over $50</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 mx-auto mb-3 bg-teal-100 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <h3 class="font-medium text-gray-900 text-sm mb-1">Secure Payment</h3>
        <p class="text-gray-500 text-xs">100% protected</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 mx-auto mb-3 bg-teal-100 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
        </div>
        <h3 class="font-medium text-gray-900 text-sm mb-1">Easy Returns</h3>
        <p class="text-gray-500 text-xs">30-day returns</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 mx-auto mb-3 bg-teal-100 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="font-medium text-gray-900 text-sm mb-1">24/7 Support</h3>
        <p class="text-gray-500 text-xs">Here to help</p>
      </div>
    </div>
  </div>
</section>
