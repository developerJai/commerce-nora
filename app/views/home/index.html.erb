<!-- ═══════════════════════════════════════════════════════════ -->
<section class="py-8 sm:py-10 bg-white border-t border-stone-100">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8">
