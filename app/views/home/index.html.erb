<!-- ═══════════════════════════════════════════════════════════ -->
<!-- NEW ARRIVALS                                               -->
<!-- ═══════════════════════════════════════════════════════════ -->
<% if @new_arrivals.any? %>
<section class="py-8 sm:py-12 md:py-16 bg-stone-50">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between mb-6 sm:mb-8">
      <div>
        <p class="text-amber-700 text-[10px] sm:text-xs font-medium tracking-[0.15em] uppercase mb-1">Just Dropped</p>
        <h2 class="text-xl sm:text-2xl md:text-3xl font-serif font-semibold text-stone-900">New Arrivals</h2>
      </div>
      <%= link_to products_path(sort: 'newest'), class: 'group flex items-center gap-1.5 text-[#D4AF37] hover:text-[#B8962E] text-xs sm:text-sm font-medium transition' do %>
        View All
        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
    <div class="w-16 h-px gold-divider mb-6 sm:mb-8"></div>

