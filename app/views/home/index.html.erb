<% content_for(:title) { "Home" } %>
<% content_for(:meta_description) { "Discover exquisite artificial jewellery, traditional ethnic wear, and thoughtful gifts at Noralooks. Shop premium quality fashion jewellery online with free shipping on orders above ₹999. Easy 7-day returns & lifetime exchange policy." } %>
<% content_for(:meta_keywords) { ["buy artificial jewellery online", "fashion jewellery India", "ethnic wear online", "traditional wear shopping", "imitation jewellery", "costume jewellery", "online gift shopping", "jewellery store India", "affordable jewellery", "women's jewellery"] } %>
<% content_for(:hide_header_search) { true } %>

<% content_for(:head) do %>
  <!-- Structured Data - Organization Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Noralooks",
    "url": "<%= root_url %>",
    "logo": "<%= og_image_url %>",
    "description": "Premium artificial jewellery, ethnic wear, and gifts online store",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "IN"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "Customer Service",
      "availableLanguage": ["English", "Hindi"]
    },
    "sameAs": []
  }
  </script>

  <!-- Structured Data - WebSite Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Noralooks",
    "url": "<%= root_url %>",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "<%= search_url %>?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <!-- Structured Data - Online Store Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Store",
    "name": "Noralooks",
    "image": "<%= og_image_url %>",
    "description": "Shop exquisite artificial jewellery, ethnic wear, and thoughtful gifts",
    "priceRange": "₹₹",
    "url": "<%= root_url %>",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Jewellery & Fashion",
      "itemListElement": [
        {
          "@type": "OfferCatalog",
          "name": "Artificial Jewellery",
          "itemListElement": []
        },
        {
          "@type": "OfferCatalog",
          "name": "Traditional Wear",
          "itemListElement": []
        },
        {
          "@type": "OfferCatalog",
          "name": "Gifts",
          "itemListElement": []
        }
      ]
    }
  }
  </script>
<% end %>

<!-- CSS Animations - Cross Browser Support -->
<style>
  @keyframes float-slow {
    0%, 100% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(-20px) translateX(10px); }
  }
  @keyframes float-medium {
    0%, 100% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(-15px) translateX(-15px); }
  }
  @keyframes float-fast {
    0%, 100% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(-25px) translateX(5px); }
  }
  @keyframes sparkle {
    0%, 100% { opacity: 0.3; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
  }
  @keyframes rotate-slow {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  @keyframes pulse-glow {
    0%, 100% { filter: drop-shadow(0 0 5px rgba(225, 29, 72, 0.3)); }
    50% { filter: drop-shadow(0 0 20px rgba(225, 29, 72, 0.6)); }
  }
  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  @keyframes heart-beat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }
  @keyframes bounce-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-float-slow { 
    animation: float-slow 8s ease-in-out infinite;
    -webkit-animation: float-slow 8s ease-in-out infinite;
  }
  .animate-float-medium { 
    animation: float-medium 6s ease-in-out infinite;
    -webkit-animation: float-medium 6s ease-in-out infinite;
  }
  .animate-float-fast { 
    animation: float-fast 4s ease-in-out infinite;
    -webkit-animation: float-fast 4s ease-in-out infinite;
  }
  .animate-sparkle { 
    animation: sparkle 2s ease-in-out infinite;
    -webkit-animation: sparkle 2s ease-in-out infinite;
  }
  .animate-rotate-slow { 
    animation: rotate-slow 20s linear infinite;
    -webkit-animation: rotate-slow 20s linear infinite;
  }
  .animate-pulse-glow { 
    animation: pulse-glow 3s ease-in-out infinite;
    -webkit-animation: pulse-glow 3s ease-in-out infinite;
  }
  .animate-shimmer {
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.4) 50%, transparent 100%);
    background-size: 200% 100%;
    animation: shimmer 3s ease-in-out infinite;
    -webkit-animation: shimmer 3s ease-in-out infinite;
  }
  .animate-heart-beat {
    animation: heart-beat 1.5s ease-in-out infinite;
    -webkit-animation: heart-beat 1.5s ease-in-out infinite;
  }
  .animate-bounce-subtle {
    animation: bounce-subtle 2s ease-in-out infinite;
    -webkit-animation: bounce-subtle 2s ease-in-out infinite;
  }
</style>


<!-- Hero Section -->
<section class="bg-gradient-to-b from-rose-50 to-stone-50">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 sm:py-12 md:py-16">
    <div class="text-center">
      <p class="text-rose-700 text-xs sm:text-sm font-medium tracking-widest uppercase mb-2">Timeless Elegance</p>
      <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-serif font-semibold text-stone-900 mb-3 sm:mb-4 mx-auto leading-relaxed tracking-tight">
        <%= @hero_heading %>
      </h1>
      <p class="text-sm sm:text-base text-stone-600 mb-6 sm:mb-8 max-w-xl mx-auto leading-relaxed">
        Exquisite artificial jewellery, thoughtful gifts, and beautiful ethnic wear for every occasion
      </p>
      
      <!-- Search Bar -->
      <div class="hidden sm:block max-w-lg mx-auto" data-controller="search-autocomplete">
        <%= form_with url: products_path, method: :get, class: 'relative', data: { turbo_frame: '_top' } do |f| %>
          <div class="relative">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="search" name="q" value="<%= params[:q] %>" 
                   placeholder="<%= @search_placeholder %>" 
                   class="w-full h-12 sm:h-14 pl-12 pr-28 text-stone-800 bg-white rounded-full border border-stone-200 shadow-sm focus:ring-2 focus:ring-rose-400 focus:border-transparent placeholder:text-stone-400 text-sm"
                   autocomplete="off"
                   data-search-autocomplete-target="input"
                   data-action="input->search-autocomplete#search focus->search-autocomplete#search keydown.enter->search-autocomplete#submitForm">
            <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 h-8 sm:h-10 px-5 sm:px-6 bg-rose-800 hover:bg-rose-900 text-white text-sm font-medium rounded-full transition">
              Search
            </button>
          </div>
          
          <div data-search-autocomplete-target="results" 
               class="absolute top-full left-0 right-0 mt-2 bg-white rounded-xl shadow-xl border border-stone-200 overflow-hidden hidden z-50 text-left max-h-[60vh] overflow-y-auto">
          </div>
        <% end %>
      </div>

      <!-- Category Pills -->
      <div class="mt-6 sm:mt-8 -mx-3 sm:mx-0">
        <div class="flex md:flex-wrap md:justify-center gap-2 sm:gap-3 overflow-x-auto md:overflow-x-visible hide-scrollbar px-3 sm:px-0 pb-2 md:pb-0">
          <% Category.storefront_hero_categories.each do |category| %>
            <%= link_to category.name, category_path(category.slug), 
                class: 'px-3 sm:px-4 py-1.5 sm:py-2 bg-white text-stone-600 text-xs sm:text-sm rounded-full border border-stone-200 hover:border-rose-300 hover:text-rose-800 transition shadow-sm whitespace-nowrap flex-shrink-0' %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Banner Carousel -->
<% if @banners.any? %>
<section class="py-3 sm:py-4 md:py-6" data-controller="carousel">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="relative rounded-xl sm:rounded-2xl overflow-hidden">
      <% @banners.each_with_index do |banner, index| %>
        <div class="relative h-40 sm:h-56 md:h-64 lg:h-80 <%= index > 0 ? 'hidden' : '' %>" data-carousel-target="slide">
          <% if banner.image.attached? %>
            <%= image_tag banner.image, class: 'w-full h-full object-cover' %>
          <% else %>
            <%= image_tag asset_path('storefront/home/discount-banner.png'), class: 'w-full h-full object-cover' %>
            <%# <div class="w-full h-full bg-gradient-to-r from-rose-100 to-amber-50"></div> %>
          <% end %>
          <div class="absolute inset-0 bg-gradient-to-r from-stone-900/60 via-stone-900/30 to-transparent flex items-center">
            <div class="px-4 sm:px-8 md:px-12 lg:px-16">
              <h2 class="text-lg sm:text-2xl md:text-3xl lg:text-4xl font-serif font-semibold text-white mb-1.5 sm:mb-2"><%= banner.title %></h2>
              <% if banner.subtitle.present? %>
                <p class="text-xs sm:text-sm md:text-base text-white/90 mb-3 sm:mb-4 max-w-md"><%= banner.subtitle %></p>
              <% end %>
              <% if banner.link_url.present? %>
                <%= link_to 'Shop Now', banner.link_url, class: 'inline-block px-4 sm:px-6 py-2 sm:py-2.5 bg-white text-stone-900 text-xs sm:text-sm font-medium rounded-full hover:bg-rose-50 transition' %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- Homepage Collections -->
<% @homepage_collections.each do |collection| %>
  <% if collection.items.any? %>
    <%= render 'home/homepage_collection', collection: collection %>
  <% end %>
<% end %>

<!-- Section: Artisan Collection -->
<% if @homepage_settings&.artisan_section_enabled? %>
