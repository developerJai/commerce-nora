<%# Main collection section wrapper %>
<section class="py-8 sm:py-12 md:py-14">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <%# Section Header %>
    <% if collection.name.present? %>
      <div class="text-center mb-6 sm:mb-10">
        <h2 class="text-xl sm:text-2xl md:text-3xl font-serif font-semibold text-stone-900"><%= collection.name %></h2>
        <% if collection.subtitle.present? %>
          <p class="text-stone-500 text-sm sm:text-base mt-2 max-w-lg mx-auto leading-relaxed"><%= collection.subtitle %></p>
        <% end %>
        <div class="mt-3 sm:mt-4 flex justify-center">
          <div class="w-16 h-px gold-divider"></div>
        </div>
      </div>
    <% end %>

    <%# Render the appropriate layout %>
    <% items = collection.items.ordered %>
    <% if items.any? %>
      <%= render "home/layouts/#{collection.layout_type}", items: items %>
    <% end %>
  </div>
</section>
