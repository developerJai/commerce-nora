<!-- Section: Gifts & Celebrations -->
<section class="relative py-12 sm:py-20 md:py-24 overflow-hidden bg-white">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
      <!-- Visual -->
      <div class="relative order-2 lg:order-1">
        <div class="aspect-[4/3] rounded-2xl sm:rounded-3xl bg-gradient-to-br from-amber-100 via-rose-50 to-amber-50 shadow-xl shadow-stone-200/50 overflow-hidden">
          <div class="absolute inset-0 flex items-center justify-center">
            <!-- Elegant gift icon -->
            <div class="relative">
              <div class="w-28 h-28 sm:w-36 sm:h-36 bg-white/60 rounded-2xl flex items-center justify-center shadow-inner">
                <svg class="w-14 h-14 sm:w-18 sm:h-18 text-rose-700/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
                </svg>
              </div>
              <!-- Small decorative dots -->
              <div class="absolute -top-3 -right-3 w-6 h-6 bg-amber-300/40 rounded-full"></div>
              <div class="absolute -bottom-2 -left-4 w-8 h-8 bg-rose-300/30 rounded-full"></div>
            </div>
          </div>
          <div class="absolute inset-0 animate-shimmer-gold pointer-events-none"></div>
        </div>

        <!-- Floating badge -->
        <div class="absolute -top-3 -right-2 sm:-top-4 sm:-right-4 bg-white rounded-xl p-3 sm:p-4 shadow-xl border border-stone-100">
          <div class="w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="text-center lg:text-left order-1 lg:order-2">
        <p class="text-amber-700 text-[10px] sm:text-xs font-medium tracking-[0.2em] uppercase mb-3 sm:mb-4">Perfect Presents</p>
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-serif font-semibold text-stone-900 mb-4 sm:mb-6 leading-tight">
          Gifts &<br/>
          <span class="text-rose-800">Celebrations</span>
        </h2>
        <div class="w-12 h-px gold-divider mb-5 sm:mb-6 mx-auto lg:mx-0"></div>
        <p class="text-stone-600 text-sm sm:text-base mb-8 max-w-lg mx-auto lg:mx-0 leading-relaxed">
          Find the perfect gift for your loved ones. From elegant jewellery sets to thoughtful presents, make every celebration memorable with our curated collection.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
          <%= link_to category_path("gifts"), class: 'group inline-flex items-center justify-center px-7 py-3.5 bg-amber-600 text-white text-sm font-medium rounded-full hover:bg-amber-700 transition-all shadow-lg shadow-amber-600/20 hover:shadow-amber-600/30' do %>
            <span>Shop Gifts</span>
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>
        </div>

        <div class="mt-6 sm:mt-8 flex flex-wrap justify-center lg:justify-start gap-2">
          <span class="px-3 py-1.5 bg-rose-50 text-rose-700 text-xs rounded-full border border-rose-100">Wedding Gifts</span>
          <span class="px-3 py-1.5 bg-amber-50 text-amber-700 text-xs rounded-full border border-amber-100">Birthday Specials</span>
          <span class="px-3 py-1.5 bg-stone-100 text-stone-600 text-xs rounded-full border border-stone-200">Festive Hampers</span>
        </div>
      </div>
    </div>
  </div>
</section>
