<!-- Section: Gifts & Celebrations -->
<section class="relative py-16 sm:py-24 overflow-hidden bg-white">
  <div class="absolute inset-0 opacity-30">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, rgba(225, 29, 72, 0.1) 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Visual - Left side -->
      <div class="relative order-2 lg:order-1">
        <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-amber-100 via-rose-50 to-amber-200 shadow-2xl overflow-hidden relative">
          <div class="absolute inset-0 flex items-center justify-center">
            <svg class="w-1/2 h-1/2 text-rose-700/40 animate-bounce-subtle" viewBox="0 0 200 200" fill="currentColor">
              <rect x="40" y="80" width="120" height="90" rx="4" fill="currentColor"/>
              <rect x="30" y="60" width="140" height="25" rx="3" fill="currentColor" opacity="0.9"/>
              <rect x="90" y="60" width="20" height="110" fill="white" opacity="0.6"/>
              <rect x="40" y="110" width="120" height="20" fill="white" opacity="0.6"/>
              <path d="M100 60 C80 40 60 50 70 65 C80 75 95 60 100 60 C105 60 120 75 130 65 C140 50 120 40 100 60" fill="white" opacity="0.7"/>
              <circle cx="60" cy="100" r="4" class="animate-sparkle" fill="white"/>
              <circle cx="140" cy="130" r="3" class="animate-sparkle" fill="white"/>
              <circle cx="120" cy="90" r="5" class="animate-sparkle" fill="white"/>
            </svg>
            
            <svg class="absolute top-10 right-10 w-12 h-12 text-rose-400 animate-heart-beat" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
            <svg class="absolute bottom-20 left-10 w-8 h-8 text-amber-400 animate-float-slow" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
          </div>
          <div class="absolute inset-0 animate-shimmer pointer-events-none"></div>
        </div>
        
        <div class="absolute -top-4 -right-4 bg-white rounded-full p-4 shadow-xl animate-float-medium">
          <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
            </svg>
          </div>
        </div>
      </div>
      
      <!-- Content - Right side -->
      <div class="text-center lg:text-left order-1 lg:order-2">
        <span class="inline-block text-amber-600 text-sm font-medium tracking-widest uppercase mb-4">Perfect Presents</span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-serif font-semibold text-stone-900 mb-6 leading-tight">
          Gifts &<br/>
          <span class="text-rose-800">Celebrations</span>
        </h2>
        <p class="text-stone-600 text-base sm:text-lg mb-8 max-w-lg mx-auto lg:mx-0 leading-relaxed">
          Find the perfect gift for your loved ones. From elegant jewellery sets to thoughtful presents, make every celebration memorable with our curated collection of artificial jewellery and gift items.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <%= link_to category_path("gifts"), class: 'group inline-flex items-center justify-center px-8 py-4 bg-amber-600 text-white font-medium rounded-full hover:bg-amber-700 transition-all duration-300 shadow-lg shadow-amber-600/20 hover:shadow-amber-600/40 hover:-translate-y-0.5' do %>
            <span>Shop Gifts</span>
            <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          <% end %>
        </div>
        
        <div class="mt-8 flex flex-wrap justify-center lg:justify-start gap-3">
          <span class="px-4 py-2 bg-rose-50 text-rose-700 text-sm rounded-full">Wedding Gifts</span>
          <span class="px-4 py-2 bg-amber-50 text-amber-700 text-sm rounded-full">Birthday Specials</span>
          <span class="px-4 py-2 bg-stone-100 text-stone-600 text-sm rounded-full">Festive Hampers</span>
        </div>
      </div>
    </div>
  </div>
</section>
