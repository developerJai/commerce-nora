<!-- Section: Artisan Craftsmanship Banner -->
<section class="relative py-16 sm:py-24 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-stone-50 via-rose-50/30 to-amber-50/20"></div>
  <div class="absolute top-20 left-10 w-32 h-32 bg-rose-200/30 rounded-full blur-2xl animate-float-slow"></div>
  <div class="absolute bottom-20 right-20 w-48 h-48 bg-amber-200/30 rounded-full blur-2xl animate-float-medium"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="text-center lg:text-left">
        <span class="inline-block text-rose-700 text-sm font-medium tracking-widest uppercase mb-4">Handcrafted with Love</span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-serif font-semibold text-stone-900 mb-6 leading-tight">
          Beautiful Artificial<br/>
          <span class="text-rose-800">Jewellery Collection</span>
        </h2>
        <p class="text-stone-600 text-base sm:text-lg mb-8 max-w-lg mx-auto lg:mx-0 leading-relaxed">
          Discover stunning fashion jewellery crafted with precision and care. Our collection features elegant designs perfect for weddings, festivals, and everyday wear at affordable prices.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <%= link_to products_path, class: 'group inline-flex items-center justify-center px-8 py-4 bg-rose-800 text-white font-medium rounded-full hover:bg-rose-900 transition-all duration-300 shadow-lg shadow-rose-800/20 hover:shadow-rose-800/40 hover:-translate-y-0.5' do %>
            <span>Explore Collection</span>
            <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          <% end %>
        </div>
      </div>
      
      <div class="relative">
        <div class="relative aspect-square rounded-2xl overflow-hidden shadow-2xl bg-gradient-to-br from-rose-100 via-amber-50 to-rose-200">
          <div class="absolute inset-0 flex items-center justify-center">
            <svg class="absolute w-full h-full text-rose-300/40 animate-rotate-slow" viewBox="0 0 400 400" fill="none">
              <circle cx="200" cy="200" r="160" stroke="currentColor" stroke-width="1" stroke-dasharray="10 10"/>
            </svg>
            <svg class="w-4/5 h-4/5 text-rose-800/30 animate-pulse-glow" viewBox="0 0 300 300" fill="currentColor">
              <path d="M50 150 Q150 50 250 150" fill="none" stroke="currentColor" stroke-width="3"/>
              <circle cx="70" cy="135" r="6" class="animate-sparkle"/>
              <circle cx="100" cy="95" r="8" class="animate-sparkle"/>
              <circle cx="150" cy="75" r="10" class="animate-sparkle"/>
              <circle cx="200" cy="95" r="8" class="animate-sparkle"/>
              <circle cx="230" cy="135" r="6" class="animate-sparkle"/>
              <ellipse cx="150" cy="150" rx="35" ry="45" fill="currentColor"/>
              <ellipse cx="150" cy="150" rx="25" ry="32" fill="white" opacity="0.8"/>
              <circle cx="150" cy="145" r="12" class="animate-sparkle"/>
            </svg>
            <div class="absolute top-1/4 left-1/4 w-4 h-4 bg-rose-400/60 rounded-full animate-float-fast"></div>
            <div class="absolute top-1/3 right-1/4 w-3 h-3 bg-amber-400/60 rounded-full animate-float-medium"></div>
            <div class="absolute bottom-1/3 left-1/3 w-5 h-5 bg-rose-500/50 rounded-full animate-float-slow"></div>
            <div class="absolute bottom-1/4 right-1/3 w-3 h-3 bg-amber-300/60 rounded-full animate-float-fast"></div>
          </div>
          <div class="absolute inset-0 animate-shimmer pointer-events-none"></div>
        </div>
        
        <!-- Floating trust badge - Two Line Layout -->
        <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl p-4 sm:p-5 shadow-xl max-w-[220px]">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 sm:w-11 sm:h-11 bg-rose-100 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 sm:w-6 sm:h-6 text-rose-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
            </div>
            <div class="flex flex-col">
              <p class="font-serif font-semibold text-stone-900 text-sm leading-tight">Premium Quality</p>
              <p class="text-xs text-stone-500 mt-0.5">Fashion Jewellery</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
