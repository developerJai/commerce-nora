<!-- Section: Artisan Craftsmanship -->
<section class="relative py-12 sm:py-20 md:py-24 overflow-hidden bg-stone-50">
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #78716c 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
      <!-- Content -->
      <div class="text-center lg:text-left">
        <p class="text-amber-700 text-[10px] sm:text-xs font-medium tracking-[0.2em] uppercase mb-3 sm:mb-4">Handcrafted with Love</p>
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-serif font-semibold text-stone-900 mb-4 sm:mb-6 leading-tight">
          Beautiful Artificial<br/>
          <span class="text-rose-800">Jewellery Collection</span>
        </h2>
        <div class="w-12 h-px gold-divider mb-5 sm:mb-6 mx-auto lg:mx-0"></div>
        <p class="text-stone-600 text-sm sm:text-base mb-8 max-w-lg mx-auto lg:mx-0 leading-relaxed">
          Discover stunning fashion jewellery crafted with precision and care. Our collection features elegant designs perfect for weddings, festivals, and everyday wear at affordable prices.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
          <%= link_to products_path, class: 'group inline-flex items-center justify-center px-7 py-3.5 bg-stone-900 text-white text-sm font-medium rounded-full hover:bg-stone-800 transition-all shadow-lg shadow-stone-900/20 hover:shadow-stone-900/30' do %>
            <span>Explore Collection</span>
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          <% end %>
        </div>
      </div>

      <!-- Visual - Logo showcase on dark luxury background -->
      <div class="relative">
        <div class="aspect-[4/5] sm:aspect-square rounded-2xl sm:rounded-3xl overflow-hidden shadow-2xl shadow-stone-400/30">
          <!-- Dark luxury background matching brand -->
          <div class="absolute inset-0 bg-gradient-to-br from-[#1a1410] via-[#231c15] to-[#1a1410]"></div>
          <!-- Subtle gold dot texture -->
          <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle at 1px 1px, #d4a853 0.5px, transparent 0); background-size: 24px 24px;"></div>
          <!-- Warm ambient glows -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-1/2 bg-amber-600/[0.08] rounded-full blur-3xl"></div>
          <div class="absolute bottom-0 right-0 w-1/2 h-1/2 bg-rose-700/[0.05] rounded-full blur-3xl"></div>

          <!-- Decorative gold rings -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-[85%] h-[85%] rounded-full border border-amber-500/[0.08]"></div>
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-[70%] h-[70%] rounded-full border border-amber-400/[0.06]"></div>
          </div>

          <!-- Center: Logo large -->
          <div class="absolute inset-0 flex items-center justify-center">
            <%= image_tag asset_path('storefront/logo-icon.png'), class: 'w-40 h-40 sm:w-52 sm:h-52 md:w-56 md:h-56 rounded-3xl shadow-2xl shadow-black/40', alt: 'Noralooks' %>
          </div>

          <!-- Corner gold accents -->
          <div class="absolute top-4 sm:top-6 left-4 sm:left-6 w-8 sm:w-12 h-px bg-gradient-to-r from-amber-500/40 to-transparent"></div>
          <div class="absolute top-4 sm:top-6 left-4 sm:left-6 w-px h-8 sm:h-12 bg-gradient-to-b from-amber-500/40 to-transparent"></div>
          <div class="absolute bottom-4 sm:bottom-6 right-4 sm:right-6 w-8 sm:w-12 h-px bg-gradient-to-l from-amber-500/40 to-transparent"></div>
          <div class="absolute bottom-4 sm:bottom-6 right-4 sm:right-6 w-px h-8 sm:h-12 bg-gradient-to-t from-amber-500/40 to-transparent"></div>

          <!-- Subtle gold shimmer -->
          <div class="absolute inset-0 animate-shimmer-gold pointer-events-none"></div>
        </div>

        <!-- Floating trust badge -->
        <div class="absolute -bottom-3 -left-2 sm:-bottom-4 sm:-left-4 bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 shadow-xl border border-stone-100">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 sm:w-10 sm:h-10 bg-amber-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
            </div>
            <div>
              <p class="font-serif font-semibold text-stone-900 text-sm leading-tight">Premium Quality</p>
              <p class="text-xs text-stone-500 mt-0.5">Fashion Jewellery</p>
            </div>
          </div>
        </div>

        <!-- Top-right floating badge -->
        <div class="absolute -top-2 -right-2 sm:-top-3 sm:-right-3 bg-gradient-to-br from-amber-500 to-amber-600 rounded-xl p-2.5 sm:p-3 shadow-lg shadow-amber-600/30">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
