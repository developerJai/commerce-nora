<!-- Section: Ethnic Wear Collection -->
<section class="relative py-16 sm:py-24 md:py-28 overflow-hidden">
  <!-- Rich dark background -->
  <div class="absolute inset-0 bg-gradient-to-br from-stone-900 via-stone-800 to-stone-900"></div>
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;"></div>
  <!-- Ambient glows -->
  <div class="absolute top-0 left-1/4 w-64 h-32 bg-rose-500/[0.05] rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-1/4 w-80 h-40 bg-amber-500/[0.04] rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto">
      <!-- Icon -->
      <div class="inline-flex items-center justify-center w-14 h-14 sm:w-16 sm:h-16 bg-gradient-to-br from-rose-500/20 to-amber-500/20 rounded-2xl mb-6 border border-white/[0.08]">
        <svg class="w-7 h-7 sm:w-8 sm:h-8 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
      </div>

      <p class="text-amber-400/80 text-[10px] sm:text-xs font-medium tracking-[0.2em] uppercase mb-3 sm:mb-4">Traditional Elegance</p>
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-serif font-semibold text-white mb-4 sm:mb-6 leading-tight">
        Ethnic Wear<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-rose-400 to-amber-400">Collection</span>
      </h2>
      <div class="w-16 h-px mx-auto mb-5 sm:mb-6" style="background: linear-gradient(90deg, transparent, #d4a853, transparent);"></div>
      <p class="text-stone-400 text-sm sm:text-base mb-8 sm:mb-10 max-w-lg mx-auto leading-relaxed">
        Embrace your cultural heritage with our stunning ethnic wear collection. From traditional sarees to contemporary fusion wear, find the perfect outfit for every celebration.
      </p>

      <%= link_to products_path, class: 'group inline-flex items-center gap-2 px-7 sm:px-8 py-3 sm:py-3.5 bg-gradient-to-r from-rose-500 to-amber-500 text-white text-sm font-medium rounded-full hover:from-rose-600 hover:to-amber-600 transition-all shadow-lg shadow-rose-500/20 hover:shadow-rose-500/30' do %>
        <span>Explore Ethnic Wear</span>
        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>

      <!-- Category pills -->
      <div class="mt-8 sm:mt-10 flex flex-wrap justify-center gap-2">
        <% ethnic_parent = Category.active.find_by(name: 'Traditional Wear') || Category.active.find_by("name ILIKE ?", '%ethnic%') %>
        <% if ethnic_parent %>
          <% ethnic_parent.children.active.ordered.each do |child| %>
            <%= link_to child.name, category_path(child.slug), class: 'px-4 py-2 bg-white/[0.06] text-white/70 text-xs sm:text-sm rounded-full border border-white/[0.1] hover:bg-white/[0.12] hover:text-white hover:border-white/[0.2] transition-all' %>
          <% end %>
        <% else %>
          <%= link_to 'Sarees', products_path(q: 'sarees'), class: 'px-4 py-2 bg-white/[0.06] text-white/70 text-xs sm:text-sm rounded-full border border-white/[0.1] hover:bg-white/[0.12] hover:text-white hover:border-white/[0.2] transition-all' %>
          <%= link_to 'Kurtis', products_path(q: 'kurtis'), class: 'px-4 py-2 bg-white/[0.06] text-white/70 text-xs sm:text-sm rounded-full border border-white/[0.1] hover:bg-white/[0.12] hover:text-white hover:border-white/[0.2] transition-all' %>
          <%= link_to 'Lehengas', products_path(q: 'lehengas'), class: 'px-4 py-2 bg-white/[0.06] text-white/70 text-xs sm:text-sm rounded-full border border-white/[0.1] hover:bg-white/[0.12] hover:text-white hover:border-white/[0.2] transition-all' %>
          <%= link_to 'Suits', products_path(q: 'suits'), class: 'px-4 py-2 bg-white/[0.06] text-white/70 text-xs sm:text-sm rounded-full border border-white/[0.1] hover:bg-white/[0.12] hover:text-white hover:border-white/[0.2] transition-all' %>
          <%= link_to 'Fusion Wear', products_path(q: 'fusion wear'), class: 'px-4 py-2 bg-white/[0.06] text-white/70 text-xs sm:text-sm rounded-full border border-white/[0.1] hover:bg-white/[0.12] hover:text-white hover:border-white/[0.2] transition-all' %>
        <% end %>
      </div>
    </div>
  </div>
</section>
