<% if @homepage_settings&.flash_sale_active? %>
<!-- Flash Sale Section -->
<section class="relative py-10 sm:py-14 bg-gradient-to-br from-rose-900 via-red-800 to-rose-900 overflow-hidden">
  <!-- 3D Depth Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/20 to-transparent"></div>
  
  <!-- Decorative 3D Elements -->
  <div class="absolute right-10 top-1/2 -translate-y-1/2 w-64 h-64 bg-gradient-to-br from-amber-400/20 to-amber-600/10 rounded-full blur-2xl"></div>
  <div class="absolute left-20 bottom-0 w-48 h-48 bg-gradient-to-tr from-rose-500/20 to-red-600/10 rounded-full blur-xl"></div>
  
  <!-- Animated Background Particles -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-2 h-2 bg-amber-400/60 rounded-full animate-ping" style="animation-duration: 2s;"></div>
    <div class="absolute top-3/4 left-1/3 w-1.5 h-1.5 bg-rose-400/60 rounded-full animate-ping" style="animation-duration: 2.5s; animation-delay: 0.5s;"></div>
    <div class="absolute top-1/3 right-1/4 w-2 h-2 bg-amber-300/60 rounded-full animate-ping" style="animation-duration: 3s; animation-delay: 1s;"></div>
    <div class="absolute bottom-1/4 right-1/3 w-1 h-1 bg-white/40 rounded-full animate-ping" style="animation-duration: 2.2s; animation-delay: 0.3s;"></div>
  </div>
  
  <style>
    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-20px) rotate(5deg); }
    }
    @keyframes pulse-ring {
      0% { transform: scale(1); opacity: 0.8; }
      50% { transform: scale(1.1); opacity: 0.4; }
      100% { transform: scale(1); opacity: 0.8; }
    }
    @keyframes spin-slow {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    @keyframes morph {
      0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
      25% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
      50% { border-radius: 50% 60% 30% 60% / 30% 60% 70% 40%; }
      75% { border-radius: 60% 40% 60% 30% / 70% 30% 50% 60%; }
    }
    @keyframes glow {
      0%, 100% { box-shadow: 0 0 20px rgba(251, 191, 36, 0.5), 0 0 40px rgba(251, 191, 36, 0.3); }
      50% { box-shadow: 0 0 40px rgba(251, 191, 36, 0.8), 0 0 80px rgba(251, 191, 36, 0.5); }
    }
    @keyframes shimmer {
      0% { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
    .animate-float-badge {
      animation: float 6s ease-in-out infinite;
    }
    .animate-pulse-ring {
      animation: pulse-ring 3s ease-in-out infinite;
    }
    .animate-spin-slow {
      animation: spin-slow 20s linear infinite;
    }
    .animate-morph {
      animation: morph 8s ease-in-out infinite;
    }
    .animate-glow {
      animation: glow 3s ease-in-out infinite;
    }
    .shimmer-text {
      background: linear-gradient(90deg, #fcd34d 0%, #fff 50%, #fcd34d 100%);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 3s linear infinite;
    }
  </style>
  
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
      
      <!-- Left: Content -->
      <div class="text-center lg:text-left">
        <!-- Sale Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 backdrop-blur-sm rounded-full border border-amber-400/40 mb-4 shadow-[0_4px_15px_rgba(251,191,36,0.3)]">
          <span class="w-2 h-2 bg-amber-400 rounded-full animate-pulse"></span>
          <span class="text-amber-300 font-semibold text-xs uppercase tracking-wider"><%= @homepage_settings.flash_sale_title %></span>
        </div>
        
        <!-- Main Heading with 3D effect -->
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-3 leading-tight drop-shadow-[0_4px_8px_rgba(0,0,0,0.5)]">
          <%= @homepage_settings.flash_sale_heading %>
        </h2>
        
        <!-- Description -->
        <p class="text-rose-100/80 text-base sm:text-lg mb-6 max-w-lg leading-relaxed">
          <%= @homepage_settings.flash_sale_description %>
        </p>
        
        <!-- CTA Button with 3D effect -->
        <%= link_to @homepage_settings.flash_sale_cta_link, class: 'inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-amber-400 to-amber-500 text-rose-900 font-bold rounded-full shadow-[0_8px_25px_rgba(251,191,36,0.4)] hover:shadow-[0_12px_35px_rgba(251,191,36,0.6)] hover:-translate-y-1 transition-all duration-300 border-2 border-amber-300/50' do %>
          <span><%= @homepage_settings.flash_sale_cta_text %></span>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        <% end %>
      </div>
      
      <!-- Right: Creative Animated Discount Badge -->
      <div class="relative animate-float-badge">
        <!-- Outer pulsing rings -->
        <div class="absolute inset-0 rounded-full bg-amber-400/30 animate-pulse-ring blur-md"></div>
        <div class="absolute inset-[-20px] rounded-full bg-amber-400/20 animate-pulse-ring blur-lg" style="animation-delay: 0.5s;"></div>
        <div class="absolute inset-[-40px] rounded-full bg-amber-400/10 animate-pulse-ring blur-xl" style="animation-delay: 1s;"></div>
        
        <!-- Rotating decorative ring -->
        <div class="absolute inset-[-10px] border-2 border-dashed border-amber-400/40 rounded-full animate-spin-slow"></div>
        
        <!-- Main Badge with morphing shape -->
        <div class="relative w-40 h-40 sm:w-48 sm:h-48 animate-morph animate-glow flex items-center justify-center overflow-hidden">
          <!-- Background gradient -->
          <div class="absolute inset-0 bg-gradient-to-br from-amber-400 via-amber-500 to-rose-500"></div>
          
          <!-- Shimmer overlay -->
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent animate-shimmer"></div>
          
          <!-- Inner glow -->
          <div class="absolute inset-4 rounded-full bg-gradient-to-br from-amber-300 to-amber-500 shadow-inner"></div>
          
          <!-- Text content -->
          <div class="relative z-10 text-center">
            <span class="block text-5xl sm:text-6xl font-black shimmer-text drop-shadow-lg"><%= @homepage_settings.flash_sale_discount %></span>
            <span class="block text-lg sm:text-xl font-bold text-rose-800 mt-1">% OFF</span>
          </div>
          
          <!-- Decorative sparkles -->
          <div class="absolute top-2 right-4 text-2xl animate-pulse">✨</div>
          <div class="absolute bottom-4 left-2 text-xl animate-pulse" style="animation-delay: 0.5s;">⭐</div>
          <div class="absolute top-1/2 -right-2 text-lg animate-pulse" style="animation-delay: 1s;">💫</div>
        </div>
        
        <!-- Floating price tag -->
        <div class="absolute -bottom-2 -right-4 bg-white rounded-lg px-3 py-2 shadow-xl transform rotate-12 animate-float-badge" style="animation-delay: 1s;">
          <span class="text-rose-600 font-bold text-sm">SAVE BIG!</span>
        </div>
        
        <!-- Lightning bolt accents -->
        <div class="absolute -top-4 -left-4 text-amber-400 text-3xl animate-pulse">⚡</div>
        <div class="absolute -bottom-2 -left-6 text-amber-300 text-2xl animate-pulse" style="animation-delay: 0.3s;">⚡</div>
      </div>
      
    </div>
  </div>
</section>
<% end %>
