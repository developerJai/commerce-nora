<% if @homepage_settings&.flash_sale_active? %>
<!-- Flash Sale Section -->
<section class="relative py-10 sm:py-14 md:py-16 overflow-hidden">
  <!-- Luxury dark background with rose accent -->
  <div class="absolute inset-0 bg-gradient-to-br from-stone-900 via-rose-950 to-stone-900"></div>
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 28px 28px;"></div>
  <!-- Ambient glow -->
  <div class="absolute top-0 right-1/4 w-80 h-40 bg-amber-500/[0.06] rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-1/4 w-60 h-32 bg-rose-500/[0.05] rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-8 lg:gap-12">

      <!-- Content -->
      <div class="text-center lg:text-left flex-1">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-amber-500/10 rounded-full border border-amber-500/20 mb-4">
          <span class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse"></span>
          <span class="text-amber-400 font-medium text-[10px] sm:text-xs uppercase tracking-wider"><%= @homepage_settings.flash_sale_title %></span>
        </div>

        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-serif font-semibold text-white mb-3 sm:mb-4 leading-tight">
          <%= @homepage_settings.flash_sale_heading %>
        </h2>

        <p class="text-stone-400 text-sm sm:text-base mb-6 sm:mb-8 max-w-lg leading-relaxed">
          <%= @homepage_settings.flash_sale_description %>
        </p>

        <%= link_to @homepage_settings.flash_sale_cta_link, class: 'inline-flex items-center gap-2 px-6 sm:px-7 py-3 bg-gradient-to-r from-amber-500 to-amber-400 text-stone-900 text-sm font-semibold rounded-full hover:from-amber-400 hover:to-amber-300 transition-all shadow-lg shadow-amber-500/20 hover:shadow-amber-500/30 group' do %>
          <span><%= @homepage_settings.flash_sale_cta_text %></span>
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>

      <!-- Discount Badge -->
      <div class="relative flex-shrink-0">
        <!-- Outer rings -->
        <div class="absolute inset-[-12px] rounded-full border border-amber-500/20"></div>
        <div class="absolute inset-[-24px] rounded-full border border-amber-500/10"></div>
        <!-- Main badge -->
        <div class="w-36 h-36 sm:w-44 sm:h-44 rounded-full bg-gradient-to-br from-amber-400 via-amber-500 to-rose-500 flex items-center justify-center shadow-2xl shadow-amber-500/25">
          <div class="w-28 h-28 sm:w-36 sm:h-36 rounded-full bg-gradient-to-br from-amber-300 to-amber-500 flex items-center justify-center border-2 border-white/20">
            <div class="text-center">
              <span class="block text-4xl sm:text-5xl font-serif font-bold text-white drop-shadow-md"><%= @homepage_settings.flash_sale_discount %></span>
              <span class="block text-sm sm:text-base font-semibold text-white/90 -mt-0.5">% OFF</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
<% end %>
