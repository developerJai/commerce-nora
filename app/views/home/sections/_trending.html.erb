<!-- Section: Trending Now -->
<section class="py-8 sm:py-12 md:py-16 bg-white">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="flex items-end justify-between mb-6 sm:mb-8">
      <div>
        <div class="flex items-center gap-2 mb-1">
          <svg class="w-4 h-4 sm:w-5 sm:h-5 text-[#D4AF37]" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"/>
          </svg>
          <p class="text-[#D4AF37] text-[10px] sm:text-xs font-semibold tracking-[0.15em] uppercase">Trending Now</p>
        </div>
        <h2 class="text-xl sm:text-2xl md:text-3xl font-serif font-semibold text-stone-900">Hot Selling Items</h2>
      </div>
      <%= link_to products_path, class: 'group flex items-center gap-1.5 text-[#D4AF37] hover:text-[#B8962E] text-xs sm:text-sm font-medium transition' do %>
        View All
        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
    <div class="w-16 h-px gold-divider mb-6 sm:mb-8"></div>

    <% products_to_display = @hot_selling_products.any? ? @hot_selling_products.limit(4) : [] %>

    <% if products_to_display.any? %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2.5 sm:gap-3 md:gap-4">
        <% products_to_display.each do |product| %>
          <%= render 'shared/product_card', product: product %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 bg-stone-50 rounded-2xl">
        <p class="text-stone-400 text-sm">Trending products coming soon</p>
      </div>
    <% end %>
  </div>
</section>
