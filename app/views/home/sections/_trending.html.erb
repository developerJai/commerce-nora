<!-- Section: Trending Now - Hot Items -->
<section class="py-12 sm:py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <svg class="w-6 h-6 text-rose-600 animate-bounce" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"/>
          </svg>
          <span class="text-rose-600 font-bold text-sm uppercase tracking-wider">Trending Now</span>
        </div>
        <h2 class="text-2xl sm:text-3xl font-serif font-semibold text-stone-900">Hot Selling Items</h2>
      </div>
      <%= link_to products_path, class: 'text-rose-600 hover:text-rose-700 font-medium flex items-center gap-1' do %>
        View All 
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% 4.times do |i| %>
        <div class="group relative bg-stone-50 rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300">
          <div class="absolute top-3 left-3 z-10">
            <span class="px-2 py-1 bg-rose-600 text-white text-xs font-bold rounded-full">HOT</span>
          </div>
          <div class="aspect-square bg-gradient-to-br from-rose-100 to-amber-100 flex items-center justify-center">
            <svg class="w-16 h-16 text-rose-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
          </div>
          <div class="p-4">
            <h3 class="font-medium text-stone-900 mb-1">Trending Item <%= i + 1 %></h3>
            <div class="flex items-center gap-2">
              <span class="text-rose-700 font-bold">Rs. 999</span>
              <span class="text-stone-400 text-sm line-through">Rs. 1,499</span>
            </div>
            <div class="mt-2 flex items-center gap-1">
              <div class="flex text-amber-400">
                <% 5.times do %>
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                <% end %>
              </div>
              <span class="text-xs text-stone-500">(128 sold)</span>
            </div>
          </div>
          <%= link_to products_path, class: 'absolute inset-0' do %>
            <span class="sr-only">View Product</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
