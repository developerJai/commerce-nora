<!-- Section: Bundle Deals -->
<section class="py-12 sm:py-16 bg-gradient-to-b from-amber-50 to-rose-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <span class="inline-block px-4 py-1 bg-amber-100 text-amber-700 rounded-full text-sm font-medium mb-4">Bundle and Save</span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-serif font-semibold text-stone-900 mb-4">Complete Your Look</h2>
      <p class="text-stone-600 max-w-2xl mx-auto">Buy matching sets and save big! Perfect combinations for weddings and festivals.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
        <div class="relative">
          <div class="aspect-video bg-gradient-to-br from-rose-200 to-amber-200 flex items-center justify-center">
            <span class="text-6xl">💍</span>
          </div>
          <div class="absolute top-3 right-3 bg-rose-600 text-white px-3 py-1 rounded-full text-sm font-bold">SAVE 30%</div>
        </div>
        <div class="p-6">
          <h3 class="font-serif font-semibold text-lg text-stone-900 mb-2">Wedding Essential Set</h3>
          <p class="text-stone-500 text-sm mb-4">Necklace, Earrings and Maang Tikka</p>
          <div class="flex items-center justify-between">
            <div>
              <span class="text-rose-700 font-bold text-xl">Rs. 2,499</span>
              <span class="text-stone-400 text-sm line-through ml-2">Rs. 3,599</span>
            </div>
            <%= link_to "Add to Cart", products_path, class: "px-4 py-2 bg-rose-700 text-white rounded-full text-sm font-medium hover:bg-rose-800" %>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
        <div class="relative">
          <div class="aspect-video bg-gradient-to-br from-amber-200 to-rose-200 flex items-center justify-center">
            <span class="text-6xl">📿</span>
          </div>
          <div class="absolute top-3 right-3 bg-rose-600 text-white px-3 py-1 rounded-full text-sm font-bold">SAVE 25%</div>
        </div>
        <div class="p-6">
          <h3 class="font-serif font-semibold text-lg text-stone-900 mb-2">Festive Combo</h3>
          <p class="text-stone-500 text-sm mb-4">Bangles and Earrings Pair</p>
          <div class="flex items-center justify-between">
            <div>
              <span class="text-rose-700 font-bold text-xl">Rs. 1,299</span>
              <span class="text-stone-400 text-sm line-through ml-2">Rs. 1,749</span>
            </div>
            <%= link_to "Add to Cart", products_path, class: "px-4 py-2 bg-rose-700 text-white rounded-full text-sm font-medium hover:bg-rose-800" %>
          </div>
        </div>
      </div>
      
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
        <div class="relative">
          <div class="aspect-video bg-gradient-to-br from-rose-200 via-amber-200 to-rose-200 flex items-center justify-center">
            <span class="text-6xl">💎</span>
          </div>
          <div class="absolute top-3 right-3 bg-rose-600 text-white px-3 py-1 rounded-full text-sm font-bold">SAVE 40%</div>
        </div>
        <div class="p-6">
          <h3 class="font-serif font-semibold text-lg text-stone-900 mb-2">Complete Jewelry Set</h3>
          <p class="text-stone-500 text-sm mb-4">Full Bridal Collection 8 pieces</p>
          <div class="flex items-center justify-between">
            <div>
              <span class="text-rose-700 font-bold text-xl">Rs. 4,999</span>
              <span class="text-stone-400 text-sm line-through ml-2">Rs. 8,499</span>
            </div>
            <%= link_to "Add to Cart", products_path, class: "px-4 py-2 bg-rose-700 text-white rounded-full text-sm font-medium hover:bg-rose-800" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
