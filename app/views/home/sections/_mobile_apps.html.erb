<% store_setting = StoreSetting.instance %>
<% if store_setting.has_mobile_apps? %>
<div data-controller="mobile-app-section"
     data-mobile-app-section-ios-url-value="<%= store_setting.ios_app_url %>"
     data-mobile-app-section-android-url-value="<%= store_setting.android_app_url %>">

  <!-- Main section -->
  <section class="py-8 sm:py-12 md:py-16 bg-stone-50" data-mobile-app-section-target="section">
    <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
      <div class="relative rounded-2xl sm:rounded-3xl overflow-hidden">
        <!-- Background -->
        <div class="absolute inset-0" style="background: linear-gradient(135deg, #1A1A1A 0%, #2B1B0E 50%, #1A1A1A 100%);"></div>
        <!-- Subtle texture -->
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #d4a853 1px, transparent 0); background-size: 32px 32px;"></div>
        <!-- Decorative glows -->
        <div class="absolute top-0 right-0 w-72 h-72 bg-amber-500/[0.08] rounded-full -translate-y-1/3 translate-x-1/4 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-56 h-56 bg-rose-500/[0.06] rounded-full translate-y-1/3 -translate-x-1/4 blur-3xl"></div>
        <!-- Phone mockup glow -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-amber-400/[0.04] rounded-full blur-[80px]"></div>

        <!-- Dismiss button -->
        <button data-action="mobile-app-section#dismiss" class="absolute top-4 right-4 z-20 w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 text-stone-400 hover:text-white flex items-center justify-center transition backdrop-blur-sm" aria-label="Dismiss">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>

        <div class="relative px-6 py-10 sm:px-10 sm:py-14 md:px-14 md:py-16">
          <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
            <!-- Left content -->
            <div class="flex-1 text-center md:text-left">
              <!-- App brand identity -->
              <div class="inline-flex items-center gap-3 mb-5 sm:mb-6">
                <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-2xl shadow-lg shadow-black/30 overflow-hidden bg-gradient-to-br from-amber-800 to-stone-900 flex items-center justify-center border border-amber-500/20">
                  <%= image_tag asset_path('storefront/logo-icon.png'), class: 'w-full h-full object-cover', alt: 'Noralooks App' %>
                </div>
                <div class="text-left">
                  <p class="text-white font-serif font-semibold text-base sm:text-lg leading-tight">Noralooks</p>
                  <p class="text-amber-400/70 text-[10px] sm:text-xs font-medium tracking-wider uppercase">Official App</p>
                </div>
              </div>

              <h2 class="text-2xl sm:text-3xl md:text-4xl font-serif font-semibold text-white mb-3 sm:mb-4 leading-tight">
                <%= store_setting.effective_mobile_app_section_title %>
              </h2>
              <p class="text-sm sm:text-base text-stone-400 mb-6 sm:mb-8 max-w-md mx-auto md:mx-0 leading-relaxed">
                <%= store_setting.effective_mobile_app_section_subtitle %>
              </p>

              <!-- Features list -->
              <div class="grid grid-cols-2 gap-x-4 gap-y-3 sm:gap-x-6 sm:gap-y-3.5 mb-8 max-w-sm mx-auto md:mx-0">
                <div class="flex items-center gap-2.5 text-stone-300 text-xs sm:text-sm">
                  <div class="w-6 h-6 rounded-full bg-amber-500/15 flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  Exclusive deals
                </div>
                <div class="flex items-center gap-2.5 text-stone-300 text-xs sm:text-sm">
                  <div class="w-6 h-6 rounded-full bg-amber-500/15 flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  Faster checkout
                </div>
                <div class="flex items-center gap-2.5 text-stone-300 text-xs sm:text-sm">
                  <div class="w-6 h-6 rounded-full bg-amber-500/15 flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  Order tracking
                </div>
                <div class="flex items-center gap-2.5 text-stone-300 text-xs sm:text-sm">
                  <div class="w-6 h-6 rounded-full bg-amber-500/15 flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  New drop alerts
                </div>
              </div>

              <!-- Download buttons -->
              <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start">
                <% if store_setting.ios_app_url.present? %>
                  <a href="<%= store_setting.ios_app_url %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 px-5 py-3 bg-white hover:bg-stone-50 text-stone-900 rounded-xl transition shadow-lg shadow-black/20 group">
                    <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                    <div class="text-left">
                      <p class="text-[10px] text-stone-500 leading-none">Download on the</p>
                      <p class="text-sm font-semibold leading-tight">App Store</p>
                    </div>
                    <svg class="w-4 h-4 text-stone-400 group-hover:translate-x-0.5 transition-transform ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </a>
                <% end %>
                <% if store_setting.android_app_url.present? %>
                  <a href="<%= store_setting.android_app_url %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 px-5 py-3 bg-white hover:bg-stone-50 text-stone-900 rounded-xl transition shadow-lg shadow-black/20 group">
                    <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.482 1.436c.871.504.871 1.608 0 2.112l-2.482 1.436-2.532-2.492 2.532-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/></svg>
                    <div class="text-left">
                      <p class="text-[10px] text-stone-500 leading-none">Get it on</p>
                      <p class="text-sm font-semibold leading-tight">Google Play</p>
                    </div>
                    <svg class="w-4 h-4 text-stone-400 group-hover:translate-x-0.5 transition-transform ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </a>
                <% end %>
              </div>

              <!-- Rating hint -->
              <div class="mt-5 flex items-center gap-2 justify-center md:justify-start">
                <div class="flex -space-x-0.5">
                  <% 5.times do %>
                    <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  <% end %>
                </div>
                <span class="text-stone-500 text-[10px] sm:text-xs">Loved by thousands of shoppers</span>
              </div>
            </div>

            <!-- Right side: Dual phone mockup -->
            <div class="hidden md:flex flex-shrink-0 items-center justify-center">
              <div class="relative">
                <!-- Background phone (tilted) -->
                <div class="absolute -left-8 top-6 w-44 h-[360px] bg-stone-800 rounded-[2.2rem] border-4 border-stone-700/60 shadow-xl shadow-black/30 overflow-hidden rotate-[-8deg] opacity-40">
                  <div class="absolute inset-2 rounded-[1.8rem] overflow-hidden" style="background: linear-gradient(180deg, #2B1B0E 0%, #0F0F0F 100%);">
                    <div class="pt-10 px-4">
                      <div class="h-8 bg-white/10 rounded-full mb-4"></div>
                      <div class="grid grid-cols-2 gap-2">
                        <div class="aspect-square bg-gradient-to-br from-amber-900/30 to-stone-800 rounded-lg"></div>
                        <div class="aspect-square bg-gradient-to-br from-rose-900/30 to-stone-800 rounded-lg"></div>
                        <div class="aspect-square bg-gradient-to-br from-stone-700/30 to-stone-800 rounded-lg"></div>
                        <div class="aspect-square bg-gradient-to-br from-amber-800/30 to-stone-800 rounded-lg"></div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Main phone frame -->
                <div class="relative w-52 h-[420px] bg-stone-800 rounded-[2.5rem] border-4 border-stone-700 shadow-2xl shadow-black/50 overflow-hidden z-10">
                  <!-- Notch -->
                  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-28 h-6 bg-stone-800 rounded-b-2xl z-10"></div>
                  <!-- Screen content -->
                  <div class="absolute inset-2 rounded-[2rem] overflow-hidden" style="background: linear-gradient(180deg, #2B1B0E 0%, #0F0F0F 100%);">
                    <div class="pt-10 px-4">
                      <!-- App header with logo -->
                      <div class="flex items-center gap-2 mb-4">
                        <div class="w-7 h-7 rounded-lg overflow-hidden bg-gradient-to-br from-amber-800 to-stone-900">
                          <%= image_tag asset_path('storefront/logo-icon.png'), class: 'w-full h-full object-cover', alt: '' %>
                        </div>
                        <span class="text-sm font-serif font-semibold text-white">Noralooks</span>
                      </div>
                      <!-- Search bar mockup -->
                      <div class="h-8 bg-white/10 rounded-full mb-4 flex items-center px-3">
                        <svg class="w-3 h-3 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        <span class="ml-2 text-[9px] text-stone-500">Search jewellery...</span>
                      </div>
                      <!-- Product grid mockup -->
                      <div class="grid grid-cols-2 gap-2">
                        <div class="aspect-square bg-gradient-to-br from-amber-900/30 to-stone-800 rounded-lg"></div>
                        <div class="aspect-square bg-gradient-to-br from-rose-900/30 to-stone-800 rounded-lg"></div>
                        <div class="aspect-square bg-gradient-to-br from-stone-700/30 to-stone-800 rounded-lg"></div>
                        <div class="aspect-square bg-gradient-to-br from-amber-800/30 to-stone-800 rounded-lg"></div>
                      </div>
                    </div>
                    <!-- Bottom nav mockup -->
                    <div class="absolute bottom-0 inset-x-0 h-10 bg-stone-900/80 backdrop-blur-sm flex items-center justify-around px-4">
                      <svg class="w-4 h-4 text-stone-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                      <svg class="w-4 h-4 text-stone-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                      <svg class="w-4 h-4 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                      <svg class="w-4 h-4 text-stone-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    </div>
                  </div>
                </div>

                <!-- Floating notification badge -->
                <div class="absolute -top-2 -right-4 z-20 bg-white rounded-xl shadow-xl shadow-black/20 px-3 py-2 flex items-center gap-2 animate-gentle-float">
                  <div class="w-6 h-6 rounded-full bg-green-500/15 flex items-center justify-center">
                    <svg class="w-3 h-3 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <div>
                    <p class="text-[8px] text-stone-500 leading-none">Order shipped!</p>
                    <p class="text-[9px] font-semibold text-stone-800 leading-tight">Track now</p>
                  </div>
                </div>

                <!-- Floating deal badge -->
                <div class="absolute -bottom-1 -left-6 z-20 bg-amber-500 text-stone-900 text-[9px] font-bold px-3 py-1.5 rounded-full shadow-lg animate-gentle-float" style="animation-delay: -3s;">
                  App-only 15% OFF
                </div>
              </div>
            </div>
          </div>

          <!-- Mobile: compact phone preview -->
          <div class="md:hidden mt-8 flex justify-center">
            <div class="relative flex items-end gap-3">
              <div class="w-28 h-48 bg-stone-800 rounded-2xl border-2 border-stone-700 shadow-lg shadow-black/30 overflow-hidden">
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-14 h-3 bg-stone-800 rounded-b-lg z-10"></div>
                <div class="absolute inset-1.5 rounded-[0.85rem] overflow-hidden" style="background: linear-gradient(180deg, #2B1B0E 0%, #0F0F0F 100%);">
                  <div class="pt-5 px-2">
                    <div class="flex items-center gap-1 mb-2">
                      <div class="w-4 h-4 rounded overflow-hidden bg-gradient-to-br from-amber-800 to-stone-900">
                        <%= image_tag asset_path('storefront/logo-icon.png'), class: 'w-full h-full object-cover', alt: '' %>
                      </div>
                      <span class="text-[7px] font-serif font-semibold text-white">Noralooks</span>
                    </div>
                    <div class="h-4 bg-white/10 rounded-full mb-2"></div>
                    <div class="grid grid-cols-2 gap-1">
                      <div class="aspect-square bg-gradient-to-br from-amber-900/30 to-stone-800 rounded"></div>
                      <div class="aspect-square bg-gradient-to-br from-rose-900/30 to-stone-800 rounded"></div>
                      <div class="aspect-square bg-gradient-to-br from-stone-700/30 to-stone-800 rounded"></div>
                      <div class="aspect-square bg-gradient-to-br from-amber-800/30 to-stone-800 rounded"></div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="absolute -top-2 -right-2 z-10 bg-amber-500 text-stone-900 text-[8px] font-bold px-2 py-1 rounded-full shadow-lg">
                App-only deals
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky floating app button (shown after dismiss) -->
  <div data-mobile-app-section-target="fab"
       class="hidden fixed bottom-6 right-6 z-50 scale-0 opacity-0 transition-all duration-300">
    <button data-action="mobile-app-section#openFromFab"
            class="relative group flex items-center gap-2 bg-stone-900 hover:bg-stone-800 text-white pl-3 pr-4 py-2.5 rounded-full shadow-2xl shadow-black/30 border border-stone-700/50 transition-all hover:shadow-amber-900/20">
      <!-- App icon -->
      <div class="w-9 h-9 rounded-xl overflow-hidden bg-gradient-to-br from-amber-800 to-stone-900 flex-shrink-0 border border-amber-500/20 shadow-sm">
        <%= image_tag asset_path('storefront/logo-icon.png'), class: 'w-full h-full object-cover', alt: 'Noralooks App' %>
      </div>
      <div class="text-left">
        <p class="text-[10px] text-amber-400/80 leading-none font-medium">Get our app</p>
        <p class="text-xs font-semibold leading-tight text-white">Noralooks</p>
      </div>
      <!-- Pulse indicator -->
      <span class="absolute -top-1 -right-1 flex h-3 w-3">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-3 w-3 bg-amber-500"></span>
      </span>
    </button>
  </div>

</div>
<% end %>
