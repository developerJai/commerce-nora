<%# Asymmetric Layout - Large statement image left + 2 stacked right
    Inspired by the "Handpicked Just For You" section in the reference %>
<div class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-4">
  <%# First item: Large hero on left spanning full height %>
  <% if items[0] %>
    <% item = items[0] %>
    <% tag_class = "relative group overflow-hidden rounded-xl sm:rounded-2xl md:row-span-2 block h-72 sm:h-80 md:h-full md:min-h-[520px]" %>
    <% if item.link_url.present? %>
      <%= link_to item.link_url, class: tag_class do %>
        <%= render "home/layouts/item_inner", item: item, aspect: "absolute inset-0 w-full h-full" %>
      <% end %>
    <% else %>
      <div class="<%= tag_class %>">
        <%= render "home/layouts/item_inner", item: item, aspect: "absolute inset-0 w-full h-full" %>
      </div>
    <% end %>
  <% end %>

  <%# Second and third items: Stacked on the right %>
  <% items[1..2]&.each do |item| %>
    <% tag_class = "relative group overflow-hidden rounded-xl sm:rounded-2xl block h-56 sm:h-64 md:h-[252px]" %>
    <% if item.link_url.present? %>
      <%= link_to item.link_url, class: tag_class do %>
        <%= render "home/layouts/item_inner", item: item, aspect: "absolute inset-0 w-full h-full" %>
      <% end %>
    <% else %>
      <div class="<%= tag_class %>">
        <%= render "home/layouts/item_inner", item: item, aspect: "absolute inset-0 w-full h-full" %>
      </div>
    <% end %>
  <% end %>
</div>
