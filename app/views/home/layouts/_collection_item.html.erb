<%# Standard collection item card - used in equal-column grids %>
<% tag_class = "relative group overflow-hidden rounded-xl sm:rounded-2xl" %>

<% if item.link_url.present? %>
  <%= link_to item.link_url, class: tag_class do %>
    <%= render "home/layouts/item_inner", item: item, aspect: aspect %>
  <% end %>
<% else %>
  <div class="<%= tag_class %>">
    <%= render "home/layouts/item_inner", item: item, aspect: aspect %>
  </div>
<% end %>
