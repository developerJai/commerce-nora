<% content_for(:title) { "Create Account" } %>
<% content_for(:native_title) { "Join Noralooks" } %>
<% content_for(:meta_description) { "Create your free Noralooks account to shop fashion jewellery, ethnic wear, and gifts. Get exclusive access to deals, track orders, save wishlist items, and enjoy personalized shopping experience." } %>
<% content_for(:meta_keywords) { ["create account", "sign up", "register", "new account", "customer registration", "Noralooks signup", "join Noralooks", "free account", "jewellery shopping account"] } %>

<% content_for(:head) do %>
  <!-- Structured Data - WebPage Schema for Registration -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Create Account - Noralooks",
    "description": "Create your free Noralooks account",
    "url": "<%= signup_url %>",
    "mainEntity": {
      "@type": "WebApplication",
      "name": "Noralooks Customer Registration",
      "applicationCategory": "E-commerce",
      "operatingSystem": "Web Browser",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "INR",
        "description": "Free account registration"
      }
    }
  }
  </script>
  
  <% if request.user_agent&.include?("NoraLooks/iOS") %>
  <!-- Mobile app specific styles -->
  <style>
    /* Prevent zoom on iOS - minimum 16px font size */
    input, select, textarea {
      font-size: 16px !important;
    }
    /* Larger touch targets for mobile app */
    .mobile-input {
      min-height: 48px;
    }
    /* Hide decorative elements in mobile app */
    .mobile-app .decorative-icon {
      display: none;
    }
  </style>
  <% end %>
<% end %>

<!-- Add intl-tel-input CSS -->
<%= stylesheet_link_tag "https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.19/css/intlTelInput.css", "data-turbo-track": "reload" %>

<div class="<%= request.user_agent&.include?('NoraLooks/iOS') ? 'mobile-app flex items-center justify-center px-4 py-4' : 'sm:min-h-[60vh] flex items-center justify-center px-4 py-4 sm:py-12' %>">
  <div class="w-full max-w-md">
    <div class="bg-white <%= request.user_agent&.include?('NoraLooks/iOS') ? 'p-5' : 'rounded-xl border border-stone-200 p-5 sm:p-6 md:p-8 shadow-sm sm:shadow-none' %>">
      <!-- Header -->
      <header class="text-center mb-6">
        <%= image_tag asset_path('storefront/logo-icon.png'), class: 'w-16 h-16 sm:w-20 sm:h-20 mx-auto rounded-xl shadow-lg shadow-amber-900/20 mb-3', alt: 'Noralooks' %>
        <h1 class="text-xl font-semibold text-stone-900 font-sans">Create Account</h1>
        <p class="text-stone-500 mt-1.5 text-sm">Join Noralooks for exclusive deals</p>
      </header>

      <%= form_with model: @customer, url: signup_path, method: :post, class: 'space-y-4',
          data: { controller: 'signup-form', action: 'submit->signup-form#submit', show_loader: 'true' },
          aria: { label: 'Create account registration form' } do |f| %>
        <% if @customer.errors.any? %>
          <div class="rounded-lg bg-red-50 border border-red-200 p-3">
            <div class="flex items-start gap-2">
              <div class="flex-shrink-0 w-6 h-6 bg-red-100 rounded-full flex items-center justify-center">
                <svg class="h-3 w-3 text-red-600" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <h3 class="text-xs font-medium text-red-800">Please fix:</h3>
                <ul class="mt-1 text-xs text-red-700 list-disc list-inside">
                  <% @customer.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        <% end %>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= f.label :first_name, class: 'block text-sm font-medium text-stone-700 mb-1' %>
            <%= f.text_field :first_name, required: true, placeholder: 'First name',
                class: 'mobile-input w-full px-3 py-2.5 border border-stone-300 rounded-lg text-base focus:ring-2 focus:ring-rose-400 focus:border-transparent',
                data: { signup_form_target: 'firstName' } %>
          </div>
          <div>
            <%= f.label :last_name, class: 'block text-sm font-medium text-stone-700 mb-1' %>
            <%= f.text_field :last_name, required: true, placeholder: 'Last name',
                class: 'mobile-input w-full px-3 py-2.5 border border-stone-300 rounded-lg text-base focus:ring-2 focus:ring-rose-400 focus:border-transparent',
                data: { signup_form_target: 'lastName' } %>
          </div>
        </div>

        <div>
          <%= f.label :email, class: 'block text-sm font-medium text-stone-700 mb-1' %>
          <div class="relative">
            <%= f.email_field :email, autofocus: true, autocomplete: 'email', required: true,
                placeholder: 'Enter your email',
                class: 'mobile-input w-full px-3 py-2.5 border border-stone-300 rounded-lg text-base focus:ring-2 focus:ring-rose-400 focus:border-transparent',
                data: { signup_form_target: 'email', action: 'input->signup-form#validateEmail blur->signup-form#validateEmail' } %>
          </div>
          <div id="email-error" class="mt-1 text-xs text-red-600 hidden" data-signup-form-target="emailError"></div>
        </div>

        <div>
          <%= f.label :phone, class: 'block text-sm font-medium text-stone-700 mb-1' %>
          <div class="relative">
            <%= f.telephone_field :phone, autocomplete: 'tel', placeholder: 'Phone number (optional)',
                class: 'mobile-input w-full px-3 py-2.5 border border-stone-300 rounded-lg text-base focus:ring-2 focus:ring-rose-400 focus:border-transparent',
                id: 'phone',
                data: { signup_form_target: 'phone', action: 'input->signup-form#validatePhone blur->signup-form#validatePhone' } %>
            <div id="phone-error" class="mt-1 text-xs text-red-600 hidden" data-signup-form-target="phoneError"></div>
          </div>
        </div>

        <div>
          <%= f.label :password, class: 'block text-sm font-medium text-stone-700 mb-1' %>
          <div class="relative">
            <%= f.password_field :password, autocomplete: 'new-password', required: true,
                placeholder: 'Create password',
                class: 'mobile-input w-full px-3 py-2.5 pr-12 border border-stone-300 rounded-lg text-base focus:ring-2 focus:ring-rose-400 focus:border-transparent',
                id: 'customer_password',
                data: { signup_form_target: 'password' } %>
            <button type="button" 
                    class="absolute right-3 top-1/2 transform -translate-y-1/2 text-stone-400 hover:text-stone-600 p-2 touch-manipulation" 
                    data-action="click->signup-form#togglePassword touchstart->signup-form#togglePassword" 
                    data-field-id="customer_password"
                    aria-label="Toggle password visibility">
              <svg class="w-5 h-5 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </button>
          </div>
          <p class="mt-1 text-xs text-stone-500">Minimum 8 characters</p>
        </div>

        <div>
          <%= f.label :password_confirmation, 'Confirm Password', class: 'block text-sm font-medium text-stone-700 mb-1' %>
          <div class="relative">
            <%= f.password_field :password_confirmation, autocomplete: 'new-password', required: true,
                placeholder: 'Confirm password',
                class: 'mobile-input w-full px-3 py-2.5 pr-12 border border-stone-300 rounded-lg text-base focus:ring-2 focus:ring-rose-400 focus:border-transparent',
                id: 'customer_password_confirmation',
                data: { signup_form_target: 'passwordConfirmation' } %>
            <button type="button" 
                    class="absolute right-3 top-1/2 transform -translate-y-1/2 text-stone-400 hover:text-stone-600 p-2 touch-manipulation" 
                    data-action="click->signup-form#togglePassword touchstart->signup-form#togglePassword" 
                    data-field-id="customer_password_confirmation"
                    aria-label="Toggle password confirmation visibility">
              <svg class="w-5 h-5 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </button>
          </div>
        </div>

        <div id="password-match-error"
             class="mt-1 text-xs text-red-600 hidden"
             data-signup-form-target="passwordMatchError">
          Password does not match
        </div>

        <%= f.submit 'Create Account', 
            class: 'mobile-input w-full py-3 px-4 bg-rose-800 text-white text-base font-medium rounded-lg hover:bg-rose-900 transition cursor-pointer shadow-md',
            data: { signup_form_target: 'submitButton' } %>
      <% end %>

      <p class="mt-5 text-center text-sm text-stone-600">
        Already have an account?
        <%= link_to 'Sign in', login_path, class: 'text-rose-700 hover:text-rose-900 font-medium' %>
      </p>
    </div>
  </div>
</div>
