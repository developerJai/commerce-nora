<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <title><%= content_for(:title) || "Auracraft" %> | Modern E-Commerce</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="min-h-full flex flex-col bg-gray-50">
  <!-- Header -->
  <header class="sticky top-0 z-50 bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
      <div class="flex items-center h-14 sm:h-16 gap-3 sm:gap-6">
        <!-- Logo -->
        <%= link_to root_path, class: 'flex-shrink-0 flex items-center gap-2' do %>
          <div class="w-8 h-8 sm:w-9 sm:h-9 bg-gradient-to-br from-teal-400 to-teal-500 rounded-xl flex items-center justify-center shadow-sm">
            <span class="text-white font-bold text-sm sm:text-base">A</span>
          </div>
          <span class="text-lg sm:text-xl font-bold text-gray-900 tracking-tight">Auracraft</span>
        <% end %>

        <!-- Search -->
        <% unless content_for?(:hide_header_search) %>
          <div class="flex-1 max-w-xl hidden sm:block" data-controller="search-autocomplete">
            <%= form_with url: search_path, method: :get, class: 'relative' do |f| %>
              <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <%= f.search_field :q, value: params[:q], 
                    placeholder: 'Search products...', 
                    class: 'w-full h-10 pl-10 pr-4 bg-gray-100 text-gray-900 rounded-full border-0 focus:ring-2 focus:ring-teal-500 focus:bg-white placeholder:text-gray-500 text-sm transition',
                    autocomplete: 'off',
                    data: { 
                      search_autocomplete_target: 'input',
                      action: 'input->search-autocomplete#search focus->search-autocomplete#search'
                    } %>
              </div>
              <div data-search-autocomplete-target="results" 
                   class="absolute top-full left-0 right-0 mt-2 bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden hidden z-50">
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="flex-1"></div>
        <% end %>

        <!-- Mobile search toggle -->
        <button type="button" 
                class="sm:hidden p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition"
                onclick="document.getElementById('mobile-search').classList.toggle('hidden')">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </button>

        <!-- Right side -->
        <div class="flex items-center gap-1 sm:gap-2">
          <!-- Account -->
          <div class="relative" data-controller="dropdown">
            <button class="flex items-center gap-2 px-2 sm:px-3 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition" data-action="click->dropdown#toggle">
              <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span class="hidden sm:block text-sm font-medium">Account</span>
              <svg class="w-4 h-4 text-gray-400 hidden sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-gray-200 py-2 z-50" data-dropdown-target="menu">
              <% if customer_logged_in? %>
                <div class="px-4 py-3 border-b border-gray-100">
                  <p class="text-sm font-medium text-gray-900"><%= current_customer.full_name %></p>
                  <p class="text-xs text-gray-500 mt-0.5"><%= current_customer.email %></p>
                </div>
                <%= link_to account_path, class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50' do %>
                  My Account
                <% end %>
                <%= link_to orders_path, class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50' do %>
                  My Orders
                <% end %>
                <%= link_to addresses_path, class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50' do %>
                  Addresses
                <% end %>
                <%= link_to support_tickets_path, class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50' do %>
                  Help & Support
                <% end %>
                <hr class="my-2 border-gray-100">
                <%= button_to logout_path, method: :delete, class: 'block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50' do %>
                  Sign Out
                <% end %>
              <% else %>
                <div class="px-4 py-3">
                  <%= link_to 'Sign In', login_path, class: 'block w-full py-2 px-4 bg-teal-500 hover:bg-teal-600 text-white text-center text-sm font-medium rounded-lg transition' %>
                  <p class="mt-3 text-xs text-gray-500 text-center">
                    New here? <%= link_to 'Create account', signup_path, class: 'text-teal-600 font-medium hover:underline' %>
                  </p>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Cart -->
          <%= link_to cart_path, class: 'flex items-center gap-1 px-2 sm:px-3 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition' do %>
            <div class="relative">
              <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
              <% if current_cart.item_count > 0 %>
                <span id="cart-count" class="absolute -top-1 -right-1 h-4 w-4 rounded-full bg-teal-500 text-white text-[10px] font-bold flex items-center justify-center">
                  <%= current_cart.item_count %>
                </span>
              <% else %>
                <span id="cart-count" class="hidden"></span>
              <% end %>
            </div>
            <span class="hidden sm:block text-sm font-medium">Cart</span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Mobile Search -->
    <div id="mobile-search" class="sm:hidden border-t border-gray-100 px-3 py-2 hidden">
      <%= form_with url: search_path, method: :get, class: 'relative' do |f| %>
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <%= f.search_field :q, value: params[:q], 
            placeholder: 'Search products...', 
            class: 'w-full h-10 pl-10 pr-4 bg-gray-100 text-gray-900 rounded-full border-0 focus:ring-2 focus:ring-teal-500 placeholder:text-gray-500 text-sm' %>
      <% end %>
    </div>

    <!-- Categories Nav -->
    <nav class="border-t border-gray-100 bg-white">
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex items-center gap-1 sm:gap-2 h-10 overflow-x-auto scrollbar-hide">
          <%= link_to products_path, class: 'flex items-center gap-1.5 px-3 py-1.5 text-sm text-gray-600 hover:text-teal-600 hover:bg-teal-50 rounded-full transition whitespace-nowrap' do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            All
          <% end %>
          <% Category.active.root.ordered.limit(6).each do |category| %>
            <%= link_to category.name, category_path(category.slug), class: 'px-3 py-1.5 text-sm text-gray-600 hover:text-teal-600 hover:bg-teal-50 rounded-full transition whitespace-nowrap' %>
          <% end %>
          <%= link_to 'Deals', products_path(featured: true), class: 'px-3 py-1.5 text-sm text-rose-600 font-medium hover:bg-rose-50 rounded-full transition whitespace-nowrap' %>
        </div>
      </div>
    </nav>
  </header>

  <!-- Flash messages -->
  <div id="flash" class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 mt-4">
    <% if flash[:notice] %>
      <div class="rounded-lg bg-teal-50 border border-teal-200 p-4 mb-4" data-controller="flash">
        <div class="flex items-center">
          <svg class="h-5 w-5 text-teal-500 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <p class="ml-3 text-sm font-medium text-teal-800 flex-1"><%= flash[:notice] %></p>
          <button data-action="click->flash#dismiss" class="text-teal-500 hover:text-teal-700">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-4 mb-4" data-controller="flash">
        <div class="flex items-center">
          <svg class="h-5 w-5 text-red-500 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
          <p class="ml-3 text-sm font-medium text-red-800 flex-1"><%= flash[:alert] %></p>
          <button data-action="click->flash#dismiss" class="text-red-500 hover:text-red-700">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Main content -->
  <main class="flex-grow">
    <%= yield %>
  </main>

  <!-- Footer -->
  <footer class="bg-white border-t border-gray-200 mt-12 sm:mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="col-span-2 md:col-span-1">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-8 h-8 bg-gradient-to-br from-teal-400 to-teal-500 rounded-xl flex items-center justify-center">
              <span class="text-white font-bold text-sm">A</span>
            </div>
            <span class="text-lg font-bold text-gray-900">Auracraft</span>
          </div>
          <p class="text-gray-500 text-sm leading-relaxed">Quality products, fast delivery, and exceptional customer service.</p>
        </div>
        <div>
          <h4 class="text-gray-900 font-semibold mb-4 text-sm">Shop</h4>
          <ul class="space-y-2.5 text-sm">
            <li><%= link_to 'All Products', products_path, class: 'text-gray-500 hover:text-teal-600 transition' %></li>
            <li><%= link_to 'New Arrivals', products_path(sort: 'newest'), class: 'text-gray-500 hover:text-teal-600 transition' %></li>
            <li><%= link_to 'Best Sellers', products_path(featured: true), class: 'text-gray-500 hover:text-teal-600 transition' %></li>
          </ul>
        </div>
        <div>
          <h4 class="text-gray-900 font-semibold mb-4 text-sm">Account</h4>
          <ul class="space-y-2.5 text-sm">
            <li><%= link_to 'My Account', account_path, class: 'text-gray-500 hover:text-teal-600 transition' %></li>
            <li><%= link_to 'Orders', orders_path, class: 'text-gray-500 hover:text-teal-600 transition' %></li>
            <li><%= link_to 'Addresses', addresses_path, class: 'text-gray-500 hover:text-teal-600 transition' %></li>
          </ul>
        </div>
        <div>
          <h4 class="text-gray-900 font-semibold mb-4 text-sm">Help</h4>
          <ul class="space-y-2.5 text-sm">
            <li><%= link_to 'Support', support_tickets_path, class: 'text-gray-500 hover:text-teal-600 transition' %></li>
            <li><%= link_to 'Shipping', '#', class: 'text-gray-500 hover:text-teal-600 transition' %></li>
            <li><%= link_to 'Returns', '#', class: 'text-gray-500 hover:text-teal-600 transition' %></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-200 mt-10 pt-8 text-center">
        <p class="text-gray-400 text-sm">&copy; <%= Date.current.year %> Auracraft. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Mobile Bottom Navigation -->
  <nav class="sm:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-40 safe-area-pb">
    <div class="flex items-center justify-around h-14">
      <%= link_to root_path, class: "flex flex-col items-center justify-center flex-1 py-2 #{current_page?(root_path) ? 'text-teal-600' : 'text-gray-400'}" do %>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        <span class="text-[10px] mt-0.5">Home</span>
      <% end %>
      <%= link_to products_path, class: "flex flex-col items-center justify-center flex-1 py-2 #{current_page?(products_path) ? 'text-teal-600' : 'text-gray-400'}" do %>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <span class="text-[10px] mt-0.5">Browse</span>
      <% end %>
      <%= link_to cart_path, class: "flex flex-col items-center justify-center flex-1 py-2 relative #{current_page?(cart_path) ? 'text-teal-600' : 'text-gray-400'}" do %>
        <div class="relative">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          <% if current_cart.item_count > 0 %>
            <span class="absolute -top-1 -right-1 h-4 w-4 rounded-full bg-teal-500 text-white text-[9px] font-bold flex items-center justify-center">
              <%= current_cart.item_count %>
            </span>
          <% end %>
        </div>
        <span class="text-[10px] mt-0.5">Cart</span>
      <% end %>
      <%= link_to orders_path, class: "flex flex-col items-center justify-center flex-1 py-2 #{current_page?(orders_path) ? 'text-teal-600' : 'text-gray-400'}" do %>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <span class="text-[10px] mt-0.5">Orders</span>
      <% end %>
      <%= link_to (customer_logged_in? ? account_path : login_path), class: "flex flex-col items-center justify-center flex-1 py-2 #{current_page?(account_path) ? 'text-teal-600' : 'text-gray-400'}" do %>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span class="text-[10px] mt-0.5">Account</span>
      <% end %>
    </div>
  </nav>
  
  <div class="sm:hidden h-14"></div>
</body>
</html>
