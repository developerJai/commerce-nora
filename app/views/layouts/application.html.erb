<!DOCTYPE html>
<html lang="en" data-turbo-prefetch="false">
<head>
  <% if Rails.env.production? %>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2GPGNSFCEE"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-2GPGNSFCEE');
    </script>
  <% end %>

  <% if request.user_agent&.include?("Hotwire") %>
    <title><%= native_page_title(content_for(:native_title)) %></title>
  <% else %>
    <title><%= meta_title(content_for(:title)) %></title>
  <% end %>
  <meta name="viewport" content="width=device-width,initial-scale=1,<%= 'maximum-scale=1,user-scalable=no,' if request.user_agent&.include?('Hotwire') %>viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  
  <!-- SEO Meta Tags -->
  <meta name="description" content="<%= meta_description(content_for(:meta_description)) %>">
  <meta name="keywords" content="<%= meta_keywords(content_for(:meta_keywords) || []) %>">
  <meta name="author" content="Noralooks">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <link rel="canonical" href="<%= canonical_url %>">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="<%= content_for(:og_type) || 'website' %>">
  <meta property="og:url" content="<%= canonical_url %>">
  <meta property="og:title" content="<%= meta_title(content_for(:title)) %>">
  <meta property="og:description" content="<%= meta_description(content_for(:meta_description)) %>">
  <meta property="og:image" content="<%= content_for(:og_image) || og_image_url %>">
  <meta property="og:site_name" content="Noralooks">
  <meta property="og:locale" content="en_IN">
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content="<%= canonical_url %>">
  <meta name="twitter:title" content="<%= meta_title(content_for(:title)) %>">
  <meta name="twitter:description" content="<%= meta_description(content_for(:meta_description)) %>">
  <meta name="twitter:image" content="<%= content_for(:og_image) || og_image_url %>">
  
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <!-- Favicon - SVG with brand colors (modern browsers) -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">

  <!-- Fallback PNG favicons (older browsers) -->
  <link rel="icon" href="/icon-32.png" type="image/png" sizes="32x32">
  <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192">

  <!-- Apple Touch Icon -->
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180">

  <!-- PWA Manifest -->
  <link rel="manifest" href="/manifest.json">
  <!-- Theme color for browser UI -->
  <meta name="theme-color" content="#1a1410">
  <meta name="apple-mobile-web-app-title" content="Noralooks">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  
  <style>
    .font-serif { font-family: 'Playfair Display', serif; }
    .font-sans { font-family: 'Inter', sans-serif; }
    <% if request.user_agent&.include?("Hotwire") %>
      /* Only affects Hotwire Native app */
      body {
        -webkit-overflow-scrolling: touch;
        overflow-y: auto !important;
        height: auto !important;
      }
      /* Prevent long-press context menu / link preview in native app */
      a, img, button {
        -webkit-touch-callout: none !important;
        -webkit-user-select: none !important;
      }
    <% end %>
  </style>
</head>
<body class="min-h-screen flex flex-col bg-stone-50 font-sans">
  <!-- Top Bar -->
  <% banner = StoreSetting.instance %>
  <div class="hidden sm:block text-center py-2 px-3" style="background-color: <%= banner.effective_banner_bg_color %>;">
    <p class="text-xs sm:text-sm" style="color: <%= banner.effective_banner_text_color %>;">
      <span class="font-medium" style="color: <%= banner.effective_banner_accent_color %>;">Free Shipping</span> on orders above <%= format_price(free_delivery_threshold) %> |
      <span class="hidden sm:inline">Quality Checked Before Dispatch | </span>24-Hour Dispatch
    </p>
  </div>

  <!-- Header -->
  <header class="sticky top-0 z-50 shadow-md relative" style="background: #0F0F0F;">
    <div class="absolute inset-0 pointer-events-none"></div>
    <div class="max-w-7xl sm:mx-auto sm:px-6 lg:px-8 relative z-20">
      <div class="flex items-center h-12 sm:h-16 gap-3 sm:gap-6 px-3 sm:px-0">
        <!-- Logo -->
        <%= link_to root_path, class: 'flex-shrink-0' do %>
          <span class="text-xl sm:text-2xl font-serif font-semibold" style="color: #F5F5F5;">Noralooks</span>
        <% end %>

        <!-- Search -->
        <% unless content_for?(:hide_header_search) %>
          <div class="flex-1 max-w-lg hidden sm:block" data-controller="search-autocomplete">
            <%= form_with url: products_path, method: :get, class: 'relative', data: { turbo_frame: '_top' } do |f| %>
              <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <%= f.search_field :q, value: params[:q], 
                    placeholder: search_placeholder, 
                    class: 'w-full h-10 pl-10 pr-4 bg-stone-100 text-stone-800 rounded-full border-0 focus:ring-2 focus:ring-[#D4AF37] focus:bg-white placeholder:text-stone-400 text-sm transition',
                    autocomplete: 'off',
                    data: { 
                      search_autocomplete_target: 'input',
                      action: 'input->search-autocomplete#search focus->search-autocomplete#search keydown.enter->search-autocomplete#submitForm'
                    } %>
              </div>
              <div data-search-autocomplete-target="results" 
                   class="absolute top-full left-0 right-0 mt-2 bg-white rounded-lg shadow-xl border border-stone-200 overflow-hidden hidden z-50">
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="flex-1"></div>
        <% end %>

        <!-- Mobile search -->
        <div class="sm:hidden flex-1" data-controller="search-autocomplete" data-search-autocomplete-mobile-value="true">
          <%= form_with url: products_path, method: :get, class: 'relative', data: { turbo_frame: '_top' } do |f| %>
            <div class="relative">
              <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              <%= f.search_field :q, value: params[:q],
                  placeholder: 'Search...',
                  class: 'w-full h-8 pl-8 pr-8 bg-white/20 text-white rounded-full border border-white/30 focus:ring-1 focus:ring-[#D4AF37] focus:bg-white focus:text-stone-800 placeholder:text-white/70 focus:placeholder:text-stone-400 text-base sm:text-xs transition',
                  autocomplete: 'off',
                  data: {
                    search_autocomplete_target: 'input',
                    action: 'input->search-autocomplete#search focus->search-autocomplete#search keydown.enter->search-autocomplete#submitForm'
                  } %>
              <button type="button" data-search-autocomplete-target="clearButton" data-action="click->search-autocomplete#clearInput" class="hidden absolute right-2 top-1/2 -translate-y-1/2 p-0.5 text-stone-400 hover:text-stone-600">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
            <div data-search-autocomplete-target="results"
                 class="absolute top-full left-0 right-0 mt-2 bg-white rounded-lg shadow-xl border border-stone-200 overflow-hidden hidden z-50 max-h-[60vh] overflow-y-auto">
            </div>
          <% end %>
        </div>

        <!-- Right side -->
        <div class="hidden sm:flex items-center gap-1">
          <!-- Account -->
         <div class="relative" data-controller="dropdown">
            <button class="flex items-center gap-1.5 px-2 sm:px-3 py-2 text-white hover:text-[#D4AF37] transition" data-action="mouseenter->dropdown#open mouseleave->dropdown#close">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span class="hidden sm:block text-sm">Account</span>
              <svg class="hidden sm:block w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="hidden absolute right-0 mt-2 w-56 bg-white rounded-lg shadow-xl border border-stone-200 py-2 z-50" data-dropdown-target="menu" data-action="mouseenter->dropdown#open mouseleave->dropdown#close">
              <% if customer_logged_in? %>
                <div class="px-4 py-3 border-b border-stone-100">
                  <p class="text-sm font-medium text-stone-900"><%= current_customer.full_name %></p>
                  <p class="text-xs text-stone-500"><%= current_customer.email %></p>
                </div>
                <%= link_to 'My Account', account_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <%= link_to 'My Orders', orders_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <%= link_to 'Addresses', addresses_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <%= link_to 'Wishlist', wishlists_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <%= link_to 'Help', support_tickets_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <hr class="my-2 border-stone-100">
                <%= button_to logout_path, method: :delete, data: { show_loader: 'true' }, class: 'block w-full text-left px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' do %>
                  Sign Out
                <% end %>
              <% else %>
                <div class="px-4 py-3">
                  <%= link_to 'Sign In', login_path, class: 'block w-full py-2 px-4 text-white text-center text-sm font-medium rounded-lg transition', style: 'background-color: #B8962E;' %>
                  <p class="mt-3 text-xs text-stone-500 text-center">
                    New here? <%= link_to 'Register', signup_path, class: 'text-rose-700 font-medium hover:underline' %>
                  </p>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Wishlist -->
          <%= link_to wishlists_path, class: 'flex items-center gap-1.5 px-2 sm:px-3 py-2 text-white hover:text-[#D4AF37] transition' do %>
            <div class="relative" data-wishlist-icon-wrapper>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
              <span id="wishlist-count">
                <%= render 'shared/wishlist_count_badge' %>
              </span>
            </div>
            <span class="hidden sm:block text-sm">Wishlist</span>
          <% end %>

          <!-- Cart -->
          <%= link_to cart_path, class: 'flex items-center gap-1.5 px-2 sm:px-3 py-2 text-white hover:text-[#D4AF37] transition' do %>
            <div class="relative" data-cart-icon-wrapper>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
              <span id="cart-count">
                <%= render 'shared/cart_count_badge' %>
              </span>
            </div>
            <span class="hidden sm:block text-sm">Bag</span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Mobile Search -->
    <div id="mobile-search" class="sm:hidden border-t border-white/20 px-3 py-2 hidden relative z-10">
      <%= form_with url: products_path, method: :get, class: 'relative', data: { turbo_frame: '_top' } do |f| %>
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <%= f.search_field :q, value: params[:q], 
            placeholder: search_placeholder, 
            class: 'w-full h-10 pl-10 pr-4 bg-stone-100 text-stone-800 rounded-full border-0 focus:ring-2 focus:ring-rose-400 placeholder:text-stone-400 text-sm' %>
      <% end %>
    </div>

    <!-- Categories Nav with Subcategory Dropdowns -->
    <% unless controller_name == 'products' && action_name == 'index' %>
      <nav class="hidden sm:block relative z-10" style="background: #FFFFFF; border-bottom: 1px solid #EAEAEA;">
        <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
          <div class="overflow-x-auto overflow-y-visible scrollbar-hide">
            <div class="flex items-center gap-1 sm:gap-4 h-10 min-w-max">
              <% active_class = 'px-3 py-1.5 text-sm font-medium whitespace-nowrap' + ' text-[#D4AF37]' %>
              <% inactive_class = 'px-3 py-1.5 text-sm whitespace-nowrap transition text-[#1A1A1A] hover:text-[#D4AF37]' %>
              <% selected_category_ids = Array(params[:category_ids]).reject(&:blank?).map(&:to_s) %>
              <% collections_active = params[:featured].present? && ActiveModel::Type::Boolean.new.cast(params[:featured]) %>
              <% all_active = selected_category_ids.empty? && !collections_active %>
              <% navbar_categories = Category.storefront_navbar_tree %>
              <% standalone_subcategories = Category.storefront_navbar_standalone_subcategories %>

              <%= link_to products_path, class: (all_active ? active_class : inactive_class) do %>
                All
              <% end %>
              <%= link_to 'Collections', products_path(featured: true), class: (collections_active ? active_class : inactive_class) %>
              <% navbar_categories.each do |category, visible_children| %>
                <% category_active = selected_category_ids.include?(category.id.to_s) || visible_children.any? { |child| selected_category_ids.include?(child.id.to_s) } %>
                <% if visible_children.any? %>
                  <div class="relative" data-controller="dropdown" data-dropdown-fixed-value="true">
                    <%= link_to category_path(category.slug), class: "flex items-center gap-1.5 px-3 py-1.5 text-sm whitespace-nowrap transition #{category_active ? 'text-[#D4AF37] font-medium' : 'text-[#1A1A1A] hover:text-[#D4AF37]'}", data: { action: "mouseenter->dropdown#open mouseleave->dropdown#close" } do %>
                      <span><%= category.name %></span>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
                      </svg>
                    <% end %>
                    <div class="hidden" data-dropdown-target="menu" data-action="mouseenter->dropdown#open mouseleave->dropdown#close">
                      <div class="bg-white border border-stone-200 rounded-lg shadow-lg py-2 min-w-[180px]">
                        <% visible_children.each do |child| %>
                          <% child_active = selected_category_ids.include?(child.id.to_s) %>
                          <%= link_to child.name, category_path(child.slug), class: "block px-4 py-2 text-sm transition #{child_active ? 'text-[#D4AF37] font-medium bg-amber-50' : 'text-[#1A1A1A] hover:text-[#D4AF37] hover:bg-amber-50'}" %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% else %>
                  <%= link_to category.name, category_path(category.slug), class: (category_active ? active_class : inactive_class) %>
                <% end %>
              <% end %>
              <% standalone_subcategories.each do |category| %>
                <% category_active = selected_category_ids.include?(category.id.to_s) %>
                <%= link_to category.name, category_path(category.slug), class: (category_active ? active_class : inactive_class) %>
              <% end %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>
  </header>

  <div id="toasts" class="fixed top-20 sm:top-24 right-3 sm:right-6 z-[60] flex flex-col gap-2 items-end">
    <% if flash[:notice].present? %>
      <%= render 'shared/toast', message: flash[:notice], variant: :success %>
    <% end %>
    <% if flash[:alert].present? %>
      <%= render 'shared/toast', message: flash[:alert], variant: :error %>
    <% end %>
  </div>

  <main class="flex-1">
    <%= yield %>
  </main>

  <!-- Footer -->
  <% no_footer_pages = %w[products accounts orders addresses wishlists support_tickets account_passwords order_reviews carts checkouts callbacks sessions registrations] %>
  <% hide_footer_completely = no_footer_pages.include?(controller_name) %>
  <!-- Mobile-only compact footer with social links -->
  <% unless hide_footer_completely %>
    <div class="sm:hidden bg-stone-900 mt-auto pt-6 pb-20 px-4">
      <% mobile_footer_store_setting = StoreSetting.instance %>
      <% if mobile_footer_store_setting.has_social_links? %>
        <p class="text-stone-400 text-xs text-center mb-3">Follow us</p>
        <div class="flex items-center justify-center gap-5 mb-4">
          <% if mobile_footer_store_setting.instagram_url.present? %>
            <a href="<%= mobile_footer_store_setting.instagram_url %>" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-pink-400 transition" aria-label="Instagram">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          <% end %>
          <% if mobile_footer_store_setting.youtube_url.present? %>
            <a href="<%= mobile_footer_store_setting.youtube_url %>" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-red-400 transition" aria-label="YouTube">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          <% end %>
          <% if mobile_footer_store_setting.facebook_url.present? %>
            <a href="<%= mobile_footer_store_setting.facebook_url %>" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-blue-400 transition" aria-label="Facebook">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          <% end %>
          <% if mobile_footer_store_setting.twitter_url.present? %>
            <a href="<%= mobile_footer_store_setting.twitter_url %>" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-white transition" aria-label="X">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          <% end %>
        </div>
      <% end %>
      <p class="text-stone-500 text-[10px] text-center">&copy; <%= Date.current.year %> Noralooks. All rights reserved.</p>
    </div>
  <% end %>

  <footer class="<%= hide_footer_completely ? 'hidden' : 'hidden sm:block' %> bg-stone-900 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8">
        <% footer_store_setting = StoreSetting.instance %>
        <div class="col-span-2 md:col-span-1">
          <span class="text-xl font-serif font-semibold text-white">Noralooks</span>
          <p class="text-stone-400 text-sm mt-3 leading-relaxed">Buy fashion jewellery, fashion jewellery, ethnic wear & gifts online. Premium quality at affordable prices with free shipping across India.</p>
          <% if footer_store_setting.has_social_links? %>
            <div class="flex items-center gap-3 mt-4">
              <% if footer_store_setting.instagram_url.present? %>
                <a href="<%= footer_store_setting.instagram_url %>" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-pink-400 transition" aria-label="Follow Noralooks on Instagram">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
              <% end %>
              <% if footer_store_setting.youtube_url.present? %>
                <a href="<%= footer_store_setting.youtube_url %>" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-red-400 transition" aria-label="Subscribe to Noralooks on YouTube">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a>
              <% end %>
              <% if footer_store_setting.facebook_url.present? %>
                <a href="<%= footer_store_setting.facebook_url %>" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-blue-400 transition" aria-label="Follow Noralooks on Facebook">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              <% end %>
              <% if footer_store_setting.twitter_url.present? %>
                <a href="<%= footer_store_setting.twitter_url %>" target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-white transition" aria-label="Follow Noralooks on X">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              <% end %>
            </div>
          <% end %>
        </div>
        <div>
          <h4 class="text-white font-medium mb-4 text-sm">Shop Jewellery</h4>
          <ul class="space-y-2 text-sm">
            <li><%= link_to 'All Fashion Jewellery', products_path(sort: 'price_low'), class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'New Arrivals', products_path(sort: 'newest'), class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Best Sellers', products_path(sort: 'rating'), class: 'text-stone-400 hover:text-rose-400 transition' %></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-medium mb-4 text-sm">Account</h4>
          <ul class="space-y-2 text-sm">
            <li><%= link_to 'My Account', account_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Orders', orders_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Addresses', addresses_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Wishlist', wishlists_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-medium mb-4 text-sm">Help</h4>
          <ul class="space-y-2 text-sm">
            <li><%= link_to 'Contact Us', support_tickets_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Shipping', shipping_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Returns & Exchange', returns_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-medium mb-4 text-sm">Company</h4>
          <ul class="space-y-2 text-sm">
            <li><%= link_to 'About Us', about_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Privacy Policy', privacy_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Terms & Conditions', terms_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
          </ul>
        </div>
      </div>
      
      <!-- Trust badges -->
      <div class="border-t border-stone-800 mt-8 pt-8">
        <div class="flex flex-wrap justify-center gap-6 sm:gap-10 text-center text-xs text-stone-400">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <span>100% Certified</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>24-Hour Dispatch</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
            <span>Free Shipping</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            <span>Secure Payments</span>
          </div>
        </div>
      </div>
      
      <div class="border-t border-stone-800 mt-8 pt-8 text-center">
        <p class="text-stone-500 text-xs">&copy; <%= Date.current.year %> Noralooks - Buy Fashion Jewellery, Gifts & Ethnic Wear Online India. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Smart App Banner (mobile only) -->
  <% app_banner_setting = StoreSetting.instance %>
  <% if app_banner_setting.has_mobile_apps? && !['carts', 'checkouts'].include?(controller_name) %>
    <div data-controller="smart-app-banner"
         data-smart-app-banner-ios-url-value="<%= app_banner_setting.ios_app_url %>"
         data-smart-app-banner-android-url-value="<%= app_banner_setting.android_app_url %>">
      <div data-smart-app-banner-target="banner"
           class="hidden fixed bottom-16 left-3 right-3 z-50 sm:hidden translate-y-full opacity-0 transition-all duration-300 ease-out">
        <div class="bg-white rounded-2xl shadow-2xl shadow-black/20 border border-stone-200 p-3 flex items-center gap-3">
          <!-- App icon -->
          <div class="w-12 h-12 bg-stone-900 rounded-xl flex items-center justify-center flex-shrink-0 shadow-md">
            <span class="text-white font-serif font-bold text-lg">N</span>
          </div>
          <!-- Info -->
          <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold text-stone-900 leading-tight"><%= app_banner_setting.effective_smart_banner_title %></p>
            <p class="text-xs text-stone-500 leading-tight mt-0.5"><%= app_banner_setting.effective_smart_banner_subtitle %></p>
            <p class="text-[10px] text-stone-400 mt-0.5">Free on the <span data-smart-app-banner-target="storeName">App Store</span></p>
          </div>
          <!-- CTA -->
          <a href="#" data-smart-app-banner-target="ctaButton" class="px-4 py-2 rounded-full text-xs font-semibold text-white flex-shrink-0 transition" style="background-color: #B8962E;">
            OPEN
          </a>
          <!-- Close button -->
          <button data-action="click->smart-app-banner#dismiss" class="absolute -top-2 -right-2 w-6 h-6 bg-stone-100 hover:bg-stone-200 rounded-full flex items-center justify-center shadow-sm border border-stone-200 transition">
            <svg class="w-3 h-3 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      </div>

      <!-- Sticky app icon (shown after dismiss, ~70% from top, right side) -->
      <div data-smart-app-banner-target="fab"
           class="hidden fixed right-3 z-50 sm:hidden scale-0 opacity-0 transition-all duration-300" style="top: 70%;">
        <button data-action="click->smart-app-banner#openFromFab"
                class="relative w-12 h-12 bg-stone-900 rounded-xl shadow-xl shadow-black/25 border border-stone-700/50 flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          <!-- Pulse dot -->
          <span class="absolute -top-1 -right-1 flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-amber-500"></span>
          </span>
        </button>
      </div>
    </div>
  <% end %>

  <%# Bottom nav lives OUTSIDE the turbo-frame, so it never re-renders during tab switches.
      Tab links target "main-content" frame — only the page content swaps.
      iOS native uses its own native tab bar, so skip this entirely. %>
  <% is_native_app = request.user_agent&.include?("Hotwire") || request.user_agent&.include?("NoraLooks/Android") %>
  <% unless is_native_app %>
  <nav id="mobile-bottom-nav" data-turbo-permanent data-mobile-nav
       data-controller="mobile-nav"
       data-mobile-nav-hide-on-value='["/checkouts"]'
       class="sm:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-stone-200 z-40 safe-area-pb">
    <div class="flex items-center justify-around h-14">
      <a href="/products" data-mobile-nav-target="tab" data-path="/products"
         class="tap-target flex flex-col items-center justify-center flex-1 py-2 text-stone-400">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <span class="text-[10px] mt-0.5">Search</span>
      </a>
      <a href="/cart" data-mobile-nav-target="tab" data-path="/cart"
         class="tap-target flex flex-col items-center justify-center flex-1 py-2 relative text-stone-400">
        <div id="mobile-cart-count">
          <%= render 'shared/mobile_cart_count_badge' %>
        </div>
        <span class="text-[10px] mt-0.5">Cart</span>
      </a>
      <a href="/" data-mobile-nav-target="tab" data-path="/"
         class="tap-target flex flex-col items-center justify-center flex-1 py-2 text-stone-400">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        <span class="text-[10px] mt-0.5">Home</span>
      </a>
      <a href="/orders" data-mobile-nav-target="tab" data-path="/orders"
         class="tap-target flex flex-col items-center justify-center flex-1 py-2 text-stone-400">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <span class="text-[10px] mt-0.5">Orders</span>
      </a>
      <a href="/account" data-mobile-nav-target="tab" data-path="/account"
         class="tap-target flex flex-col items-center justify-center flex-1 py-2 text-stone-400">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span class="text-[10px] mt-0.5">Account</span>
      </a>
    </div>
  </nav>
  <div id="mobile-bottom-nav-spacer" data-turbo-permanent class="sm:hidden h-14"></div>
  <% end %>
  <div id="native-bridge"></div>

  <!-- Jewellery page loader (replaces default Turbo progress bar) -->
  <div id="jewel-loader" aria-hidden="true">
    <div style="position:relative;display:flex;align-items:center;justify-content:center">
      <div class="jewel-diamond"></div>
      <div class="jewel-orbit">
        <span class="jewel-gem"></span>
        <span class="jewel-gem"></span>
        <span class="jewel-gem"></span>
        <span class="jewel-gem"></span>
      </div>
    </div>
  </div>
</body>
</html>
