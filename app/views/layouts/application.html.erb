<!DOCTYPE html>
<html lang="en" data-turbo-prefetch="false">
<head>
  <% if Rails.env.production? %>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2GPGNSFCEE"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-2GPGNSFCEE');
    </script>
  <% end %>

  <% if request.user_agent&.include?("NoraLooks/iOS") %>
    <title><%= native_page_title(content_for(:native_title)) %></title>
  <% else %>
    <title><%= meta_title(content_for(:title)) %></title>
  <% end %>
  <% is_native = request.user_agent&.include?('NoraLooks/iOS') || request.user_agent&.include?('NoraLooks/Android') %>
  <% is_ios_native = request.user_agent&.include?('NoraLooks/iOS') %>
  <meta name="viewport" content="width=device-width,initial-scale=1<%= ',maximum-scale=1,user-scalable=no' if is_ios_native %><%= ',viewport-fit=cover' if !is_native || is_ios_native %>">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  
  <!-- SEO Meta Tags -->
  <meta name="description" content="<%= meta_description(content_for(:meta_description)) %>">
  <meta name="keywords" content="<%= meta_keywords(content_for(:meta_keywords) || []) %>">
  <meta name="author" content="Noralooks">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <link rel="canonical" href="<%= canonical_url %>">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="<%= content_for(:og_type) || 'website' %>">
  <meta property="og:url" content="<%= canonical_url %>">
  <meta property="og:title" content="<%= meta_title(content_for(:title)) %>">
  <meta property="og:description" content="<%= meta_description(content_for(:meta_description)) %>">
  <meta property="og:image" content="<%= content_for(:og_image) || og_image_url %>">
  <meta property="og:site_name" content="Noralooks">
  <meta property="og:locale" content="en_IN">
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content="<%= canonical_url %>">
  <meta name="twitter:title" content="<%= meta_title(content_for(:title)) %>">
  <meta name="twitter:description" content="<%= meta_description(content_for(:meta_description)) %>">
  <meta name="twitter:image" content="<%= content_for(:og_image) || og_image_url %>">
  
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <!-- Favicon - SVG with brand colors (modern browsers) -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">

  <!-- Fallback PNG favicons (older browsers) -->
  <link rel="icon" href="/icon-32.png" type="image/png" sizes="32x32">
  <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192">

  <!-- Apple Touch Icon -->
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180">

  <!-- PWA Manifest -->
  <link rel="manifest" href="/manifest.json">
  <!-- Theme color for browser UI -->
  <meta name="theme-color" content="#1a1410">
  <meta name="apple-mobile-web-app-title" content="Noralooks">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  
  <style>
    .font-serif { font-family: 'Playfair Display', serif; }
    .font-sans { font-family: 'Inter', sans-serif; }
    <% if request.user_agent&.include?("NoraLooks/iOS") %>
      /* Only affects Hotwire Native iOS app */
      html, body {
        -webkit-overflow-scrolling: touch;
        overflow-y: auto !important;
        height: auto !important;
      }
      /* Prevent long-press context menu / link preview in native app */
      a, img, button {
        -webkit-touch-callout: none !important;
        -webkit-user-select: none !important;
      }
      /* Fixed bottom bars: sit at true bottom, pad for home indicator */
      .ios-native-fixed-bottom {
        bottom: 0 !important;
        padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 12px) !important;
      }
    <% end %>
  </style>
</head>
<body class="min-h-screen flex flex-col bg-stone-50 font-sans">
  <% is_native_app = request.user_agent&.include?("NoraLooks/iOS") || request.user_agent&.include?("NoraLooks/Android") %>
  <!-- Top Bar -->
  <% banner = StoreSetting.instance %>
  <div class="hidden sm:block text-center py-2 px-3" style="background-color: <%= banner.effective_banner_bg_color %>;">
    <p class="text-xs sm:text-sm" style="color: <%= banner.effective_banner_text_color %>;">
      <span class="font-medium" style="color: <%= banner.effective_banner_accent_color %>;">Free Shipping</span> on orders above <%= format_price(free_delivery_threshold) %> |
      <span class="hidden sm:inline">Quality Checked Before Dispatch | </span>24-Hour Dispatch
    </p>
  </div>

  <!-- Header -->
  <header class="sticky top-0 z-50 shadow-md relative" style="background: #0F0F0F;">
    <div class="absolute inset-0 pointer-events-none"></div>
    <div class="max-w-7xl sm:mx-auto sm:px-6 lg:px-8 relative z-20">
      <div class="flex items-center h-12 sm:h-16 gap-3 sm:gap-6 px-3 sm:px-0">
        <!-- Logo -->
        <%= link_to root_path, class: 'flex-shrink-0' do %>
          <span class="text-xl sm:text-2xl font-serif font-semibold" style="color: #F5F5F5;">Noralooks</span>
        <% end %>

        <!-- Search -->
        <% unless content_for?(:hide_header_search) %>
          <div class="flex-1 max-w-lg hidden sm:block" data-controller="search-autocomplete">
            <%= form_with url: products_path, method: :get, class: 'relative', data: { turbo_frame: '_top' } do |f| %>
              <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <%= f.search_field :q, value: params[:q], 
                    placeholder: search_placeholder, 
                    class: 'w-full h-10 pl-10 pr-4 bg-stone-100 text-stone-800 rounded-full border-0 focus:ring-2 focus:ring-[#D4AF37] focus:bg-white placeholder:text-stone-400 text-sm transition',
                    autocomplete: 'off',
                    data: { 
                      search_autocomplete_target: 'input',
                      action: 'input->search-autocomplete#search focus->search-autocomplete#search keydown.enter->search-autocomplete#submitForm'
                    } %>
              </div>
              <div data-search-autocomplete-target="results" 
                   class="absolute top-full left-0 right-0 mt-2 bg-white rounded-lg shadow-xl border border-stone-200 overflow-hidden hidden z-50">
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="flex-1"></div>
        <% end %>

        <!-- Mobile search (opens fullscreen overlay) -->
        <div class="sm:hidden flex-1" data-controller="mobile-search-trigger">
          <button type="button"
                  data-action="click->mobile-search-trigger#intercept"
                  class="w-full h-8 pl-8 pr-8 text-left text-white/70 bg-white/20 rounded-full border border-white/30 text-base sm:text-xs transition cursor-pointer relative">
            <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            Search...
          </button>
        </div>

        <!-- Right side -->
        <div class="hidden sm:flex items-center gap-1">
          <!-- Account -->
         <div class="relative" data-controller="dropdown">
            <button class="flex items-center gap-1.5 px-2 sm:px-3 py-2 text-white hover:text-[#D4AF37] transition" data-action="mouseenter->dropdown#open mouseleave->dropdown#close">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span class="hidden sm:block text-sm">Account</span>
              <svg class="hidden sm:block w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="hidden absolute right-0 mt-2 w-56 bg-white rounded-lg shadow-xl border border-stone-200 py-2 z-50" data-dropdown-target="menu" data-action="mouseenter->dropdown#open mouseleave->dropdown#close">
              <% if customer_logged_in? %>
                <div class="px-4 py-3 border-b border-stone-100">
                  <p class="text-sm font-medium text-stone-900"><%= current_customer.full_name %></p>
                  <p class="text-xs text-stone-500"><%= current_customer.email %></p>
                </div>
                <%= link_to 'My Account', account_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <%= link_to 'My Orders', orders_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <%= link_to 'Addresses', addresses_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <%= link_to 'Wishlist', wishlists_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <%= link_to 'Help', support_tickets_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <hr class="my-2 border-stone-100">
                <%= button_to logout_path, method: :delete, data: { show_loader: 'true' }, class: 'block w-full text-left px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' do %>
                  Sign Out
                <% end %>
              <% else %>
                <div class="px-4 py-3">
                  <%= link_to 'Sign In', login_path, class: 'block w-full py-2 px-4 text-white text-center text-sm font-medium rounded-lg transition', style: 'background-color: #B8962E;' %>
                  <p class="mt-3 text-xs text-stone-500 text-center">
                    New here? <%= link_to 'Register', signup_path, class: 'text-rose-700 font-medium hover:underline' %>
                  </p>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Wishlist -->
          <%= link_to wishlists_path, class: 'flex items-center gap-1.5 px-2 sm:px-3 py-2 text-white hover:text-[#D4AF37] transition' do %>
            <div class="relative" data-wishlist-icon-wrapper>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
              <span id="wishlist-count">
                <%= render 'shared/wishlist_count_badge' %>
              </span>
            </div>
            <span class="hidden sm:block text-sm">Wishlist</span>
          <% end %>

          <!-- Cart -->
          <%= link_to cart_path, class: 'flex items-center gap-1.5 px-2 sm:px-3 py-2 text-white hover:text-[#D4AF37] transition' do %>
            <div class="relative" data-cart-icon-wrapper>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
              <span id="cart-count">
                <%= render 'shared/cart_count_badge' %>
              </span>
            </div>
            <span class="hidden sm:block text-sm">Bag</span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Mobile Search -->
    <div id="mobile-search" class="sm:hidden border-t border-white/20 px-3 py-2 hidden relative z-10">
      <%= form_with url: products_path, method: :get, class: 'relative', data: { turbo_frame: '_top' } do |f| %>
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <%= f.search_field :q, value: params[:q], 
            placeholder: search_placeholder, 
            class: 'w-full h-10 pl-10 pr-4 bg-stone-100 text-stone-800 rounded-full border-0 focus:ring-2 focus:ring-rose-400 placeholder:text-stone-400 text-sm' %>
      <% end %>
    </div>

    <!-- Categories Nav with Subcategory Dropdowns -->
    <% unless is_native_app || (controller_name == 'products' && action_name == 'index') %>
      <nav class="hidden sm:block relative z-10" style="background: #FFFFFF; border-bottom: 1px solid #EAEAEA;">
        <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
          <div class="overflow-x-auto overflow-y-visible scrollbar-hide">
            <div class="flex items-center gap-1 sm:gap-4 h-10 min-w-max">
              <% active_class = 'px-3 py-1.5 text-sm font-medium whitespace-nowrap' + ' text-[#D4AF37]' %>
              <% inactive_class = 'px-3 py-1.5 text-sm whitespace-nowrap transition text-[#1A1A1A] hover:text-[#D4AF37]' %>
              <% selected_category_ids = Array(params[:category_ids]).reject(&:blank?).map(&:to_s) %>
              <% collections_active = params[:featured].present? && ActiveModel::Type::Boolean.new.cast(params[:featured]) %>
              <% all_active = selected_category_ids.empty? && !collections_active %>
              <% navbar_categories = Category.storefront_navbar_tree %>
              <% standalone_subcategories = Category.storefront_navbar_standalone_subcategories %>

              <%= link_to products_path, class: (all_active ? active_class : inactive_class) do %>
                All
              <% end %>
              <%= link_to 'Collections', products_path(featured: true), class: (collections_active ? active_class : inactive_class) %>
              <% navbar_categories.each do |category, visible_children| %>
                <% category_active = selected_category_ids.include?(category.id.to_s) || visible_children.any? { |child| selected_category_ids.include?(child.id.to_s) } %>
                <% if visible_children.any? %>
                  <div class="relative" data-controller="dropdown" data-dropdown-fixed-value="true">
                    <%= link_to category_path(category.slug), class: "flex items-center gap-1.5 px-3 py-1.5 text-sm whitespace-nowrap transition #{category_active ? 'text-[#D4AF37] font-medium' : 'text-[#1A1A1A] hover:text-[#D4AF37]'}", data: { action: "mouseenter->dropdown#open mouseleave->dropdown#close" } do %>
                      <span><%= category.name %></span>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
                      </svg>
                    <% end %>
                    <div class="hidden" data-dropdown-target="menu" data-action="mouseenter->dropdown#open mouseleave->dropdown#close">
                      <div class="bg-white border border-stone-200 rounded-lg shadow-lg py-2 min-w-[180px]">
                        <% visible_children.each do |child| %>
                          <% child_active = selected_category_ids.include?(child.id.to_s) %>
                          <%= link_to child.name, category_path(child.slug), class: "block px-4 py-2 text-sm transition #{child_active ? 'text-[#D4AF37] font-medium bg-amber-50' : 'text-[#1A1A1A] hover:text-[#D4AF37] hover:bg-amber-50'}" %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% else %>
                  <%= link_to category.name, category_path(category.slug), class: (category_active ? active_class : inactive_class) %>
                <% end %>
              <% end %>
              <% standalone_subcategories.each do |category| %>
                <% category_active = selected_category_ids.include?(category.id.to_s) %>
                <%= link_to category.name, category_path(category.slug), class: (category_active ? active_class : inactive_class) %>
              <% end %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>
  </header>

  <div id="toasts" class="fixed top-20 sm:top-24 right-3 sm:right-6 z-[60] flex flex-col gap-2 items-end">
    <% if flash[:notice].present? %>
      <%= render 'shared/toast', message: flash[:notice], variant: :success %>
    <% end %>
    <% if flash[:alert].present? %>
      <%= render 'shared/toast', message: flash[:alert], variant: :error %>
    <% end %>
  </div>

  <main class="flex-1">
    <%= yield %>
  </main>

  <!-- Mobile Contact Us section (home page only, above footer & bottom nav) -->
  <% mobile_contact_setting = StoreSetting.instance %>
  <% if controller_name == "home" && (mobile_contact_setting.has_contact_info? || mobile_contact_setting.has_social_links?) %>
    <div class="sm:hidden bg-stone-900 px-4 pt-6 pb-20">
      <div class="rounded-xl bg-stone-800/40 border border-stone-700/50 px-4 py-5">
        <%# Contact cards %>
        <% if mobile_contact_setting.has_contact_info? %>
          <div class="space-y-2.5">
            <% if mobile_contact_setting.contact_email.present? %>
              <a href="mailto:<%= mobile_contact_setting.contact_email %>" class="flex items-center gap-3 rounded-lg bg-stone-800/60 px-3.5 py-3 active:bg-stone-700/60 transition">
                <span class="flex items-center justify-center w-9 h-9 rounded-full bg-amber-500/10">
                  <svg class="w-4.5 h-4.5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                </span>
                <div class="min-w-0">
                  <p class="text-stone-500 text-[10px] uppercase tracking-wider leading-none mb-0.5">Email us</p>
                  <p class="text-stone-200 text-sm truncate"><%= mobile_contact_setting.contact_email %></p>
                </div>
              </a>
            <% end %>
            <% if mobile_contact_setting.company_phone.present? %>
              <a href="https://wa.me/<%= mobile_contact_setting.company_phone.gsub(/[^\d]/, '') %>" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 rounded-lg bg-stone-800/60 px-3.5 py-3 active:bg-stone-700/60 transition">
                <span class="flex items-center justify-center w-9 h-9 rounded-full bg-green-500/10">
                  <svg class="w-4.5 h-4.5 text-green-500" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </span>
                <div class="min-w-0">
                  <p class="text-stone-500 text-[10px] uppercase tracking-wider leading-none mb-0.5">WhatsApp us</p>
                  <p class="text-stone-200 text-sm"><%= mobile_contact_setting.company_phone %></p>
                </div>
              </a>
            <% end %>
          </div>
        <% end %>

        <%# Social icons %>
        <% if mobile_contact_setting.has_social_links? %>
          <div class="<%= mobile_contact_setting.has_contact_info? ? 'mt-4 pt-3.5 border-t border-stone-700/40' : '' %>">
            <div class="flex items-center justify-center gap-3">
              <% if mobile_contact_setting.instagram_url.present? %>
                <a href="<%= mobile_contact_setting.instagram_url %>" target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-full bg-stone-800/80 text-stone-400 hover:text-pink-400 hover:bg-stone-700/80 active:scale-95 transition" aria-label="Instagram">
