<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <title><%= content_for(:title) || "Auracraft" %> | Fine Jewellery</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  
  <style>
    .font-serif { font-family: 'Playfair Display', serif; }
    .font-sans { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="min-h-full flex flex-col bg-stone-50 font-sans">
  <!-- Top Bar -->
  <div class="bg-rose-900 text-center py-2 px-3">
    <p class="text-xs sm:text-sm text-rose-100">
      <span class="text-amber-300 font-medium">Free Shipping</span> on orders above ₹999 | 
      <span class="hidden sm:inline">Lifetime Exchange & </span>Easy Returns
    </p>
  </div>

  <!-- Header -->
  <header class="sticky top-0 z-50 bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
      <div class="flex items-center h-14 sm:h-16 gap-3 sm:gap-6">
        <!-- Logo -->
        <%= link_to root_path, class: 'flex-shrink-0' do %>
          <span class="text-xl sm:text-2xl font-serif font-semibold text-rose-900 tracking-wide">Auracraft</span>
        <% end %>

        <!-- Search -->
        <% unless content_for?(:hide_header_search) %>
          <div class="flex-1 max-w-lg hidden sm:block" data-controller="search-autocomplete">
            <%= form_with url: search_path, method: :get, class: 'relative' do |f| %>
              <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <%= f.search_field :q, value: params[:q], 
                    placeholder: 'Search for jewellery...', 
                    class: 'w-full h-10 pl-10 pr-4 bg-stone-100 text-stone-800 rounded-full border-0 focus:ring-2 focus:ring-rose-400 focus:bg-white placeholder:text-stone-400 text-sm transition',
                    autocomplete: 'off',
                    data: { 
                      search_autocomplete_target: 'input',
                      action: 'input->search-autocomplete#search focus->search-autocomplete#search'
                    } %>
              </div>
              <div data-search-autocomplete-target="results" 
                   class="absolute top-full left-0 right-0 mt-2 bg-white rounded-lg shadow-xl border border-stone-200 overflow-hidden hidden z-50">
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="flex-1"></div>
        <% end %>

        <!-- Mobile search -->
        <button type="button" 
                class="sm:hidden p-2 text-stone-600 hover:text-rose-800"
                onclick="document.getElementById('mobile-search').classList.toggle('hidden')">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </button>

        <!-- Right side -->
        <div class="flex items-center gap-1">
          <!-- Account -->
          <div class="relative" data-controller="dropdown">
            <button class="flex items-center gap-1.5 px-2 sm:px-3 py-2 text-stone-700 hover:text-rose-800 transition" data-action="click->dropdown#toggle">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span class="hidden sm:block text-sm">Account</span>
            </button>
            <div class="hidden absolute right-0 mt-2 w-56 bg-white rounded-lg shadow-xl border border-stone-200 py-2 z-50" data-dropdown-target="menu">
              <% if customer_logged_in? %>
                <div class="px-4 py-3 border-b border-stone-100">
                  <p class="text-sm font-medium text-stone-900"><%= current_customer.full_name %></p>
                  <p class="text-xs text-stone-500"><%= current_customer.email %></p>
                </div>
                <%= link_to 'My Account', account_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <%= link_to 'My Orders', orders_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <%= link_to 'Addresses', addresses_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <%= link_to 'Help', support_tickets_path, class: 'block px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' %>
                <hr class="my-2 border-stone-100">
                <%= button_to logout_path, method: :delete, class: 'block w-full text-left px-4 py-2 text-sm text-stone-700 hover:bg-rose-50 hover:text-rose-800' do %>
                  Sign Out
                <% end %>
              <% else %>
                <div class="px-4 py-3">
                  <%= link_to 'Sign In', login_path, class: 'block w-full py-2 px-4 bg-rose-800 hover:bg-rose-900 text-white text-center text-sm font-medium rounded-lg transition' %>
                  <p class="mt-3 text-xs text-stone-500 text-center">
                    New here? <%= link_to 'Register', signup_path, class: 'text-rose-700 font-medium hover:underline' %>
                  </p>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Wishlist -->
          <%= link_to '#', class: 'hidden sm:flex items-center gap-1.5 px-2 py-2 text-stone-700 hover:text-rose-800 transition' do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          <% end %>

          <!-- Cart -->
          <%= link_to cart_path, class: 'flex items-center gap-1.5 px-2 sm:px-3 py-2 text-stone-700 hover:text-rose-800 transition' do %>
            <div class="relative">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
              <% if current_cart.item_count > 0 %>
                <span id="cart-count" class="absolute -top-1.5 -right-1.5 h-4 w-4 rounded-full bg-rose-700 text-white text-[10px] font-bold flex items-center justify-center">
                  <%= current_cart.item_count %>
                </span>
              <% else %>
                <span id="cart-count" class="hidden"></span>
              <% end %>
            </div>
            <span class="hidden sm:block text-sm">Bag</span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Mobile Search -->
    <div id="mobile-search" class="sm:hidden border-t border-stone-100 px-3 py-2 hidden">
      <%= form_with url: search_path, method: :get, class: 'relative' do |f| %>
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <%= f.search_field :q, value: params[:q], 
            placeholder: 'Search jewellery...', 
            class: 'w-full h-10 pl-10 pr-4 bg-stone-100 text-stone-800 rounded-full border-0 focus:ring-2 focus:ring-rose-400 placeholder:text-stone-400 text-sm' %>
      <% end %>
    </div>

    <!-- Categories Nav -->
    <nav class="border-t border-stone-100">
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex items-center gap-1 sm:gap-4 h-10 overflow-x-auto scrollbar-hide">
          <%= link_to products_path, class: 'px-3 py-1.5 text-sm text-stone-600 hover:text-rose-800 whitespace-nowrap transition' do %>
            All Jewellery
          <% end %>
          <% Category.active.root.ordered.limit(6).each do |category| %>
            <%= link_to category.name, category_path(category.slug), class: 'px-3 py-1.5 text-sm text-stone-600 hover:text-rose-800 whitespace-nowrap transition' %>
          <% end %>
          <%= link_to 'Collections', products_path(featured: true), class: 'px-3 py-1.5 text-sm text-rose-700 font-medium whitespace-nowrap' %>
        </div>
      </div>
    </nav>
  </header>

  <!-- Flash messages -->
  <div id="flash" class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 mt-4">
    <% if flash[:notice] %>
      <div class="rounded-lg bg-emerald-50 border border-emerald-200 p-3 sm:p-4 mb-4" data-controller="flash">
        <div class="flex items-center gap-3">
          <div class="flex-shrink-0 w-8 h-8 bg-emerald-100 rounded-full flex items-center justify-center">
            <svg class="h-4 w-4 text-emerald-600" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          </div>
          <p class="text-sm text-emerald-800 flex-1"><%= flash[:notice] %></p>
          <button data-action="click->flash#dismiss" class="text-emerald-500 hover:text-emerald-700 p-1">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-3 sm:p-4 mb-4" data-controller="flash">
        <div class="flex items-center gap-3">
          <div class="flex-shrink-0 w-8 h-8 bg-red-100 rounded-full flex items-center justify-center">
            <svg class="h-4 w-4 text-red-600" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          </div>
          <p class="text-sm text-red-800 flex-1"><%= flash[:alert] %></p>
          <button data-action="click->flash#dismiss" class="text-red-500 hover:text-red-700 p-1">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Main content -->
  <main class="flex-grow">
    <%= yield %>
  </main>

  <!-- Footer -->
  <footer class="bg-stone-900 mt-12 sm:mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="col-span-2 md:col-span-1">
          <span class="text-xl font-serif font-semibold text-white">Auracraft</span>
          <p class="text-stone-400 text-sm mt-3 leading-relaxed">Exquisite jewellery crafted with love. Timeless designs for every occasion.</p>
          <div class="flex gap-3 mt-4">
            <a href="#" class="w-8 h-8 bg-stone-800 hover:bg-rose-800 rounded-full flex items-center justify-center transition">
              <svg class="w-4 h-4 text-stone-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href="#" class="w-8 h-8 bg-stone-800 hover:bg-rose-800 rounded-full flex items-center justify-center transition">
              <svg class="w-4 h-4 text-stone-300" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
            </a>
          </div>
        </div>
        <div>
          <h4 class="text-white font-medium mb-4 text-sm">Shop</h4>
          <ul class="space-y-2 text-sm">
            <li><%= link_to 'All Jewellery', products_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'New Arrivals', products_path(sort: 'newest'), class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Best Sellers', products_path(featured: true), class: 'text-stone-400 hover:text-rose-400 transition' %></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-medium mb-4 text-sm">Account</h4>
          <ul class="space-y-2 text-sm">
            <li><%= link_to 'My Account', account_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Orders', orders_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Addresses', addresses_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-medium mb-4 text-sm">Help</h4>
          <ul class="space-y-2 text-sm">
            <li><%= link_to 'Contact Us', support_tickets_path, class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Shipping', '#', class: 'text-stone-400 hover:text-rose-400 transition' %></li>
            <li><%= link_to 'Returns & Exchange', '#', class: 'text-stone-400 hover:text-rose-400 transition' %></li>
          </ul>
        </div>
      </div>
      
      <!-- Trust badges -->
      <div class="border-t border-stone-800 mt-8 pt-8">
        <div class="flex flex-wrap justify-center gap-6 sm:gap-10 text-center text-xs text-stone-400">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <span>100% Certified</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            <span>Lifetime Exchange</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
            <span>Free Shipping</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>30-Day Returns</span>
          </div>
        </div>
      </div>
      
      <div class="border-t border-stone-800 mt-8 pt-8 text-center">
        <p class="text-stone-500 text-xs">&copy; <%= Date.current.year %> Auracraft Jewellery. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Mobile Bottom Navigation -->
  <nav class="sm:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-stone-200 z-40 safe-area-pb">
    <div class="flex items-center justify-around h-14">
      <%= link_to root_path, class: "flex flex-col items-center justify-center flex-1 py-2 #{current_page?(root_path) ? 'text-rose-800' : 'text-stone-400'}" do %>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        <span class="text-[10px] mt-0.5">Home</span>
      <% end %>
      <%= link_to products_path, class: "flex flex-col items-center justify-center flex-1 py-2 #{current_page?(products_path) ? 'text-rose-800' : 'text-stone-400'}" do %>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <span class="text-[10px] mt-0.5">Shop</span>
      <% end %>
      <%= link_to cart_path, class: "flex flex-col items-center justify-center flex-1 py-2 relative #{current_page?(cart_path) ? 'text-rose-800' : 'text-stone-400'}" do %>
        <div class="relative">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          <% if current_cart.item_count > 0 %>
            <span class="absolute -top-1 -right-1 h-4 w-4 rounded-full bg-rose-700 text-white text-[9px] font-bold flex items-center justify-center">
              <%= current_cart.item_count %>
            </span>
          <% end %>
        </div>
        <span class="text-[10px] mt-0.5">Bag</span>
      <% end %>
      <%= link_to orders_path, class: "flex flex-col items-center justify-center flex-1 py-2 #{current_page?(orders_path) ? 'text-rose-800' : 'text-stone-400'}" do %>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <span class="text-[10px] mt-0.5">Orders</span>
      <% end %>
      <%= link_to (customer_logged_in? ? account_path : login_path), class: "flex flex-col items-center justify-center flex-1 py-2 #{current_page?(account_path) ? 'text-rose-800' : 'text-stone-400'}" do %>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span class="text-[10px] mt-0.5">Account</span>
      <% end %>
    </div>
  </nav>
  
  <div class="sm:hidden h-14"></div>
</body>
</html>
