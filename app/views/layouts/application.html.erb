          <!-- Close button -->
          <button data-action="click->smart-app-banner#dismiss" class="absolute -top-2 -right-2 w-6 h-6 bg-stone-100 hover:bg-stone-200 rounded-full flex items-center justify-center shadow-sm border border-stone-200 transition">
            <svg class="w-3 h-3 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      </div>

      <!-- Sticky app icon (shown after dismiss, ~70% from top, right side) -->
      <div data-smart-app-banner-target="fab"
           class="hidden fixed right-3 z-50 sm:hidden scale-0 opacity-0 transition-all duration-300" style="top: 70%;">
        <button data-action="click->smart-app-banner#openFromFab"
                class="relative w-12 h-12 bg-white rounded-2xl shadow-xl shadow-black/15 border border-stone-200 flex items-center justify-center">
          <%# Apple App Store icon (shown on iOS) %>
          <svg data-smart-app-banner-target="fabIconIos" class="hidden w-7 h-7 text-stone-900" viewBox="0 0 384 512" fill="currentColor">
            <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5c0 26.2 4.8 53.3 14.4 81.2 12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
          </svg>
          <%# Google Play Store icon (shown on Android) %>
          <svg data-smart-app-banner-target="fabIconAndroid" class="hidden w-7 h-7" viewBox="0 0 512 512" fill="none">
            <path d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58.9-34.1-65.7 64.5 65.7 64.5 60.1-34.1c18-14.3 18-46.5-1.2-60.8zM104.6 499l280.8-161.2-60.1-60.1L104.6 499z" fill="currentColor"/>
          </svg>
          <%# Fallback icon (non-detectable platform) %>
          <svg data-smart-app-banner-target="fabIconFallback" class="w-6 h-6 text-stone-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          <!-- Pulse dot -->
          <span class="absolute -top-1 -right-1 flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-amber-500"></span>
          </span>
        </button>
      </div>
    </div>
  <% end %>

  <%# Bottom nav lives OUTSIDE the turbo-frame, so it never re-renders during tab switches.
      Tab links target "main-content" frame — only the page content swaps.
      iOS native uses its own native tab bar, so skip this entirely. %>
  <% unless is_native_app %>
  <nav id="mobile-bottom-nav" data-turbo-permanent data-mobile-nav
       data-controller="mobile-nav"
       data-mobile-nav-hide-on-value='["/checkouts"]'
       class="sm:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-stone-200 z-40 safe-area-pb">
    <div class="flex items-center justify-around h-14">
      <a href="/products" data-mobile-nav-target="tab" data-path="/products"
         class="tap-target flex flex-col items-center justify-center flex-1 py-2 text-stone-400">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <span class="text-[10px] mt-0.5">Search</span>
      </a>
      <a href="/cart" data-mobile-nav-target="tab" data-path="/cart"
         class="tap-target flex flex-col items-center justify-center flex-1 py-2 relative text-stone-400">
        <div id="mobile-cart-count">
          <%= render 'shared/mobile_cart_count_badge' %>
        </div>
        <span class="text-[10px] mt-0.5">Cart</span>
      </a>
      <a href="/" data-mobile-nav-target="tab" data-path="/"
         class="tap-target flex flex-col items-center justify-center flex-1 py-2 text-stone-400">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        <span class="text-[10px] mt-0.5">Home</span>
      </a>
      <a href="/orders" data-mobile-nav-target="tab" data-path="/orders"
         class="tap-target flex flex-col items-center justify-center flex-1 py-2 text-stone-400">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <span class="text-[10px] mt-0.5">Orders</span>
      </a>
      <a href="/account" data-mobile-nav-target="tab" data-path="/account"
         class="tap-target flex flex-col items-center justify-center flex-1 py-2 text-stone-400">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span class="text-[10px] mt-0.5">Account</span>
      </a>
    </div>
  </nav>
  <div id="mobile-bottom-nav-spacer" data-turbo-permanent class="sm:hidden h-14"></div>
  <% end %>
  <div id="native-bridge"></div>

  <%# Mobile Fullscreen Search Overlay — renders on all platforms (native + browser) %>
  <div data-controller="mobile-search"
       data-turbo-permanent
       id="mobile-search-overlay-container"
       class="sm:hidden">
    <div data-mobile-search-target="overlay"
         class="fixed inset-0 z-[100] flex flex-col mobile-search-overlay pointer-events-none"
         style="background: #0F0F0F;">

      <!-- Search bar with safe area -->
      <div class="safe-area-top px-4 pt-3 pb-3" style="background: linear-gradient(180deg, #1a1410 0%, #0F0F0F 100%);">
        <div class="flex items-center gap-3">
          <button type="button"
                  data-action="click->mobile-search#close"
                  class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-full text-stone-400 hover:text-white transition">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
          </button>
          <div class="flex-1 relative">
            <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4" style="color: #D4AF37;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="search" name="q"
                   placeholder="Search jewellery, gifts..."
                   data-mobile-search-target="input"
                   data-action="input->mobile-search#search keydown.enter->mobile-search#submitForm"
                   autocomplete="off"
                   class="w-full h-11 pl-11 pr-10 rounded-full text-white text-base placeholder:text-stone-500 border border-stone-700 focus:border-[#D4AF37] focus:ring-1 focus:ring-[#D4AF37]/50 outline-none transition"
                   style="background: #1a1a1a;">
            <button type="button"
                    data-mobile-search-target="clearButton"
                    data-action="click->mobile-search#clearInput"
                    class="hidden absolute right-3 top-1/2 -translate-y-1/2 p-1 text-stone-500 hover:text-white transition">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Gold divider -->
      <div class="h-px" style="background: linear-gradient(90deg, transparent, #D4AF37, transparent);"></div>

      <!-- Scrollable content area -->
      <div class="flex-1 overflow-y-auto" style="max-height: calc(100vh - 80px); max-height: calc(100dvh - 80px);">
        <!-- Empty state: popular categories & quick links -->
        <div data-mobile-search-target="emptyState" class="px-5 pt-6">
          <p class="text-xs font-medium uppercase tracking-widest mb-4" style="color: #D4AF37;">Popular Categories</p>
          <div class="flex flex-wrap gap-2">
            <% Category.storefront_hero_categories.each do |category| %>
              <a href="<%= category_path(category.slug) %>"
                 data-turbo-frame="_top"
                 data-action="click->mobile-search#close"
                 class="px-4 py-2.5 rounded-full text-sm border transition hover:border-[#D4AF37] hover:text-[#D4AF37]"
                 style="color: #e8e0d4; border-color: #333; background: #1a1a1a;">
                <%= category.name %>
              </a>
            <% end %>
          </div>
          <div class="mt-8">
            <p class="text-xs font-medium uppercase tracking-widest mb-3" style="color: #D4AF37;">Quick Links</p>
            <a href="/products?sort=newest" data-turbo-frame="_top" data-action="click->mobile-search#close"
               class="flex items-center gap-3 py-3 border-b border-stone-800">
              <span class="text-sm text-stone-300">New Arrivals</span>
              <svg class="w-4 h-4 text-stone-600 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a href="/products" data-turbo-frame="_top" data-action="click->mobile-search#close"
               class="flex items-center gap-3 py-3 border-b border-stone-800">
              <span class="text-sm text-stone-300">All Products</span>
              <svg class="w-4 h-4 text-stone-600 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a href="/products?featured=true" data-turbo-frame="_top" data-action="click->mobile-search#close"
               class="flex items-center gap-3 py-3 border-b border-stone-800">
              <span class="text-sm text-stone-300">Featured Collections</span>
              <svg class="w-4 h-4 text-stone-600 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Search results (populated by JS) -->
        <div data-mobile-search-target="results" class="hidden"></div>
      </div>
    </div>
  </div>

  <!-- Jewellery page loader (replaces default Turbo progress bar) -->
  <div id="jewel-loader" aria-hidden="true">
    <div style="position:relative;display:flex;align-items:center;justify-content:center">
      <div class="jewel-diamond"></div>
      <div class="jewel-orbit">
        <span class="jewel-gem"></span>
        <span class="jewel-gem"></span>
        <span class="jewel-gem"></span>
        <span class="jewel-gem"></span>
      </div>
    </div>
  </div>

  <% if is_native %>
    <%= render "shared/app_update_check" %>
  <% end %>
</body>
</html>
