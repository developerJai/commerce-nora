<!DOCTYPE html>
<html lang="en" class="h-full" data-turbo-prefetch="false">
<head>
  <title><%= content_for(:title) || "Admin" %> | Noralooks</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  
  <!-- Tom Select for searchable dropdowns -->
  <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
</head>
<body class="h-full bg-gray-100" data-controller="sidebar">
  <div class="min-h-screen bg-gray-100">
    <!-- Sidebar -->
    <aside class="fixed inset-y-0 left-0 z-50 w-64 bg-slate-900 transform transition-transform duration-300 ease-in-out lg:translate-x-0 overflow-y-auto" 
           data-sidebar-target="sidebar"
           id="sidebar">
      <!-- Logo -->
      <div class="flex h-16 items-center justify-between px-6 border-b border-slate-700">
        <a href="<%= admin_root_path %>" class="flex items-center gap-2">
          <span class="text-2xl font-bold text-white">Noralooks</span>
        </a>
        <button class="lg:hidden text-gray-400 hover:text-white" data-action="click->sidebar#toggle">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <% if vendor_role? %>
        <div class="px-6 py-2 bg-slate-800 border-b border-slate-700">
          <p class="text-xs text-slate-400 uppercase tracking-wider">Vendor Panel</p>
          <p class="text-sm text-white font-medium truncate"><%= current_vendor&.business_name %></p>
        </div>
      <% end %>

      <!-- Navigation -->
      <nav class="mt-6 px-4 space-y-1">
        <%= render 'admin/shared/sidebar_link', path: admin_root_path, icon: 'dashboard', label: 'Dashboard', active: controller_name == 'dashboard' %>
        
        <div class="pt-4">
          <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Store</p>
        </div>
        <%= render 'admin/shared/sidebar_link', path: admin_products_path, icon: 'products', label: 'Products', active: controller_name.in?(['products', 'product_variants']) %>
        <% if admin_role? %>
          <%= render 'admin/shared/sidebar_link', path: admin_categories_path, icon: 'categories', label: 'Categories', active: controller_name == 'categories' %>
        <% end %>
        <%= render 'admin/shared/sidebar_link', path: admin_inventory_index_path, icon: 'inventory', label: 'Inventory', active: controller_name == 'inventory' %>

        <div class="pt-4">
          <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Sales</p>
        </div>
        <%= render 'admin/shared/sidebar_link', path: admin_orders_path, icon: 'orders', label: 'Orders', active: controller_name == 'orders' && action_name != 'drafts' && action_name != 'refunds' %>
        <% if admin_role? %>
          <%= render 'admin/shared/sidebar_link', path: admin_checkout_sessions_path, icon: 'payments', label: 'Checkout Sessions', active: controller_name == 'checkout_sessions' %>
        <% end %>
        <% if admin_role? %>
          <% pending_refunds = Order.placed.where(refund_status: 'initiated').count %>
          <%= render 'admin/shared/sidebar_link', path: refunds_admin_orders_path, icon: 'refunds', label: 'Refunds', active: controller_name == 'orders' && action_name == 'refunds', badge: pending_refunds > 0 ? pending_refunds : nil %>
        <% end %>
        <% if admin_role? %>
          <%= render 'admin/shared/sidebar_link', path: admin_draft_orders_path, icon: 'draft', label: 'Draft Orders', active: controller_name == 'draft_orders' %>
          <%= render 'admin/shared/sidebar_link', path: admin_coupons_path, icon: 'coupons', label: 'Coupons', active: controller_name == 'coupons' %>
        <% end %>
        
        <% if admin_role? %>
          <div class="pt-4">
            <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Customers</p>
          </div>
          <%= render 'admin/shared/sidebar_link', path: admin_customers_path, icon: 'customers', label: 'Customers', active: controller_name == 'customers' %>
        <% end %>
        
        <% unless admin_role? %>
          <div class="pt-4">
            <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Feedback</p>
          </div>
        <% end %>
        <%= render 'admin/shared/sidebar_link', path: admin_reviews_path, icon: 'reviews', label: 'Reviews', active: controller_name == 'reviews' %>
        <%= render 'admin/shared/sidebar_link', path: admin_support_tickets_path, icon: 'support', label: 'Support', active: controller_name == 'support_tickets' %>
        
        <% if vendor_role? || session[:acting_as_vendor_id] %>
          <div class="pt-4">
            <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Earnings</p>
          </div>
          <%= render 'admin/shared/sidebar_link', path: admin_vendor_earnings_path, icon: 'earnings', label: 'My Earnings', active: controller_name == 'vendor_earnings' && action_name == 'index' %>
          <%= render 'admin/shared/sidebar_link', path: admin_payouts_vendor_earnings_path, icon: 'payouts', label: 'Payout History', active: controller_name == 'vendor_earnings' && action_name == 'payouts' %>
        <% end %>

        <% if admin_role? %>
          <div class="pt-4">
            <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Settings</p>
          </div>
          
          <div class="px-3 py-1">
            <p class="text-xs text-slate-500 uppercase tracking-wider">Homepage</p>
          </div>
          <%= render 'admin/shared/sidebar_link', path: admin_banners_path, icon: 'banners', label: 'Banners', active: controller_name == 'banners' %>
          <%= render 'admin/shared/sidebar_link', path: admin_homepage_collections_path, icon: 'collections', label: 'Collections', active: controller_name.in?(['homepage_collections', 'homepage_collection_items']) %>
          <%= render 'admin/shared/sidebar_link', path: admin_homepage_settings_path, icon: 'settings', label: 'Homepage Sections', active: controller_name == 'homepage_settings' %>
          
          <div class="px-3 py-1 mt-2">
            <p class="text-xs text-slate-500 uppercase tracking-wider">Store</p>
          </div>
          <%= render 'admin/shared/sidebar_link', path: admin_store_settings_path, icon: 'store_settings', label: 'Storefront', active: controller_name == 'store_settings' %>
          <%= render 'admin/shared/sidebar_link', path: admin_mobile_app_settings_path, icon: 'mobile_apps', label: 'Mobile Apps', active: controller_name == 'mobile_app_settings' %>

          <div class="px-3 py-1 mt-2">
            <p class="text-xs text-slate-500 uppercase tracking-wider">Platform</p>
          </div>
          <%= render 'admin/shared/sidebar_link', path: admin_platform_fee_config_path, icon: 'settings', label: 'Fee Settings', active: controller_name == 'platform_fee_configs' %>
          <%= render 'admin/shared/sidebar_link', path: admin_payouts_path, icon: 'payouts', label: 'Payouts', active: controller_name == 'payouts' %>

          <div class="pt-4">
            <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Management</p>
          </div>
          <%= render 'admin/shared/sidebar_link', path: admin_vendors_path, icon: 'vendors', label: 'Vendors', active: controller_name == 'vendors' %>
          <%= render 'admin/shared/sidebar_link', path: admin_hsn_codes_path, icon: 'hsn', label: 'HSN Codes', active: controller_name == 'hsn_codes' %>

          <div class="pt-4">
            <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Analytics</p>
          </div>
          <%= render 'admin/shared/sidebar_link', path: admin_reports_path, icon: 'reports', label: 'Reports', active: controller_name == 'reports' %>
        <% end %>
      </nav>
    </aside>

    <!-- Main content -->
    <div class="lg:pl-64">
      <!-- Top header -->
      <header class="sticky top-0 z-40 bg-white shadow">
        <div class="flex h-16 items-center justify-between px-4 sm:px-6 lg:px-8">
          <button class="lg:hidden text-gray-500 hover:text-gray-700" data-action="click->sidebar#toggle">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>

          <div class="flex-1"></div>

          <div class="flex items-center gap-4">
            <!-- Settings dropdown -->
            <div class="relative" data-controller="dropdown">
              <button class="flex items-center gap-2 text-gray-700 hover:text-gray-900" data-action="click->dropdown#toggle">
                <span class="hidden sm:block text-sm font-medium"><%= current_admin.name %></span>
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="hidden absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg ring-1 ring-black ring-opacity-5 py-1" data-dropdown-target="menu">
                <%= link_to 'Settings', admin_settings_path, class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100' %>
                <%= link_to 'Change Password', edit_admin_password_path, class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100' %>
                <hr class="my-1">
                <% if vendor_role? %>
                  <%= button_to 'Logout', vendor_logout_path, method: :delete, class: 'block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100' %>
                <% else %>
                  <%= button_to 'Logout', admin_logout_path, method: :delete, class: 'block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100' %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </header>

      <% if admin_role? && session[:acting_as_vendor_id] && current_vendor %>
        <div class="bg-amber-500 text-amber-900 px-4 py-2 flex items-center justify-between text-sm font-medium">
          <span>Acting as vendor: <strong><%= current_vendor.business_name %></strong></span>
          <%= button_to "Exit Vendor Mode", admin_exit_vendor_mode_path, method: :delete, class: "bg-amber-700 text-white px-3 py-1 rounded text-xs hover:bg-amber-800" %>
        </div>
      <% end %>

      <!-- Page content -->
      <main class="py-6 px-4 sm:px-6 lg:px-8">
        <% if flash[:notice] %>
          <div class="mb-4 rounded-md bg-green-50 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-green-800"><%= flash[:notice] %></p>
              </div>
            </div>
          </div>
        <% end %>

        <% if flash[:alert] %>
          <div class="mb-4 rounded-md bg-red-50 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-red-800"><%= flash[:alert] %></p>
              </div>
            </div>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </div>

  <!-- Sidebar overlay for mobile -->
  <div class="fixed inset-0 z-40 bg-gray-600 bg-opacity-75 hidden lg:hidden" 
       data-sidebar-target="overlay"
       data-action="click->sidebar#toggle"></div>
</body>
</html>
