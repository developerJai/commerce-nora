<% content_for(:title) { "My Wishlist" } %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 lg:py-10">
    <div class="flex flex-col lg:flex-row gap-6 lg:gap-8">
      <div class="w-full lg:w-72 flex-shrink-0">
        <%= render 'shared/account_sidebar', active_page: 'wishlist' %>
      </div>

      <div class="flex-1 min-h-[600px]">
      <div id="wishlist-header" class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6 sm:mb-8">
        <div>
          <h1 class="text-2xl font-serif font-semibold text-stone-900">My Wishlist</h1>
          <p class="text-sm text-stone-600 mt-1">
            <% if @wishlist_items.any? %>
              <%= pluralize(@wishlist_items.size, 'item') %> saved
            <% else %>
              Save items you love and revisit them anytime
            <% end %>
          </p>
        </div>

        <% if @wishlist_items.any? %>
          <%= button_to clear_wishlists_path, method: :delete,
              data: { turbo_confirm: "Are you sure you want to clear your entire wishlist?" },
              class: 'inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-stone-100 hover:bg-stone-200 text-stone-700 text-sm font-medium rounded-lg transition' do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            Clear Wishlist
          <% end %>
        <% end %>
      </div>

      <div id="wishlist-content">
        <% if @wishlist_items.any? %>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-3 lg:grid-cols-3 xl:grid-cols-4 gap-3 sm:gap-4">
            <% @wishlist_items.each do |wishlist_item| %>
              <% product = wishlist_item.product %>
              <div id="wishlist-item-<%= product.id %>" class="relative">
                <%= button_to wishlist_path(product_id: product.id), method: :delete,
                    data: { turbo_confirm: "Remove this item from your wishlist?" },
                    class: "absolute top-2 right-2 z-10 inline-flex items-center justify-center w-8 h-8 rounded-full bg-white/90 hover:bg-white border border-stone-200 text-stone-700 hover:text-rose-800 shadow-sm transition" do %>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                <% end %>
                <%= render 'shared/product_card', product: product, badge_side: :left %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="bg-white rounded-xl border border-stone-200 p-8 text-center">
            <div class="w-16 h-16 mx-auto bg-stone-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.0 0 00-6.364 0z"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-stone-900 mb-2">Your wishlist is empty</h3>
            <p class="text-stone-500 mb-4">Start adding items you love to keep track of them</p>
            <%= link_to 'Browse Products', products_path, class: 'inline-flex items-center gap-2 px-4 py-2 bg-rose-800 hover:bg-rose-900 text-white text-sm font-medium rounded-lg transition' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

