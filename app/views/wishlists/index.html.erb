<% content_for(:title) { "My Wishlist" } %>
<% content_for(:native_title) { "Wishlist" } %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 lg:py-10">
    <div class="flex flex-col md:flex-row gap-6 md:gap-8">
      <div class="w-full md:w-72 flex-shrink-0">
        <%= render 'shared/account_sidebar', active_page: 'wishlist' %>
      </div>

      <div class="flex-1 min-h-[600px]">
      <% if @wishlist_items.any? %>
        <div id="wishlist-header" class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6 sm:mb-8">
          <div>
            <h1 class="text-2xl font-sans font-semibold text-stone-900">My Wishlist</h1>
            <p class="text-sm text-stone-600 mt-1"><%= pluralize(@wishlist_items.size, 'item') %> saved</p>
          </div>

          <%= button_to clear_wishlists_path, method: :delete,
              data: { turbo_confirm: "Are you sure you want to clear your entire wishlist?" },
              class: 'inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-stone-100 hover:bg-stone-200 text-stone-700 text-sm font-medium rounded-lg transition' do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            Clear Wishlist
          <% end %>
        </div>
      <% end %>

      <div id="wishlist-content">
        <% if @wishlist_items.any? %>
          <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2.5 sm:gap-3 md:gap-4">
            <% @wishlist_items.each do |wishlist_item| %>
              <% product = wishlist_item.product %>
              <% variant = wishlist_item.product_variant %>
              <div id="wishlist-item-<%= product.id %>-<%= variant&.id || 'none' %>" class="relative">
                <%= button_to wishlist_path(product_id: product.id, variant_id: variant&.id), method: :delete,
                    data: { turbo_confirm: "Remove this item from your wishlist?" },
                    class: "absolute top-2 right-2 z-10 inline-flex items-center justify-center w-8 h-8 rounded-full bg-white/90 hover:bg-white border border-stone-200 text-stone-700 hover:text-rose-800 shadow-sm transition" do %>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                <% end %>
                <%= render 'shared/product_card', product: product, variant: variant, badge_side: :left, show_variant: true %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="flex items-center justify-center min-h-[calc(100vh-16rem)] sm:min-h-0 sm:py-16 px-4">
            <div class="w-full max-w-sm mx-auto border-2 border-dashed border-stone-200 rounded-2xl p-8 sm:p-10 bg-white/50">
              <div class="text-center">
                <div class="w-20 h-20 mx-auto mb-5 bg-rose-50 rounded-2xl flex items-center justify-center border border-rose-100">
                  <svg class="w-9 h-9 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                  </svg>
                </div>
                <h3 class="text-lg font-semibold text-stone-900 mb-1">Your wishlist is empty</h3>
                <p class="text-sm text-stone-500 mb-6 leading-relaxed">Start adding items you love<br class="sm:hidden"> to keep track of them</p>
                <%= link_to 'Browse Products', products_path, class: 'inline-block w-full px-6 py-3 bg-rose-800 hover:bg-rose-900 text-white text-sm font-medium rounded-xl transition' %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

