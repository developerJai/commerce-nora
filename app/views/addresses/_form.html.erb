<%= form_with(model: address, class: 'space-y-5') do |f| %>
  <% if address.errors.any? %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4">
      <div class="flex items-start gap-3">
        <div class="flex-shrink-0 w-8 h-8 bg-red-100 rounded-full flex items-center justify-center">
          <svg class="h-4 w-4 text-red-600" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="text-sm font-medium text-red-800">Please fix the following errors:</h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% address.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Address Type -->
  <div>
    <%= f.label :address_type, "Address Type", class: 'block text-sm font-medium text-stone-700 mb-2' %>
    <div class="grid grid-cols-2 gap-3">
      <% Address::ADDRESS_TYPES.each do |type| %>
        <label class="relative flex items-center justify-center px-4 py-3 border-2 rounded-lg cursor-pointer transition <%= address.address_type == type ? 'border-rose-600 bg-rose-50' : 'border-stone-200 hover:border-stone-300' %>">
          <%= f.radio_button :address_type, type, class: 'sr-only' %>
          <span class="text-sm font-medium <%= address.address_type == type ? 'text-rose-900' : 'text-stone-700' %>">
            <%= type.titleize %>
          </span>
        </label>
      <% end %>
    </div>
  </div>

  <!-- Name -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :first_name, "First Name *", class: 'block text-sm font-medium text-stone-700 mb-2' %>
      <%= f.text_field :first_name, required: true, class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
    </div>
    <div>
      <%= f.label :last_name, "Last Name *", class: 'block text-sm font-medium text-stone-700 mb-2' %>
      <%= f.text_field :last_name, required: true, class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
    </div>
  </div>

  <!-- Phone -->
  <div>
    <%= f.label :phone, "Phone Number", class: 'block text-sm font-medium text-stone-700 mb-2' %>
    <%= f.telephone_field :phone, placeholder: '+91 1234567890', class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
  </div>

  <!-- Street Address -->
  <div>
    <%= f.label :street_address, "Street Address *", class: 'block text-sm font-medium text-stone-700 mb-2' %>
    <%= f.text_field :street_address, required: true, placeholder: 'House number and street name', class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
  </div>

  <!-- Apartment -->
  <div>
    <%= f.label :apartment, "Apartment, Suite, etc. (optional)", class: 'block text-sm font-medium text-stone-700 mb-2' %>
    <%= f.text_field :apartment, placeholder: 'Apartment, suite, unit, building, floor, etc.', class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
  </div>

  <!-- City, State, Postal Code -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div>
      <%= f.label :city, "City *", class: 'block text-sm font-medium text-stone-700 mb-2' %>
      <%= f.text_field :city, required: true, class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
    </div>
    <div>
      <%= f.label :state, "State *", class: 'block text-sm font-medium text-stone-700 mb-2' %>
      <%= f.text_field :state, required: true, class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
    </div>
    <div>
      <%= f.label :postal_code, "Postal Code *", class: 'block text-sm font-medium text-stone-700 mb-2' %>
      <%= f.text_field :postal_code, required: true, class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
    </div>
  </div>

  <!-- Country -->
  <div>
    <%= f.label :country, "Country *", class: 'block text-sm font-medium text-stone-700 mb-2' %>
    <%= f.text_field :country, required: true, value: address.country.presence || 'India', class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
  </div>

  <!-- Default Checkbox -->
  <div>
    <label class="flex items-start gap-3 cursor-pointer">
      <%= f.check_box :is_default, class: 'mt-0.5 w-4 h-4 text-rose-600 border-stone-300 rounded focus:ring-2 focus:ring-rose-400' %>
      <div>
        <span class="text-sm font-medium text-stone-700">Set as default <%= address.address_type || 'shipping' %> address</span>
        <p class="text-xs text-stone-500 mt-0.5">This address will be used by default at checkout</p>
      </div>
    </label>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-3 pt-2">
    <%= f.submit "Save Address", class: 'px-6 py-2.5 bg-rose-800 hover:bg-rose-900 text-white text-sm font-medium rounded-lg transition cursor-pointer' %>
    <%= link_to 'Cancel', addresses_path, class: 'px-6 py-2.5 bg-stone-100 hover:bg-stone-200 text-stone-700 text-sm font-medium rounded-lg transition' %>
  </div>
<% end %>
