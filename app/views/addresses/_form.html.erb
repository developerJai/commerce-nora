<%= form_with model: address, 
    data: { 
      controller: 'address-form', 
      action: 'submit->address-form#submit',
      address_form_states_by_country_value: states_by_country_json
    },
    class: 'space-y-4' do |f| %>
  
  <%= f.hidden_field :redirect_to, value: local_assigns[:redirect_to] if local_assigns[:redirect_to] %>
  
  <% if address.errors.any? %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% address.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Name -->
  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :first_name, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
      <%= f.text_field :first_name, required: true, placeholder: 'First name',
          class: 'w-full px-3.5 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
    </div>
    <div>
      <%= f.label :last_name, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
      <%= f.text_field :last_name, required: true, placeholder: 'Last name',
          class: 'w-full px-3.5 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
    </div>
  </div>

  <!-- Phone with Country Code (intl-tel-input) -->
  <div>
    <%= f.label :phone, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
    <%= f.hidden_field :country_code, data: { address_form_target: 'countryCodeField' } %>
    <%= f.telephone_field :phone, placeholder: 'Phone number',
        class: 'w-full px-3.5 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm',
        data: { 
          address_form_target: 'phone', 
          action: 'input->address-form#validatePhone blur->address-form#validatePhone',
          initial_country: country_code_to_iso(address.country_code)
        } %>
    <div class="mt-1.5 text-xs text-red-600 hidden" data-address-form-target="phoneError"></div>
  </div>

  <!-- Street Address -->
  <div>
    <%= f.label :street_address, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
    <%= f.text_field :street_address, required: true, placeholder: 'House number and street name',
        class: 'w-full px-3.5 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
  </div>

  <!-- Apartment -->
  <div>
    <%= f.label :apartment, 'Apartment, suite (optional)', class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
    <%= f.text_field :apartment, placeholder: 'Apt, suite, etc.',
        class: 'w-full px-3.5 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
  </div>

  <!-- City and State -->
  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :city, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
      <%= f.text_field :city, required: true, placeholder: 'City',
          class: 'w-full px-3.5 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
    </div>
    <div>
      <%= f.label :state, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
      <%= f.select :state,
          state_options_for_select(address.country.presence || 'India', address.state),
          { include_blank: 'Select state' },
          { class: 'w-full px-3.5 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm',
            required: true,
            data: { address_form_target: 'state' } } %>
    </div>
  </div>

  <!-- PIN Code and Country -->
  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :postal_code, 'PIN Code', class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
      <%= f.text_field :postal_code, required: true, placeholder: 'PIN code',
          class: 'w-full px-3.5 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
    </div>
    <div>
      <%= f.label :country, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
      <%= f.select :country,
          country_options_for_select(address.country),
          {},
          { class: 'w-full px-3.5 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm',
            required: true,
            data: { address_form_target: 'country', action: 'change->address-form#countryChanged' } } %>
    </div>
  </div>

  <!-- Default Checkbox -->
  <div class="flex items-center pt-1">
    <%= f.check_box :is_default, class: 'h-4 w-4 text-rose-700 focus:ring-rose-400 border-stone-300 rounded' %>
    <%= f.label :is_default, 'Set as default address', class: 'ml-2 text-sm text-stone-600' %>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-3 pt-3">
    <%= f.submit (address.persisted? ? "Update Address" : "Save Address"), class: 'flex-1 py-3 px-4 bg-rose-800 text-white text-base font-semibold rounded-lg hover:bg-rose-900 transition cursor-pointer' %>
    <% cancel_path = local_assigns[:redirect_to] == 'checkout' ? checkout_path : addresses_path %>
    <%= link_to 'Cancel', cancel_path, class: 'py-3 px-6 bg-stone-100 hover:bg-stone-200 text-stone-700 text-sm font-medium rounded-lg transition' %>
  </div>
<% end %>
