<% content_for(:title) { "My Addresses" } %>
<% content_for(:native_title) { "Addresses" } %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 lg:py-10">
    <div class="flex flex-col md:flex-row gap-6 md:gap-8">
      <!-- Sidebar -->
      <div class="w-full md:w-72 flex-shrink-0">
        <%= render 'shared/account_sidebar', active_page: 'addresses' %>
      </div>

      <!-- Main Content -->
      <div class="flex-1 min-h-[600px]">
        <!-- Address Grid -->
        <% if @addresses.any? %>
          <!-- Page Header -->
          <div class="bg-white rounded-2xl border border-stone-200 p-5 lg:p-6 mb-6 shadow-sm">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <div>
                <h1 class="text-2xl lg:text-3xl font-sans font-semibold text-stone-900 mb-1">Saved Addresses</h1>
                <p class="text-sm text-stone-600">Manage your delivery addresses</p>
              </div>
              <%= link_to new_address_path, class: 'inline-flex items-center justify-center gap-2 px-5 py-3 bg-rose-700 hover:bg-rose-800 text-white text-sm font-semibold rounded-xl shadow-sm hover:shadow-md transition-all' do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                Add New Address
              <% end %>
            </div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-5">
            <% @addresses.each do |address| %>
              <div class="group bg-white rounded-xl border <%= address.is_default? ? 'border-rose-200 ring-2 ring-rose-100' : 'border-stone-200' %> hover:shadow-lg transition-all duration-200">
                <!-- Card Header -->
                <div class="p-4 lg:p-5 border-b border-stone-100">
                  <div class="flex items-start justify-between">
                    <div class="flex-1">
                      <div class="flex items-center gap-2 mb-1">
                        <h3 class="text-base font-semibold text-stone-900"><%= address.full_name %></h3>
                        <% if address.is_default? %>
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-rose-100 text-rose-700 text-xs font-semibold rounded-full">
                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            Default
                          </span>
                        <% end %>
                      </div>
                      <% if address.phone.present? %>
                        <p class="text-sm text-stone-600"><%= address.full_phone %></p>
                      <% end %>
                    </div>
                    
                    <!-- Actions Menu -->
                    <div class="relative" data-controller="dropdown">
                      <button type="button" data-action="click->dropdown#toggle click@window->dropdown#hide" class="p-2 text-stone-400 hover:text-stone-600 hover:bg-stone-100 rounded-lg transition-colors">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"/>
                        </svg>
                      </button>
                      
                      <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-stone-200 py-1 z-10">
                        <%= link_to edit_address_path(address), class: 'flex items-center gap-3 px-4 py-2.5 text-sm text-stone-700 hover:bg-stone-50 transition-colors' do %>
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                          </svg>
                          Edit Address
                        <% end %>
                        
                        <% unless address.is_default? %>
                          <%= button_to set_default_address_path(address), method: :patch, class: 'w-full flex items-center gap-3 px-4 py-2.5 text-sm text-stone-700 hover:bg-stone-50 transition-colors' do %>
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                            </svg>
                            Set as Default
                          <% end %>
                        <% end %>
                        
                        <div class="border-t border-stone-100 my-1"></div>
                        
                        <%= button_to address_path(address), method: :delete, 
                            data: { turbo_confirm: "Delete this address?" }, 
                            class: 'w-full flex items-center gap-3 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 transition-colors' do %>
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                          </svg>
                          Delete Address
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Address Details -->
                <div class="p-4 lg:p-5">
                  <div class="flex items-start gap-3 text-sm text-stone-700 leading-relaxed">
                    <svg class="w-5 h-5 text-stone-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <div>
                      <p><%= address.street_address %></p>
                      <% if address.apartment.present? %>
                        <p><%= address.apartment %></p>
                      <% end %>
                      <p><%= address.city %>, <%= address.state %> <%= address.postal_code %></p>
                    </div>
                  </div>
                </div>

                <!-- Quick Action Button -->
                <div class="px-4 pb-4 lg:px-5 lg:pb-5">
                  <%= link_to edit_address_path(address), class: 'w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-stone-50 hover:bg-stone-100 text-stone-700 text-sm font-medium rounded-lg transition-colors' do %>
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                    </svg>
                    Edit Address
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <!-- Empty State -->
          <div class="flex items-center justify-center min-h-[calc(100vh-16rem)] sm:min-h-0 sm:py-16 px-4">
            <div class="w-full max-w-sm mx-auto border-2 border-dashed border-stone-200 rounded-2xl p-8 sm:p-10 bg-white/50">
              <div class="text-center">
                <div class="w-20 h-20 mx-auto mb-5 bg-sky-50 rounded-2xl flex items-center justify-center border border-sky-100">
                  <svg class="w-9 h-9 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <h3 class="text-lg font-semibold text-stone-900 mb-1">No saved addresses yet</h3>
                <p class="text-sm text-stone-500 mb-6 leading-relaxed">Add a delivery address to make<br class="sm:hidden"> checkout faster and easier</p>
                <%= link_to new_address_path, class: 'inline-flex items-center justify-center gap-2 w-full px-6 py-3 bg-rose-800 hover:bg-rose-900 text-white text-sm font-semibold rounded-xl transition' do %>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                  </svg>
                  Add Your First Address
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
