<% content_for(:title) { "My Addresses" } %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
  <div class="flex flex-col lg:flex-row gap-6">
    <!-- Sidebar -->
    <div class="w-full lg:w-64 flex-shrink-0">
      <%= render 'shared/account_sidebar', active_page: 'addresses' %>
    </div>

    <!-- Main Content -->
    <div class="flex-1">
      <!-- Page Header -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-serif font-semibold text-stone-900">Saved Addresses</h1>
          <p class="text-sm text-stone-600 mt-1">Manage your delivery addresses</p>
        </div>
        <%= link_to new_address_path, class: 'inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-rose-800 hover:bg-rose-900 text-white text-sm font-medium rounded-lg transition' do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          Add New Address
        <% end %>
      </div>

      <!-- Address Grid -->
      <% if @addresses.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% @addresses.each do |address| %>
            <div class="bg-white rounded-lg border-2 <%= address.is_default? ? 'border-rose-200 bg-rose-50/30' : 'border-stone-200' %> p-5 hover:shadow-md transition">
              <!-- Header -->
              <div class="flex items-start justify-between mb-3">
                <% if address.is_default? %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-rose-600 text-white text-xs font-semibold rounded-full">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    Default
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-1 bg-stone-100 text-stone-600 text-xs font-medium rounded-full">
                    <%= address.address_type.titleize %>
                  </span>
                <% end %>
              </div>

              <!-- Address Details -->
              <div class="mb-4">
                <h3 class="font-semibold text-stone-900 mb-2"><%= address.full_name %></h3>
                <div class="text-sm text-stone-600 space-y-0.5">
                  <p><%= address.street_address %></p>
                  <% if address.apartment.present? %>
                    <p><%= address.apartment %></p>
                  <% end %>
                  <p><%= address.city %>, <%= address.state %> <%= address.postal_code %></p>
                  <% if address.phone.present? %>
                    <p class="mt-2 font-medium text-stone-700">
                      <svg class="w-3.5 h-3.5 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                      </svg>
                      <%= address.phone %>
                    </p>
                  <% end %>
                </div>
              </div>

              <!-- Actions -->
              <div class="flex items-center gap-2 pt-4 border-t border-stone-200">
                <%= link_to edit_address_path(address), class: 'flex-1 text-center px-3 py-2 text-sm text-rose-700 hover:bg-rose-50 font-medium rounded-lg transition' do %>
                  <svg class="w-4 h-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                  </svg>
                  Edit
                <% end %>
                <%= button_to address_path(address), method: :delete, 
                    data: { turbo_confirm: "Delete this address?" }, 
                    class: 'flex-1 text-center px-3 py-2 text-sm text-stone-600 hover:bg-stone-100 hover:text-red-600 font-medium rounded-lg transition' do %>
                  <svg class="w-4 h-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                  Delete
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white rounded-lg border border-stone-200 p-12 text-center">
          <div class="w-20 h-20 mx-auto bg-stone-100 rounded-full flex items-center justify-center mb-4">
            <svg class="w-10 h-10 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-stone-900 mb-2">No saved addresses</h3>
          <p class="text-stone-500 mb-6 max-w-sm mx-auto">Add a delivery address to make checkout faster and easier</p>
          <%= link_to new_address_path, class: 'inline-flex items-center gap-2 px-5 py-2.5 bg-rose-800 hover:bg-rose-900 text-white text-sm font-medium rounded-lg transition' do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
            Add Your First Address
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
