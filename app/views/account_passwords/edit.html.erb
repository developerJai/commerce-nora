<% content_for(:title) { "Change Password" } %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
  <div class="flex flex-col lg:flex-row gap-6">
    <div class="w-full lg:w-64 flex-shrink-0">
      <%= render 'shared/account_sidebar', active_page: 'profile' %>
    </div>

    <div class="flex-1 max-w-2xl">
      <div class="mb-6">
        <h1 class="text-2xl font-serif font-semibold text-stone-900">Change Password</h1>
        <p class="text-sm text-stone-600 mt-1">Update your account password</p>
      </div>

      <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6">
        <%= form_with(url: account_password_path, method: :patch, class: 'space-y-5') do |f| %>
          <!-- Current Password -->
          <div>
            <%= label_tag :current_password, "Current Password *", class: 'block text-sm font-medium text-stone-700 mb-2' %>
            <%= password_field_tag :current_password, nil, required: true, class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
          </div>

          <!-- New Password -->
          <div>
            <%= label_tag :password, "New Password *", class: 'block text-sm font-medium text-stone-700 mb-2' %>
            <%= password_field_tag :password, nil, required: true, minlength: 6, class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
            <p class="text-xs text-stone-500 mt-1">Must be at least 6 characters long</p>
          </div>

          <!-- Confirm New Password -->
          <div>
            <%= label_tag :password_confirmation, "Confirm New Password *", class: 'block text-sm font-medium text-stone-700 mb-2' %>
            <%= password_field_tag :password_confirmation, nil, required: true, minlength: 6, class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
          </div>

          <!-- Security Notice -->
          <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
              </svg>
              <div class="text-sm text-blue-800">
                <p class="font-medium">Password Security Tips</p>
                <ul class="mt-2 space-y-1 list-disc list-inside">
                  <li>Use a mix of uppercase, lowercase, numbers, and symbols</li>
                  <li>Avoid using personal information or common words</li>
                  <li>Don't reuse passwords from other accounts</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex items-center gap-3 pt-2">
            <%= f.submit "Update Password", class: 'px-6 py-2.5 bg-rose-800 hover:bg-rose-900 text-white text-sm font-medium rounded-lg transition cursor-pointer' %>
            <%= link_to 'Cancel', account_path, class: 'px-6 py-2.5 bg-stone-100 hover:bg-stone-200 text-stone-700 text-sm font-medium rounded-lg transition' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
