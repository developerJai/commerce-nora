<% content_for(:title) { "Support" } %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <div class="flex items-center justify-between mb-6 sm:mb-8">
    <h1 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900">Support Tickets</h1>
    <%= link_to 'New Ticket', new_support_ticket_path, class: 'px-4 py-2 bg-rose-800 text-white font-medium rounded-lg hover:bg-rose-900 transition text-sm' %>
  </div>

  <% if @tickets.any? %>
    <div class="bg-white rounded-xl border border-stone-200 overflow-hidden">
      <ul class="divide-y divide-stone-100">
        <% @tickets.each do |ticket| %>
          <li>
            <%= link_to support_ticket_path(ticket), class: 'block p-4 sm:p-6 hover:bg-stone-50 transition' do %>
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    <span class="text-sm font-mono text-stone-500"><%= ticket.ticket_number %></span>
                    <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= ticket_status_class(ticket.status) %>">
                      <%= ticket.status.titleize %>
                    </span>
                    <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= priority_class(ticket.priority) %>">
                      <%= ticket.priority.titleize %>
                    </span>
                  </div>
                  <h3 class="font-medium text-stone-900 truncate"><%= ticket.subject %></h3>
                  <% if ticket.order %>
                    <p class="text-sm text-stone-500 mt-1">Order: <%= ticket.order.order_number %></p>
                  <% end %>
                </div>
                <p class="text-sm text-stone-500 whitespace-nowrap"><%= time_ago_in_words(ticket.created_at) %> ago</p>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>

    <div class="mt-8">
      <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
    </div>
  <% else %>
    <div class="text-center py-12 sm:py-16 bg-white rounded-xl border border-stone-200">
      <div class="w-16 h-16 mx-auto mb-4 bg-rose-50 rounded-full flex items-center justify-center">
        <svg class="w-8 h-8 text-rose-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
      </div>
      <h2 class="text-lg font-serif font-medium text-stone-900 mb-2">No support tickets</h2>
      <p class="text-stone-500 text-sm mb-6">Need help? Create a support ticket.</p>
      <%= link_to 'Create Ticket', new_support_ticket_path, class: 'inline-block px-5 py-2 bg-rose-800 text-white font-medium rounded-full hover:bg-rose-900 transition' %>
    </div>
  <% end %>
</div>

<%
def ticket_status_class(status)
  case status
  when 'open' then 'bg-amber-100 text-amber-800'
  when 'in_progress' then 'bg-sky-100 text-sky-800'
  when 'resolved' then 'bg-emerald-100 text-emerald-800'
  when 'closed' then 'bg-stone-100 text-stone-800'
  else 'bg-stone-100 text-stone-800'
  end
end

def priority_class(priority)
  case priority
  when 'low' then 'bg-stone-100 text-stone-800'
  when 'normal' then 'bg-sky-100 text-sky-800'
  when 'high' then 'bg-amber-100 text-amber-800'
  when 'urgent' then 'bg-red-100 text-red-800'
  else 'bg-stone-100 text-stone-800'
  end
end
%>
