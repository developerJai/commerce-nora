<% content_for(:title) { "Support" } %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Support Tickets</h1>
    <%= link_to 'New Ticket', new_support_ticket_path, class: 'px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition' %>
  </div>

  <% if @tickets.any? %>
    <div class="bg-white rounded-lg shadow-sm overflow-hidden">
      <ul class="divide-y divide-gray-200">
        <% @tickets.each do |ticket| %>
          <li>
            <%= link_to support_ticket_path(ticket), class: 'block p-6 hover:bg-gray-50' do %>
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-sm font-mono text-gray-500"><%= ticket.ticket_number %></span>
                    <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= ticket_status_class(ticket.status) %>">
                      <%= ticket.status.titleize %>
                    </span>
                    <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= priority_class(ticket.priority) %>">
                      <%= ticket.priority.titleize %>
                    </span>
                  </div>
                  <h3 class="font-medium text-gray-900"><%= ticket.subject %></h3>
                  <% if ticket.order %>
                    <p class="text-sm text-gray-500 mt-1">Order: <%= ticket.order.order_number %></p>
                  <% end %>
                </div>
                <p class="text-sm text-gray-500"><%= time_ago_in_words(ticket.created_at) %> ago</p>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>

    <div class="mt-8">
      <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-white rounded-lg shadow-sm">
      <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
      </svg>
      <h2 class="text-xl font-medium text-gray-900 mb-4">No support tickets</h2>
      <p class="text-gray-500 mb-8">Need help? Create a support ticket.</p>
      <%= link_to 'Create Ticket', new_support_ticket_path, class: 'inline-block px-6 py-3 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition' %>
    </div>
  <% end %>
</div>

<%
def ticket_status_class(status)
  case status
  when 'open' then 'bg-yellow-100 text-yellow-800'
  when 'in_progress' then 'bg-blue-100 text-blue-800'
  when 'resolved' then 'bg-green-100 text-green-800'
  when 'closed' then 'bg-gray-100 text-gray-800'
  else 'bg-gray-100 text-gray-800'
  end
end

def priority_class(priority)
  case priority
  when 'low' then 'bg-gray-100 text-gray-800'
  when 'normal' then 'bg-blue-100 text-blue-800'
  when 'high' then 'bg-orange-100 text-orange-800'
  when 'urgent' then 'bg-red-100 text-red-800'
  else 'bg-gray-100 text-gray-800'
  end
end
%>
