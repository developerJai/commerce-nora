<% content_for(:title) { "Support" } %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 lg:py-10">
    <div class="flex flex-col lg:flex-row gap-6 lg:gap-8">
      <div class="w-full lg:w-72 flex-shrink-0">
        <%= render 'shared/account_sidebar', active_page: 'support' %>
      </div>

      <div class="flex-1 min-h-[600px]">
        <!-- Page Header -->
        <div class="bg-white rounded-2xl border border-stone-200 p-5 lg:p-6 mb-6 shadow-sm">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <h1 class="text-2xl lg:text-3xl font-serif font-semibold text-stone-900 mb-1">Support Tickets</h1>
              <p class="text-sm text-stone-600">Get help with your orders, payments, and deliveries</p>
            </div>
            <%= link_to new_support_ticket_path, class: 'inline-flex items-center justify-center gap-2 px-5 py-3 bg-rose-700 hover:bg-rose-800 text-white text-sm font-semibold rounded-xl shadow-sm hover:shadow-md transition-all' do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
              </svg>
              New Ticket
            <% end %>
          </div>
        </div>

        <!-- Tickets List -->
        <% if @tickets.any? %>
          <div class="space-y-3 lg:space-y-4">
            <% @tickets.each do |ticket| %>
              <%= link_to support_ticket_path(ticket), class: 'block bg-white rounded-xl border border-stone-200 hover:shadow-lg transition-all duration-200' do %>
                <div class="p-4 lg:p-5">
                  <div class="flex items-start justify-between gap-4 mb-3">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-2">
                        <span class="text-xs font-mono text-stone-500 bg-stone-100 px-2 py-1 rounded"><%= ticket.ticket_number %></span>
                        <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold <%= ticket_status_class(ticket.status) %>">
                          <%= ticket.status.titleize %>
                        </span>
                        <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold <%= priority_class(ticket.priority) %>">
                          <%= ticket.priority.titleize %>
                        </span>
                      </div>
                      <h3 class="text-base font-semibold text-stone-900 mb-1"><%= ticket.subject %></h3>
                      <div class="flex items-center gap-3 text-sm text-stone-600">
                        <span><%= time_ago_in_words(ticket.created_at) %> ago</span>
                        <% if ticket.order %>
                          <span class="text-stone-400">•</span>
                          <span>Order: <%= ticket.order.order_number %></span>
                        <% end %>
                      </div>
                    </div>
                    <svg class="w-5 h-5 text-stone-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>

        <div class="mt-8">
          <%== @pagy.series_nav if @pagy.last > 1 %>
        </div>
        <% else %>
          <!-- Empty State -->
          <div class="bg-white rounded-2xl border border-stone-200 p-12 lg:p-16 text-center shadow-sm">
            <div class="max-w-md mx-auto">
              <div class="w-20 h-20 lg:w-24 lg:h-24 mx-auto bg-gradient-to-br from-rose-100 to-rose-50 rounded-full flex items-center justify-center mb-6">
                <svg class="w-10 h-10 lg:w-12 lg:h-12 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-stone-900 mb-2">No support tickets yet</h3>
              <p class="text-stone-600 mb-8">Need help? Create a support ticket and our team will assist you</p>
              <%= link_to new_support_ticket_path, class: 'inline-flex items-center gap-2 px-6 py-3 bg-rose-700 hover:bg-rose-800 text-white text-sm font-semibold rounded-xl shadow-sm hover:shadow-md transition-all' do %>
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                Create Your First Ticket
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%
def ticket_status_class(status)
  case status
  when 'open' then 'bg-amber-100 text-amber-800'
  when 'in_progress' then 'bg-sky-100 text-sky-800'
  when 'resolved' then 'bg-emerald-100 text-emerald-800'
  when 'closed' then 'bg-stone-100 text-stone-800'
  else 'bg-stone-100 text-stone-800'
  end
end

def priority_class(priority)
  case priority
  when 'low' then 'bg-stone-100 text-stone-800'
  when 'normal' then 'bg-sky-100 text-sky-800'
  when 'high' then 'bg-amber-100 text-amber-800'
  when 'urgent' then 'bg-red-100 text-red-800'
  else 'bg-stone-100 text-stone-800'
  end
end
%>
