<% content_for(:title) { "New Support Ticket" } %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-8">Create Support Ticket</h1>

  <div class="bg-white rounded-lg shadow-sm p-6">
    <%= form_with model: @ticket, url: support_tickets_path, method: :post, class: 'space-y-6' do |f| %>
      <% if @ticket.errors.any? %>
        <div class="rounded-md bg-red-50 p-4">
          <ul class="text-sm text-red-700 list-disc list-inside">
            <% @ticket.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :subject, class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.text_field :subject, required: true, placeholder: 'Brief description of your issue',
            class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
      </div>

      <% if @orders.any? %>
        <div>
          <%= f.label :order_id, 'Related Order (optional)', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.select :order_id, @orders.map { |o| ["#{o.order_number} - #{o.placed_at&.strftime('%b %d, %Y')}", o.id] },
              { include_blank: 'Select an order...' },
              class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
        </div>
      <% end %>

      <div>
        <%= f.label :priority, class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.select :priority, [['Normal', 'normal'], ['High', 'high'], ['Urgent', 'urgent']],
            {},
            class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
      </div>

      <div>
        <%= label_tag :message, 'Message', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= text_area_tag :message, '', rows: 6, required: true, placeholder: 'Describe your issue in detail...',
            class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
      </div>

      <div class="flex gap-4">
        <%= link_to 'Cancel', support_tickets_path, class: 'flex-1 py-3 px-4 border border-gray-300 text-gray-700 text-center font-medium rounded-lg hover:bg-gray-50 transition' %>
        <%= f.submit 'Submit Ticket', class: 'flex-1 py-3 px-4 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition cursor-pointer' %>
      </div>
    <% end %>
  </div>
</div>
