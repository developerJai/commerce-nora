<% content_for(:title) { "New Support Ticket" } %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-3xl mx-auto px-3 sm:px-6 lg:px-8 py-6 lg:py-10">
    <!-- Page Header -->
    <div class="bg-white rounded-2xl border border-stone-200 p-5 lg:p-6 mb-6 shadow-sm">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl lg:text-3xl font-serif font-semibold text-stone-900 mb-1">Create Support Ticket</h1>
          <p class="text-sm text-stone-600">Describe your issue and we'll help you resolve it</p>
        </div>
        <%= link_to support_tickets_path, class: 'inline-flex items-center gap-2 px-4 py-2 text-sm text-stone-600 hover:text-stone-900 hover:bg-stone-100 rounded-lg transition-colors' do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
          Cancel
        <% end %>
      </div>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-2xl border border-stone-200 p-5 lg:p-8 shadow-sm">
    <%= form_with model: @ticket, url: support_tickets_path, method: :post, class: 'space-y-5' do |f| %>
      <% if @ticket.errors.any? %>
        <div class="rounded-lg bg-red-50 border border-red-200 p-4">
          <ul class="text-sm text-red-700 list-disc list-inside">
            <% @ticket.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :subject, class: 'block text-sm font-semibold text-stone-900 mb-2' %>
        <%= f.text_field :subject, required: true, placeholder: 'Brief description of your issue',
            class: 'w-full px-4 py-3 border border-stone-300 rounded-xl focus:ring-2 focus:ring-rose-500 focus:border-transparent text-sm transition-shadow' %>
      </div>

      <% if @orders.any? %>
        <div>
          <%= f.label :order_id, 'Related Order (optional)', class: 'block text-sm font-semibold text-stone-900 mb-2' %>
          <%= f.select :order_id, @orders.map { |o| ["#{o.order_number} - #{o.placed_at&.strftime('%b %d, %Y')}", o.id] },
              { include_blank: 'Select an order...' },
              class: 'w-full px-4 py-3 border border-stone-300 rounded-xl focus:ring-2 focus:ring-rose-500 focus:border-transparent text-sm transition-shadow' %>
        </div>
      <% end %>

      <div>
        <%= f.label :priority, class: 'block text-sm font-semibold text-stone-900 mb-2' %>
        <%= f.select :priority, [['Normal', 'normal'], ['High', 'high'], ['Urgent', 'urgent']],
            {},
            class: 'w-full px-4 py-3 border border-stone-300 rounded-xl focus:ring-2 focus:ring-rose-500 focus:border-transparent text-sm transition-shadow' %>
      </div>

      <div>
        <%= label_tag :message, 'Message', class: 'block text-sm font-semibold text-stone-900 mb-2' %>
        <%= text_area_tag :message, '', rows: 8, required: true, placeholder: 'Describe your issue in detail...',onkeydown: "if(event.key === ' ' && this.value.length === 0){ event.preventDefault(); }",
            class: 'w-full px-4 py-3 border border-stone-300 rounded-xl focus:ring-2 focus:ring-rose-500 focus:border-transparent text-sm transition-shadow resize-none' %>
        <p class="mt-2 text-xs text-stone-500">Provide as much detail as possible to help us assist you better</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 pt-4">
        <%= link_to support_tickets_path, class: 'sm:flex-1 py-3 px-6 border-2 border-stone-300 text-stone-700 text-center font-semibold rounded-xl hover:bg-stone-50 transition-colors' do %>
          Cancel
        <% end %>
        <%= f.submit 'Submit Ticket', class: 'sm:flex-1 py-3 px-6 bg-rose-700 hover:bg-rose-800 text-white font-semibold rounded-xl shadow-sm hover:shadow-md transition-all cursor-pointer' %>
      </div>
    <% end %>
  </div>
</div>
