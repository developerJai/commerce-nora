<% content_for(:title) { "New Support Ticket" } %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <h1 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900 mb-6 sm:mb-8">Create Support Ticket</h1>

  <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6">
    <%= form_with model: @ticket, url: support_tickets_path, method: :post, class: 'space-y-5' do |f| %>
      <% if @ticket.errors.any? %>
        <div class="rounded-lg bg-red-50 border border-red-200 p-4">
          <ul class="text-sm text-red-700 list-disc list-inside">
            <% @ticket.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :subject, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
        <%= f.text_field :subject, required: true, placeholder: 'Brief description of your issue',
            class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
      </div>

      <% if @orders.any? %>
        <div>
          <%= f.label :order_id, 'Related Order (optional)', class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
          <%= f.select :order_id, @orders.map { |o| ["#{o.order_number} - #{o.placed_at&.strftime('%b %d, %Y')}", o.id] },
              { include_blank: 'Select an order...' },
              class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
        </div>
      <% end %>

      <div>
        <%= f.label :priority, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
        <%= f.select :priority, [['Normal', 'normal'], ['High', 'high'], ['Urgent', 'urgent']],
            {},
            class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
      </div>

      <div>
        <%= label_tag :message, 'Message', class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
        <%= text_area_tag :message, '', rows: 6, required: true, placeholder: 'Describe your issue in detail...',
            class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
      </div>

      <div class="flex gap-4 pt-2">
        <%= link_to 'Cancel', support_tickets_path, class: 'flex-1 py-3 px-4 border border-stone-300 text-stone-700 text-center font-medium rounded-lg hover:bg-stone-50 transition' %>
        <%= f.submit 'Submit Ticket', class: 'flex-1 py-3 px-4 bg-rose-800 text-white font-medium rounded-lg hover:bg-rose-900 transition cursor-pointer' %>
      </div>
    <% end %>
  </div>
</div>
