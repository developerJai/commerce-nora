<% content_for(:title) { "Ticket #{@ticket.ticket_number}" } %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 lg:py-10">
    <div class="flex flex-col md:flex-row gap-6 md:gap-8">
      <div class="w-full md:w-72 flex-shrink-0">
        <%= render 'shared/account_sidebar', active_page: 'profile' %>
      </div>

      <div class="flex-1 min-h-[600px]">
        <!-- Page Header -->
        <div class="bg-white rounded-2xl border border-stone-200 p-5 lg:p-6 mb-6 shadow-sm">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-mono text-stone-500 bg-stone-100 px-2 py-1 rounded"><%= @ticket.ticket_number %></span>
                <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold <%= ticket_status_class(@ticket.status) %>">
                  <%= @ticket.status.titleize %>
                </span>
              </div>
              <h1 class="text-xl lg:text-2xl font-sans font-semibold text-stone-900 mb-2"><%= @ticket.subject %></h1>
              <% if @ticket.order %>
                <p class="text-sm text-stone-600">
                  Related to order: <%= link_to @ticket.order.order_number, order_path(@ticket.order), class: 'text-rose-700 hover:text-rose-900 font-semibold' %>
                </p>
              <% end %>
            </div>
            <%= link_to support_tickets_path, class: 'inline-flex items-center gap-2 px-4 py-2 text-sm text-stone-600 hover:text-stone-900 hover:bg-stone-100 rounded-lg transition-colors' do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
              Back
            <% end %>
          </div>
        </div>

        <!-- Messages -->
        <div class="space-y-4 mb-6">
          <% @messages.each do |message| %>
            <div class="<%= message.from_customer? ? 'ml-0 sm:ml-8' : 'mr-0 sm:mr-8' %>">
              <div class="bg-white rounded-xl border-2 <%= message.from_admin? ? 'border-rose-200 bg-gradient-to-br from-rose-50/50 to-white' : 'border-stone-200' %> p-4 lg:p-5 shadow-sm">
                <div class="flex items-center justify-between mb-3">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full <%= message.from_admin? ? 'bg-rose-600' : 'bg-stone-600' %> flex items-center justify-center">
                      <% if message.from_admin? %>
                        <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
                        </svg>
                      <% else %>
                        <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                      <% end %>
                    </div>
                    <p class="font-semibold text-stone-900 text-sm">
                      <%= message.from_admin? ? 'Support Team' : 'You' %>
                    </p>
                  </div>
                  <p class="text-xs text-stone-500"><%= message.created_at.strftime('%b %d, %I:%M %p') %></p>
                </div>
                <div class="text-stone-700 text-sm leading-relaxed whitespace-pre-wrap pl-10"><%= message.body %></div>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Reply Form -->
        <% if @ticket.can_reply? %>
          <div class="bg-white rounded-2xl border border-stone-200 p-5 lg:p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-stone-900 mb-4">Send Reply</h2>
            <%= form_with url: support_ticket_messages_path(@ticket), method: :post, class: 'space-y-4' do |f| %>
              <%= f.text_area :body, rows: 5, required: true, placeholder: 'Type your reply...',
              onkeydown: "if(event.key === ' ' && this.value.length === 0){ event.preventDefault(); }",
              class: 'w-full px-4 py-3 border border-stone-300 rounded-xl focus:ring-2 focus:ring-rose-500 focus:border-transparent text-sm transition-shadow resize-none' %>
              <div class="flex justify-end">
                <%= f.submit 'Send Reply', class: 'px-6 py-3 bg-rose-700 hover:bg-rose-800 text-white font-semibold rounded-xl shadow-sm hover:shadow-md transition-all cursor-pointer' %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="bg-stone-100 rounded-2xl border border-stone-200 p-8 text-center">
            <svg class="w-12 h-12 mx-auto mb-3 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
            <p class="text-stone-600 font-medium">This ticket is closed</p>
            <p class="text-stone-500 text-sm mt-1">No new replies can be added</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%
def ticket_status_class(status)
  case status
  when 'open' then 'bg-amber-100 text-amber-800'
  when 'in_progress' then 'bg-sky-100 text-sky-800'
  when 'resolved' then 'bg-emerald-100 text-emerald-800'
  when 'closed' then 'bg-stone-100 text-stone-800'
  else 'bg-stone-100 text-stone-800'
  end
end
%>
