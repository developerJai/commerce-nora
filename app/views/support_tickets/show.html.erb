<% content_for(:title) { "Ticket #{@ticket.ticket_number}" } %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <!-- Header -->
  <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6 mb-6">
    <div class="flex items-start justify-between mb-4">
      <div>
        <p class="text-sm font-mono text-stone-500 mb-1"><%= @ticket.ticket_number %></p>
        <h1 class="text-lg sm:text-xl font-serif font-semibold text-stone-900"><%= @ticket.subject %></h1>
      </div>
      <span class="px-3 py-1 rounded-full text-sm font-medium <%= ticket_status_class(@ticket.status) %>">
        <%= @ticket.status.titleize %>
      </span>
    </div>
    <% if @ticket.order %>
      <p class="text-sm text-stone-600">
        Related to order: <%= link_to @ticket.order.order_number, order_path(@ticket.order), class: 'text-rose-700 hover:text-rose-900 font-medium' %>
      </p>
    <% end %>
  </div>

  <!-- Messages -->
  <div class="space-y-4 mb-6">
    <% @messages.each do |message| %>
      <div class="<%= message.from_customer? ? 'ml-4 sm:ml-8' : 'mr-4 sm:mr-8' %>">
        <div class="bg-white rounded-xl border p-4 <%= message.from_admin? ? 'border-rose-200 bg-rose-50/50' : 'border-stone-200' %>">
          <div class="flex items-center justify-between mb-2">
            <p class="font-medium text-stone-900 text-sm">
              <%= message.from_admin? ? 'Support Team' : 'You' %>
            </p>
            <p class="text-xs text-stone-500"><%= message.created_at.strftime('%b %d, %Y at %I:%M %p') %></p>
          </div>
          <div class="text-stone-700 text-sm whitespace-pre-wrap"><%= message.body %></div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Reply Form -->
  <% if @ticket.can_reply? %>
    <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6">
      <h2 class="text-base font-serif font-semibold text-stone-900 mb-4">Reply</h2>
      <%= form_with url: support_ticket_messages_path(@ticket), method: :post, class: 'space-y-4' do |f| %>
        <%= f.text_area :body, rows: 4, required: true, placeholder: 'Type your reply...',
            class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
        <%= f.submit 'Send Reply', class: 'px-6 py-2.5 bg-rose-800 text-white font-medium rounded-lg hover:bg-rose-900 transition cursor-pointer' %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-stone-50 rounded-xl border border-stone-200 p-6 text-center">
      <p class="text-stone-500 text-sm">This ticket is closed and cannot receive new replies.</p>
    </div>
  <% end %>
</div>

<%
def ticket_status_class(status)
  case status
  when 'open' then 'bg-amber-100 text-amber-800'
  when 'in_progress' then 'bg-sky-100 text-sky-800'
  when 'resolved' then 'bg-emerald-100 text-emerald-800'
  when 'closed' then 'bg-stone-100 text-stone-800'
  else 'bg-stone-100 text-stone-800'
  end
end
%>
