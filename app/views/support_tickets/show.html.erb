<% content_for(:title) { "Ticket #{@ticket.ticket_number}" } %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
    <div class="flex items-start justify-between mb-4">
      <div>
        <p class="text-sm font-mono text-gray-500 mb-1"><%= @ticket.ticket_number %></p>
        <h1 class="text-xl font-bold text-gray-900"><%= @ticket.subject %></h1>
      </div>
      <span class="px-3 py-1 rounded-full text-sm font-medium <%= ticket_status_class(@ticket.status) %>">
        <%= @ticket.status.titleize %>
      </span>
    </div>
    <% if @ticket.order %>
      <p class="text-sm text-gray-600">
        Related to order: <%= link_to @ticket.order.order_number, order_path(@ticket.order), class: 'text-indigo-600 hover:text-indigo-800' %>
      </p>
    <% end %>
  </div>

  <!-- Messages -->
  <div class="space-y-4 mb-6">
    <% @messages.each do |message| %>
      <div class="<%= message.from_customer? ? 'ml-8' : 'mr-8' %>">
        <div class="bg-white rounded-lg shadow-sm p-4 <%= message.from_admin? ? 'border-l-4 border-indigo-500' : '' %>">
          <div class="flex items-center justify-between mb-2">
            <p class="font-medium text-gray-900">
              <%= message.from_admin? ? 'Support Team' : 'You' %>
            </p>
            <p class="text-xs text-gray-500"><%= message.created_at.strftime('%b %d, %Y at %I:%M %p') %></p>
          </div>
          <div class="text-gray-700 whitespace-pre-wrap"><%= message.body %></div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Reply Form -->
  <% if @ticket.can_reply? %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Reply</h2>
      <%= form_with url: support_ticket_messages_path(@ticket), method: :post, class: 'space-y-4' do |f| %>
        <%= f.text_area :body, rows: 4, required: true, placeholder: 'Type your reply...',
            class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
        <%= f.submit 'Send Reply', class: 'px-6 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition cursor-pointer' %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-50 rounded-lg p-6 text-center">
      <p class="text-gray-500">This ticket is closed and cannot receive new replies.</p>
    </div>
  <% end %>
</div>

<%
def ticket_status_class(status)
  case status
  when 'open' then 'bg-yellow-100 text-yellow-800'
  when 'in_progress' then 'bg-blue-100 text-blue-800'
  when 'resolved' then 'bg-green-100 text-green-800'
  when 'closed' then 'bg-gray-100 text-gray-800'
  else 'bg-gray-100 text-gray-800'
  end
end
%>
