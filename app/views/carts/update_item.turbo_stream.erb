<%# shared/_cart_controls has its own <div id="cart-controls-*"> wrapper, so use REPLACE %>
<%= turbo_stream.replace "cart-controls-#{@variant.id}" do %>
  <%= render 'shared/cart_controls', variant: @variant, cart_item: @cart_item %>
<% end %>

<%# products/_cart_controls has NO wrapper, so use UPDATE to keep the outer div %>
<%= turbo_stream.update "product-cart-controls-#{@variant.id}" do %>
  <%= render 'products/cart_controls', variant: @variant, cart_item: @cart_item %>
<% end %>

<%# Update mobile sticky bar to reflect cart state %>
<%= turbo_stream.update "mobile-sticky-bar-#{@variant.id}" do %>
  <%= render 'products/mobile_sticky_bar', variant: @variant, cart_item: @cart_item %>
<% end %>

<%= turbo_stream.update "cart-count" do %>
  <%= render 'shared/cart_count_badge' %>
<% end %>

<%= turbo_stream.update "mobile-cart-count" do %>
  <%= render 'shared/mobile_cart_count_badge' %>
<% end %>

<%= turbo_stream.update "cart-item-count", @cart.item_count.to_s %>

<%= turbo_stream.update "cart-items" do %>
  <%= render 'carts/items', cart_items: @cart_items %>
<% end %>

<%= turbo_stream.update "cart-summary" do %>
  <%= render 'carts/summary', cart: @cart %>
<% end %>

<%= turbo_stream.update "cart-summary-mobile" do %>
  <%= render 'carts/summary_mobile', cart: @cart %>
<% end %>
