<% if cart_items.any? %>
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <ul class="divide-y divide-gray-100">
    <% cart_items.each do |item| %>
      <li class="p-4" id="cart-item-<%= item.id %>">
        <div class="flex gap-4">
          <!-- Image -->
          <div class="w-20 h-20 flex-shrink-0 bg-gray-100 rounded-lg overflow-hidden">
            <% if item.product_variant.image.attached? %>
              <%= image_tag item.product_variant.image, class: 'w-full h-full object-cover' %>
            <% elsif item.product_variant.product.images.attached? %>
              <%= image_tag item.product_variant.product.images.first, class: 'w-full h-full object-cover' %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center">
                <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
            <% end %>
          </div>

          <!-- Details -->
          <div class="flex-1 min-w-0">
            <div class="flex justify-between">
              <div>
                <h3 class="text-sm font-medium text-gray-900">
                  <%= link_to item.product_variant.product.name, product_path(item.product_variant.product.slug), class: 'hover:text-teal-600' %>
                </h3>
                <p class="text-xs text-gray-500 mt-0.5"><%= item.product_variant.name %></p>
                <p class="text-sm font-medium text-gray-900 mt-1"><%= format_price(item.unit_price) %></p>
              </div>
              <button type="button" 
                      onclick="removeCartItem('<%= remove_from_cart_path(item) %>')"
                      class="text-gray-400 hover:text-red-500 p-1" 
                      title="Remove">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </button>
            </div>

            <!-- Quantity & Total -->
            <div class="flex items-center justify-between mt-3">
              <div class="inline-flex items-center border border-gray-200 rounded-lg">
                <button type="button" 
                        onclick="updateCartQuantity('<%= update_item_cart_path(item) %>', <%= item.quantity - 1 %>)" 
                        class="w-8 h-8 flex items-center justify-center text-gray-500 hover:bg-gray-50 rounded-l-lg transition">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/>
                  </svg>
                </button>
                <span class="w-10 text-center text-sm font-medium text-gray-900"><%= item.quantity %></span>
                <button type="button" 
                        onclick="updateCartQuantity('<%= update_item_cart_path(item) %>', <%= item.quantity + 1 %>)"
                        <% if item.quantity >= item.available_quantity %>disabled<% end %>
                        class="w-8 h-8 flex items-center justify-center text-gray-500 hover:bg-gray-50 rounded-r-lg transition disabled:opacity-40">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                  </svg>
                </button>
              </div>
              <span class="font-semibold text-gray-900"><%= format_price(item.total_price) %></span>
            </div>

            <% if item.product_variant.low_stock? && !item.product_variant.out_of_stock? %>
              <p class="text-xs text-amber-600 mt-2">Only <%= item.product_variant.stock_quantity %> left</p>
            <% end %>
          </div>
        </div>
        
        <% if item.exceeds_stock? %>
          <div class="mt-3 p-2 bg-amber-50 rounded-lg text-xs text-amber-700">
            Only <%= item.available_quantity %> available. Please reduce quantity.
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>
<% else %>
  <div class="text-center py-16 bg-white rounded-xl border border-gray-200">
    <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
    </svg>
    <h3 class="mt-4 text-lg font-medium text-gray-900">Your cart is empty</h3>
    <p class="mt-2 text-sm text-gray-500">Start adding items to your cart.</p>
    <%= link_to 'Browse Products', products_path, class: 'mt-6 inline-block px-6 py-2.5 bg-teal-500 hover:bg-teal-600 text-white font-medium rounded-full transition' %>
  </div>
<% end %>
