<% content_for(:title) { "Shopping Bag" } %>
<% content_for(:head) do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-3 sm:py-4 md:py-8">
  <!-- Header -->
  <div id="cart-header">
    <%= render 'header', cart: @cart %>
  </div>

  <div id="cart-content">
    <% if @cart.empty? %>
      <!-- Empty State -->
      <div class="flex items-center justify-center min-h-[calc(100vh-10rem)] sm:min-h-0 sm:py-16 px-4">
        <div class="w-full max-w-sm mx-auto border-2 border-dashed border-stone-200 rounded-2xl p-8 sm:p-10 bg-white/50">
          <div class="text-center">
            <div class="w-20 h-20 mx-auto mb-5 bg-rose-50 rounded-2xl flex items-center justify-center border border-rose-100">
              <svg class="w-9 h-9 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-stone-900 mb-1">Your bag is empty</h3>
            <p class="text-sm text-stone-500 mb-6 leading-relaxed">Start adding items to your bag<br class="sm:hidden"> and they'll appear here</p>
            <%= link_to products_path, class: 'inline-block w-full px-6 py-3 bg-rose-800 hover:bg-rose-900 text-white text-sm font-semibold rounded-xl transition active:scale-[0.98]' do %>
              Start Shopping
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="md:flex md:gap-6 xl:gap-8">
        <!-- Cart Items -->
        <div class="md:flex-1 pb-[140px] md:pb-0">
          <div id="cart-items">
            <% if @multi_vendor %>
              <%= render 'items_by_vendor', items_by_vendor: @items_by_vendor %>
            <% else %>
              <%= render 'items', cart_items: @cart_items %>
            <% end %>
          </div>

          <!-- Mobile: Coupon & Summary in scrollable area -->
          <div class="md:hidden mt-4 space-y-4">
            <div id="cart-coupon-section-mobile">
              <%= render 'coupon_section_mobile', coupons_enabled: @coupons_enabled, multi_vendor: @coupon_blocked_by_multi_vendor, cart: @cart %>
            </div>

            <div id="cart-summary-mobile" class="bg-white rounded-xl border border-stone-200 p-4">
              <h3 class="text-sm font-semibold text-stone-900 mb-3">Price Details</h3>
              <%= render 'summary_mobile', cart: @cart %>
            </div>
          </div>
        </div>

        <!-- Desktop Order Summary (sidebar) -->
        <div class="hidden md:block md:w-80">
          <div class="bg-white border md:rounded-xl shadow-sm p-5 sticky top-24">
            <h2 class="text-base font-sans font-semibold text-stone-900 mb-4">Order Summary</h2>

            <div id="cart-coupon-section">
              <%= render 'coupon_section', coupons_enabled: @coupons_enabled, multi_vendor: @coupon_blocked_by_multi_vendor %>
            </div>

            <div id="cart-summary" class="mb-4">
              <%= render 'summary', cart: @cart %>
            </div>

            <% unless @cart.empty? %>
              <%= link_to checkout_path, class: 'w-full block py-2.5 bg-rose-800 hover:bg-rose-900 text-white text-center text-base font-semibold rounded-lg transition' do %>
                Proceed to Checkout
              <% end %>
            <% end %>

            <div class="mt-3 text-center">
              <%= link_to 'Continue Shopping', products_path, class: 'text-sm text-stone-500 hover:text-rose-700' %>
            </div>

            <!-- Trust -->
            <div class="mt-5 pt-5 border-t border-stone-100">
              <div class="flex items-center justify-center gap-4 text-xs text-stone-400">
                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                  <span>Secure</span>
                </div>
                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                  <span>Certified</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Mobile: Fixed bottom checkout bar -->
        <% unless @cart.empty? %>
          <div id="cart-checkout-bar" class="md:hidden fixed bottom-14 left-0 right-0 z-[45] bg-white border-t border-stone-200 shadow-[0_-2px_12px_rgba(0,0,0,0.08)] px-4 py-3">
            <%= render 'checkout_bar_mobile', cart: @cart %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%= turbo_frame_tag 'coupon_modal' %>
</div>
