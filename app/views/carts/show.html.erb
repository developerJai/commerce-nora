<% content_for(:title) { "Shopping Cart" } %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-4 sm:py-8">
  <!-- Header -->
  <div class="flex items-center justify-between mb-4 sm:mb-6">
    <h1 class="text-xl sm:text-2xl font-bold text-gray-900">
      Shopping Cart
      <span class="text-gray-400 font-normal text-base">(<span id="cart-item-count"><%= @cart.item_count %></span>)</span>
    </h1>
    <% unless @cart.empty? %>
      <%= button_to 'Clear Cart', clear_cart_path, method: :delete, 
          class: 'text-sm text-gray-500 hover:text-red-500 transition', 
          form: { data: { turbo_confirm: 'Clear your entire cart?' } } %>
    <% end %>
  </div>

  <div id="cart-content">
    <% if @cart.empty? %>
      <!-- Empty State -->
      <div class="text-center py-16 bg-white rounded-xl border border-gray-200">
        <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-900">Your cart is empty</h3>
        <p class="mt-2 text-sm text-gray-500">Start adding items to your cart.</p>
        <%= link_to 'Browse Products', products_path, class: 'mt-6 inline-block px-6 py-2.5 bg-teal-500 hover:bg-teal-600 text-white font-medium rounded-full transition' %>
      </div>
    <% else %>
      <div class="lg:flex lg:gap-8">
        <!-- Cart Items -->
        <div class="lg:flex-1">
          <div id="cart-items">
            <%= render 'items', cart_items: @cart_items %>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="lg:w-80 mt-6 lg:mt-0">
          <div class="bg-white rounded-xl border border-gray-200 p-5 lg:sticky lg:top-24">
            <h2 class="text-base font-semibold text-gray-900 mb-4">Order Summary</h2>

            <!-- Coupon -->
            <div class="mb-4 pb-4 border-b border-gray-100">
              <% if session[:coupon_id] %>
                <% coupon = Coupon.find_by(id: session[:coupon_id]) %>
                <% if coupon %>
                  <div class="flex items-center justify-between p-3 bg-teal-50 rounded-lg border border-teal-200">
                    <div>
                      <p class="text-sm font-medium text-teal-800"><%= coupon.code %></p>
                      <p class="text-xs text-teal-600"><%= coupon.display_value %> off</p>
                    </div>
                    <%= button_to remove_coupon_cart_path, method: :delete, class: 'text-gray-400 hover:text-red-500' do %>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    <% end %>
                  </div>
                <% end %>
              <% else %>
                <%= form_with url: apply_coupon_cart_path, method: :post, class: 'flex gap-2' do |f| %>
                  <%= f.text_field :coupon_code, placeholder: 'Coupon code', 
                      class: 'flex-1 px-3 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent uppercase' %>
                  <%= f.submit 'Apply', class: 'px-4 py-2 text-sm bg-gray-900 text-white font-medium rounded-lg hover:bg-gray-800 cursor-pointer' %>
                <% end %>
              <% end %>
            </div>

            <!-- Summary -->
            <div id="cart-summary">
              <%= render 'summary', cart: @cart %>
            </div>

            <!-- Checkout -->
            <%= link_to checkout_path, class: 'mt-5 w-full block py-3 bg-teal-500 hover:bg-teal-600 text-white text-center font-medium rounded-lg transition' do %>
              Checkout
            <% end %>

            <div class="mt-3 text-center">
              <%= link_to 'Continue Shopping', products_path, class: 'text-sm text-gray-500 hover:text-teal-600' %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
