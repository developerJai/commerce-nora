<% content_for(:title) { "Shopping Bag" } %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-4 sm:py-8">
  <!-- Header -->
  <div class="flex items-center justify-between mb-4 sm:mb-6">
    <h1 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900">
      Shopping Bag
      <span class="text-stone-400 font-sans font-normal text-base">(<span id="cart-item-count"><%= @cart.item_count %></span>)</span>
    </h1>
    <% unless @cart.empty? %>
      <%= button_to 'Clear All', clear_cart_path, method: :delete, 
          class: 'text-sm text-stone-500 hover:text-rose-700 transition', 
          form: { data: { turbo_confirm: 'Clear your entire bag?' } } %>
    <% end %>
  </div>

  <div id="cart-content">
    <% if @cart.empty? %>
      <!-- Empty State -->
      <div class="text-center py-16 bg-white rounded-xl border border-stone-200">
        <div class="w-20 h-20 mx-auto mb-4 bg-rose-50 rounded-full flex items-center justify-center">
          <svg class="w-10 h-10 text-rose-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
        </div>
        <h3 class="text-lg font-serif font-medium text-stone-900">Your bag is empty</h3>
        <p class="mt-2 text-sm text-stone-500">Discover our exquisite collection</p>
        <%= link_to 'Browse Jewellery', products_path, class: 'mt-6 inline-block px-6 py-2.5 bg-rose-800 hover:bg-rose-900 text-white font-medium rounded-full transition' %>
      </div>
    <% else %>
      <div class="lg:flex lg:gap-8">
        <!-- Cart Items -->
        <div class="lg:flex-1">
          <div id="cart-items">
            <%= render 'items', cart_items: @cart_items %>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="lg:w-80 mt-6 lg:mt-0">
          <div class="bg-white rounded-xl border border-stone-200 p-5 lg:sticky lg:top-24">
            <h2 class="text-base font-serif font-semibold text-stone-900 mb-4">Order Summary</h2>

            <!-- Coupon -->
            <div class="mb-4 pb-4 border-b border-stone-100">
              <% if session[:coupon_id] %>
                <% coupon = Coupon.find_by(id: session[:coupon_id]) %>
                <% if coupon %>
                  <div class="flex items-center justify-between p-3 bg-emerald-50 rounded-lg border border-emerald-200">
                    <div>
                      <p class="text-sm font-medium text-emerald-800"><%= coupon.code %></p>
                      <p class="text-xs text-emerald-600"><%= coupon.display_value %> off</p>
                    </div>
                    <%= button_to remove_coupon_cart_path, method: :delete, class: 'text-stone-400 hover:text-red-500' do %>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    <% end %>
                  </div>
                <% end %>
              <% else %>
                <%= form_with url: apply_coupon_cart_path, method: :post, class: 'flex gap-2' do |f| %>
                  <%= f.text_field :coupon_code, placeholder: 'Coupon code', 
                      class: 'flex-1 px-3 py-2 text-sm bg-stone-50 border border-stone-200 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent uppercase' %>
                  <%= f.submit 'Apply', class: 'px-4 py-2 text-sm bg-stone-900 text-white font-medium rounded-lg hover:bg-stone-800 cursor-pointer' %>
                <% end %>
              <% end %>
            </div>

            <!-- Summary -->
            <div id="cart-summary">
              <%= render 'summary', cart: @cart %>
            </div>

            <!-- Checkout -->
            <%= link_to checkout_path, class: 'mt-5 w-full block py-3 bg-rose-800 hover:bg-rose-900 text-white text-center font-medium rounded-lg transition' do %>
              Proceed to Checkout
            <% end %>

            <div class="mt-3 text-center">
              <%= link_to 'Continue Shopping', products_path, class: 'text-sm text-stone-500 hover:text-rose-700' %>
            </div>
            
            <!-- Trust -->
            <div class="mt-5 pt-5 border-t border-stone-100">
              <div class="flex items-center justify-center gap-4 text-xs text-stone-400">
                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                  <span>Secure</span>
                </div>
                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                  <span>Certified</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
