<% content_for(:title) { "Shopping Bag" } %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-3 sm:py-4 md:py-8">
  <!-- Header -->
  <div id="cart-header">
    <%= render 'header', cart: @cart %>
  </div>

  <div id="cart-content">
    <% if @cart.empty? %>
      <!-- Empty State -->
      <div class="fixed inset-0 sm:relative flex items-center justify-center sm:py-16" style="top: 60px;">
        <div class="text-center px-4 max-w-sm mx-auto">
          <div class="w-24 h-24 sm:w-28 sm:h-28 mx-auto mb-6 sm:mb-8 bg-gradient-to-br from-rose-50 to-rose-100 rounded-full flex items-center justify-center shadow-lg">
            <svg class="w-12 h-12 sm:w-14 sm:h-14 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
          </div>
          <h3 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900 mb-2">Your bag is empty</h3>
          <p class="text-sm sm:text-base text-stone-500 mb-8 sm:mb-10">Start adding items to your bag and they'll appear here</p>
          <%= link_to products_path, class: 'inline-block w-full sm:w-auto px-8 py-3.5 bg-rose-800 hover:bg-rose-900 text-white text-base font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all transform hover:scale-[1.02] active:scale-[0.98]' do %>
            <span class="flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              Start Shopping
            </span>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="md:flex md:gap-6 xl:gap-8">
        <!-- Cart Items -->
        <div class="md:flex-1 pb-[280px] md:pb-0">
          <div id="cart-items">
            <% if @multi_vendor %>
              <%= render 'items_by_vendor', items_by_vendor: @items_by_vendor %>
            <% else %>
              <%= render 'items', cart_items: @cart_items %>
            <% end %>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="<%= is_android_app ? 'bottom-14 left-0 right-0 md:relative md:w-80 md:mt-0 z-[45] md:bottom-auto md:pb-0' : 'fixed md:static md:w-80 md:mt-0 z-[45] bottom-14 left-0 right-0 md:bottom-auto md:z-auto overflow-y-auto md:pb-0' %>">
          <div class="bg-white border-t-2 border-stone-200 md:border md:border-t md:rounded-xl shadow-[0_-2px_12px_rgba(0,0,0,0.08)] md:shadow-sm p-3.5 md:p-5 md:sticky md:top-24">
            <h2 class="hidden md:block text-sm sm:text-base font-serif font-semibold text-stone-900 mb-3 sm:mb-4">Order Summary</h2>

            <!-- Coupon Section -->
            <% if false && @coupons_enabled && !@multi_vendor %>
              <div class="mb-3 sm:mb-4 pb-3 sm:pb-4 border-b border-stone-100">
                <% if session[:coupon_id] %>
                  <% coupon = Coupon.find_by(id: session[:coupon_id]) %>
                  <% if coupon %>
                    <div class="flex items-center justify-between p-2.5 sm:p-3 bg-emerald-50 rounded-lg border border-emerald-200">
                      <div>
                        <p class="text-xs sm:text-sm font-medium text-emerald-800"><%= coupon.code %></p>
                        <p class="text-[10px] sm:text-xs text-emerald-600"><%= coupon.display_value %> off</p>
                      </div>
                      <%= button_to remove_coupon_cart_path, method: :delete, class: 'text-stone-400 hover:text-red-500' do %>
                        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                      <% end %>
                    </div>
                  <% end %>
                <% else %>
                  <div class="flex items-center justify-between mb-1.5 sm:mb-2">
                    <p class="text-[10px] sm:text-xs text-stone-500">Have a coupon?</p>
                    <%= link_to 'See available coupons', coupons_cart_path,
                        data: { turbo_frame: 'coupon_modal' },
                        class: 'text-xs text-rose-700 hover:text-rose-900 font-medium' %>
                  </div>
                  <%= form_with url: apply_coupon_cart_path, method: :post, class: 'flex gap-1.5 sm:gap-2' do |f| %>
                    <%= f.text_field :coupon_code, placeholder: 'Coupon code', 
                        class: 'flex-1 px-2.5 sm:px-3 py-1.5 sm:py-2 text-xs sm:text-sm bg-stone-50 border border-stone-200 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent uppercase' %>
                    <%= f.submit 'Apply', class: 'px-3 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm bg-stone-900 text-white font-medium rounded-lg hover:bg-stone-800 cursor-pointer' %>
                  <% end %>
                <% end %>
              </div>
            <% elsif @multi_vendor %>
              <!-- Multi-vendor: Coupons not available -->
            <% end %>

            <!-- Summary -->
            <div id="cart-summary" class="hidden md:block mb-4">
              <%= render 'summary', cart: @cart %>
            </div>

            <!-- Mobile Summary (Detailed) -->
            <div id="cart-summary-mobile" class="md:hidden mb-3">
              <%= render 'summary_mobile', cart: @cart %>
            </div>

            <!-- Checkout -->
            <% unless @cart.empty? %>
              <%= link_to checkout_path, class: 'w-full block py-3 md:py-2.5 bg-rose-800 hover:bg-rose-900 text-white text-center text-base font-semibold rounded-xl md:rounded-lg transition shadow-lg md:shadow-none' do %>
                Proceed to Checkout
              <% end %>
            <% end %>

            <div class="hidden md:block mt-2.5 sm:mt-3 text-center">
              <%= link_to 'Continue Shopping', products_path, class: 'text-xs sm:text-sm text-stone-500 hover:text-rose-700' %>
            </div>
            
            <!-- Trust -->
            <div class="hidden md:block mt-4 sm:mt-5 pt-4 sm:pt-5 border-t border-stone-100">
              <div class="flex items-center justify-center gap-3 sm:gap-4 text-[10px] sm:text-xs text-stone-400">
                <div class="flex items-center gap-0.5 sm:gap-1">
                  <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                  <span>Secure</span>
                </div>
                <div class="flex items-center gap-0.5 sm:gap-1">
                  <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                  <span>Certified</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%= turbo_frame_tag 'coupon_modal' %>
</div>
