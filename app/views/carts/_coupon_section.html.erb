<% if coupons_enabled && !multi_vendor %>
  <div class="mb-4 pb-4 border-b border-stone-100">
    <% if session[:coupon_id] %>
      <% coupon = Coupon.find_by(id: session[:coupon_id]) %>
      <% if coupon %>
        <div class="p-3 bg-emerald-50 rounded-xl border border-emerald-200">
          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-2.5 min-w-0">
              <div class="w-8 h-8 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <div class="min-w-0">
                <p class="text-sm font-bold text-emerald-800"><%= coupon.code %> <span class="text-[10px] font-semibold text-emerald-600">applied</span></p>
                <p class="text-xs text-emerald-600 mt-0.5">Saving <span class="font-semibold"><%= coupon.display_value %></span></p>
              </div>
            </div>
            <%= button_to remove_coupon_cart_path, method: :delete, class: 'flex-shrink-0 text-xs font-medium text-rose-500 hover:text-rose-700 transition' do %>
              Remove
            <% end %>
          </div>
        </div>
        <div class="mt-2 text-center">
          <%= link_to coupons_cart_path,
              data: { turbo_frame: 'coupon_modal' },
              class: 'text-xs text-stone-600 hover:text-stone-900 font-medium' do %>
            View all coupons
            <svg class="w-3 h-3 inline ml-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="flex items-center gap-2 mb-3">
        <div class="w-7 h-7 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0">
          <span class="text-white text-xs font-bold">%</span>
        </div>
        <p class="text-sm font-semibold text-stone-900">Coupons & offers</p>
      </div>
      <%= form_with url: apply_coupon_cart_path, method: :post, class: 'flex gap-2' do |f| %>
        <%= f.text_field :coupon_code, placeholder: 'Enter coupon code',
            class: 'flex-1 px-3 py-2 text-sm bg-stone-50 border border-stone-200 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent uppercase placeholder:normal-case placeholder:text-stone-400' %>
        <%= f.submit 'Apply', class: 'px-4 py-2 text-sm bg-stone-900 text-white font-medium rounded-lg hover:bg-stone-800 cursor-pointer' %>
      <% end %>
      <div class="mt-2 text-center">
        <%= link_to coupons_cart_path,
            data: { turbo_frame: 'coupon_modal' },
            class: 'flex items-center justify-center gap-1 text-xs text-stone-600 hover:text-stone-900 font-medium' do %>
          See available coupons
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
