<% coupon = session[:coupon_id] ? Coupon.find_by(id: session[:coupon_id]) : nil %>
<% bundle_deal = session[:bundle_deal_id] ? BundleDeal.find_by(id: session[:bundle_deal_id]) : nil %>
<% subtotal = cart.subtotal %>
<% coupon_discount = coupon&.calculate_discount(subtotal) || 0 %>
<% bundle_discount = session[:bundle_discount].to_f %>
<% total_discount = coupon_discount + bundle_discount %>
<% total = subtotal - total_discount %>

<div class="space-y-2 text-sm">
  <div class="flex justify-between">
    <span class="text-stone-500">Subtotal</span>
    <span class="text-stone-800"><%= format_price(subtotal) %></span>
  </div>
  
  <% if bundle_discount > 0 && bundle_deal %>
    <div class="flex justify-between text-amber-600">
      <span>Bundle: <%= bundle_deal.title %></span>
      <span>-<%= format_price(bundle_discount) %></span>
    </div>
  <% end %>
  
  <% if coupon_discount > 0 %>
    <div class="flex justify-between text-emerald-600">
      <span>Coupon: <%= coupon.code %></span>
      <span>-<%= format_price(coupon_discount) %></span>
    </div>
  <% end %>
  
  <div class="flex justify-between">
    <span class="text-stone-500">Shipping</span>
    <span class="text-stone-400 text-xs">Calculated at checkout</span>
  </div>
  
  <div class="border-t border-stone-100 pt-2 mt-2 flex justify-between">
    <span class="font-medium text-stone-900">Total</span>
    <span class="font-semibold text-stone-900 text-base"><%= format_price(total) %></span>
  </div>
</div>
