<!-- Empty State -->
<div class="fixed inset-0 sm:relative flex items-center justify-center sm:py-16" style="top: 60px;">
  <div class="text-center px-4 max-w-sm mx-auto">
    <div class="w-24 h-24 sm:w-28 sm:h-28 mx-auto mb-6 sm:mb-8 bg-gradient-to-br from-rose-50 to-rose-100 rounded-full flex items-center justify-center shadow-lg">
      <svg class="w-12 h-12 sm:w-14 sm:h-14 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
      </svg>
    </div>
    <h3 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900 mb-2">Your bag is empty</h3>
    <p class="text-sm sm:text-base text-stone-500 mb-8 sm:mb-10">Start adding items to your bag and they'll appear here</p>
    <%= link_to products_path, class: 'inline-block w-full sm:w-auto px-8 py-3.5 bg-rose-800 hover:bg-rose-900 text-white text-base font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all transform hover:scale-[1.02] active:scale-[0.98]' do %>
      <span class="flex items-center justify-center gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        Start Shopping
      </span>
    <% end %>
  </div>
</div>
