<%= turbo_frame_tag 'coupon_modal' do %>
  <div class="fixed inset-0 z-50">
    <%= link_to coupons_cart_path(close: 1),
        data: { turbo_frame: 'coupon_modal' },
        class: "absolute inset-0 bg-black/60" do %>
    <% end %>

    <div class="absolute inset-0 flex items-end sm:items-center justify-center p-4">
      <div class="w-full max-w-lg bg-white rounded-xl shadow-xl border border-stone-200 overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-stone-100">
          <div>
            <h2 class="text-base font-sans font-semibold text-stone-900">Available Coupons</h2>
            <p class="text-xs text-stone-500 mt-0.5">Based on your cart subtotal: <%= format_price(@subtotal) %></p>
          </div>
          <%= link_to coupons_cart_path(close: 1), data: { turbo_frame: 'coupon_modal' }, class: 'text-stone-400 hover:text-stone-700 transition' do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          <% end %>
        </div>

        <div class="p-5">
          <% if @coupons.blank? %>
            <div class="text-center py-10">
              <p class="text-sm text-stone-600">No coupons available right now.</p>
            </div>
          <% else %>
            <% if @applicable_coupons.any? %>
              <div class="space-y-3">
                <% @applicable_coupons.each do |coupon| %>
                  <div class="flex items-start justify-between gap-4 p-4 rounded-lg border border-stone-200 bg-stone-50">
                    <div class="min-w-0">
                      <p class="text-sm font-semibold text-stone-900"><%= coupon.code %> <span class="text-stone-500 font-normal">(<%= coupon.display_value %> off)</span></p>
                      <p class="text-xs text-stone-500 mt-1"><%= coupon.name %></p>
                      <% if coupon.minimum_order_amount.present? && coupon.minimum_order_amount > 0 %>
                        <p class="text-xs text-stone-500 mt-1">Min order: <%= format_price(coupon.minimum_order_amount) %></p>
                      <% end %>
                    </div>

                    <%= form_with url: apply_coupon_cart_path, method: :post do |f| %>
                      <%= f.hidden_field :coupon_code, value: coupon.code %>
                      <%= f.submit 'Apply', class: 'px-4 py-2 text-sm bg-stone-900 text-white font-medium rounded-lg hover:bg-stone-800 cursor-pointer whitespace-nowrap' %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-8">
                <p class="text-sm text-stone-600">No coupons apply to your current subtotal.</p>
              </div>
            <% end %>

            <% if @inapplicable_coupons.any? %>
              <div class="mt-6">
                <h3 class="text-xs font-semibold text-stone-500 uppercase tracking-wide mb-3">Not applicable</h3>
                <div class="space-y-3">
                  <% @inapplicable_coupons.each do |coupon| %>
                    <div class="flex items-start justify-between gap-4 p-4 rounded-lg border border-stone-200">
                      <div class="min-w-0">
                        <p class="text-sm font-semibold text-stone-900"><%= coupon.code %> <span class="text-stone-500 font-normal">(<%= coupon.display_value %> off)</span></p>
                        <p class="text-xs text-stone-500 mt-1"><%= coupon.name %></p>
                        <% if coupon.minimum_order_amount.present? && coupon.minimum_order_amount > 0 %>
                          <p class="text-xs text-stone-500 mt-1">Min order: <%= format_price(coupon.minimum_order_amount) %></p>
                        <% end %>
                      </div>
                      <span class="px-3 py-1 text-xs font-medium rounded-full bg-stone-100 text-stone-600 whitespace-nowrap">Not eligible</span>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>

        <div class="px-5 py-4 border-t border-stone-100 flex items-center justify-end">
          <%= link_to 'Close', coupons_cart_path(close: 1), data: { turbo_frame: 'coupon_modal' }, class: 'px-4 py-2 text-sm bg-stone-100 hover:bg-stone-200 text-stone-700 font-medium rounded-lg transition' %>
        </div>
      </div>
    </div>
  </div>
<% end %>
