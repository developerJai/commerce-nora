<% content_for(:title) { "My Account" } %>
<% content_for(:native_title) { "Account" } %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-3 md:py-6 lg:py-10">
    <div class="flex flex-col md:flex-row gap-4 md:gap-8">
      <!-- Sidebar (hidden on mobile for account page — tabs are redundant with quick stats) -->
      <div class="hidden md:block w-full md:w-72 flex-shrink-0">
        <%= render 'shared/account_sidebar', active_page: 'profile' %>
      </div>

      <!-- Main Content -->
      <div class="flex-1 space-y-3 md:space-y-5 lg:space-y-8">
        <!-- Welcome Header -->
        <div class="bg-white md:bg-gradient-to-br md:from-rose-50 md:to-amber-50 rounded-xl md:rounded-2xl border border-stone-200 p-3.5 md:p-6 lg:p-8 shadow-sm">
          <div class="flex items-center gap-3 md:block">
            <div class="w-11 h-11 md:hidden bg-rose-100 rounded-full flex items-center justify-center flex-shrink-0">
              <span class="text-base font-bold text-rose-700"><%= @customer.first_name[0] %><%= @customer.last_name&.first %></span>
            </div>
            <div>
              <h1 class="text-base md:text-2xl lg:text-3xl font-sans font-semibold text-stone-900 md:mb-2">
                <%= @customer.first_name %>
              </h1>
              <p class="text-xs md:text-sm lg:text-base text-stone-500"><%= @customer.email %></p>
            </div>
          </div>
        </div>

        <!-- Quick Stats - Compact horizontal on mobile -->
        <div class="grid grid-cols-3 gap-2 md:gap-5">
          <%= link_to orders_path, class: "group bg-white rounded-xl border border-stone-200 p-3 md:p-6 text-center md:text-left hover:shadow-lg hover:border-rose-300 transition-all" do %>
            <div class="md:flex md:items-center md:gap-4">
              <div class="w-10 h-10 mx-auto md:mx-0 md:w-14 md:h-14 bg-rose-50 rounded-xl flex items-center justify-center flex-shrink-0 mb-1.5 md:mb-0">
                <svg class="w-5 h-5 md:w-7 md:h-7 text-rose-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                </svg>
              </div>
              <div>
                <p class="text-xl md:text-3xl font-bold text-stone-900"><%= @customer.orders.placed.count %></p>
                <p class="text-[11px] md:text-sm text-stone-500 font-medium">Orders</p>
              </div>
            </div>
          <% end %>

          <%= link_to wishlists_path, class: "group bg-white rounded-xl border border-stone-200 p-3 md:p-6 text-center md:text-left hover:shadow-lg hover:border-amber-300 transition-all" do %>
            <div class="md:flex md:items-center md:gap-4">
              <div class="w-10 h-10 mx-auto md:mx-0 md:w-14 md:h-14 bg-amber-50 rounded-xl flex items-center justify-center flex-shrink-0 mb-1.5 md:mb-0">
                <svg class="w-5 h-5 md:w-7 md:h-7 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-xl md:text-3xl font-bold text-stone-900"><%= @customer.wishlist_count %></p>
                <p class="text-[11px] md:text-sm text-stone-500 font-medium">Wishlist</p>
              </div>
            </div>
          <% end %>

          <%= link_to addresses_path, class: "group bg-white rounded-xl border border-stone-200 p-3 md:p-6 text-center md:text-left hover:shadow-lg hover:border-emerald-300 transition-all" do %>
            <div class="md:flex md:items-center md:gap-4">
              <div class="w-10 h-10 mx-auto md:mx-0 md:w-14 md:h-14 bg-emerald-50 rounded-xl flex items-center justify-center flex-shrink-0 mb-1.5 md:mb-0">
                <svg class="w-5 h-5 md:w-7 md:h-7 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-xl md:text-3xl font-bold text-stone-900"><%= @customer.addresses.count %></p>
                <p class="text-[11px] md:text-sm text-stone-500 font-medium">Addresses</p>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Settings Menu - Clean list on mobile, cards on desktop -->
        <div class="bg-white rounded-xl border border-stone-200 overflow-hidden md:bg-transparent md:border-0 md:rounded-none">
          <h2 class="hidden md:block text-lg font-semibold text-stone-900 mb-4 px-1">Account Settings</h2>

          <!-- Mobile: list menu / Desktop: grid cards -->
          <div class="md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-5">
            <%= link_to edit_account_path, class: "flex items-center gap-3.5 px-4 py-3.5 border-b border-stone-100 md:border md:border-stone-200 md:rounded-xl md:bg-white md:p-5 md:hover:shadow-lg md:hover:border-blue-300 transition-all group" do %>
              <div class="w-9 h-9 md:w-12 md:h-12 bg-blue-50 rounded-lg md:rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-4.5 h-4.5 md:w-6 md:h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm md:text-base font-medium text-stone-900">Edit Profile</p>
                <p class="text-xs text-stone-500 md:mt-0.5">Update your personal information</p>
              </div>
              <svg class="w-4 h-4 md:w-5 md:h-5 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            <% end %>

            <%= link_to edit_account_password_path, class: "flex items-center gap-3.5 px-4 py-3.5 border-b border-stone-100 md:border md:border-stone-200 md:rounded-xl md:bg-white md:p-5 md:hover:shadow-lg md:hover:border-purple-300 transition-all group" do %>
              <div class="w-9 h-9 md:w-12 md:h-12 bg-purple-50 rounded-lg md:rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-4.5 h-4.5 md:w-6 md:h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm md:text-base font-medium text-stone-900">Change Password</p>
                <p class="text-xs text-stone-500 md:mt-0.5">Update your security settings</p>
              </div>
              <svg class="w-4 h-4 md:w-5 md:h-5 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            <% end %>

            <% unread_support_count = current_customer&.unread_support_tickets_count.to_i %>
            <%= link_to support_tickets_path, class: "flex items-center gap-3.5 px-4 py-3.5 md:border md:border-stone-200 md:rounded-xl md:bg-white md:p-5 md:hover:shadow-lg md:hover:border-indigo-300 transition-all group relative" do %>
              <div class="w-9 h-9 md:w-12 md:h-12 bg-indigo-50 rounded-lg md:rounded-xl flex items-center justify-center flex-shrink-0 relative">
                <svg class="w-4.5 h-4.5 md:w-6 md:h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
                <% if unread_support_count > 0 %>
                  <span class="absolute -top-1 -right-1 inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 text-[10px] font-bold rounded-full bg-rose-600 text-white">
                    <%= unread_support_count %>
                  </span>
                <% end %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm md:text-base font-medium text-stone-900">Help & Support</p>
                <p class="text-xs text-stone-500 md:mt-0.5">Get help with your orders</p>
              </div>
              <svg class="w-4 h-4 md:w-5 md:h-5 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            <% end %>
          </div>
        </div>

        <!-- Profile Information Card - Hidden on mobile (shown inline in header), visible on desktop -->
        <div class="hidden md:block bg-white rounded-xl border border-stone-200 shadow-sm overflow-hidden">
          <div class="px-6 py-4 border-b border-stone-200 flex items-center justify-between bg-stone-50">
            <h2 class="text-base font-semibold text-stone-900">Profile Information</h2>
            <%= link_to edit_account_path, class: 'inline-flex items-center gap-1.5 text-sm text-rose-700 hover:text-rose-900 font-medium transition' do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
              </svg>
              Edit Profile
            <% end %>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-stone-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-stone-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-medium text-stone-500 uppercase tracking-wide mb-1">Full Name</p>
                  <p class="text-base font-semibold text-stone-900"><%= @customer.full_name %></p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-stone-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-stone-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-medium text-stone-500 uppercase tracking-wide mb-1">Email Address</p>
                  <p class="text-base font-semibold text-stone-900 truncate"><%= @customer.email %></p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-stone-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-stone-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-medium text-stone-500 uppercase tracking-wide mb-1">Phone Number</p>
                  <p class="text-base font-semibold text-stone-900"><%= @customer.phone.presence || 'Not provided' %></p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Logout Button (mobile only - desktop uses sidebar) -->
        <div class="md:hidden">
          <%= button_to logout_path, method: :delete, data: { show_loader: 'true' }, class: "w-full flex items-center justify-center gap-2 px-4 py-3 text-sm font-medium text-red-600 bg-red-50 border border-red-200 rounded-xl hover:bg-red-100 active:scale-[0.98] transition" do %>
            <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            Sign Out
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
