<% content_for(:title) { "My Account" } %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <h1 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900 mb-6 sm:mb-8">My Account</h1>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
    <!-- Sidebar -->
    <div class="lg:col-span-1">
      <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6">
        <div class="text-center mb-6">
          <div class="w-20 h-20 mx-auto bg-rose-100 rounded-full flex items-center justify-center mb-4">
            <span class="text-2xl font-bold text-rose-800"><%= @customer.first_name.first.upcase %></span>
          </div>
          <h2 class="font-semibold text-stone-900"><%= @customer.full_name %></h2>
          <p class="text-sm text-stone-500"><%= @customer.email %></p>
        </div>

        <nav class="space-y-1">
          <%= link_to account_path, class: 'flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium bg-rose-50 text-rose-800' do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Profile
          <% end %>
          <%= link_to orders_path, class: 'flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-stone-600 hover:bg-stone-50' do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            Orders
          <% end %>
          <%= link_to addresses_path, class: 'flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-stone-600 hover:bg-stone-50' do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Addresses
          <% end %>
          <%= link_to support_tickets_path, class: 'flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-stone-600 hover:bg-stone-50' do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            Support
          <% end %>
        </nav>
      </div>
    </div>

    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Profile Info -->
      <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-base font-serif font-semibold text-stone-900">Profile Information</h2>
          <%= link_to 'Edit', edit_account_path, class: 'text-sm text-rose-700 hover:text-rose-900 font-medium' %>
        </div>
        <dl class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <dt class="text-stone-500">Full Name</dt>
            <dd class="font-medium text-stone-900 mt-0.5"><%= @customer.full_name %></dd>
          </div>
          <div>
            <dt class="text-stone-500">Email</dt>
            <dd class="font-medium text-stone-900 mt-0.5"><%= @customer.email %></dd>
          </div>
          <div>
            <dt class="text-stone-500">Phone</dt>
            <dd class="font-medium text-stone-900 mt-0.5"><%= @customer.phone.presence || 'Not provided' %></dd>
          </div>
          <div>
            <dt class="text-stone-500">Member Since</dt>
            <dd class="font-medium text-stone-900 mt-0.5"><%= @customer.created_at.strftime('%B %Y') %></dd>
          </div>
        </dl>
        <div class="mt-4 pt-4 border-t border-stone-200">
          <%= link_to 'Change Password', edit_account_password_path, class: 'text-sm text-rose-700 hover:text-rose-900 font-medium' %>
        </div>
      </div>

      <!-- Recent Orders -->
      <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-base font-serif font-semibold text-stone-900">Recent Orders</h2>
          <%= link_to 'View All', orders_path, class: 'text-sm text-rose-700 hover:text-rose-900 font-medium' %>
        </div>
        <% if @recent_orders.any? %>
          <ul class="divide-y divide-stone-100">
            <% @recent_orders.each do |order| %>
              <li class="py-4 flex items-center justify-between">
                <div>
                  <p class="font-medium text-stone-900"><%= order.order_number %></p>
                  <p class="text-sm text-stone-500"><%= order.placed_at&.strftime('%B %d, %Y') %></p>
                </div>
                <div class="text-right">
                  <p class="font-medium text-stone-900"><%= format_price(order.total_amount) %></p>
                  <p class="text-sm text-stone-500"><%= order.status.titleize %></p>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-stone-500 text-center py-4">No orders yet</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
