<% content_for(:title) { "My Account" } %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 lg:py-10">
    <div class="flex flex-col lg:flex-row gap-6 lg:gap-8">
      <!-- Sidebar - Desktop Only -->
      <div class="w-full lg:w-72 flex-shrink-0">
        <%= render 'shared/account_sidebar', active_page: 'profile' %>
      </div>

      <!-- Main Content -->
      <div class="flex-1 space-y-6 lg:space-y-8">
        <!-- Welcome Header -->
        <div class="bg-gradient-to-br from-rose-50 to-amber-50 rounded-2xl border border-stone-200 p-6 lg:p-8 shadow-sm">
          <h1 class="text-2xl lg:text-3xl font-serif font-semibold text-stone-900 mb-2">
            Welcome back, <%= @customer.first_name %>!
          </h1>
          <p class="text-sm lg:text-base text-stone-600">Manage your account settings and preferences</p>
        </div>

        <!-- Quick Stats Section -->
        <div>
          <h2 class="text-base lg:text-lg font-semibold text-stone-900 mb-3 lg:mb-4 px-1">Quick Access</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 lg:gap-5">
            <%= link_to orders_path, class: "group bg-white rounded-xl border border-stone-200 p-3 sm:p-4 lg:p-6 hover:shadow-xl hover:border-rose-300 hover:-translate-y-1 transition-all duration-200" do %>
              <div class="flex items-center gap-3 lg:gap-4">
                <div class="w-10 h-10 sm:w-12 sm:h-12 lg:w-14 lg:h-14 bg-gradient-to-br from-rose-100 to-rose-50 rounded-lg lg:rounded-xl flex items-center justify-center group-hover:from-rose-200 group-hover:to-rose-100 transition-all flex-shrink-0">
                  <svg class="w-5 h-5 sm:w-6 sm:h-6 lg:w-7 lg:h-7 text-rose-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xl sm:text-2xl lg:text-3xl font-bold text-stone-900"><%= @customer.orders.placed.count %></p>
                  <p class="text-xs sm:text-sm text-stone-600 font-medium">Orders</p>
                </div>
                <svg class="w-4 h-4 lg:w-5 lg:h-5 text-stone-300 group-hover:text-rose-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            <% end %>

            <%= link_to wishlists_path, class: "group bg-white rounded-xl border border-stone-200 p-3 sm:p-4 lg:p-6 hover:shadow-xl hover:border-amber-300 hover:-translate-y-1 transition-all duration-200" do %>
              <div class="flex items-center gap-3 lg:gap-4">
                <div class="w-10 h-10 sm:w-12 sm:h-12 lg:w-14 lg:h-14 bg-gradient-to-br from-amber-100 to-amber-50 rounded-lg lg:rounded-xl flex items-center justify-center group-hover:from-amber-200 group-hover:to-amber-100 transition-all flex-shrink-0">
                  <svg class="w-5 h-5 sm:w-6 sm:h-6 lg:w-7 lg:h-7 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xl sm:text-2xl lg:text-3xl font-bold text-stone-900"><%= @customer.wishlist_count %></p>
                  <p class="text-xs sm:text-sm text-stone-600 font-medium">Wishlist</p>
                </div>
                <svg class="w-4 h-4 lg:w-5 lg:h-5 text-stone-300 group-hover:text-amber-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            <% end %>

            <%= link_to addresses_path, class: "group bg-white rounded-xl border border-stone-200 p-3 sm:p-4 lg:p-6 hover:shadow-xl hover:border-emerald-300 hover:-translate-y-1 transition-all duration-200" do %>
              <div class="flex items-center gap-3 lg:gap-4">
                <div class="w-10 h-10 sm:w-12 sm:h-12 lg:w-14 lg:h-14 bg-gradient-to-br from-emerald-100 to-emerald-50 rounded-lg lg:rounded-xl flex items-center justify-center group-hover:from-emerald-200 group-hover:to-emerald-100 transition-all flex-shrink-0">
                  <svg class="w-5 h-5 sm:w-6 sm:h-6 lg:w-7 lg:h-7 text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xl sm:text-2xl lg:text-3xl font-bold text-stone-900"><%= @customer.addresses.count %></p>
                  <p class="text-xs sm:text-sm text-stone-600 font-medium">Addresses</p>
                </div>
                <svg class="w-4 h-4 lg:w-5 lg:h-5 text-stone-300 group-hover:text-emerald-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Account Settings Section -->
        <div>
          <h2 class="text-lg font-semibold text-stone-900 mb-4 px-1">Account Settings</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5">
            <%= link_to edit_account_path, class: "group bg-white rounded-xl border border-stone-200 p-5 hover:shadow-lg hover:border-blue-300 transition-all duration-200" do %>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-gradient-to-br from-blue-100 to-blue-50 rounded-xl flex items-center justify-center group-hover:from-blue-200 group-hover:to-blue-100 transition-all flex-shrink-0">
                  <svg class="w-6 h-6 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="text-base font-semibold text-stone-900 mb-0.5">Edit Profile</p>
                  <p class="text-sm text-stone-600">Update personal info</p>
                </div>
                <svg class="w-5 h-5 text-stone-300 group-hover:text-blue-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            <% end %>

            <%= link_to edit_account_password_path, class: "group bg-white rounded-xl border border-stone-200 p-5 hover:shadow-lg hover:border-purple-300 transition-all duration-200" do %>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-gradient-to-br from-purple-100 to-purple-50 rounded-xl flex items-center justify-center group-hover:from-purple-200 group-hover:to-purple-100 transition-all flex-shrink-0">
                  <svg class="w-6 h-6 text-purple-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="text-base font-semibold text-stone-900 mb-0.5">Security</p>
                  <p class="text-sm text-stone-600">Change password</p>
                </div>
                <svg class="w-5 h-5 text-stone-300 group-hover:text-purple-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            <% end %>

            <% unread_support_count = current_customer&.unread_support_tickets_count.to_i %>
            <%= link_to support_tickets_path, class: "group bg-white rounded-xl border border-stone-200 p-5 hover:shadow-lg hover:border-indigo-300 transition-all duration-200 relative" do %>
              <% if unread_support_count > 0 %>
                <span class="absolute top-3 right-3 inline-flex items-center justify-center min-w-[22px] h-5 px-2 text-xs font-bold rounded-full bg-rose-600 text-white shadow-sm">
                  <%= unread_support_count %>
                </span>
              <% end %>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-gradient-to-br from-indigo-100 to-indigo-50 rounded-xl flex items-center justify-center group-hover:from-indigo-200 group-hover:to-indigo-100 transition-all flex-shrink-0">
                  <svg class="w-6 h-6 text-indigo-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="text-base font-semibold text-stone-900 mb-0.5">Support</p>
                  <p class="text-sm text-stone-600">Get help & support</p>
                </div>
                <svg class="w-5 h-5 text-stone-300 group-hover:text-indigo-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Profile Information Card -->
        <div class="bg-white rounded-xl border border-stone-200 shadow-sm overflow-hidden">
          <div class="px-6 py-4 border-b border-stone-200 flex items-center justify-between bg-stone-50">
            <h2 class="text-base font-semibold text-stone-900">Profile Information</h2>
            <%= link_to edit_account_path, class: 'inline-flex items-center gap-1.5 text-sm text-rose-700 hover:text-rose-900 font-medium transition' do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
              </svg>
              Edit Profile
            <% end %>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-stone-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-stone-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-medium text-stone-500 uppercase tracking-wide mb-1">Full Name</p>
                  <p class="text-base font-semibold text-stone-900"><%= @customer.full_name %></p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-stone-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-stone-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-medium text-stone-500 uppercase tracking-wide mb-1">Email Address</p>
                  <p class="text-base font-semibold text-stone-900 truncate"><%= @customer.email %></p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-stone-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-stone-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-medium text-stone-500 uppercase tracking-wide mb-1">Phone Number</p>
                  <p class="text-base font-semibold text-stone-900"><%= @customer.phone.presence || 'Not provided' %></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
