<% content_for(:title) { "Edit Profile" } %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
  <div class="flex flex-col lg:flex-row gap-6">
    <!-- Sidebar -->
    <div class="w-full lg:w-64 flex-shrink-0">
      <%= render 'shared/account_sidebar', active_page: 'profile' %>
    </div>

    <!-- Main Content -->
    <div class="flex-1 max-w-3xl">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-stone-500 mb-4">
        <%= link_to 'Profile', account_path, class: 'hover:text-rose-700 transition' %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-stone-900">Edit Profile</span>
      </nav>

      <h1 class="text-2xl font-serif font-semibold text-stone-900 mb-6">Edit Profile</h1>

      <div class="bg-white rounded-lg border border-stone-200 p-6">
        <%= form_with(model: @customer, url: account_path, method: :patch, class: 'space-y-6') do |f| %>
          <% if @customer.errors.any? %>
            <div class="rounded-lg bg-red-50 border border-red-200 p-4">
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 w-8 h-8 bg-red-100 rounded-full flex items-center justify-center">
                  <svg class="h-4 w-4 text-red-600" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-sm font-medium text-red-800">Please fix the following errors:</h3>
                  <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
                    <% @customer.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          <% end %>

          <!-- Name -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <%= f.label :first_name, "First Name", class: 'block text-sm font-medium text-stone-700 mb-2' %>
              <%= f.text_field :first_name, required: true, class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 text-sm transition' %>
            </div>
            <div>
              <%= f.label :last_name, "Last Name", class: 'block text-sm font-medium text-stone-700 mb-2' %>
              <%= f.text_field :last_name, required: true, class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 text-sm transition' %>
            </div>
          </div>

          <!-- Email -->
          <div>
            <%= f.label :email, "Email Address", class: 'block text-sm font-medium text-stone-700 mb-2' %>
            <%= f.email_field :email, required: true, class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 text-sm transition' %>
          </div>

          <!-- Phone -->
          <div>
            <%= f.label :phone, "Phone Number", class: 'block text-sm font-medium text-stone-700 mb-2' %>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <svg class="w-4 h-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <%= f.telephone_field :phone, placeholder: '+91 1234567890', class: 'w-full pl-11 pr-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 text-sm transition' %>
            </div>
            <p class="mt-1.5 text-xs text-stone-500">Include country code for international numbers</p>
          </div>

          <!-- Info Box -->
          <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
              </svg>
              <div class="text-sm text-blue-800">
                <p class="font-medium">Need to change your password?</p>
                <p class="mt-1">Visit <%= link_to 'Change Password', edit_account_password_path, class: 'underline hover:text-blue-900 font-medium' %> to update your account security.</p>
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex items-center gap-3 pt-4 border-t border-stone-200">
            <%= f.submit "Save Changes", class: 'px-6 py-2.5 bg-rose-800 hover:bg-rose-900 text-white text-sm font-medium rounded-lg transition cursor-pointer' %>
            <%= link_to 'Cancel', account_path, class: 'px-6 py-2.5 bg-stone-100 hover:bg-stone-200 text-stone-700 text-sm font-medium rounded-lg transition' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
