<% content_for(:title) { "Edit Profile" } %>
<% content_for(:native_title) { "Edit Profile" } %>

<% content_for(:head) do %>
  <%= stylesheet_link_tag "https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.19/css/intlTelInput.css", "data-turbo-temporary": true %>
<% end %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-4 sm:py-6 lg:py-8">
  <div class="flex flex-col md:flex-row gap-4 md:gap-6">
    <!-- Sidebar - Visible on all devices -->
    <div class="w-full md:w-64 flex-shrink-0">
      <%= render 'shared/account_sidebar', active_page: 'profile' %>
    </div>

    <!-- Main Content -->
    <div class="flex-1 max-w-3xl">
      <!-- Breadcrumb - Mobile Optimized -->
      <nav class="flex items-center gap-2 text-xs sm:text-sm text-stone-500 mb-3 sm:mb-4">
        <%= link_to 'Profile', account_path, class: 'hover:text-rose-700 active:text-rose-900 transition' %>
        <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-stone-900">Edit Profile</span>
      </nav>

      <h1 class="text-xl sm:text-2xl font-sans font-semibold text-stone-900 mb-4 sm:mb-6">Edit Profile</h1>

      <div class="bg-white rounded-xl sm:rounded-2xl border border-stone-200 p-4 sm:p-6">
        <%= form_with(model: @customer, url: account_path, method: :patch, class: 'space-y-4 sm:space-y-6',
            data: { controller: 'signup-form', action: 'submit->signup-form#submit' }) do |f| %>
          <% if @customer.errors.any? %>
            <div class="rounded-lg sm:rounded-xl bg-red-50 border border-red-200 p-3 sm:p-4">
              <div class="flex items-start gap-2 sm:gap-3">
                <div class="flex-shrink-0 w-6 h-6 sm:w-8 sm:h-8 bg-red-100 rounded-full flex items-center justify-center">
                  <svg class="h-3 w-3 sm:h-4 sm:w-4 text-red-600" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-xs sm:text-sm font-medium text-red-800">Please fix the following errors:</h3>
                  <ul class="mt-2 text-xs sm:text-sm text-red-700 list-disc list-inside">
                    <% @customer.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          <% end %>

          <!-- Name - Mobile Optimized -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
            <div>
              <%= f.label :first_name, "First Name", class: 'block text-xs sm:text-sm font-medium text-stone-700 mb-1.5 sm:mb-2' %>
              <%= f.text_field :first_name, required: true, class: 'w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 text-base sm:text-sm transition',
                  data: { signup_form_target: 'firstName' } %>
            </div>
            <div>
              <%= f.label :last_name, "Last Name", class: 'block text-xs sm:text-sm font-medium text-stone-700 mb-1.5 sm:mb-2' %>
              <%= f.text_field :last_name, required: true, class: 'w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 text-base sm:text-sm transition',
                  data: { signup_form_target: 'lastName' } %>
            </div>
          </div>

          <!-- Email - Mobile Optimized -->
          <div>
            <%= f.label :email, "Email Address", class: 'block text-xs sm:text-sm font-medium text-stone-700 mb-1.5 sm:mb-2' %>
            <div class="relative">
              <%= f.email_field :email, required: true, autocomplete: 'email',
                  class: 'w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 text-base sm:text-sm transition',
                  data: { signup_form_target: 'email', action: 'input->signup-form#validateEmail blur->signup-form#validateEmail' } %>
            </div>
            <div id="email-error" class="mt-1 sm:mt-1.5 text-[10px] sm:text-xs text-red-600 hidden" data-signup-form-target="emailError"></div>
          </div>

          <!-- Phone - Mobile Optimized -->
          <div>
            <%= f.label :phone, "Phone Number", class: 'block text-xs sm:text-sm font-medium text-stone-700 mb-1.5 sm:mb-2' %>
            <div class="relative">
              <%= f.telephone_field :phone, autocomplete: 'tel', placeholder: 'Phone number (optional)',
                  class: 'w-full px-3 sm:px-4 py-2.5 sm:py-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 text-base sm:text-sm transition',
                  id: 'phone',
                  data: { signup_form_target: 'phone', action: 'input->signup-form#validatePhone blur->signup-form#validatePhone' } %>
              <div id="phone-error" class="mt-1 sm:mt-1.5 text-[10px] sm:text-xs text-red-600 hidden" data-signup-form-target="phoneError"></div>
            </div>
          </div>

          <!-- Info Box - Mobile Optimized -->
          <div class="bg-blue-50 border border-blue-200 rounded-lg sm:rounded-xl p-3 sm:p-4">
            <div class="flex items-start gap-2 sm:gap-3">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
              </svg>
              <div class="text-xs sm:text-sm text-blue-800">
                <p class="font-medium">Need to change your password?</p>
                <p class="mt-1">Visit <%= link_to 'Change Password', edit_account_password_path, class: 'underline hover:text-blue-900 active:text-blue-950 font-medium' %> to update your account security.</p>
              </div>
            </div>
          </div>

          <!-- Actions - Mobile Optimized -->
          <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 sm:gap-3 pt-4 border-t border-stone-200">
            <%= f.submit "Save Changes", class: 'w-full sm:w-auto px-6 py-2.5 sm:py-3 bg-rose-800 hover:bg-rose-900 active:bg-rose-950 text-white text-sm font-medium rounded-lg transition cursor-pointer' %>
            <%= link_to 'Cancel', account_path, class: 'w-full sm:w-auto px-6 py-2.5 sm:py-3 bg-stone-100 hover:bg-stone-200 active:bg-stone-300 text-stone-700 text-sm font-medium rounded-lg transition text-center' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
