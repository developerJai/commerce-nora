<% content_for(:title) { "Sign In" } %>

<div class="min-h-[60vh] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-xl border border-stone-200 p-8">
      <!-- Header -->
      <div class="text-center mb-8">
        <div class="w-14 h-14 mx-auto mb-4 bg-rose-50 rounded-full flex items-center justify-center">
          <svg class="w-7 h-7 text-rose-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <h1 class="text-2xl font-serif font-semibold text-stone-900">Welcome Back</h1>
        <p class="text-stone-500 mt-2 text-sm">Sign in to your account to continue</p>
      </div>

      <%= form_with url: login_path, method: :post, class: 'space-y-5' do |f| %>
        <div>
          <%= f.label :email, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
          <%= f.email_field :email, autofocus: true, autocomplete: 'email', required: true,
              placeholder: 'Enter your email',
              class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
        </div>

        <div>
          <%= f.label :password, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
          <%= f.password_field :password, autocomplete: 'current-password', required: true,
              placeholder: 'Enter your password',
              class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
        </div>

        <%= f.submit 'Sign In', class: 'w-full py-3 px-4 bg-rose-800 text-white font-medium rounded-lg hover:bg-rose-900 transition cursor-pointer' %>
      <% end %>

      <p class="mt-6 text-center text-sm text-stone-600">
        Don't have an account?
        <%= link_to 'Create one', signup_path, class: 'text-rose-700 hover:text-rose-900 font-medium' %>
      </p>
    </div>
  </div>
</div>
