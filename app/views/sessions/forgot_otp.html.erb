<div class="min-h-screen flex items-center justify-center bg-gray-100 px-4">
  <div class="max-w-md w-full bg-white border border-gray-200 rounded-2xl p-8 shadow">

    <!-- Heading -->
    <h1 class="text-2xl font-semibold text-gray-900 mb-2">
      Verify with WhatsApp
    </h1>

    <!-- Description -->
    <p class="text-sm text-gray-600 mb-6">
      Enter the code we sent to your phone number 
      <span class="font-medium text-gray-900">
        <%= ("#{@login}").gsub(/\d(?=\d{2})/, "*") %>
      </span> on WhatsApp.
    </p>

    <!-- FORM -->
    <%= form_with url: verify_otp_path, method: :post, class: "space-y-4" do %>

      <%= hidden_field_tag :login, @login %>
      <%= hidden_field_tag :country_code, @country_code %>

      <!-- OTP Input -->
      <input type="text" name="otp" maxlength="6" required
        class="w-full px-4 py-3 border border-gray-300 rounded-lg 
               bg-gray-50 focus:bg-white 
               focus:ring-2 focus:ring-yellow-400 focus:outline-none">

      <!-- Error -->
      <div id="otp_error"></div>

      <!-- Resend -->

      <!-- Verify Button -->
      <%= submit_tag "Verify",
            class: "w-full py-3 rounded-full bg-yellow-400 text-black font-semibold hover:bg-yellow-500 transition" %>

    <% end %>
<div data-controller="otp" class="text-center mt-4" data-otp-time-value="<%= @remaining_time %>">
  <span data-otp-target="timerText" class="text-gray-500 text-sm">
    Resend OTP in <span data-otp-target="countdown"><%= @remaining_time %></span>s
  </span>

  <%= button_to "Resend OTP",
      resend_otp_path,
      method: :post,
      params: { login: @login, country_code: @country_code },
      class: "text-blue-600 text-sm bg-transparent border-0 hover:underline hidden",
      data: { otp_target: "resendBtn" } %>
</div>

    <!-- Help text -->
    <div class="mt-6 text-sm text-gray-500">
      <p class="font-medium text-gray-700 mb-1">Need help?</p>
      <p>
        If you cannot receive the code or if you changed your email or phone number, 
        <a href="#" class="text-blue-600 hover:underline">try a different way</a>.
      </p>
    </div>

    <!-- Footer -->
    <div class="mt-6 text-sm text-gray-600">
      <p class="font-semibold text-gray-800">Don’t have WhatsApp?</p>
      <p>You can download the app on your device.</p>
    </div>

  </div>
</div>