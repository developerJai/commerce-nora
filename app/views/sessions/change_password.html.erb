<div class="min-h-screen flex flex-col items-center bg-gray-100 px-4 pt-10">

  <div class="w-full max-w-md bg-white border border-gray-300 rounded-lg p-6">

    <%=render 'header'%>


    <!-- Title -->
    <h1 class="text-2xl font-medium text-gray-900 mb-2">
      Create new password
    </h1>

    <!-- Subtitle -->
    <p class="text-sm text-gray-700 mb-5">
      We'll ask for this password whenever you sign in.
    </p>

    <!-- FORM -->
    <%= form_with url: password_update_path, method: :post, scope: :customer, class: "space-y-4" do %>

      <!-- New Password -->
      <div>
        <label class="block text-sm font-medium text-gray-800 mb-1">
          New password
        </label>
        <%= password_field_tag :password, nil,
              required: true,
              class: "w-full px-3 py-2 border border-gray-400 rounded-md bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-yellow-400" %>
      </div>

      <!-- Confirm Password -->
      <div>
        <label class="block text-sm font-medium text-gray-800 mb-1">
          Password again
        </label>
        <%= password_field_tag :password_confirmation, nil,
              required: true,
              class: "w-full px-3 py-2 border border-gray-400 rounded-md bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-yellow-400" %>
      </div>

      <!-- Button -->
      <%= submit_tag "Save changes and sign in",
            class: "w-full py-2.5 rounded-full bg-yellow-400 text-black font-medium hover:bg-yellow-500 transition" %>

    <% end %>
  </div>

  <!-- Tips -->
  <div class="max-w-md w-full mt-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">
      Secure password tips:
    </h2>

    <ul class="list-disc pl-5 space-y-2 text-sm text-gray-800">
      <li>Use at least 6 characters, a combination of numbers and letters is best.</li>
      <li>Do not use the same password you have used with us previously.</li>
      <li>Do not use dictionary words, your name, email address, mobile phone number or other personal information that can be easily obtained.</li>
      <li>Do not use the same password for multiple online accounts.</li>
    </ul>
  </div>

</div>