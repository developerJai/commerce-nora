<% content_for(:title) { "Sign In" } %>
<% content_for(:meta_description) { "Sign in to your Noralooks account to shop artificial jewellery, track orders, manage wishlist, and enjoy exclusive benefits. Secure login for registered customers." } %>
<% content_for(:meta_keywords) { ["sign in", "login", "customer login", "account login", "Noralooks login", "jewellery store login", "customer account", "secure login"] } %>
<% content_for(:head) do %>
<!-- Structured Data - WebPage Schema for Login -->
<script type="application/ld+json">
   {
     "@context": "https://schema.org",
     "@type": "WebPage",
     "name": "Sign In - Noralooks",
     "description": "Sign in to your Noralooks account",
     "url": "<%= login_url %>",
     "mainEntity": {
       "@type": "WebApplication",
       "name": "Noralooks Customer Login",
       "applicationCategory": "E-commerce",
       "operatingSystem": "Web Browser"
     }
   }
</script>
<% if request.user_agent&.include?("Hotwire") %>
<!-- Mobile app specific styles -->
<style>
   /* Prevent zoom on iOS - minimum 16px font size */
   input, select, textarea {
   font-size: 16px !important;
   }
   /* Larger touch targets for mobile app */
   .mobile-input {
   min-height: 48px;
   }
   /* Hide decorative elements in mobile app */
   .mobile-app .decorative-icon {
   display: none;
   }
</style>
<% end %>
<% end %>
<div class="bg-white <%= request.user_agent&.include?('Hotwire') ? '' : 'rounded-none sm:rounded-xl p-5 sm:p-6 md:p-8' %>">
   <!-- Header -->
   <header class="text-center mb-6">
      <% unless request.user_agent&.include?("Hotwire") %>
      <div class="w-12 h-12 mx-auto mb-3 bg-rose-50 rounded-full flex items-center justify-center">
         <svg class="w-6 h-6 text-rose-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
               d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 007-7z"/>
         </svg>
      </div>
      <% end %>
      <h1 class="text-2xl font-semibold text-stone-900">Sign In</h1>
   </header>

   <div class="mb-4 text-sm">
      <span class="text-stone-800 font-medium">
      <% if @login.to_s.match?(/\A\d+\z/) %>
      <%= @country_code %> <%= @login %>
      <% else %>
      <%= @login %>
      <% end %>
      </span>
      <%= link_to "Change", signin_path,
         class: "text-blue-600 ml-2 hover:underline" %>
   </div>
   <%= form_with url: signin_path,
      method: :post,
      data: {
        turbo_frame: "login_step",
        controller: "otp-form",
        action: "turbo:submit-end->otp-form#handleResponse"
      },
      class: "space-y-4" do |f| %>
   <%= hidden_field_tag :login, @login %>
   <%= hidden_field_tag :country_code, @country_code %>
   <!-- Label + Forgot -->
   <div class="flex justify-between items-center mb-1">
      <%= f.label :password, class: "text-sm font-medium text-stone-800" %>
      <div class="text-right mt-2">
         <%= link_to "Forgot Password?",
            forgotpassword_path(login: @login, country_code: @country_code),
            class: "text-sm text-blue-500 hover:underline" %>
      </div>
   </div>

   <div class="relative">
      <%= f.password_field :password,
         required: true,
         placeholder: "Enter password",
         data: { otp_form_target: "input" },
         class: "w-full px-6 py-2 border border-stone-400 rounded-xl focus:ring-2 focus:ring-blue-400 focus:outline-none" %>
      <button type="button" 
         class="absolute right-3 top-1/2 transform -translate-y-1/2 text-stone-400 hover:text-stone-600 p-2 touch-manipulation" 
         data-action="click->signup-form#togglePassword touchstart->signup-form#togglePassword" 
         data-field-id="password"
         aria-label="Toggle password visibility">
         <svg class="w-5 h-5 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
         </svg>
      </button>
   </div>
   <div id="login_error"></div>
   <%= f.submit "Sign in",
      class: "w-full py-2 rounded-full bg-rose-800 text-white text-base font-medium hover:bg-rose-900" %>
   <% end %>
   <% unless @login.include?("@") %>
   <!-- Divider -->
   <div class="flex items-center my-4">
      <div class="flex-grow border-t border-stone-300"></div>
      <span class="mx-3 text-sm text-stone-500">or</span>
      <div class="flex-grow border-t border-stone-300"></div>
   </div>
   <!-- WhatsApp OTP -->
   <%= button_to "Sign in with WhatsApp OTP",
      send_otp_path,
      method: :post,
      params: { login: @login, country_code: @country_code, type: "whatsapp" },
      class: "block w-full text-center py-2 mb-3 border border-stone-400 rounded-full hover:bg-stone-50" %>
   <!-- SMS OTP -->
   <%= button_to "Get an OTP on your phone",
      send_otp_path,
      method: :post,
      params: { login: @login, country_code: @country_code, type: "login" },
      class: "block w-full text-center py-2 border border-stone-400 rounded-full hover:bg-stone-50" %>
   <%end%>
</div>