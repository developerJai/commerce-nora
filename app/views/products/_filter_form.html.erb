<%# Shared filter form used in desktop sidebar and mobile drawer %>
<%# Locals: remove_filter_url (lambda), mobile (optional) %>
<% fc = @filter_config %>
<% mobile = local_assigns.fetch(:mobile, false) %>

<%= form_with url: products_path, method: :get, class: 'space-y-1', data: mobile ? { turbo_frame: '_top' } : { controller: 'filters', action: 'change->filters#scheduleSubmit', turbo_frame: 'products-content' } do |f| %>
  <%= hidden_field_tag :sort, @sort %>
  <%= hidden_field_tag :q, @q if @q.present? %>

  <!-- ── Availability Toggle ── -->
  <% if fc["show_availability"] %>
    <div class="py-3 border-b border-stone-100">
      <label class="flex items-center justify-between cursor-pointer group">
        <span class="text-sm font-medium text-stone-800 group-hover:text-stone-900">In Stock Only</span>
        <div class="relative">
          <%= check_box_tag :in_stock, "1", @in_stock,
              class: 'sr-only peer' %>
          <div class="w-9 h-5 bg-stone-200 rounded-full peer-checked:bg-rose-800 transition"></div>
          <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full shadow transition peer-checked:translate-x-4"></div>
        </div>
      </label>
    </div>
  <% end %>

  <!-- ── Categories ── -->
  <% if fc["show_categories"] && @category_tree.any? %>
    <div data-controller="filter-section" data-filter-section-open-value="true" class="py-3 border-b border-stone-100">
      <button type="button" data-action="click->filter-section#toggle" class="w-full flex items-center justify-between mb-2 group">
        <span class="text-sm font-semibold text-stone-800 group-hover:text-stone-900">Categories</span>
        <svg data-filter-section-target="icon" class="w-4 h-4 text-stone-400 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div data-filter-section-target="content" class="-mx-1">
        <% @category_tree.each do |parent, children| %>
          <%
            parent_selected = @category_ids.include?(parent.id.to_s)
            any_child_selected = children.any? { |c| @category_ids.include?(c.id.to_s) }
            parent_count = (@category_counts[parent.id] || 0) + children.sum { |c| @category_counts[c.id] || 0 }
            is_expanded = parent_selected || any_child_selected
            show_children = fc["show_subcategories"] && children.any?
          %>
          <div data-controller="category-filter"
               data-category-filter-open-value="<%= is_expanded %>"
               class="rounded-lg mb-0.5 <%= parent_selected || any_child_selected ? 'bg-rose-50/60' : 'hover:bg-stone-50' %> transition-colors">
            <!-- Parent row -->
            <div class="flex items-center gap-1 px-2 py-2 cursor-pointer"
                 data-action="click->category-filter#toggle">
              <% if show_children %>
                <svg data-category-filter-target="arrow"
                     class="w-3.5 h-3.5 text-stone-400 flex-shrink-0 transition-transform duration-200"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              <% else %>
                <span class="w-3.5 flex-shrink-0"></span>
              <% end %>

              <label class="flex items-center gap-2 flex-1 min-w-0 cursor-pointer" onclick="event.stopPropagation()">
                <%= check_box_tag 'category_ids[]', parent.id, parent_selected,
                    data: { category_filter_target: 'parentCheckbox' },
                    class: 'h-4 w-4 rounded border-2 text-rose-800 focus:ring-2 focus:ring-rose-500 focus:ring-offset-0 flex-shrink-0 ' +
                           (parent_selected ? 'border-rose-800' : 'border-stone-300') %>
                <span data-category-filter-target="parentName"
                      class="text-sm font-medium truncate flex-1 min-w-0 <%= parent_selected ? 'text-rose-900' : 'text-stone-700' %>">
                  <%= parent.name %>
                </span>
              </label>
            </div>

            <!-- Children (collapsible) — only if subcategories enabled -->
            <% if show_children %>
              <div data-category-filter-target="children"
                   class="overflow-hidden transition-all duration-200 ease-in-out"
                   style="max-height: <%= is_expanded ? '500px' : '0px' %>; opacity: <%= is_expanded ? '1' : '0' %>;">
                <div class="pl-7 pr-2 pb-2 space-y-0.5">
                  <% children.each do |child| %>
                    <%
                      child_selected = @category_ids.include?(child.id.to_s)
                      child_count = @category_counts[child.id] || 0
                    %>
                    <label class="flex items-center gap-2 py-1.5 px-2 rounded-md cursor-pointer transition-colors
                                  <%= child_selected ? 'bg-rose-100/60' : 'hover:bg-white' %>">
                      <%= check_box_tag 'category_ids[]', child.id, child_selected,
                          class: 'h-3.5 w-3.5 rounded border-2 text-rose-800 focus:ring-2 focus:ring-rose-500 focus:ring-offset-0 flex-shrink-0 ' +
                                 (child_selected ? 'border-rose-800' : 'border-stone-300') %>
                      <span class="text-sm flex-1 min-w-0 truncate <%= child_selected ? 'text-rose-800 font-medium' : 'text-stone-600' %>">
                        <%= child.name %>
                      </span>
                    </label>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- ── Price Range ── -->
  <% if fc["show_price_range"] %>
    <div data-controller="filter-section" data-filter-section-open-value="true" class="py-3 border-b border-stone-100">
      <button type="button" data-action="click->filter-section#toggle" class="w-full flex items-center justify-between mb-2 group">
        <span class="text-sm font-semibold text-stone-800">Price Range</span>
        <svg data-filter-section-target="icon" class="w-4 h-4 text-stone-400 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div data-filter-section-target="content" data-controller="price-range">
        <%= hidden_field_tag :min_price, @min_price, data: { price_range_target: 'minInput' } %>
        <%= hidden_field_tag :max_price, @max_price, data: { price_range_target: 'maxInput' } %>
        <div class="flex items-center justify-between text-xs text-stone-500 mb-2">
          <span data-price-range-target="minLabel"></span>
          <span data-price-range-target="maxLabel"></span>
        </div>
        <div class="range-slider relative h-8">
          <input type="range" min="<%= @catalog_min_price %>" max="<%= @catalog_max_price %>" step="1"
                 value="<%= (@min_price.presence || @catalog_min_price).to_i %>"
                 data-price-range-target="min"
                 data-action="input->price-range#update change->price-range#commit mousedown->price-range#activateMin touchstart->price-range#activateMin"
                 class="absolute inset-0 w-full z-20">
          <input type="range" min="<%= @catalog_min_price %>" max="<%= @catalog_max_price %>" step="1"
                 value="<%= (@max_price.presence || @catalog_max_price).to_i %>"
                 data-price-range-target="max"
                 data-action="input->price-range#update change->price-range#commit mousedown->price-range#activateMax touchstart->price-range#activateMax"
                 class="absolute inset-0 w-full">
        </div>
      </div>
    </div>
  <% end %>

  <!-- ── Color ── -->
  <% if fc["show_color"] && @facets[:colors].any? %>
    <div data-controller="filter-section" data-filter-section-open-value="true" class="py-3 border-b border-stone-100">
      <button type="button" data-action="click->filter-section#toggle" class="w-full flex items-center justify-between mb-2 group">
        <span class="text-sm font-semibold text-stone-800">Color</span>
        <svg data-filter-section-target="icon" class="w-4 h-4 text-stone-400 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div data-filter-section-target="content" class="flex flex-wrap gap-2">
        <%
          color_map = {
            "Gold" => "#D4AF37", "Silver" => "#C0C0C0", "Rose Gold" => "#B76E79",
            "White" => "#FFFFFF", "Black" => "#1a1a1a", "Green" => "#2D6A4F",
            "Red" => "#DC2626", "Blue" => "#2563EB", "Pink" => "#EC4899",
            "Multi" => "conic-gradient(red, yellow, green, blue, red)",
            "Oxidised" => "#4A4A4A", "Antique Gold" => "#C5A04C", "Copper" => "#B87333",
            "Two-Tone" => "linear-gradient(135deg, #D4AF37 50%, #C0C0C0 50%)",
            "Yellow" => "#EAB308", "Brown" => "#92400E",
            "Maroon" => "#7F1D1D", "Navy Blue" => "#1E3A5F", "Purple" => "#7C3AED",
            "Orange" => "#EA580C", "Magenta" => "#DB2777", "Teal" => "#0D9488",
            "Peach" => "#FBBF8E", "Cream" => "#FFFDD0", "Beige" => "#D4C5A9"
          }
        %>
        <% @facets[:colors].sort_by { |_, count| -count }.each do |color, count| %>
          <label class="group cursor-pointer" title="<%= color %>">
            <%= check_box_tag 'colors[]', color, @colors.include?(color), class: 'sr-only peer' %>
            <div class="flex items-center gap-1.5 px-2.5 py-1.5 border-2 rounded-full text-xs font-medium transition
                        peer-checked:border-rose-800 peer-checked:bg-rose-50 peer-checked:text-rose-800
                        border-stone-200 text-stone-600 hover:border-stone-300 group-hover:bg-stone-50">
              <span class="w-3.5 h-3.5 rounded-full border border-stone-300 flex-shrink-0"
                    style="background: <%= color_map[color] || '#ccc' %>"></span>
              <%= color %>
            </div>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- ── Material ── -->
  <% if fc["show_material"] && @facets[:materials].any? %>
    <div data-controller="filter-section" data-filter-section-open-value="<%= @materials.any? %>" class="py-3 border-b border-stone-100">
      <button type="button" data-action="click->filter-section#toggle" class="w-full flex items-center justify-between mb-2 group">
        <span class="text-sm font-semibold text-stone-800">Material</span>
        <svg data-filter-section-target="icon" class="w-4 h-4 text-stone-400 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div data-filter-section-target="content" class="space-y-1.5">
        <% @facets[:materials].sort_by { |_, count| -count }.each do |material, count| %>
          <label class="flex items-center gap-2 text-sm text-stone-600 cursor-pointer hover:text-stone-800">
            <%= check_box_tag 'materials[]', material, @materials.include?(material),
                class: 'h-3.5 w-3.5 rounded border-2 border-stone-300 text-rose-800 focus:ring-rose-500' %>
            <span class="flex-1"><%= material %></span>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- ── Gemstone / Stone Type ── -->
  <% if fc["show_stone_type"] && @facets[:gemstones].any? %>
    <div data-controller="filter-section" data-filter-section-open-value="<%= @gemstones.any? %>" class="py-3 border-b border-stone-100">
      <button type="button" data-action="click->filter-section#toggle" class="w-full flex items-center justify-between mb-2 group">
        <span class="text-sm font-semibold text-stone-800">Stone Type</span>
        <svg data-filter-section-target="icon" class="w-4 h-4 text-stone-400 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div data-filter-section-target="content" class="space-y-1.5">
        <% @facets[:gemstones].sort_by { |_, count| -count }.each do |stone, count| %>
          <label class="flex items-center gap-2 text-sm text-stone-600 cursor-pointer hover:text-stone-800">
            <%= check_box_tag 'gemstones[]', stone, @gemstones.include?(stone),
                class: 'h-3.5 w-3.5 rounded border-2 border-stone-300 text-rose-800 focus:ring-rose-500' %>
            <span class="flex-1"><%= stone %></span>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- ── Occasion ── -->
  <% if fc["show_occasion"] && @facets[:occasions].any? %>
    <div data-controller="filter-section" data-filter-section-open-value="<%= @occasions.any? %>" class="py-3 border-b border-stone-100">
      <button type="button" data-action="click->filter-section#toggle" class="w-full flex items-center justify-between mb-2 group">
        <span class="text-sm font-semibold text-stone-800">Occasion</span>
        <svg data-filter-section-target="icon" class="w-4 h-4 text-stone-400 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div data-filter-section-target="content" class="space-y-1.5">
        <% @facets[:occasions].sort_by { |_, count| -count }.each do |occasion, count| %>
          <label class="flex items-center gap-2 text-sm text-stone-600 cursor-pointer hover:text-stone-800">
            <%= check_box_tag 'occasions[]', occasion, @occasions.include?(occasion),
                class: 'h-3.5 w-3.5 rounded border-2 border-stone-300 text-rose-800 focus:ring-rose-500' %>
            <span class="flex-1"><%= occasion %></span>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- ── Discount ── -->
  <% if fc["show_discount"] %>
    <div data-controller="filter-section" data-filter-section-open-value="<%= @discount.present? %>" class="py-3 border-b border-stone-100">
      <button type="button" data-action="click->filter-section#toggle" class="w-full flex items-center justify-between mb-2 group">
        <span class="text-sm font-semibold text-stone-800">Discount</span>
        <svg data-filter-section-target="icon" class="w-4 h-4 text-stone-400 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div data-filter-section-target="content" class="space-y-1.5">
        <% [10, 20, 30, 40, 50].each do |pct| %>
          <label class="flex items-center gap-2 text-sm cursor-pointer group/opt">
            <%= radio_button_tag :discount, pct, @discount.to_i == pct,
                class: 'h-4 w-4 border-2 border-stone-300 text-rose-800 focus:ring-rose-500 focus:ring-offset-0' %>
            <span class="flex items-center gap-1.5 text-stone-600 group-hover/opt:text-stone-800">
              <svg class="w-3.5 h-3.5 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
              <%= pct %>% and above
            </span>
          </label>
        <% end %>
        <% if @discount.present? %>
          <label class="flex items-center gap-2 text-sm text-stone-400 cursor-pointer hover:text-stone-600 mt-1 pt-1 border-t border-stone-100">
            <%= radio_button_tag :discount, "", false,
                class: 'h-4 w-4 border-2 border-stone-300 text-rose-800 focus:ring-rose-500 focus:ring-offset-0' %>
            <span>Clear discount filter</span>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- ── Customer Rating ── -->
  <% if fc["show_rating"] %>
    <div data-controller="filter-section" data-filter-section-open-value="<%= @rating.present? %>" class="py-3 border-b border-stone-100">
      <button type="button" data-action="click->filter-section#toggle" class="w-full flex items-center justify-between mb-2 group">
        <span class="text-sm font-semibold text-stone-800">Customer Rating</span>
        <svg data-filter-section-target="icon" class="w-4 h-4 text-stone-400 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div data-filter-section-target="content" class="space-y-1.5">
        <% [4, 3, 2].each do |stars| %>
          <label class="flex items-center gap-2 text-sm cursor-pointer group/star">
            <%= radio_button_tag :rating, stars, @rating.to_i == stars,
                class: 'h-4 w-4 border-2 border-stone-300 text-rose-800 focus:ring-rose-500 focus:ring-offset-0' %>
            <span class="flex items-center gap-1.5">
              <span class="flex items-center">
                <% stars.times do %>
                  <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <% end %>
                <% (5 - stars).times do %>
                  <svg class="w-4 h-4 text-stone-200" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <% end %>
              </span>
              <span class="text-stone-500 text-xs group-hover/star:text-stone-700">& above</span>
            </span>
          </label>
        <% end %>
        <% if @rating.present? %>
          <label class="flex items-center gap-2 text-sm text-stone-400 cursor-pointer hover:text-stone-600 mt-1 pt-1 border-t border-stone-100">
            <%= radio_button_tag :rating, "", false,
                class: 'h-4 w-4 border-2 border-stone-300 text-rose-800 focus:ring-rose-500 focus:ring-offset-0' %>
            <span>Clear rating filter</span>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if mobile %>
    <div class="sticky bottom-0 bg-white border-t border-stone-200 pt-3 pb-2 mt-3 -mx-4 px-4">
      <div class="flex gap-3">
        <%= link_to 'Clear All', products_path, class: 'flex-1 py-2.5 text-center text-sm font-medium text-stone-600 bg-stone-100 rounded-lg hover:bg-stone-200 transition' %>
        <%= f.submit 'Apply Filters', class: 'flex-1 py-2.5 text-center text-sm font-semibold text-white bg-rose-800 rounded-lg hover:bg-rose-900 transition cursor-pointer' %>
      </div>
    </div>
  <% else %>
    <%= f.submit 'Apply Filters', class: 'hidden' %>
  <% end %>
<% end %>
