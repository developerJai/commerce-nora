<%# locals: (variant:, cart_item:) %>
<div class="flex-1 min-w-0">
  <div class="flex items-baseline gap-2">
    <span class="text-base font-semibold text-stone-900 truncate"><%= format_price(variant.price) %></span>
    <% if variant.on_sale? %>
      <span class="text-xs text-stone-400 line-through"><%= format_price(variant.compare_at_price) %></span>
      <span class="text-xs font-semibold text-emerald-700"><%= variant.discount_percentage %>% off</span>
    <% end %>
  </div>
</div>
<% if variant.in_stock? %>
  <% if cart_item.present? && cart_item.quantity > 0 %>
    <%= link_to cart_path, class: "px-6 py-2.5 bg-[#B8962E] text-white text-sm font-medium rounded-lg hover:bg-[#A6872A] transition flex items-center gap-1.5 flex-shrink-0" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
      Go to Bag
    <% end %>
  <% else %>
    <%= form_with url: add_to_cart_path(variant), method: :post, class: 'flex-shrink-0' do |f| %>
      <input type="hidden" name="variant_id" value="<%= variant.id %>">
      <input type="hidden" name="quantity" value="1">
      <input type="hidden" name="from_product_page" value="1">
      <button type="submit" class="px-6 py-2.5 bg-[#B8962E] text-white text-sm font-medium rounded-lg hover:bg-[#A6872A] transition flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        Add to Bag
      </button>
    <% end %>
  <% end %>
<% else %>
  <button disabled class="px-6 py-2.5 bg-stone-200 text-stone-500 text-sm font-medium rounded-lg cursor-not-allowed flex-shrink-0">
    Out of Stock
  </button>
<% end %>
