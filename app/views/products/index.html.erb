<% content_for(:title) { "Jewellery Collection" } %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-4 sm:py-8">
  <div class="flex flex-col lg:flex-row gap-4 sm:gap-8">
    <!-- Filters Sidebar -->
    <aside class="w-full lg:w-72 flex-shrink-0">
      <!-- Mobile Filter Toggle -->
      <button type="button" 
              onclick="document.getElementById('filters-panel').classList.toggle('hidden')"
              class="lg:hidden w-full flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-stone-200 mb-4">
        <span class="font-medium text-stone-900">Filters</span>
        <svg class="w-5 h-5 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
        </svg>
      </button>
      
      <div id="filters-panel" class="hidden lg:block bg-white rounded-lg shadow-sm border border-stone-200 p-4 sm:p-6 lg:sticky lg:top-[120px]">
        <h2 class="font-serif font-semibold text-stone-900 mb-4 pb-3 border-b border-stone-200">Filters</h2>
        
        <%= form_with url: products_path, method: :get, class: 'space-y-4 sm:space-y-6', data: { controller: 'filters', action: 'change->filters#scheduleSubmit' } do |f| %>
          <%= hidden_field_tag :sort, @sort %>

          <!-- Categories (Multi-select) -->
          <div>
            <span class="block text-sm font-medium text-stone-700 mb-2">Categories</span>
            <div class="max-h-56 overflow-auto pr-1 space-y-2">
              <% @categories.each do |category| %>
                <label class="flex items-center gap-2 text-sm text-stone-700 cursor-pointer hover:text-stone-900 transition">
                  <%= check_box_tag 'category_ids[]', category.id, @category_ids.include?(category.id.to_s),
                      class: 'h-4 w-4 rounded border-2 border-stone-300 text-rose-800 focus:ring-2 focus:ring-rose-500 focus:ring-offset-0 checked:border-rose-800 checked:bg-rose-800' %>
                  <span class="leading-snug"><%= category.name %></span>
                </label>
              <% end %>
            </div>
          </div>

          <!-- Price Range Slider -->
          <div data-controller="price-range">
            <span class="block text-sm font-medium text-stone-700 mb-2">Price Range</span>

            <%= hidden_field_tag :min_price, @min_price, data: { price_range_target: 'minInput' } %>
            <%= hidden_field_tag :max_price, @max_price, data: { price_range_target: 'maxInput' } %>

            <div class="flex items-center justify-between text-xs text-stone-500 mb-2">
              <span data-price-range-target="minLabel"></span>
              <span data-price-range-target="maxLabel"></span>
            </div>

            <div class="range-slider relative h-8">
              <input type="range"
                     min="<%= @catalog_min_price %>"
                     max="<%= @catalog_max_price %>"
                     step="1"
                     value="<%= (@min_price.presence || @catalog_min_price).to_i %>"
                     data-price-range-target="min"
                     data-action="input->price-range#update change->price-range#commit mousedown->price-range#activateMin touchstart->price-range#activateMin"
                     class="absolute inset-0 w-full z-20">

              <input type="range"
                     min="<%= @catalog_min_price %>"
                     max="<%= @catalog_max_price %>"
                     step="1"
                     value="<%= (@max_price.presence || @catalog_max_price).to_i %>"
                     data-price-range-target="max"
                     data-action="input->price-range#update change->price-range#commit mousedown->price-range#activateMax touchstart->price-range#activateMax"
                     class="absolute inset-0 w-full">
            </div>
          </div>

          <%= f.submit 'Apply Filters', class: 'hidden' %>
        <% end %>

        <% if @category_ids.any? || @min_price.present? || @max_price.present? %>
          <%= link_to 'Clear Filters', products_path, class: 'block mt-4 text-center text-sm text-rose-700 hover:text-rose-900' %>
        <% end %>
      </div>
    </aside>

    <!-- Products Grid -->
    <div class="flex-1">
      <!-- Header: Results Counter and Sort -->
      <div class="sticky top-[104px] sm:top-[112px] z-10 bg-white shadow-sm mb-4 sm:mb-6">
        <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2.5 py-3 border-b border-stone-200">
          <!-- Results Counter -->
          <div id="results-counter" class="flex items-center">
            <%= render 'results_counter' %>
          </div>

          <!-- Sort By Dropdown (Mobile) and Tabs (Desktop) -->
          <div class="flex items-center gap-2">
            <label class="text-sm font-medium text-stone-700 flex-shrink-0">Sort by:</label>
            
            <!-- Mobile: Dropdown Select -->
            <div class="sm:hidden flex-1">
              <% tabs = [
                ['Popularity', 'rating'],
                ['Price: Low to High', 'price_low'],
                ['Price: High to Low', 'price_high'],
                ['Newest Arrivals', 'newest']
              ] %>
              <select onchange="window.location.href=this.value" 
                      class="w-full px-3 py-2 text-sm border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-rose-500 bg-white">
                <% tabs.each do |label, value| %>
                  <% active = (@sort == value) || (@sort.blank? && value == 'rating') %>
                  <option value="<%= url_for(params.permit!.to_h.merge(sort: value, page: nil)) %>" <%= 'selected' if active %>>
                    <%= label %>
                  </option>
                <% end %>
              </select>
            </div>

            <!-- Desktop: Tab Navigation -->
            <div class="hidden sm:flex items-center gap-1 bg-stone-50 rounded-lg p-1">
              <% tabs.each do |label, value| %>
                <% active = (@sort == value) || (@sort.blank? && value == 'rating') %>
                <%= link_to label,
                    url_for(params.permit!.to_h.merge(sort: value, page: nil)),
                    class: "px-3 py-1.5 text-xs font-medium rounded-md transition whitespace-nowrap #{active ? 'bg-white text-rose-800 shadow-sm' : 'text-stone-600 hover:text-stone-900 hover:bg-white/50'}" %>
              <% end %>
            </div>
          </div>
        </div>
        </div>
      </div>

      <% if @products.any? %>
        <div id="infinite-scroll-wrapper" data-controller="infinite-scroll">
          <div id="products-grid" class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4 lg:gap-5">
            <%= render 'cards', products: @products %>
          </div>
          
          <div id="infinite-scroll-pagination" 
               data-next-url="<%= @pagy.next ? url_for(params.permit!.to_h.merge(page: @pagy.next)) : '' %>"
               data-has-next="<%= @pagy.next.present? %>"
               data-updated="<%= Time.current.to_i %>"
               data-infinite-scroll-target="pagination"
               style="display: none;"></div>
        </div>
      <% else %>
        <div class="text-center py-12 sm:py-16 bg-white rounded-xl border border-stone-200">
          <div class="w-16 h-16 mx-auto mb-4 bg-rose-50 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-rose-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
            </svg>
          </div>
          <h3 class="text-lg font-serif font-medium text-stone-900 mb-2">No jewellery found</h3>
          <p class="text-stone-500 text-sm mb-4">Try adjusting your search or filters</p>
          <%= link_to 'Clear Filters', products_path, class: 'inline-block px-5 py-2 bg-rose-800 text-white text-sm font-medium rounded-full hover:bg-rose-900 transition' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
