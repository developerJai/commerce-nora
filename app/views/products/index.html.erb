<% content_for(:title) { "Jewellery Collection" } %>

<%# ── Helper to build "remove this filter" URL ── %>
<% remove_filter_url = ->(param, value) {
  new_params = params.permit!.to_h.except("page")
  if new_params[param].is_a?(Array)
    new_params[param] = new_params[param].reject { |v| v.to_s == value.to_s }
    new_params.delete(param) if new_params[param].empty?
  else
    new_params.delete(param)
  end
  url_for(new_params)
} %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-1 sm:py-8 lg:pt-8" data-controller="filter-drawer">
  <div class="flex flex-col lg:flex-row gap-4 sm:gap-8">

    <!-- ═══════════════ Mobile Filter & Sort Buttons (Two Column) ═══════════════ -->
    <div class="lg:hidden fixed top-[3.5rem] left-0 right-0 z-40 bg-white pb-2 pt-2 shadow-sm" data-scroll-header-target="header">
      <%= turbo_frame_tag "mobile-filter-buttons" do %>
        <%= render 'mobile_filter_buttons' %>
      <% end %>
    </div>

    <!-- ═══════════════ Mobile Filter Drawer (Bottom Sheet) ═══════════════ -->
    <div data-filter-drawer-target="overlay" class="hidden fixed inset-0 bg-black/40 z-40 lg:hidden" data-action="click->filter-drawer#closeAny"></div>
    <div data-filter-drawer-target="drawer" class="fixed left-0 right-0 bottom-0 max-h-[85vh] bg-white z-50 shadow-2xl transform translate-y-full transition-transform duration-300 ease-out lg:hidden overflow-hidden rounded-t-3xl pb-[max(env(safe-area-inset-bottom),16px)]">
      <div class="sticky top-0 bg-white border-b border-stone-200 px-4 py-3 z-10">
        <div class="w-12 h-1 bg-stone-300 rounded-full mx-auto mb-3"></div>
        <div class="flex items-center justify-between">
          <h2 class="font-serif font-semibold text-stone-900 text-lg">Filters</h2>
          <button type="button" data-action="click->filter-drawer#close" class="p-2 text-stone-400 hover:text-stone-600">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      </div>
      <div class="p-4 overflow-y-auto overscroll-contain" style="max-height: calc(85vh - 130px); touch-action: pan-y;">
        <%= render 'filter_form', remove_filter_url: remove_filter_url, mobile: true %>
      </div>
    </div>
    
    <!-- ═══════════════ Mobile Sort Drawer (Bottom Sheet) ═══════════════ -->
    <div data-filter-drawer-target="sortDrawer" class="fixed left-0 right-0 bottom-0 max-h-[80vh] bg-white z-50 shadow-2xl transform translate-y-full transition-transform duration-300 ease-out lg:hidden rounded-t-3xl pb-[max(env(safe-area-inset-bottom),16px)]">
      <div class="px-4 py-3">
        <div class="w-12 h-1 bg-stone-300 rounded-full mx-auto mb-3"></div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-serif font-semibold text-stone-900 text-lg">Sort By</h2>
          <button type="button" data-action="click->filter-drawer#closeSort" class="p-2 text-stone-400 hover:text-stone-600">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="space-y-2 pb-4 overflow-y-auto overscroll-contain" style="max-height: calc(80vh - 150px); touch-action: pan-y;">
          <% tabs = [
            ['Popularity', 'rating'],
            ['Price: Low to High', 'price_low'],
            ['Price: High to Low', 'price_high'],
            ['Discount', 'discount'],
            ['Newest First', 'newest']
          ] %>
          <% tabs.each do |label, value| %>
            <% active = (@sort == value) || (@sort.blank? && value == 'rating') %>
            <%= link_to label,
                url_for(params.permit!.to_h.merge(sort: value, page: nil)),
                data: { turbo_frame: '_top', action: 'click->filter-drawer#closeSort' },
                class: "block px-4 py-3 rounded-xl border transition #{active ? 'bg-rose-50 border-rose-800 text-rose-900 font-semibold' : 'bg-white border-stone-200 text-stone-700 hover:bg-stone-50'}" %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- ═══════════════ Desktop Sidebar ═══════════════ -->
    <aside class="hidden lg:block w-72 flex-shrink-0">
      <div class="bg-white rounded-xl shadow-sm border border-stone-200 p-5 lg:sticky lg:top-[120px] max-h-[calc(100vh-140px)] overflow-y-auto hide-scrollbar">
        <div class="flex justify-between items-center mb-4 pb-3 border-b border-stone-200">
          <h2 class="font-serif font-semibold text-stone-900">Filters</h2>
          <% if @active_filters.any? %>
            <%= link_to 'Clear all', products_path, class: 'text-xs text-stone-500 hover:text-rose-700 underline' %>
          <% end %>
        </div>
        <%= render 'filter_form', remove_filter_url: remove_filter_url %>
      </div>
    </aside>

    <!-- ═══════════════ Products Grid ═══════════════ -->
    <div class="flex-1 min-w-0">
      <%= turbo_frame_tag "products-content", data: { turbo_action: "advance" } do %>
        <!-- Spacer for fixed mobile filter bar -->
        <div class="lg:hidden h-16"></div>
      <!-- Header: Results Counter (Desktop Sort Only) -->
      <div class="hidden sm:block sticky top-[60px] z-20 bg-white/95 backdrop-blur-sm border-b border-stone-200 mb-4 sm:mb-5">
        <div class="px-4 sm:px-5 py-2.5">
          <div class="flex items-center justify-between gap-3">
            <div id="results-counter" class="flex items-center">
              <%= render 'results_counter' %>
            </div>
            <div class="flex items-center gap-2">
              <label class="text-xs font-medium text-stone-500 flex-shrink-0">Sort by:</label>
              <% tabs = [
                ['Popularity', 'rating'],
                ['Price: Low', 'price_low'],
                ['Price: High', 'price_high'],
                ['Discount', 'discount'],
                ['Newest', 'newest']
              ] %>
              <!-- Desktop: Tabs -->
              <div class="flex items-center gap-0.5 bg-stone-100 rounded-lg p-0.5">
                <% tabs.each do |label, value| %>
                  <% active = (@sort == value) || (@sort.blank? && value == 'rating') %>
                  <%= link_to label,
                      url_for(params.permit!.to_h.merge(sort: value, page: nil)),
                      class: "px-2.5 py-1 text-xs font-medium rounded-md transition whitespace-nowrap #{active ? 'bg-white text-rose-700 shadow-sm' : 'text-stone-600 hover:text-stone-900 hover:bg-white/60'}" %>
                <% end %>
              </div>
            </div>
          </div>

          <%# Active Filter Chips %>
          <% if @active_filters.any? %>
            <div class="flex flex-wrap items-center gap-2 mt-3 pt-3 border-t border-stone-100">
              <span class="text-xs text-stone-500 mr-1">Active filters:</span>
              <% @active_filters.each do |filter| %>
                <%= link_to remove_filter_url.call(filter[:param], filter[:value]),
                    class: "inline-flex items-center gap-1 px-2.5 py-1 bg-rose-50 text-rose-800 text-xs font-medium rounded-full hover:bg-rose-100 transition",
                    data: { turbo_frame: '_top' } do %>
                  <%= filter[:label] %>
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                <% end %>
              <% end %>
              <%= link_to 'Clear all', products_path, class: 'text-xs text-stone-400 hover:text-rose-700 underline ml-1', data: { turbo_frame: '_top' } %>
            </div>
          <% end %>
        </div>
      </div>

      <% if @products.any? %>
        <div id="infinite-scroll-wrapper" data-controller="infinite-scroll">
          <div id="products-grid" class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 gap-2 sm:gap-3 md:gap-4">
            <%= render 'cards', products: @products %>
          </div>

          <div id="infinite-scroll-pagination"
               data-next-url="<%= @pagy.next ? url_for(params.permit!.to_h.merge(page: @pagy.next)) : '' %>"
               data-has-next="<%= @pagy.next.present? %>"
               data-updated="<%= Time.current.to_i %>"
               data-infinite-scroll-target="pagination"
               style="display: none;"></div>
        </div>
      <% else %>
        <div class="text-center py-12 sm:py-16 bg-white rounded-xl border border-stone-200">
          <div class="w-16 h-16 mx-auto mb-4 bg-rose-50 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-rose-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
            </svg>
          </div>
          <h3 class="text-lg font-serif font-medium text-stone-900 mb-2">No products found</h3>
          <p class="text-stone-500 text-sm mb-4">Try adjusting your filters to find what you're looking for</p>
          <%= link_to 'Clear All Filters', products_path, data: { turbo_frame: "_top" }, class: 'inline-block px-5 py-2 bg-rose-800 text-white text-sm font-medium rounded-full hover:bg-rose-900 transition' %>
        </div>
      <% end %>
      <% end %>
    </div>
  </div>
</div>
