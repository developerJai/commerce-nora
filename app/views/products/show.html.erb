<% content_for(:title) { "Buy #{@product.name} Online at Best Price" } %>
<% content_for(:native_title) { @product.name.truncate(25) } %>
<% content_for(:meta_description) { truncate(@product.description.to_s, length: 120).presence&.+(". ").to_s + "Buy #{@product.name} online at Noralooks starting #{format_price(@product.min_price)}. #{@product.exchange_in_days.to_i > 0 ? "#{@product.exchange_in_days}-day exchange." : ''} Free shipping above #{format_price(free_delivery_threshold)}. Quality checked. Shop now!" } %>
<% content_for(:meta_keywords) { [@product.category&.name, "buy #{@product.name.downcase}", "#{@product.name.downcase} online", "#{@product.name.downcase} price", "#{@product.category&.name&.downcase} online", "fashion jewellery", "buy #{@product.category&.name&.downcase} online India"].compact } %>
<% content_for(:og_type) { 'product' } %>
<% og_image = @selected_variant&.image&.attached? ? @selected_variant.image : (@product.images.attached? ? @product.images.first : nil) %>
<% content_for(:og_image) { url_for(og_image) } if og_image %>
<% default_variant = @selected_variant %>

<% content_for(:head) do %>
  <!-- Product Schema - JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "<%= j @product.name %>",
    "description": "<%= j truncate(@product.description.to_s, length: 500) %>",
    <% if og_image %>"image": "<%= url_for(og_image) %>",<% end %>
    "sku": "<%= default_variant&.sku.presence || @product.sku.presence || '' %>",
    "brand": {
      "@type": "Brand",
      "name": "Noralooks"
    },
    "category": "<%= j @product.category&.name.to_s %>",
    "url": "<%= request.original_url.split('?').first %>",
    <% if @product.average_rating > 0 %>
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "<%= @product.average_rating.round(1) %>",
      "reviewCount": "<%= @product.ratings_count %>",
      "bestRating": "5",
      "worstRating": "1"
    },
    <% end %>
    <% if @reviews.any? %>
    "review": [
      <% @reviews.first(5).each_with_index do |review, idx| %>
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "<%= j review.customer_name %>" },
        "datePublished": "<%= review.created_at.iso8601 %>",
        "reviewRating": {
          "@type": "Rating",
          "ratingValue": "<%= review.rating %>",
          "bestRating": "5"
        }<%= ", \"reviewBody\": \"#{j truncate(review.body.to_s, length: 200)}\"" if review.body.present? %>
      }<%= ',' unless idx == [@reviews.first(5).size - 1, @reviews.size - 1].min %>
      <% end %>
    ],
    <% end %>
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "INR",
      "lowPrice": "<%= @variants.map(&:price).compact.min %>",
      "highPrice": "<%= @variants.map(&:price).compact.max %>",
      "offerCount": "<%= @variants.count %>",
      "availability": "<%= @product.in_stock? ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock' %>",
      "seller": {
        "@type": "Organization",
        "name": "Noralooks"
      },
      "url": "<%= request.original_url.split('?').first %>"
    }
  }
  </script>

  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "<%= root_url %>"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Jewellery",
        "item": "<%= products_url %>"
      }<%= raw(",") if @product.category %>
      <% if @product.category %>
      {
        "@type": "ListItem",
        "position": 3,
        "name": "<%= j @product.category.name %>",
        "item": "<%= category_url(@product.category.slug) %>"
      },
      {
        "@type": "ListItem",
        "position": 4,
        "name": "<%= j @product.name %>"
      }
      <% end %>
    ]
  }
  </script>
<% end %>

<div class="max-w-7xl mx-auto px-3 sm:px-4 md:px-6 lg:px-8 py-3 sm:py-4 md:py-6 pb-24 sm:pb-6" data-controller="product-gallery product-variant product-page">
  <!-- Breadcrumb with back button -->
  <nav class="mb-2 sm:mb-4 md:mb-6 flex items-center gap-1.5 sm:gap-0 overflow-hidden" aria-label="Breadcrumb">
    <a href="<%= products_path %>" onclick="if (window.history.length > 1) { window.history.back(); return false; }" class="sm:hidden flex-shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-full hover:bg-stone-100 active:bg-stone-200 transition text-stone-600">
      <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
    </a>
    <ol class="flex items-center gap-1.5 sm:gap-2 text-[10px] sm:text-xs md:text-sm whitespace-nowrap overflow-hidden text-ellipsis">
      <li class="hidden sm:inline"><%= link_to 'Home', root_path, class: 'text-stone-500 hover:text-[#D4AF37]' %></li>
      <li class="hidden sm:inline"><span class="text-stone-300">/</span></li>
      <li><%= link_to 'Shop', products_path, class: 'text-stone-500 hover:text-[#D4AF37] flex-shrink-0' %></li>
      <% if @product.category %>
        <li><span class="text-stone-300">/</span></li>
        <li class="truncate max-w-[80px] sm:max-w-none"><%= link_to @product.category.name, category_path(@product.category.slug), class: 'text-stone-500 hover:text-[#D4AF37]' %></li>
      <% end %>
      <li><span class="text-stone-300">/</span></li>
      <li class="text-stone-900 font-medium truncate max-w-[100px] sm:max-w-[200px] md:max-w-[250px]"><%= @product.name %></li>
    </ol>
  </nav>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 sm:gap-6 md:gap-8 lg:gap-10 items-start">
    <!-- Product Images -->
    <div class="md:col-span-6">
      <div>
        <div class="flex flex-row gap-3">
          <% variant_image = default_variant&.image&.attached? ? default_variant.image : nil %>
          <% gallery_images = [] %>
          <% gallery_images << variant_image if variant_image %>
          <% gallery_images.concat(@product.images.to_a) if @product.images.attached? %>

          <!-- Vertical Thumbnails (Desktop) -->
          <% if gallery_images.count > 1 %>
            <div class="hidden sm:block w-16 md:w-20 flex-shrink-0">
              <div class="flex flex-col gap-1.5 md:gap-2">
                <% gallery_images.each_with_index do |image, index| %>
                  <button type="button"
                          data-action="click->product-gallery#selectImage"
                          data-product-gallery-index-param="<%= index %>"
                          class="w-16 h-16 md:w-20 md:h-20 bg-stone-100 rounded-md md:rounded-lg overflow-hidden border-2 transition <%= index == 0 ? 'border-[#D4AF37]' : 'border-stone-200 hover:border-[#D4AF37]' %>"
                          data-product-gallery-target="thumbnail">
                    <%= image_tag image, class: 'w-full h-full object-cover' %>
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>

          <!-- Main Image with Zoom -->
          <div class="flex-1 min-w-0">
            <div class="aspect-square bg-stone-100 rounded-lg md:rounded-xl overflow-hidden relative group cursor-zoom-in" data-product-gallery-target="zoomContainer">
              <% if gallery_images.any? %>
                <% gallery_images.each_with_index do |image, index| %>
                  <div class="absolute inset-0 transition-opacity duration-300 <%= index == 0 ? 'opacity-100' : 'opacity-0' %>" data-product-gallery-target="slide">
                    <%= image_tag image, alt: "#{@product.name} - #{@product.category&.name || 'Fashion Jewellery'} | Noralooks#{index > 0 ? " - Image #{index + 1}" : ''}", class: 'w-full h-full object-cover transition-transform duration-200', data: { product_gallery_target: 'zoomImage' } %>
                  </div>
                <% end %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-rose-50 to-amber-50">
                  <svg class="w-20 h-20 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
                  </svg>
                </div>
              <% end %>

              <!-- Badges -->
              <div class="absolute top-3 left-3 flex flex-col gap-1 z-[1]">
                <% if @product.featured? %>
                  <span class="px-2.5 py-1 bg-rose-800 text-white text-xs font-medium rounded">Bestseller</span>
                <% end %>
                <% if default_variant&.on_sale? %>
                  <span class="px-2.5 py-1 bg-amber-500 text-white text-xs font-bold rounded"><%= default_variant.discount_percentage %>% OFF</span>
                <% end %>
              </div>
            </div>

            <!-- Mobile Thumbnails (Horizontal) -->
            <% if gallery_images.count > 1 %>
              <div class="sm:hidden flex gap-1.5 mt-2 overflow-x-auto hide-scrollbar pb-1">
                <% gallery_images.each_with_index do |image, index| %>
                  <button type="button"
                          data-action="click->product-gallery#selectImage"
                          data-product-gallery-index-param="<%= index %>"
                          class="w-14 h-14 flex-shrink-0 bg-stone-100 rounded-md overflow-hidden border-2 transition <%= index == 0 ? 'border-[#D4AF37]' : 'border-stone-200' %>"
                          data-product-gallery-target="thumbnail">
                    <%= image_tag image, class: 'w-full h-full object-cover' %>
                  </button>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Product Info -->
    <div class="md:col-span-6">
      <div class="bg-white rounded-none sm:rounded-xl md:rounded-2xl border-0 sm:border border-stone-200 p-4 sm:p-5 md:p-6">
        <!-- Title & Share -->
        <div class="flex items-start justify-between gap-3">
          <div>
            <h1 class="text-lg sm:text-xl md:text-2xl font-sans font-semibold text-stone-900 leading-tight"><%= @product.name %></h1>
            <% if @product.short_description.present? %>
              <p class="text-xs sm:text-sm text-stone-500 mt-1"><%= @product.short_description %></p>
            <% end %>
          </div>
          <button type="button" onclick="navigator.share ? navigator.share({title: '<%= j @product.name %>', url: window.location.href}) : navigator.clipboard.writeText(window.location.href).then(() => this.querySelector('span').textContent = 'Copied!')" class="flex-shrink-0 p-2 text-stone-400 hover:text-[#D4AF37] transition" title="Share">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z"/>
            </svg>
          </button>
        </div>

        <!-- Rating Summary -->
        <% if @product.average_rating > 0 %>
          <div class="flex items-center gap-2 sm:gap-3 mt-2 sm:mt-3">
            <div class="flex items-center gap-1 px-2 sm:px-2.5 py-0.5 sm:py-1 bg-emerald-600 text-white rounded">
              <span class="font-semibold text-xs sm:text-sm"><%= @product.average_rating.round(1) %></span>
              <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            </div>
            <a href="#reviews" data-turbo="false" class="text-xs sm:text-sm text-stone-500 hover:text-[#D4AF37]">
              <%= @product.ratings_count %> <%= 'Review'.pluralize(@product.ratings_count) %>
            </a>
          </div>
        <% end %>

        <!-- Price Section -->
        <div class="mt-3 sm:mt-4 pb-3 sm:pb-4 border-b border-stone-200">
          <div class="flex items-baseline gap-2 sm:gap-3 flex-wrap" data-product-variant-target="priceSection">
            <span class="text-xl sm:text-2xl md:text-3xl font-semibold text-stone-900" data-product-variant-target="price">
              <%= format_price(default_variant&.price) %>
            </span>
            <% if default_variant&.on_sale? %>
              <span class="text-base sm:text-lg text-stone-400 line-through" data-product-variant-target="comparePrice">
                <%= format_price(default_variant.compare_at_price) %>
              </span>
              <span class="px-1.5 sm:px-2 py-0.5 bg-emerald-100 text-emerald-800 text-xs sm:text-sm font-medium rounded" data-product-variant-target="discount">
                Save <%= default_variant.discount_percentage %>%
              </span>
            <% else %>
              <span class="hidden text-base sm:text-lg text-stone-400 line-through" data-product-variant-target="comparePrice"></span>
              <span class="hidden px-1.5 sm:px-2 py-0.5 bg-emerald-100 text-emerald-800 text-xs sm:text-sm font-medium rounded" data-product-variant-target="discount"></span>
            <% end %>
          </div>
          <p class="text-[10px] sm:text-xs text-stone-500 mt-0.5 sm:mt-1">Inclusive of all taxes</p>
          <% if default_variant&.price.to_f >= free_delivery_threshold %>
            <p class="text-[10px] sm:text-xs text-emerald-600 font-medium mt-1 flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              FREE Delivery
            </p>
          <% else %>
            <p class="text-[10px] sm:text-xs text-stone-500 mt-1">Free delivery on orders above <%= format_price(free_delivery_threshold) %></p>
          <% end %>
        </div>

        <!-- Available Offers -->
        <% if @available_coupons.any? %>
          <div class="mt-3 sm:mt-4 pb-3 sm:pb-4 border-b border-stone-200">
            <h3 class="text-xs sm:text-sm font-semibold text-stone-900 mb-2 flex items-center gap-1.5">
              <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
              Available Offers
            </h3>
            <div class="space-y-2.5 sm:space-y-2">
              <% @available_coupons.each do |coupon| %>
                <div class="flex items-start gap-2 text-xs sm:text-sm">
                  <span class="mt-1 sm:mt-0.5 w-1.5 h-1.5 rounded-full bg-emerald-500 flex-shrink-0"></span>
                  <div class="text-stone-600">
                    <p>
                      <% if coupon.percentage? %>
                        Get <span class="font-semibold text-stone-900"><%= coupon.discount_value.to_i %>% off</span><%= " (up to #{format_price(coupon.maximum_discount)})" if coupon.maximum_discount.present? %>
                      <% else %>
                        Get <span class="font-semibold text-stone-900"><%= format_price(coupon.discount_value) %> off</span>
                      <% end %>
                      <% if coupon.minimum_order_amount.to_f > 0 %>
                        <br class="sm:hidden">on orders above <%= format_price(coupon.minimum_order_amount) %>
                      <% end %>
                    </p>
                    <p class="mt-0.5">Use code <button type="button" onclick="navigator.clipboard.writeText('<%= coupon.code %>'); this.textContent='Copied!'; setTimeout(() => this.textContent='<%= coupon.code %>', 2000)" class="font-bold text-[#B8962E] border border-dashed border-[#D4AF37]/40 px-1.5 py-0.5 rounded bg-amber-50 hover:bg-amber-100 transition cursor-pointer"><%= coupon.code %></button></p>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Variant Selection -->
        <% if @variants.count > 1 %>
          <div class="mt-3 sm:mt-4">
            <p class="text-xs sm:text-sm font-medium text-stone-700 mb-2 sm:mb-3">
              Select: <span class="text-stone-900" data-product-variant-target="selectedName"><%= default_variant&.name %></span>
            </p>
            <div class="flex flex-wrap gap-2">
              <% @variants.each do |variant| %>
                <button type="button"
                        data-action="click->product-variant#selectVariant"
                        data-product-variant-target="option"
                        data-variant-slug="<%= variant.name.parameterize %>"
                        class="px-3 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm font-medium rounded-md sm:rounded-lg border-2 transition <%= variant.id == @selected_variant.id ? 'border-[#D4AF37] bg-amber-50 text-[#B8962E]' : 'border-stone-200 text-stone-700 hover:border-[#D4AF37]' %> <%= variant.in_stock? ? '' : 'opacity-50' %>">
                  <%= variant.name %>
                  <% unless variant.in_stock? %>
                    <span class="block text-[10px] text-stone-500 font-normal">Out of Stock</span>
                  <% end %>
                </button>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Stock Status -->
        <div class="mt-3 sm:mt-4" data-product-variant-target="stockStatus">
          <% if default_variant&.in_stock? %>
            <% if default_variant.low_stock? %>
              <p class="text-xs sm:text-sm text-amber-600 flex items-center gap-1 sm:gap-1.5">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                Hurry! Only <%= default_variant.stock_quantity %> left in stock
              </p>
            <% else %>
              <p class="text-xs sm:text-sm text-emerald-600 flex items-center gap-1 sm:gap-1.5">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                In Stock
              </p>
            <% end %>
          <% else %>
            <p class="text-xs sm:text-sm text-stone-500">Currently unavailable</p>
          <% end %>
        </div>

        <!-- Action Buttons -->
        <div class="mt-4 sm:mt-6">
          <div class="flex items-center gap-2 sm:gap-3">
            <% if @selected_variant&.in_stock? %>
              <div id="product-cart-controls-<%= @selected_variant.id %>" class="flex-1">
                <%= render 'products/cart_controls', variant: @selected_variant, cart_item: @cart_item %>
              </div>
            <% else %>
              <button disabled class="flex-1 h-11 sm:h-12 px-4 sm:px-6 bg-stone-200 text-stone-500 text-sm sm:text-base font-medium rounded-lg cursor-not-allowed">
                Out of Stock
              </button>
            <% end %>

            <div id="wishlist-toggle-<%= @product.id %>">
              <%= render 'shared/wishlist_toggle', product: @product, icon_only: true, variant_id: @selected_variant&.id %>
            </div>
          </div>
        </div>

        <!-- Delivery Info -->
        <div class="mt-4 sm:mt-5 p-3 sm:p-4 bg-stone-50 rounded-lg sm:rounded-xl">
          <div class="flex items-start gap-3 text-xs sm:text-sm">
            <svg class="w-5 h-5 text-stone-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H6.375c-.621 0-1.125-.504-1.125-1.125V14.25m0 0h13.5m-13.5 0V4.875c0-.621.504-1.125 1.125-1.125h8.25c.621 0 1.125.504 1.125 1.125v9.375m-4.5 4.5h4.5m0 0h2.25a1.125 1.125 0 001.125-1.125v-4.5A1.125 1.125 0 0019.125 9h-2.25a1.125 1.125 0 00-1.125 1.125v8.625"/>
            </svg>
            <div class="flex-1">
              <p class="font-medium text-stone-900">Delivery in 3–5 business days</p>
              <p class="text-stone-500 mt-0.5">Dispatched within 24 hours</p>
              <div class="flex items-center gap-3 mt-2">
                <% if StoreSetting.instance.cod_enabled? %>
                  <span class="inline-flex items-center gap-1 text-[10px] sm:text-xs text-stone-600">
                    <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    COD Available
                  </span>
                <% end %>
                <span class="inline-flex items-center gap-1 text-[10px] sm:text-xs text-stone-600">
                  <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  Secure Payments
                </span>
              </div>
            </div>
          </div>
        </div>

        <!-- Trust Badges -->
        <% exchange_days = @product.exchange_in_days.to_i
           return_days   = @product.return_in_days.to_i %>
        <div class="mt-4 sm:mt-5 grid grid-cols-2 gap-2 sm:gap-3">
          <div class="flex items-center gap-1.5 sm:gap-2 p-2 sm:p-3 bg-stone-50 rounded-md sm:rounded-lg">
            <svg class="w-4 h-4 sm:w-5 sm:h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <div>
              <p class="text-[10px] sm:text-xs font-medium text-stone-900">Certified Quality</p>
              <p class="text-[9px] sm:text-[10px] text-stone-500">Checked Before Dispatch</p>
            </div>
          </div>
          <div class="flex items-center gap-1.5 sm:gap-2 p-2 sm:p-3 bg-stone-50 rounded-md sm:rounded-lg">
            <svg class="w-4 h-4 sm:w-5 sm:h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div>
              <p class="text-[10px] sm:text-xs font-medium text-stone-900">24-Hour Dispatch</p>
              <p class="text-[9px] sm:text-[10px] text-stone-500">Fast Processing</p>
            </div>
          </div>
          <% if exchange_days > 0 %>
            <div class="flex items-center gap-1.5 sm:gap-2 p-2 sm:p-3 bg-stone-50 rounded-md sm:rounded-lg">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              <div>
                <p class="text-[10px] sm:text-xs font-medium text-stone-900"><%= exchange_days %>-Day Exchange</p>
                <p class="text-[9px] sm:text-[10px] text-stone-500">Easy Replacement</p>
              </div>
            </div>
          <% else %>
            <div class="flex items-center gap-1.5 sm:gap-2 p-2 sm:p-3 bg-stone-50 rounded-md sm:rounded-lg">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              <div>
                <p class="text-[10px] sm:text-xs font-medium text-stone-900">Secure Payments</p>
                <p class="text-[9px] sm:text-[10px] text-stone-500">Safe Checkout</p>
              </div>
            </div>
          <% end %>
          <% if return_days > 0 %>
            <div class="flex items-center gap-1.5 sm:gap-2 p-2 sm:p-3 bg-stone-50 rounded-md sm:rounded-lg">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 15v-1a4 4 0 00-4-4H8m0 0l3 3m-3-3l3-3m9 14V5a2 2 0 00-2-2H6a2 2 0 00-2 2v16l4-2 4 2 4-2 4 2z"/></svg>
              <div>
                <p class="text-[10px] sm:text-xs font-medium text-stone-900"><%= return_days %>-Day Returns</p>
                <p class="text-[9px] sm:text-[10px] text-stone-500">Easy Refund</p>
              </div>
            </div>
          <% else %>
            <div class="flex items-center gap-1.5 sm:gap-2 p-2 sm:p-3 bg-stone-50 rounded-md sm:rounded-lg">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
              <div>
                <p class="text-[10px] sm:text-xs font-medium text-stone-900">Gift-Ready Packaging</p>
                <p class="text-[9px] sm:text-[10px] text-stone-500">Signature Noralooks Finish</p>
              </div>
            </div>
          <% end %>
        </div>

      </div>
    </div>
  </div>

  <!-- Product Information Sections (Accordion) -->
  <div class="mt-4 sm:mt-6 md:mt-8 bg-white rounded-none sm:rounded-xl md:rounded-2xl border-0 sm:border border-stone-200 divide-y divide-stone-200">

    <!-- Description -->
    <% if @product.description.present? %>
      <details open class="group">
        <summary class="flex items-center justify-between px-4 sm:px-5 md:px-6 py-3.5 sm:py-4 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
          <h2 class="text-sm sm:text-base font-semibold text-stone-900">Description</h2>
          <svg class="w-5 h-5 text-stone-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-4 sm:px-5 md:px-6 pb-4 sm:pb-5 md:pb-6">
          <div class="prose prose-sm prose-stone max-w-none text-stone-600 leading-relaxed">
            <%= simple_format(@product.description) %>
          </div>
        </div>
      </details>
    <% end %>

    <!-- Product Details -->
    <details open class="group">
      <summary class="flex items-center justify-between px-4 sm:px-5 md:px-6 py-3.5 sm:py-4 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
        <h2 class="text-sm sm:text-base font-semibold text-stone-900">Product Details</h2>
        <svg class="w-5 h-5 text-stone-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </summary>
      <div class="px-4 sm:px-5 md:px-6 pb-4 sm:pb-5 md:pb-6">
        <table class="w-full text-xs sm:text-sm">
          <tbody class="divide-y divide-stone-100">
            <tr>
              <td class="py-2.5 sm:py-3 pr-4 text-stone-500 w-2/5 align-top">SKU</td>
              <td class="py-2.5 sm:py-3 font-medium text-stone-900"><%= default_variant&.sku.presence || @product.sku.presence || 'N/A' %></td>
            </tr>
            <% if @product.category %>
              <tr>
                <td class="py-2.5 sm:py-3 pr-4 text-stone-500 align-top">Category</td>
                <td class="py-2.5 sm:py-3 font-medium text-stone-900"><%= @product.category.name %></td>
              </tr>
            <% end %>
            <% @product.filled_attributes.each do |label, value| %>
              <tr>
                <td class="py-2.5 sm:py-3 pr-4 text-stone-500 align-top"><%= label %></td>
                <td class="py-2.5 sm:py-3 font-medium text-stone-900"><%= value %></td>
              </tr>
            <% end %>
            <% if default_variant %>
              <% default_variant.variant_attribute_definitions.each do |defn| %>
                <% val = default_variant.attribute_value(defn[:key]) %>
                <% if val.present? %>
                  <tr>
                    <td class="py-2.5 sm:py-3 pr-4 text-stone-500 align-top"><%= defn[:label] %></td>
                    <td class="py-2.5 sm:py-3 font-medium text-stone-900"><%= val %></td>
                  </tr>
                <% end %>
              <% end %>
              <% if default_variant.weight.present? && default_variant.weight > 0 %>
                <tr>
                  <td class="py-2.5 sm:py-3 pr-4 text-stone-500 align-top">Weight</td>
                  <td class="py-2.5 sm:py-3 font-medium text-stone-900"><%= default_variant.weight %> g</td>
                </tr>
              <% end %>
            <% end %>
            <% if @variants.count > 1 %>
              <tr>
                <td class="py-2.5 sm:py-3 pr-4 text-stone-500 align-top">Variants</td>
                <td class="py-2.5 sm:py-3 font-medium text-stone-900"><%= @variants.count %> options available</td>
              </tr>
            <% end %>
            <% if @product.country_of_origin.present? %>
              <tr>
                <td class="py-2.5 sm:py-3 pr-4 text-stone-500 align-top">Country of Origin</td>
                <td class="py-2.5 sm:py-3 font-medium text-stone-900"><%= @product.country_of_origin %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </details>

    <!-- Shipping & Returns -->
    <details class="group">
      <summary class="flex items-center justify-between px-4 sm:px-5 md:px-6 py-3.5 sm:py-4 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
        <h2 class="text-sm sm:text-base font-semibold text-stone-900">Shipping & Returns</h2>
        <svg class="w-5 h-5 text-stone-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </summary>
      <div class="px-4 sm:px-5 md:px-6 pb-4 sm:pb-5 md:pb-6">
        <div class="space-y-4 sm:space-y-5">
          <!-- Shipping -->
          <div class="flex gap-3">
            <div class="flex-shrink-0 w-9 h-9 rounded-full bg-sky-50 flex items-center justify-center">
              <svg class="w-4.5 h-4.5 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H6.375c-.621 0-1.125-.504-1.125-1.125V14.25m0 0h13.5m-13.5 0V4.875c0-.621.504-1.125 1.125-1.125h8.25c.621 0 1.125.504 1.125 1.125v9.375"/></svg>
            </div>
            <div class="text-xs sm:text-sm">
              <p class="font-medium text-stone-900 mb-0.5">Shipping</p>
              <p class="text-stone-600 leading-relaxed">Free shipping on orders above <%= format_price(free_delivery_threshold) %>. Orders below this are charged <%= format_price(delivery_charge) %>. Dispatched within 24 hours, delivered in 3–5 business days.</p>
            </div>
          </div>

          <!-- Exchange -->
          <% if exchange_days > 0 %>
            <div class="flex gap-3">
              <div class="flex-shrink-0 w-9 h-9 rounded-full bg-amber-50 flex items-center justify-center">
                <svg class="w-4.5 h-4.5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              </div>
              <div class="text-xs sm:text-sm">
                <p class="font-medium text-stone-900 mb-0.5"><%= exchange_days %>-Day Easy Exchange</p>
                <p class="text-stone-600 leading-relaxed">If the product doesn't meet your expectations, request an exchange within <%= exchange_days %> days of delivery. We'll replace it at no extra cost.</p>
              </div>
            </div>
          <% end %>

          <!-- Returns -->
          <% if return_days > 0 %>
            <div class="flex gap-3">
              <div class="flex-shrink-0 w-9 h-9 rounded-full bg-emerald-50 flex items-center justify-center">
                <svg class="w-4.5 h-4.5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 15v-1a4 4 0 00-4-4H8m0 0l3 3m-3-3l3-3m9 14V5a2 2 0 00-2-2H6a2 2 0 00-2 2v16l4-2 4 2 4-2 4 2z"/></svg>
              </div>
              <div class="text-xs sm:text-sm">
                <p class="font-medium text-stone-900 mb-0.5"><%= return_days %>-Day Returns</p>
                <p class="text-stone-600 leading-relaxed">Not satisfied? Return within <%= return_days %> days for an easy refund. Product must be in original condition with tags attached.</p>
              </div>
            </div>
          <% end %>

          <% if exchange_days == 0 && return_days == 0 %>
            <div class="flex gap-3">
              <div class="flex-shrink-0 w-9 h-9 rounded-full bg-stone-100 flex items-center justify-center">
                <svg class="w-4.5 h-4.5 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/></svg>
              </div>
              <div class="text-xs sm:text-sm">
                <p class="font-medium text-stone-900 mb-0.5">No Returns or Exchanges</p>
                <p class="text-stone-600 leading-relaxed">This product is not eligible for returns or exchanges. Please review product details carefully before purchasing.</p>
              </div>
            </div>
          <% end %>

          <!-- Quality -->
          <div class="flex gap-3">
            <div class="flex-shrink-0 w-9 h-9 rounded-full bg-amber-50 flex items-center justify-center">
              <svg class="w-4.5 h-4.5 text-[#D4AF37]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <div class="text-xs sm:text-sm">
              <p class="font-medium text-stone-900 mb-0.5">Quality Assurance</p>
              <p class="text-stone-600 leading-relaxed">Every product is inspected and quality-checked before dispatch. 100% certified quality guaranteed.</p>
            </div>
          </div>
        </div>
      </div>
    </details>

  </div>

  <!-- Reviews Section -->
  <section id="reviews" class="mt-4 sm:mt-6 md:mt-8 bg-white rounded-none sm:rounded-xl md:rounded-2xl border-0 sm:border border-stone-200 p-4 sm:p-5 md:p-6">
    <div class="sm:flex sm:items-start sm:justify-between mb-4 sm:mb-6">
      <div>
        <h2 class="text-base sm:text-lg md:text-xl font-sans font-semibold text-stone-900">Customer Reviews</h2>
        <% if @product.average_rating > 0 %>
          <div class="flex items-center gap-3 mt-2">
            <div class="flex items-center gap-1">
              <% 5.times do |i| %>
                <svg class="w-5 h-5 <%= i < @product.average_rating.round ? 'text-amber-400' : 'text-stone-200' %>" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              <% end %>
            </div>
            <span class="text-stone-600 text-sm">
              <%= @product.average_rating.round(1) %> out of 5 (<%= @product.ratings_count %> reviews)
            </span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Rating Distribution Bars -->
    <% if @rating_distribution.any? %>
      <div class="mb-5 sm:mb-6 pb-5 sm:pb-6 border-b border-stone-200">
        <div class="max-w-sm space-y-1.5">
          <% (5).downto(1).each do |star| %>
            <% count = @rating_distribution[star] || 0 %>
            <% pct = @product.ratings_count > 0 ? (count.to_f / @product.ratings_count * 100).round : 0 %>
            <div class="flex items-center gap-2 text-xs sm:text-sm">
              <span class="w-4 text-stone-600 text-right font-medium"><%= star %></span>
              <svg class="w-3.5 h-3.5 text-amber-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              <div class="flex-1 h-2 bg-stone-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full <%= star >= 4 ? 'bg-emerald-500' : star == 3 ? 'bg-amber-400' : 'bg-red-400' %>" style="width: <%= pct %>%"></div>
              </div>
              <span class="w-8 text-stone-500 text-right text-xs"><%= count %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @reviews.any? %>
      <div class="space-y-3 sm:space-y-4">
        <% avatar_colors = %w[bg-rose-100 bg-amber-100 bg-emerald-100 bg-sky-100 bg-violet-100 bg-pink-100 bg-teal-100 bg-indigo-100] %>
        <% text_colors = %w[text-rose-700 text-amber-700 text-emerald-700 text-sky-700 text-violet-700 text-pink-700 text-teal-700 text-indigo-700] %>
        <% @reviews.each_with_index do |review, idx| %>
          <% initials = review.customer&.first_name&.first.to_s.upcase + review.customer&.last_name&.first.to_s.upcase %>
          <% initials = "AN" if initials.blank? %>
          <% color_idx = idx % avatar_colors.length %>
          <div class="bg-white rounded-lg sm:rounded-xl border border-stone-200 p-3 sm:p-4 md:p-5">
            <div class="flex items-start gap-3">
              <!-- Avatar -->
              <div class="flex-shrink-0 w-9 h-9 sm:w-10 sm:h-10 rounded-full <%= avatar_colors[color_idx] %> flex items-center justify-center">
                <span class="text-xs sm:text-sm font-semibold <%= text_colors[color_idx] %>"><%= initials %></span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="font-medium text-stone-900 text-sm"><%= review.customer_name %></span>
                  <span class="text-stone-300 text-xs">|</span>
                  <span class="text-xs text-stone-400"><%= review.created_at.strftime('%b %d, %Y') %></span>
                </div>
                <div class="flex items-center gap-1.5 mt-1">
                  <div class="flex items-center gap-0.5">
                    <% 5.times do |i| %>
                      <svg class="w-3.5 h-3.5 <%= i < review.rating ? 'text-amber-400' : 'text-stone-200' %>" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    <% end %>
                  </div>
                  <% if review.title.present? %>
                    <span class="font-medium text-stone-800 text-xs sm:text-sm"><%= review.title %></span>
                  <% end %>
                </div>
                <% if review.body.present? %>
                  <p class="text-stone-600 text-sm mt-2"><%= review.body %></p>
                <% end %>
                <% if review.has_admin_response? %>
                  <div class="mt-3 ml-2 pl-3 border-l-2 border-[#D4AF37]/30 py-1.5">
                    <p class="text-xs font-medium text-[#B8962E] mb-0.5">Response from Noralooks</p>
                    <p class="text-sm text-stone-700"><%= review.admin_response %></p>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-10 bg-stone-50 rounded-xl">
        <svg class="w-12 h-12 mx-auto text-stone-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <p class="text-stone-500 text-sm">No reviews yet</p>
        <p class="text-stone-400 text-xs mt-1">Be the first to share your experience!</p>
      </div>
    <% end %>
  </section>

  <!-- Related Products -->
  <% if @related_products.any? %>
    <section class="mt-4 sm:mt-6 md:mt-8 bg-white rounded-none sm:rounded-xl md:rounded-2xl border-0 sm:border border-stone-200 p-4 sm:p-5 md:p-6">
      <h2 class="text-base sm:text-lg md:text-xl font-sans font-semibold text-stone-900 mb-4 sm:mb-6">You May Also Like</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-3 lg:grid-cols-4 gap-2 sm:gap-3 md:gap-4">
        <% @related_products.each do |product| %>
          <%= render 'shared/product_card', product: product %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>

<!-- Sticky Mobile Bottom Bar -->
<% if @selected_variant %>
  <% is_native_app_pdp = request.user_agent&.include?('Hotwire') || request.user_agent&.include?('NoraLooks/Android') %>
  <div class="sm:hidden fixed <%= is_native_app_pdp ? 'bottom-0 pb-[calc(0.75rem+max(0.5rem,env(safe-area-inset-bottom)))]' : 'bottom-14' %> left-0 right-0 bg-white border-t border-stone-200 px-3 py-2.5 z-[45]">
    <div id="mobile-sticky-bar-<%= @selected_variant.id %>" class="flex items-center gap-3">
      <%= render 'products/mobile_sticky_bar', variant: @selected_variant, cart_item: @cart_item %>
    </div>
  </div>
<% end %>
