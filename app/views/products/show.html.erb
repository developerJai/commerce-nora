<% content_for(:title) { @product.name } %>
<% default_variant = @variants.first %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-6" data-controller="product-gallery product-variant">
  <!-- Breadcrumb -->
  <nav class="mb-4 sm:mb-6 overflow-x-auto" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-xs sm:text-sm whitespace-nowrap">
      <li><%= link_to 'Home', root_path, class: 'text-stone-500 hover:text-rose-700' %></li>
      <li><span class="text-stone-300">/</span></li>
      <li><%= link_to 'Jewellery', products_path, class: 'text-stone-500 hover:text-rose-700' %></li>
      <% if @product.category %>
        <li><span class="text-stone-300">/</span></li>
        <li><%= link_to @product.category.name, category_path(@product.category.slug), class: 'text-stone-500 hover:text-rose-700' %></li>
      <% end %>
      <li><span class="text-stone-300">/</span></li>
      <li class="text-stone-900 font-medium truncate max-w-[150px] sm:max-w-[250px]"><%= @product.name %></li>
    </ol>
  </nav>

  <div class="lg:flex lg:gap-10">
    <!-- Product Images - Vertical Thumbnails on Left -->
    <div class="lg:flex-1 lg:max-w-[55%]">
      <div class="flex flex-row gap-3">
        <!-- Vertical Thumbnails (Left Side) -->
        <% if @product.images.attached? && @product.images.count > 1 %>
          <div class="hidden sm:block w-20 flex-shrink-0">
            <div class="flex flex-col gap-2 sticky top-24">
              <% @product.images.each_with_index do |image, index| %>
                <button type="button"
                        data-action="click->product-gallery#selectImage"
                        data-product-gallery-index-param="<%= index %>"
                        class="w-20 h-20 bg-stone-100 rounded-lg overflow-hidden border-2 transition <%= index == 0 ? 'border-rose-500' : 'border-stone-200 hover:border-rose-300' %>"
                        data-product-gallery-target="thumbnail">
                  <%= image_tag image, class: 'w-full h-full object-cover' %>
                </button>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Main Image -->
        <div class="flex-1 min-w-0">
          <div class="aspect-square bg-stone-100 rounded-xl overflow-hidden relative">
            <% if @product.images.attached? %>
              <% @product.images.each_with_index do |image, index| %>
                <div class="absolute inset-0 transition-opacity duration-300 <%= index == 0 ? 'opacity-100' : 'opacity-0' %>" data-product-gallery-target="slide">
                  <%= image_tag image, class: 'w-full h-full object-cover' %>
                </div>
              <% end %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-rose-50 to-amber-50">
                <svg class="w-20 h-20 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
                </svg>
              </div>
            <% end %>
            
            <!-- Badges -->
            <div class="absolute top-3 left-3 flex flex-col gap-1">
              <% if @product.featured? %>
                <span class="px-2.5 py-1 bg-rose-800 text-white text-xs font-medium rounded">Bestseller</span>
              <% end %>
              <% if default_variant&.on_sale? %>
                <span class="px-2.5 py-1 bg-amber-500 text-white text-xs font-bold rounded"><%= default_variant.discount_percentage %>% OFF</span>
              <% end %>
            </div>

            <!-- Wishlist -->
            <button type="button" class="absolute top-3 right-3 w-10 h-10 bg-white/90 hover:bg-white rounded-full flex items-center justify-center shadow-sm transition">
              <svg class="w-5 h-5 text-stone-600 hover:text-rose-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </button>
          </div>

          <!-- Mobile Thumbnails (Horizontal - Below Image) -->
          <% if @product.images.attached? && @product.images.count > 1 %>
            <div class="sm:hidden flex gap-2 mt-3 overflow-x-auto pb-1">
              <% @product.images.each_with_index do |image, index| %>
                <button type="button"
                        data-action="click->product-gallery#selectImage"
                        data-product-gallery-index-param="<%= index %>"
                        class="w-16 h-16 flex-shrink-0 bg-stone-100 rounded-lg overflow-hidden border-2 transition <%= index == 0 ? 'border-rose-500' : 'border-stone-200' %>"
                        data-product-gallery-target="thumbnail">
                  <%= image_tag image, class: 'w-full h-full object-cover' %>
                </button>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Product Info -->
    <div class="lg:flex-1 mt-6 lg:mt-0">
      <!-- Title -->
      <h1 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900 leading-tight"><%= @product.name %></h1>
      
      <!-- Rating Summary -->
      <% if @product.average_rating > 0 %>
        <div class="flex items-center gap-3 mt-3">
          <div class="flex items-center gap-1 px-2.5 py-1 bg-emerald-600 text-white rounded">
            <span class="font-semibold text-sm"><%= @product.average_rating.round(1) %></span>
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          </div>
          <a href="#reviews" class="text-sm text-stone-500 hover:text-rose-700">
            <%= @product.ratings_count %> <%= 'Review'.pluralize(@product.ratings_count) %>
          </a>
        </div>
      <% end %>

      <!-- Price Section -->
      <div class="mt-4 pb-4 border-b border-stone-200">
        <div class="flex items-baseline gap-3 flex-wrap" data-product-variant-target="priceSection">
          <span class="text-2xl sm:text-3xl font-semibold text-stone-900" data-product-variant-target="price">
            <%= format_price(default_variant&.price) %>
          </span>
          <% if default_variant&.on_sale? %>
            <span class="text-lg text-stone-400 line-through" data-product-variant-target="comparePrice">
              <%= format_price(default_variant.compare_at_price) %>
            </span>
            <span class="px-2 py-0.5 bg-emerald-100 text-emerald-800 text-sm font-medium rounded" data-product-variant-target="discount">
              Save <%= default_variant.discount_percentage %>%
            </span>
          <% else %>
            <span class="hidden text-lg text-stone-400 line-through" data-product-variant-target="comparePrice"></span>
            <span class="hidden px-2 py-0.5 bg-emerald-100 text-emerald-800 text-sm font-medium rounded" data-product-variant-target="discount"></span>
          <% end %>
        </div>
        <p class="text-xs text-stone-500 mt-1">Inclusive of all taxes</p>
      </div>

      <!-- Variant Selection (Inline Tabs) -->
      <% if @variants.count > 1 %>
        <div class="mt-4">
          <p class="text-sm font-medium text-stone-700 mb-3">
            Select: <span class="text-stone-900" data-product-variant-target="selectedName"><%= default_variant&.name %></span>
          </p>
          <div class="flex flex-wrap gap-2">
            <% @variants.each_with_index do |variant, index| %>
              <button type="button"
                      data-action="click->product-variant#selectVariant"
                      data-product-variant-target="option"
                      data-variant-id="<%= variant.id %>"
                      data-variant-name="<%= variant.name %>"
                      data-variant-price="<%= format_price(variant.price) %>"
                      data-variant-compare-price="<%= variant.on_sale? ? format_price(variant.compare_at_price) : '' %>"
                      data-variant-discount="<%= variant.on_sale? ? "Save #{variant.discount_percentage}%" : '' %>"
                      data-variant-in-stock="<%= variant.in_stock? %>"
                      data-variant-stock="<%= variant.stock_quantity %>"
                      class="px-4 py-2 text-sm font-medium rounded-lg border-2 transition <%= index == 0 ? 'border-rose-500 bg-rose-50 text-rose-800' : 'border-stone-200 text-stone-700 hover:border-rose-300' %> <%= variant.in_stock? ? '' : 'opacity-50' %>">
                <%= variant.name %>
                <% unless variant.in_stock? %>
                  <span class="block text-[10px] text-stone-500 font-normal">Out of Stock</span>
                <% end %>
              </button>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Stock Status -->
      <div class="mt-4" data-product-variant-target="stockStatus">
        <% if default_variant&.in_stock? %>
          <% if default_variant.low_stock? %>
            <p class="text-sm text-amber-600 flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
              Only <%= default_variant.stock_quantity %> left in stock
            </p>
          <% else %>
            <p class="text-sm text-emerald-600 flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              In Stock
            </p>
          <% end %>
        <% else %>
          <p class="text-sm text-stone-500">Currently unavailable</p>
        <% end %>
      </div>

      <!-- Quantity Selection -->
      <div class="mt-5">
        <label class="text-sm font-medium text-stone-700 mb-2 block">Quantity</label>
        <div class="inline-flex items-center border border-stone-300 rounded-lg" data-controller="quantity">
          <button type="button" 
                  data-action="click->quantity#decrease"
                  class="w-11 h-11 flex items-center justify-center text-stone-600 hover:bg-stone-100 rounded-l-lg transition">
            <span class="text-xl font-light">−</span>
          </button>
          <input type="number" 
                 id="quantity-input" 
                 value="1" 
                 min="1" 
                 max="10" 
                 data-quantity-target="input"
                 class="w-14 h-11 text-center border-x border-stone-300 text-sm font-medium text-stone-900 focus:outline-none"
                 readonly>
          <button type="button" 
                  data-action="click->quantity#increase"
                  class="w-11 h-11 flex items-center justify-center text-stone-600 hover:bg-stone-100 rounded-r-lg transition">
            <span class="text-xl font-light">+</span>
          </button>
        </div>
      </div>

      <!-- Action Buttons -->
      <%= form_with url: add_to_cart_path(default_variant), method: :post, id: 'add-to-cart-form', class: 'mt-5', data: { product_variant_target: 'form' } do |f| %>
        <input type="hidden" name="variant_id" value="<%= default_variant&.id %>" data-product-variant-target="variantInput">
        <input type="hidden" name="quantity" id="form-quantity" value="1">
        
        <div class="flex gap-3">
          <% if @product.in_stock? %>
            <button type="submit" 
                    class="flex-1 py-3.5 px-6 bg-rose-800 text-white font-medium rounded-lg hover:bg-rose-900 transition flex items-center justify-center gap-2"
                    data-product-variant-target="addToCartBtn">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
              Add to Bag
            </button>
            <button type="button" 
                    onclick="this.form.action='<%= checkout_path %>'; this.form.submit();"
                    class="flex-1 py-3.5 px-6 border-2 border-stone-900 text-stone-900 font-medium rounded-lg hover:bg-stone-900 hover:text-white transition">
              Buy Now
            </button>
          <% else %>
            <button disabled class="flex-1 py-3.5 px-6 bg-stone-200 text-stone-500 font-medium rounded-lg cursor-not-allowed">
              Out of Stock
            </button>
            <button disabled class="flex-1 py-3.5 px-6 border-2 border-stone-200 text-stone-400 font-medium rounded-lg cursor-not-allowed">
              Buy Now
            </button>
          <% end %>
        </div>
      <% end %>

      <!-- Trust Badges -->
      <div class="mt-6 grid grid-cols-2 gap-3">
        <div class="flex items-center gap-2 p-3 bg-stone-50 rounded-lg">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <div>
            <p class="text-xs font-medium text-stone-900">100% Certified</p>
            <p class="text-[10px] text-stone-500">BIS Hallmarked</p>
          </div>
        </div>
        <div class="flex items-center gap-2 p-3 bg-stone-50 rounded-lg">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          <div>
            <p class="text-xs font-medium text-stone-900">Lifetime Exchange</p>
            <p class="text-[10px] text-stone-500">On all products</p>
          </div>
        </div>
        <div class="flex items-center gap-2 p-3 bg-stone-50 rounded-lg">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
          <div>
            <p class="text-xs font-medium text-stone-900">Free Shipping</p>
            <p class="text-[10px] text-stone-500">Orders above ₹999</p>
          </div>
        </div>
        <div class="flex items-center gap-2 p-3 bg-stone-50 rounded-lg">
          <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <p class="text-xs font-medium text-stone-900">30-Day Returns</p>
            <p class="text-[10px] text-stone-500">Easy refund</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Product Details Tabs -->
  <div class="mt-10 sm:mt-12" data-controller="tabs">
    <div class="border-b border-stone-200">
      <nav class="flex gap-6 sm:gap-8 overflow-x-auto">
        <button type="button" data-action="click->tabs#select" data-tabs-target="tab" data-tab="description"
                class="pb-3 text-sm font-medium border-b-2 border-rose-700 text-rose-800 whitespace-nowrap">
          Description
        </button>
        <button type="button" data-action="click->tabs#select" data-tabs-target="tab" data-tab="details"
                class="pb-3 text-sm font-medium border-b-2 border-transparent text-stone-500 hover:text-stone-700 whitespace-nowrap">
          Product Details
        </button>
        <button type="button" data-action="click->tabs#select" data-tabs-target="tab" data-tab="shipping"
                class="pb-3 text-sm font-medium border-b-2 border-transparent text-stone-500 hover:text-stone-700 whitespace-nowrap">
          Shipping & Returns
        </button>
      </nav>
    </div>

    <div class="py-6">
      <div data-tabs-target="panel" data-tab="description">
        <% if @product.description.present? %>
          <div class="prose prose-sm prose-stone max-w-none text-stone-600">
            <%= simple_format(@product.description) %>
          </div>
        <% else %>
          <p class="text-stone-500 text-sm">No description available.</p>
        <% end %>
      </div>

      <div data-tabs-target="panel" data-tab="details" class="hidden">
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div class="p-3 bg-stone-50 rounded-lg">
            <p class="text-stone-500">SKU</p>
            <p class="font-medium text-stone-900"><%= default_variant&.sku || 'N/A' %></p>
          </div>
          <% if @product.category %>
            <div class="p-3 bg-stone-50 rounded-lg">
              <p class="text-stone-500">Category</p>
              <p class="font-medium text-stone-900"><%= @product.category.name %></p>
            </div>
          <% end %>
          <div class="p-3 bg-stone-50 rounded-lg">
            <p class="text-stone-500">Variants</p>
            <p class="font-medium text-stone-900"><%= @variants.count %> options available</p>
          </div>
        </div>
      </div>

      <div data-tabs-target="panel" data-tab="shipping" class="hidden">
        <div class="space-y-4 text-sm text-stone-600">
          <div>
            <h4 class="font-medium text-stone-900 mb-1">Shipping</h4>
            <p>Free shipping on orders above ₹999. Standard delivery takes 3-5 business days.</p>
          </div>
          <div>
            <h4 class="font-medium text-stone-900 mb-1">Returns & Exchange</h4>
            <p>Easy 30-day returns. Lifetime exchange available on all products.</p>
          </div>
          <div>
            <h4 class="font-medium text-stone-900 mb-1">Quality Assurance</h4>
            <p>All products are 100% certified and come with BIS Hallmark certification.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Reviews Section -->
  <section id="reviews" class="mt-8 sm:mt-10 pt-8 border-t border-stone-200">
    <div class="sm:flex sm:items-start sm:justify-between mb-6">
      <div>
        <h2 class="text-lg sm:text-xl font-serif font-semibold text-stone-900">Customer Reviews</h2>
        <% if @product.average_rating > 0 %>
          <div class="flex items-center gap-3 mt-2">
            <div class="flex items-center gap-1">
              <% 5.times do |i| %>
                <svg class="w-5 h-5 <%= i < @product.average_rating.round ? 'text-amber-400' : 'text-stone-200' %>" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              <% end %>
            </div>
            <span class="text-stone-600 text-sm">
              <%= @product.average_rating.round(1) %> out of 5 (<%= @product.ratings_count %> reviews)
            </span>
          </div>
        <% end %>
      </div>
    </div>
    
    <% if @reviews.any? %>
      <div class="space-y-4">
        <% @reviews.each do |review| %>
          <div class="bg-white rounded-xl border border-stone-200 p-4 sm:p-5">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <div class="flex items-center gap-0.5">
                    <% 5.times do |i| %>
                      <svg class="w-4 h-4 <%= i < review.rating ? 'text-amber-400' : 'text-stone-200' %>" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    <% end %>
                  </div>
                  <% if review.title.present? %>
                    <span class="font-medium text-stone-900 text-sm"><%= review.title %></span>
                  <% end %>
                </div>
                <p class="text-xs text-stone-500">
                  <%= review.customer_name %> • <%= review.created_at.strftime('%B %d, %Y') %>
                </p>
              </div>
            </div>
            <% if review.body.present? %>
              <p class="text-stone-600 text-sm mt-3"><%= review.body %></p>
            <% end %>
            <% if review.has_admin_response? %>
              <div class="mt-4 ml-4 pl-4 border-l-2 border-rose-200 py-2">
                <p class="text-xs font-medium text-rose-800 mb-1">Response from Auracraft</p>
                <p class="text-sm text-rose-700"><%= review.admin_response %></p>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-10 bg-stone-50 rounded-xl">
        <svg class="w-12 h-12 mx-auto text-stone-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <p class="text-stone-500 text-sm">No reviews yet</p>
        <p class="text-stone-400 text-xs mt-1">Be the first to share your experience!</p>
      </div>
    <% end %>
  </section>

  <!-- Related Products -->
  <% if @related_products.any? %>
    <section class="mt-10 sm:mt-12 pt-8 border-t border-stone-200">
      <h2 class="text-lg sm:text-xl font-serif font-semibold text-stone-900 mb-6">You May Also Like</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-4">
        <% @related_products.each do |product| %>
          <%= render 'shared/product_card', product: product %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
