<%# locals: (variant:, cart_item:) %>
<% if cart_item.present? && cart_item.quantity > 0 %>
  <!-- Item in cart - Show quantity controls -->
  <div class="flex items-center gap-3" 
       data-controller="cart-controls"
       data-cart-controls-update-url-value="<%= update_item_cart_path(variant.id) %>"
       data-cart-controls-current-quantity-value="<%= cart_item.quantity %>"
       data-cart-controls-max-stock-value="<%= variant.stock_quantity %>">
    
    <!-- Quantity Selector -->
    <div class="flex items-center border-2 border-[#D4AF37] bg-amber-50 rounded-lg">
      <!-- Decrease/Remove Button -->
      <button type="button"
              data-action="click->cart-controls#decrement"
              class="w-11 h-12 flex items-center justify-center text-[#B8962E] hover:bg-amber-100 transition"
              title="<%= cart_item.quantity == 1 ? 'Remove from bag' : 'Decrease quantity' %>">
        <% if cart_item.quantity == 1 %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        <% else %>
          <span class="text-xl font-light">−</span>
        <% end %>
      </button>
      
      <!-- Quantity Display -->
      <div class="w-12 h-12 flex items-center justify-center">
        <span class="text-base font-semibold text-[#B8962E]"><%= cart_item.quantity %></span>
      </div>
      
      <!-- Increase Button -->
      <button type="button" 
              data-action="click->cart-controls#increment"
              <% if cart_item.quantity >= variant.stock_quantity %>disabled<% end %>
              class="w-11 h-12 flex items-center justify-center text-[#B8962E] hover:bg-amber-100 transition disabled:opacity-40 disabled:cursor-not-allowed"
              title="Increase quantity">
        <span class="text-xl font-light">+</span>
      </button>
    </div>

    <div class="flex-1 text-sm">
      <p class="text-[#B8962E] font-medium">In your bag</p>
      <p class="text-stone-500 text-xs"><%= cart_item.quantity == 1 ? 'Click − to remove' : 'Update quantity or remove' %></p>
    </div>
  </div>
<% else %>
  <!-- Item not in cart - Show Add to Bag button -->
  <div data-controller="cart-controls">
    <%= form_with url: add_to_cart_path(variant), 
                  method: :post, 
                  class: 'w-full', 
                  data: { action: 'submit->cart-controls#submitForm' } do |f| %>
      <input type="hidden" name="variant_id" value="<%= variant.id %>">
      <input type="hidden" name="quantity" value="1">
      <input type="hidden" name="from_product_page" value="1">

      <button type="submit"
              class="w-full h-12 px-6 bg-[#B8962E] text-white font-medium rounded-lg hover:bg-[#A6872A] transition flex items-center justify-center gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
        Add to Bag
      </button>
    <% end %>
  </div>
<% end %>
