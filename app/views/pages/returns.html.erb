<% content_for(:title) { "Returns & Exchange" } %>
<% content_for(:native_title) { "Returns" } %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
  <h1 class="text-2xl sm:text-3xl font-sans font-semibold text-stone-900 mb-8">Returns & Exchange Policy</h1>

  <div class="bg-white rounded-xl border border-stone-200 p-6 sm:p-8 space-y-8">
    <!-- Overview -->
    <section>
      <p class="text-stone-600">At Noralooks, we want you to be completely satisfied with your purchase. If you're not happy with your jewellery, we're here to help. Return and exchange eligibility varies by product — each product page clearly shows the applicable window.</p>
    </section>

    <hr class="border-stone-200">

    <!-- Returns -->
    <section>
      <div class="flex items-start gap-4 mb-4">
        <div class="w-12 h-12 flex-shrink-0 bg-emerald-100 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6 text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 15v-1a4 4 0 00-4-4H8m0 0l3 3m-3-3l3-3m9 14V5a2 2 0 00-2-2H6a2 2 0 00-2 2v16l4-2 4 2 4-2 4 2z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-xl font-sans font-semibold text-stone-900 mb-2">Easy Returns</h2>
          <p class="text-stone-600">Eligible products can be returned within the return window shown on the product page. The return window is set per product (up to 7 days from delivery) and is displayed clearly before purchase.</p>
        </div>
      </div>
    </section>

    <hr class="border-stone-200">

    <!-- Easy Exchange -->
    <section>
      <div class="flex items-start gap-4 mb-4">
        <div class="w-12 h-12 flex-shrink-0 bg-amber-100 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
        </div>
        <div>
          <h2 class="text-xl font-sans font-semibold text-stone-900 mb-2">Easy Replacement Support</h2>
          <p class="text-stone-600">Eligible products support an exchange within the exchange window shown on the product page (up to 7 days). You can exchange for another product of equal or greater value within the specified window.</p>
        </div>
      </div>
    </section>

    <hr class="border-stone-200">

    <!-- Return Conditions -->
    <section>
      <h2 class="text-xl font-sans font-semibold text-stone-900 mb-4">Return Conditions</h2>
      <div class="space-y-3">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-rose-700 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <p class="text-stone-600">Item must be unused and in the same condition that you received it</p>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-rose-700 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <p class="text-stone-600">Item must be in its original packaging with all tags attached</p>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-rose-700 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <p class="text-stone-600">Certificate of authenticity (if provided) must be included</p>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-rose-700 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <p class="text-stone-600">Proof of purchase (order confirmation or receipt) is required</p>
        </div>
      </div>
    </section>

    <hr class="border-stone-200">

    <!-- How to Return -->
    <section>
      <h2 class="text-xl font-sans font-semibold text-stone-900 mb-4">How to Initiate a Return or Exchange</h2>
      <ol class="space-y-3 list-decimal list-inside text-stone-600">
        <li>Contact our support team through the <%= link_to 'Help Center', support_tickets_path, class: 'text-rose-700 hover:text-rose-900 font-medium' %> or email us at returns@noralooks.com</li>
        <li>Provide your order number and reason for return/exchange</li>
        <li>We'll send you a return shipping label and instructions</li>
        <li>Pack the item securely with all original packaging and accessories</li>
        <li>Ship the package using the provided label</li>
        <li>Once we receive and inspect the item, we'll process your refund or exchange</li>
      </ol>
    </section>

    <hr class="border-stone-200">

    <!-- Refund Process -->
    <section>
      <h2 class="text-xl font-sans font-semibold text-stone-900 mb-4">Refund Processing</h2>
      <p class="text-stone-600 mb-3">Once your return is received and inspected, we'll send you an email notification. If approved, your refund will be processed within 5-7 business days.</p>
      <p class="text-stone-600">The refund will be credited to your original payment method. Please note that it may take an additional 3-5 business days for the refund to appear in your account, depending on your bank or card issuer.</p>
    </section>

    <hr class="border-stone-200">

    <!-- Non-Returnable Items -->
    <section>
      <h2 class="text-xl font-sans font-semibold text-stone-900 mb-4">Non-Returnable Items</h2>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <p class="text-sm text-amber-800 mb-2 font-medium">The following items cannot be returned or exchanged:</p>
        <ul class="text-sm text-amber-800 space-y-1 list-disc list-inside">
          <li>Personalized or custom-made jewellery</li>
          <li>Items purchased during final sale or clearance events (if specified)</li>
          <li>Items damaged due to misuse or normal wear and tear</li>
        </ul>
      </div>
    </section>

    <hr class="border-stone-200">

    <!-- Contact -->
    <section class="bg-stone-50 rounded-lg p-5">
      <h3 class="font-medium text-stone-900 mb-2">Questions About Returns?</h3>
      <p class="text-sm text-stone-600 mb-3">Our customer service team is here to help with any questions about returns or exchanges.</p>
      <%= link_to 'Contact Support', support_tickets_path, class: 'inline-flex items-center gap-2 text-sm text-rose-700 hover:text-rose-900 font-medium' %>
    </section>
  </div>
</div>
