<% content_for(:title) { @category.name } %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-4 sm:py-8">
  <!-- Breadcrumb -->
  <nav class="mb-4 sm:mb-6 overflow-x-auto">
    <ol class="flex items-center gap-2 text-xs sm:text-sm whitespace-nowrap">
      <li><%= link_to 'Home', root_path, class: 'text-stone-500 hover:text-rose-700' %></li>
      <li class="text-stone-300">/</li>
      <li><%= link_to 'Jewellery', products_path, class: 'text-stone-500 hover:text-rose-700' %></li>
      <li class="text-stone-300">/</li>
      <li class="text-stone-900 font-medium truncate max-w-[150px] sm:max-w-none"><%= @category.name %></li>
    </ol>
  </nav>

  <div class="flex flex-col lg:flex-row gap-4 sm:gap-8">
    <!-- Sidebar Filters -->
    <aside class="w-full lg:w-64 flex-shrink-0">
      <!-- Mobile Filter Toggle -->
      <button type="button" 
              onclick="document.getElementById('category-filters').classList.toggle('hidden')"
              class="lg:hidden w-full flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-stone-200 mb-4">
        <span class="font-medium text-stone-900">Filters & Categories</span>
        <svg class="w-5 h-5 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
        </svg>
      </button>

      <div id="category-filters" class="hidden lg:block bg-white rounded-xl border border-stone-200 p-4 sm:p-6 lg:sticky lg:top-24">
        <h2 class="text-lg font-serif font-semibold text-stone-900 mb-4">Filters</h2>

        <!-- Sub Categories -->
        <% if @category.children.active.any? %>
          <div class="mb-6">
            <h3 class="text-sm font-medium text-stone-900 mb-3">Subcategories</h3>
            <ul class="space-y-2">
              <% @category.children.active.ordered.each do |child| %>
                <li>
                  <%= link_to category_path(child.slug), class: 'text-sm text-stone-600 hover:text-rose-700 flex justify-between items-center' do %>
                    <span><%= child.name %></span>
                    <span class="text-stone-400 text-xs">(<%= child.products.active.count %>)</span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Price Range -->
        <%= form_with url: category_path(@category.slug), method: :get, class: 'mb-6', data: { turbo_frame: '_top' } do |f| %>
          <h3 class="text-sm font-medium text-stone-900 mb-3">Price Range</h3>
          <div class="flex items-center gap-2 mb-3">
            <%= f.number_field :min_price, value: params[:min_price], placeholder: 'Min', min: 0, 
                class: 'w-full px-3 py-2 text-sm border border-stone-300 rounded-lg focus:ring-rose-500 focus:border-rose-500' %>
            <span class="text-stone-400">-</span>
            <%= f.number_field :max_price, value: params[:max_price], placeholder: 'Max', min: 0, 
                class: 'w-full px-3 py-2 text-sm border border-stone-300 rounded-lg focus:ring-rose-500 focus:border-rose-500' %>
          </div>
          <%= f.hidden_field :sort, value: params[:sort] %>
          <%= f.submit 'Apply', class: 'w-full px-4 py-2.5 bg-rose-800 text-white text-sm font-medium rounded-lg hover:bg-rose-900 cursor-pointer transition' %>
        <% end %>

        <!-- Clear Filters -->
        <% if params[:min_price].present? || params[:max_price].present? %>
          <%= link_to 'Clear Filters', category_path(@category.slug), class: 'text-sm text-rose-700 hover:text-rose-900' %>
        <% end %>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1">
      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 sm:gap-4 mb-4 sm:mb-6">
        <div>
          <h1 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900"><%= @category.name %></h1>
          <% if @category.description.present? %>
            <p class="text-xs sm:text-sm text-stone-600 mt-1 line-clamp-2"><%= @category.description %></p>
          <% end %>
          <p class="text-xs sm:text-sm text-stone-500 mt-1"><%= @pagy.count %> pieces</p>
        </div>

        <!-- Sort -->
        <%= form_with url: category_path(@category.slug), method: :get, class: 'flex items-center gap-2' do |f| %>
          <%= f.hidden_field :min_price, value: params[:min_price] %>
          <%= f.hidden_field :max_price, value: params[:max_price] %>
          <label class="text-xs sm:text-sm text-stone-600 whitespace-nowrap">Sort:</label>
          <%= f.select :sort, [
              ['Newest', 'newest'],
              ['Price: Low to High', 'price_asc'],
              ['Price: High to Low', 'price_desc'],
              ['Rating', 'rating'],
              ['Name A-Z', 'name']
            ], { selected: params[:sort] || 'newest' },
            class: 'px-2 sm:px-3 py-2 text-xs sm:text-sm border border-stone-300 rounded-lg focus:ring-rose-500 focus:border-rose-500',
            onchange: 'this.form.submit()' %>
        <% end %>
      </div>

      <!-- Products Grid -->
      <% if @products.any? %>
        <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
          <% @products.each do |product| %>
            <%= render 'shared/product_card', product: product %>
          <% end %>
        </div>

        <!-- Pagination -->
        <div class="mt-6 sm:mt-8">
          <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
        </div>
      <% else %>
        <div class="text-center py-12 sm:py-16 bg-white rounded-xl border border-stone-200">
          <div class="w-16 h-16 mx-auto mb-4 bg-rose-50 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-rose-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
            </svg>
          </div>
          <h3 class="text-lg font-serif font-medium text-stone-900 mb-2">No pieces found</h3>
          <p class="text-sm text-stone-500 px-4 mb-4">Try adjusting your filters or browse all jewellery.</p>
          <%= link_to 'Browse All Jewellery', products_path, class: 'inline-block px-5 py-2 bg-rose-800 text-white text-sm font-medium rounded-full hover:bg-rose-900 transition' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
