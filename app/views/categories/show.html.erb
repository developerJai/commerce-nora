<% content_for(:title) { @category.name } %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-4 sm:py-8">
  <!-- Breadcrumb -->
  <nav class="mb-4 sm:mb-6 overflow-x-auto">
    <ol class="flex items-center gap-2 text-xs sm:text-sm whitespace-nowrap">
      <li><%= link_to 'Home', root_path, class: 'text-gray-500 hover:text-gray-700' %></li>
      <li class="text-gray-400">/</li>
      <li><%= link_to 'Products', products_path, class: 'text-gray-500 hover:text-gray-700' %></li>
      <li class="text-gray-400">/</li>
      <li class="text-gray-900 font-medium truncate max-w-[150px] sm:max-w-none"><%= @category.name %></li>
    </ol>
  </nav>

  <div class="flex flex-col lg:flex-row gap-4 sm:gap-8">
    <!-- Sidebar Filters -->
    <aside class="w-full lg:w-64 flex-shrink-0">
      <!-- Mobile Filter Toggle -->
      <button type="button" 
              onclick="document.getElementById('category-filters').classList.toggle('hidden')"
              class="lg:hidden w-full flex items-center justify-between px-4 py-3 bg-white rounded-lg shadow-sm mb-4">
        <span class="font-medium text-gray-900">Filters & Categories</span>
        <svg class="w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
        </svg>
      </button>

      <div id="category-filters" class="hidden lg:block bg-white rounded-xl shadow-sm p-4 sm:p-6 lg:sticky lg:top-24">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Filters</h2>

        <!-- Sub Categories -->
        <% if @category.children.active.any? %>
          <div class="mb-6">
            <h3 class="text-sm font-medium text-gray-900 mb-3">Subcategories</h3>
            <ul class="space-y-2">
              <% @category.children.active.ordered.each do |child| %>
                <li>
                  <%= link_to category_path(child.slug), class: 'text-sm text-gray-600 hover:text-indigo-600 flex justify-between items-center' do %>
                    <span><%= child.name %></span>
                    <span class="text-gray-400 text-xs">(<%= child.products.active.count %>)</span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- Price Range -->
        <%= form_with url: category_path(@category.slug), method: :get, class: 'mb-6', data: { turbo_frame: '_top' } do |f| %>
          <h3 class="text-sm font-medium text-gray-900 mb-3">Price Range</h3>
          <div class="flex items-center gap-2 mb-3">
            <%= f.number_field :min_price, value: params[:min_price], placeholder: 'Min', min: 0, 
                class: 'w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500' %>
            <span class="text-gray-400">-</span>
            <%= f.number_field :max_price, value: params[:max_price], placeholder: 'Max', min: 0, 
                class: 'w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <%= f.hidden_field :sort, value: params[:sort] %>
          <%= f.submit 'Apply', class: 'w-full px-4 py-2.5 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700 cursor-pointer' %>
        <% end %>

        <!-- Clear Filters -->
        <% if params[:min_price].present? || params[:max_price].present? %>
          <%= link_to 'Clear Filters', category_path(@category.slug), class: 'text-sm text-indigo-600 hover:underline' %>
        <% end %>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1">
      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 sm:gap-4 mb-4 sm:mb-6">
        <div>
          <h1 class="text-xl sm:text-2xl font-bold text-gray-900"><%= @category.name %></h1>
          <% if @category.description.present? %>
            <p class="text-xs sm:text-sm text-gray-600 mt-1 line-clamp-2"><%= @category.description %></p>
          <% end %>
          <p class="text-xs sm:text-sm text-gray-500 mt-1"><%= @pagy.count %> products found</p>
        </div>

        <!-- Sort -->
        <%= form_with url: category_path(@category.slug), method: :get, class: 'flex items-center gap-2' do |f| %>
          <%= f.hidden_field :min_price, value: params[:min_price] %>
          <%= f.hidden_field :max_price, value: params[:max_price] %>
          <label class="text-xs sm:text-sm text-gray-600 whitespace-nowrap">Sort:</label>
          <%= f.select :sort, [
              ['Newest', 'newest'],
              ['Price: Low to High', 'price_asc'],
              ['Price: High to Low', 'price_desc'],
              ['Rating', 'rating'],
              ['Name A-Z', 'name']
            ], { selected: params[:sort] || 'newest' },
            class: 'px-2 sm:px-3 py-2 text-xs sm:text-sm border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500',
            onchange: 'this.form.submit()' %>
        <% end %>
      </div>

      <!-- Products Grid -->
      <% if @products.any? %>
        <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 sm:gap-4">
          <% @products.each do |product| %>
            <%= render 'shared/product_card', product: product %>
          <% end %>
        </div>

        <!-- Pagination -->
        <div class="mt-6 sm:mt-8">
          <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
        </div>
      <% else %>
        <div class="text-center py-12 sm:py-16 bg-white rounded-xl">
          <svg class="mx-auto h-12 w-12 sm:h-16 sm:w-16 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
          </svg>
          <h3 class="mt-4 text-lg font-medium text-gray-900">No products found</h3>
          <p class="mt-2 text-sm text-gray-500 px-4">Try adjusting your filters or browse all products.</p>
          <%= link_to 'Browse All Products', products_path, class: 'mt-4 inline-block px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
