<% content_for(:title) { "Order #{@order.order_number}" } %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Order <%= @order.order_number %></h1>
      <p class="text-sm text-gray-500">Placed on <%= @order.placed_at&.strftime('%B %d, %Y at %I:%M %p') %></p>
    </div>
    <span class="px-4 py-2 rounded-full text-sm font-medium <%= order_status_badge(@order.status) %>">
      <%= @order.status.titleize %>
    </span>
  </div>

  <!-- Order Timeline -->
  <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Order Status</h2>
    <div class="flex items-center justify-between">
      <% statuses = ['confirmed', 'processing', 'shipped', 'delivered'] %>
      <% current_index = statuses.index(@order.status) || -1 %>
      <% statuses.each_with_index do |status, index| %>
        <div class="flex flex-col items-center flex-1 <%= index < statuses.length - 1 ? 'relative' : '' %>">
          <div class="w-8 h-8 rounded-full flex items-center justify-center <%= index <= current_index ? 'bg-indigo-600 text-white' : 'bg-gray-200 text-gray-500' %>">
            <% if index < current_index %>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            <% else %>
              <%= index + 1 %>
            <% end %>
          </div>
          <p class="mt-2 text-xs text-center font-medium <%= index <= current_index ? 'text-indigo-600' : 'text-gray-500' %>"><%= status.titleize %></p>
          <% if index < statuses.length - 1 %>
            <div class="absolute top-4 left-1/2 w-full h-0.5 <%= index < current_index ? 'bg-indigo-600' : 'bg-gray-200' %>"></div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <!-- Order Items -->
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Order Items</h2>
        <ul class="divide-y divide-gray-200">
          <% @order_items.each do |item| %>
            <li class="py-4">
              <div class="flex items-start gap-4">
                <div class="w-20 h-20 bg-gray-100 rounded-lg flex-shrink-0 overflow-hidden">
                  <% if item.product_variant&.product&.images&.attached? %>
                    <%= image_tag item.product_variant.product.images.first, class: 'w-full h-full object-cover' %>
                  <% end %>
                </div>
                <div class="flex-1">
                  <p class="font-medium text-gray-900"><%= item.product_name %></p>
                  <p class="text-sm text-gray-500"><%= item.variant_name %></p>
                  <p class="text-sm text-gray-500">Qty: <%= item.quantity %> x <%= format_price(item.unit_price) %></p>
                </div>
                <p class="font-semibold text-gray-900"><%= format_price(item.total_price) %></p>
              </div>
              
              <% if @can_review && item.product_variant && !@reviewed_variants.include?(item.product_variant.product_id) %>
                <div class="mt-3">
                  <%= link_to 'Write a Review', new_order_review_path(@order, product_id: item.product_variant.product_id), 
                      class: 'text-sm text-indigo-600 hover:text-indigo-800' %>
                </div>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- Shipping Address -->
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Shipping Address</h2>
        <% if @order.shipping_address %>
          <p class="font-medium text-gray-900"><%= @order.shipping_address.full_name %></p>
          <p class="text-gray-600"><%= @order.shipping_address.full_address %></p>
          <% if @order.shipping_address.phone.present? %>
            <p class="text-gray-600"><%= @order.shipping_address.phone %></p>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="lg:col-span-1">
      <!-- Order Summary -->
      <div class="bg-white rounded-lg shadow-sm p-6 sticky top-24">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Order Summary</h2>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-600">Subtotal</span>
            <span><%= format_price(@order.subtotal) %></span>
          </div>
          <% if @order.discount_amount > 0 %>
            <div class="flex justify-between text-green-600">
              <span>Discount</span>
              <span>-<%= format_price(@order.discount_amount) %></span>
            </div>
          <% end %>
          <div class="flex justify-between">
            <span class="text-gray-600">Shipping</span>
            <span><%= @order.shipping_amount > 0 ? format_price(@order.shipping_amount) : 'Free' %></span>
          </div>
          <div class="border-t border-gray-200 pt-2 flex justify-between text-lg font-semibold">
            <span>Total</span>
            <span><%= format_price(@order.total_amount) %></span>
          </div>
        </div>

        <div class="mt-6 p-4 bg-gray-50 rounded-lg">
          <p class="text-sm text-gray-600">
            <strong>Payment Method:</strong> Cash on Delivery
          </p>
          <p class="text-sm text-gray-600 mt-1">
            <strong>Payment Status:</strong> <%= @order.payment_status.titleize %>
          </p>
        </div>

        <% if @order.can_cancel? %>
          <div class="mt-6">
            <p class="text-sm text-gray-500 mb-2">Need help with this order?</p>
            <%= link_to 'Contact Support', new_support_ticket_path(order_id: @order.id), class: 'text-indigo-600 hover:text-indigo-800 text-sm font-medium' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%
def order_status_badge(status)
  case status
  when 'pending' then 'bg-yellow-100 text-yellow-800'
  when 'confirmed' then 'bg-blue-100 text-blue-800'
  when 'processing' then 'bg-indigo-100 text-indigo-800'
  when 'shipped' then 'bg-purple-100 text-purple-800'
  when 'delivered' then 'bg-green-100 text-green-800'
  when 'cancelled' then 'bg-red-100 text-red-800'
  else 'bg-gray-100 text-gray-800'
  end
end
%>
