<% content_for(:title) { "Order #{@order.order_number}" } %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-4 sm:py-6 lg:py-8">
  <div class="flex flex-col md:flex-row gap-4 md:gap-6">
    <!-- Sidebar - Hidden on mobile, shown on tablet+ -->
    <div class="hidden md:block w-64 flex-shrink-0">
      <%= render 'shared/account_sidebar', active_page: 'orders' %>
    </div>

    <div class="flex-1">
      <!-- Header with inline actions on desktop -->
      <div class="mb-4 sm:mb-6">
        <!-- Mobile: Stacked layout -->
        <div class="md:hidden">
          <div class="flex items-center gap-2 mb-2">
            <a href="<%= orders_path %>" onclick="if (window.history.length > 1) { window.history.back(); return false; }" class="inline-flex items-center justify-center w-8 h-8 rounded-full hover:bg-stone-100 active:bg-stone-200 text-stone-600 transition-colors flex-shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
            </a>
            <h1 class="text-xl sm:text-2xl font-sans font-semibold text-stone-900">Order Details</h1>
          </div>
          <div class="flex flex-col gap-2 mb-4">
            <div class="flex items-center gap-2">
              <p class="text-xs sm:text-sm text-stone-600 font-medium"><%= @order.order_number %></p>
              <span class="px-2.5 sm:px-3 py-1 rounded-full text-[10px] sm:text-xs font-medium <%= order_status_badge(@order.status) %>">
                <%= @order.status.titleize %>
              </span>
            </div>
            <p class="text-[10px] sm:text-xs text-stone-500">Placed on <%= @order.placed_at&.strftime('%b %d, %Y at %I:%M %p') %></p>
          </div>
          
          <!-- Mobile action buttons -->
          <div class="flex gap-2">
            <%= link_to invoice_path(@order.order_number, format: :pdf), target: (request.user_agent&.include?('Hotwire') ? '_blank' : nil), download: (request.user_agent&.include?('Hotwire') ? nil : "Invoice_#{@order.order_number}.pdf"), class: 'flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-rose-800 hover:bg-rose-900 active:bg-rose-950 text-white text-xs font-medium rounded-lg transition-colors whitespace-nowrap' do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              <span>Invoice</span>
            <% end %>
            
            <!-- More Actions Dropdown -->
            <div class="relative" data-controller="dropdown">
              <button type="button" data-action="click->dropdown#toggle click@window->dropdown#hide" 
                      class="inline-flex items-center justify-center gap-1.5 px-3 py-2.5 bg-stone-100 hover:bg-stone-200 active:bg-stone-300 text-stone-700 text-xs font-medium rounded-lg transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"/>
                </svg>
              </button>
              
              <!-- Dropdown Menu -->
              <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-stone-200 py-1 z-50">
                <%= link_to new_support_ticket_path(order_id: @order.id), class: 'flex items-center gap-2 px-4 py-2.5 text-xs text-stone-700 hover:bg-stone-50 transition' do %>
                  <svg class="w-4 h-4 text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                  </svg>
                  Need Help?
                <% end %>

                <% if @order.delivered? && @order_items.any? { |item| item.exchange_in_days.to_i > 0 } %>
                  <%= link_to new_support_ticket_path(order_id: @order.id, subject: "Exchange Request for #{@order.order_number}"), class: 'flex items-center gap-2 px-4 py-2.5 text-xs text-blue-700 hover:bg-blue-50 transition' do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                    Request Exchange
                  <% end %>
                <% end %>

                <% if @order.delivered? && @order_items.any? { |item| item.return_in_days.to_i > 0 } %>
                  <%= link_to new_support_ticket_path(order_id: @order.id, subject: "Return Request for #{@order.order_number}"), class: 'flex items-center gap-2 px-4 py-2.5 text-xs text-emerald-700 hover:bg-emerald-50 transition' do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 15v-1a4 4 0 00-4-4H8m0 0l3 3m-3-3l3-3m9 14V5a2 2 0 00-2-2H6a2 2 0 00-2 2v16l4-2 4 2 4-2 4 2z"/>
                    </svg>
                    Request Return
                  <% end %>
                <% end %>

                <% if @order.can_cancel? %>
                  <button type="button" data-cancel-order class="w-full flex items-center gap-2 px-4 py-2.5 text-xs text-red-600 hover:bg-red-50 transition text-left">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                    Cancel Order
                  </button>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Desktop: Inline layout with actions next to heading -->
        <div class="hidden md:flex items-start justify-between gap-4">
          <div class="flex-1">
            <h1 class="text-2xl font-sans font-semibold text-stone-900">Order Details</h1>
            <div class="flex items-center gap-3 mt-2">
              <p class="text-sm text-stone-600 font-medium"><%= @order.order_number %></p>
              <span class="text-stone-300">•</span>
              <span class="px-3 py-1 rounded-full text-xs font-medium <%= order_status_badge(@order.status) %>">
                <%= @order.status.titleize %>
              </span>
              <span class="text-stone-300">•</span>
              <p class="text-xs text-stone-500">Placed on <%= @order.placed_at&.strftime('%b %d, %Y at %I:%M %p') %></p>
            </div>
          </div>

          <!-- Desktop action buttons inline -->
          <div class="flex items-center gap-2">
            <a href="<%= orders_path %>" onclick="if (window.history.length > 1) { window.history.back(); return false; }" class="inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-stone-100 hover:bg-stone-200 text-stone-700 text-sm font-medium rounded-lg transition whitespace-nowrap">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
              Back
            </a>
            <%= link_to invoice_path(@order.order_number, format: :pdf), download: "Invoice_#{@order.order_number}.pdf", class: 'inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-rose-800 hover:bg-rose-900 text-white text-sm font-medium rounded-lg transition-colors whitespace-nowrap' do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              Invoice
            <% end %>

            <!-- More Actions Dropdown -->
            <div class="relative" data-controller="dropdown">
              <button type="button" data-action="click->dropdown#toggle click@window->dropdown#hide"
                      class="inline-flex items-center justify-center gap-1.5 px-4 py-2.5 bg-stone-100 hover:bg-stone-200 active:bg-stone-300 text-stone-700 text-sm font-medium rounded-lg transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"/>
                </svg>
                <span>More</span>
              </button>

              <!-- Dropdown Menu -->
              <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-stone-200 py-1 z-50">
                <%= link_to new_support_ticket_path(order_id: @order.id), class: 'flex items-center gap-2 px-4 py-2.5 text-sm text-stone-700 hover:bg-stone-50 transition' do %>
                  <svg class="w-4 h-4 text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                  </svg>
                  Need Help?
                <% end %>

                <% if @order.delivered? && @order_items.any? { |item| item.exchange_in_days.to_i > 0 } %>
                  <%= link_to new_support_ticket_path(order_id: @order.id, subject: "Exchange Request for #{@order.order_number}"), class: 'flex items-center gap-2 px-4 py-2.5 text-sm text-blue-700 hover:bg-blue-50 transition' do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                    Request Exchange
                  <% end %>
                <% end %>

                <% if @order.delivered? && @order_items.any? { |item| item.return_in_days.to_i > 0 } %>
                  <%= link_to new_support_ticket_path(order_id: @order.id, subject: "Return Request for #{@order.order_number}"), class: 'flex items-center gap-2 px-4 py-2.5 text-sm text-emerald-700 hover:bg-emerald-50 transition' do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 15v-1a4 4 0 00-4-4H8m0 0l3 3m-3-3l3-3m9 14V5a2 2 0 00-2-2H6a2 2 0 00-2 2v16l4-2 4 2 4-2 4 2z"/>
                    </svg>
                    Request Return
                  <% end %>
                <% end %>

                <% if @order.can_cancel? %>
                  <button type="button" data-cancel-order class="w-full flex items-center gap-2 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 transition text-left">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                    Cancel Order
                  </button>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Order Timeline - Mobile Optimized -->
      <% unless @order.cancelled? %>
        <div class="bg-white rounded-xl sm:rounded-2xl border border-stone-200 p-4 sm:p-5 lg:p-6 mb-4 sm:mb-6">
          <h2 class="text-sm sm:text-base font-sans font-semibold text-stone-900 mb-4 sm:mb-5">Order Status</h2>
          <div class="relative flex items-start justify-between">
            <% statuses = ['confirmed', 'processing', 'shipped', 'delivered'] %>
            <% current_index = statuses.index(@order.status) || -1 %>
            
            <!-- Progress Bar Background Line -->
            <div class="absolute top-3 sm:top-4 left-0 right-0 h-0.5 bg-stone-200 -z-0"></div>
            
            <!-- Progress Bar Fill Line (industry standard: fill up to current step) -->
            <% if current_index >= 0 %>
              <div class="absolute top-3 sm:top-4 left-0 h-0.5 bg-rose-800 -z-0 transition-all duration-500" style="width: <%= [(current_index.to_f / (statuses.length - 1) * 100), 100].min %>%;"></div>
            <% end %>
            
            <% statuses.each_with_index do |status, index| %>
              <div class="flex flex-col items-center relative z-[1]" style="width: <%= 100.0 / statuses.length %>%;">
                <!-- Step Circle - Mobile optimized -->
                <div class="w-6 h-6 sm:w-8 sm:h-8 rounded-full flex items-center justify-center text-xs sm:text-sm font-semibold transition-all duration-300 <%= index <= current_index ? 'bg-rose-800 text-white ring-2 sm:ring-4 ring-rose-100' : 'bg-stone-200 text-stone-500' %>">
                  <% if index < current_index %>
                    <!-- Completed step: checkmark -->
                    <svg class="w-3.5 h-3.5 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                  <% elsif index == current_index %>
                    <!-- Current step: filled with number -->
                    <%= index + 1 %>
                  <% else %>
                    <!-- Future step: outlined number -->
                    <%= index + 1 %>
                  <% end %>
                </div>
                <!-- Step Label - Mobile optimized -->
                <p class="mt-2 sm:mt-3 text-[9px] sm:text-xs text-center font-medium <%= index <= current_index ? 'text-rose-800' : 'text-stone-500' %> leading-tight px-0.5">
                  <%= status.titleize %>
                </p>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <!-- Cancelled Order Status -->
        <div class="mb-4 sm:mb-6 space-y-1">
          <p class="text-xs text-red-600">This order has been cancelled and will not be processed.</p>
          <% if @order.payment_status == 'paid' || @order.refund_status != 'not_refunded' %>
            <p class="text-xs text-stone-500">
              Refund:
              <% case @order.refund_status %>
              <% when 'not_refunded' %>
                <span class="text-amber-600 font-medium">Pending</span>
              <% when 'initiated' %>
                <span class="text-blue-600 font-medium">Processing</span>
                <% if @order.refund_initiated_at.present? %>
                  <span class="text-stone-400">&middot; Initiated <%= time_ago_in_words(@order.refund_initiated_at) %> ago</span>
                <% end %>
              <% when 'paid' %>
                <span class="text-emerald-600 font-medium">Refunded <%= format_price(@order.refund_amount) %></span>
                <% if @order.refund_paid_at.present? %>
                  <span class="text-stone-400">&middot; <%= @order.refund_paid_at.strftime('%b %d, %Y') %></span>
                <% end %>
              <% when 'failed' %>
                <span class="text-red-600 font-medium">Failed</span>
                <span class="text-stone-400">&middot; Please contact support</span>
              <% end %>
            </p>
          <% end %>
        </div>
      <% end %>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6">
        <div class="lg:col-span-2 space-y-4 sm:space-y-6">
          <!-- Order Items - Mobile Optimized -->
          <div class="bg-white rounded-xl sm:rounded-2xl border border-stone-200 p-4 sm:p-5 lg:p-6">
            <h2 class="text-sm sm:text-base font-sans font-semibold text-stone-900 mb-3 sm:mb-4">Order Items</h2>
            <ul class="divide-y divide-stone-100">
              <% @order_items.each do |item|
                tax_rate = item.product_variant&.product&.hsn_code&.gst_rate || 3.0
                item_tax = (item.total_price.to_f * tax_rate / 100.0).round(2)
              %>
                <li class="py-3 sm:py-4">
                  <div class="flex items-start gap-3 sm:gap-4">
                    <div class="w-14 h-14 sm:w-16 sm:h-16 lg:w-20 lg:h-20 bg-stone-100 rounded-lg flex-shrink-0 overflow-hidden">
                      <% if item.product_variant&.product&.images&.attached? %>
                        <%= image_tag item.product_variant.product.images.first, class: 'w-full h-full object-cover' %>
                      <% end %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="font-medium text-xs sm:text-sm lg:text-base text-stone-900 leading-snug"><%= item.product_name %></p>
                      <p class="text-[10px] sm:text-xs text-stone-500 mt-1">
                        <%= item.variant_name %>
                        <span class="ml-1 px-1.5 py-0.5 bg-blue-100 text-blue-700 rounded text-[9px] sm:text-[10px] font-medium">
                          <%= tax_rate %>% GST
                        </span>
                      </p>
                      <p class="text-[10px] sm:text-xs text-stone-500 mt-1">Qty: <%= item.quantity %> × <%= format_price(item.unit_price) %></p>
                    </div>
                    <div class="text-right flex-shrink-0">
                      <p class="font-semibold text-xs sm:text-sm lg:text-base text-stone-900"><%= format_price(item.total_price) %></p>
                      <p class="text-[9px] sm:text-xs text-stone-500 mt-0.5">+ <%= format_price(item_tax) %> tax</p>
                    </div>
                  </div>
                  
                  <% if @can_review && item.product_variant && !@reviewed_variants.include?(item.product_variant.product_id) %>
                    <div class="mt-3">
                      <%= link_to 'Write a Review', new_order_review_path(@order, product_id: item.product_variant.product_id), 
                          class: 'text-xs sm:text-sm text-rose-700 hover:text-rose-900 active:text-rose-950 font-medium' %>
                    </div>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>

          <!-- Shipping Address - Mobile Optimized -->
          <div class="bg-white rounded-xl sm:rounded-2xl border border-stone-200 p-4 sm:p-5 lg:p-6">
            <h2 class="text-sm sm:text-base font-sans font-semibold text-stone-900 mb-3 sm:mb-4">Shipping Address</h2>
            <% if @order.shipping_address %>
              <p class="font-medium text-xs sm:text-sm lg:text-base text-stone-900"><%= @order.shipping_address.full_name %></p>
              <p class="text-stone-600 text-xs sm:text-sm mt-1 leading-relaxed"><%= @order.shipping_address.full_address %></p>
              <% if @order.shipping_address.phone.present? %>
                <p class="text-stone-600 text-xs sm:text-sm mt-1"><%= @order.shipping_address.full_phone %></p>
              <% end %>
            <% end %>
          </div>
        </div>

        <div class="lg:col-span-1">
          <!-- Order Summary - Mobile Optimized with sticky on mobile -->
          <div class="bg-white rounded-xl sm:rounded-2xl border border-stone-200 p-4 sm:p-5 lg:p-6 lg:sticky lg:top-24">
            <h2 class="text-sm sm:text-base font-sans font-semibold text-stone-900 mb-3 sm:mb-4">Order Summary</h2>

            <!-- Vendor Information - Mobile Optimized -->
            <% if @order.vendor.present? %>
              <div class="mb-3 sm:mb-4 p-2.5 sm:p-3 bg-stone-50 rounded-lg border border-stone-200">
                <div class="flex items-center gap-2">
                  <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-stone-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                  </svg>
                  <div class="min-w-0">
                    <p class="text-[10px] sm:text-xs font-medium text-stone-700">Sold by</p>
                    <p class="text-xs sm:text-sm font-semibold text-stone-900 truncate"><%= @order.vendor.business_name %></p>
                  </div>
                </div>
              </div>
            <% end %>

            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-stone-600">Subtotal</span>
                <span class="text-stone-900 font-medium"><%= format_price(@order.subtotal) %></span>
              </div>
              <% if @order.discount_amount > 0 %>
                <div class="flex justify-between text-emerald-600">
                  <span>Discount<%= @order.coupon ? " (#{@order.coupon.code})" : '' %></span>
                  <span class="font-medium">-<%= format_price(@order.discount_amount) %></span>
                </div>
              <% end %>
              <div class="flex justify-between">
                <span class="text-stone-600">Shipping</span>
                <span class="font-medium <%= @order.shipping_amount > 0 ? 'text-stone-900' : 'text-emerald-600' %>"><%= @order.shipping_amount > 0 ? format_price(@order.shipping_amount) : 'Free' %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-stone-600">Tax</span>
                <span class="text-stone-900 font-medium"><%= format_price(@order.tax_amount) %></span>
              </div>
              
              <div class="border-t-2 border-stone-200 pt-2 mt-2 flex justify-between">
                <span class="font-bold text-stone-900">Total</span>
                <span class="font-bold text-stone-900 text-lg"><%= format_price(@order.total_amount) %></span>
              </div>
              <p class="text-xs text-stone-500 text-right">Inclusive of all taxes</p>
              
              <!-- View Detailed Breakdown - Mobile Optimized -->
              <div class="mt-3 pt-3 border-t border-stone-200">
                <button type="button" 
                        id="view-order-breakdown-btn"
                        class="text-xs sm:text-sm text-rose-700 hover:text-rose-900 active:text-rose-950 underline font-medium flex items-center gap-1">
                  <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  <span class="hidden sm:inline">View detailed pricing breakdown</span>
                  <span class="sm:hidden">View breakdown</span>
                </button>
              </div>
            </div>

            <!-- Payment Info & Actions - Mobile Optimized -->
            <div class="mt-4 sm:mt-5 space-y-3">
              <!-- Payment Method & Status - Compact Layout -->
              <div class="p-2.5 sm:p-3 bg-stone-50 rounded-lg">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <% if @order.payment_method == 'razorpay' %>
                      <svg class="w-4 h-4 sm:w-5 sm:h-5 text-blue-600 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                      </svg>
                    <% else %>
                      <svg class="w-4 h-4 sm:w-5 sm:h-5 text-stone-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a1 1 0 11-2 0 1 1 0 012 0z"/>
                      </svg>
                    <% end %>
                    <div class="min-w-0">
                      <p class="text-[10px] sm:text-xs text-stone-500">Payment</p>
                      <p class="text-xs sm:text-sm font-medium text-stone-900 truncate">
                        <% case @order.payment_method %>
                        <% when 'razorpay' %>
                          Online (Razorpay)
                        <% when 'cod' %>
                          Cash on Delivery
                        <% else %>
                          <%= @order.payment_method&.titleize || 'Not specified' %>
                        <% end %>
                      </p>
                    </div>
                  </div>
                  <span class="px-2 py-1 rounded text-[10px] sm:text-xs font-medium flex-shrink-0
                    <%= case @order.payment_status
                      when 'paid' then 'bg-emerald-100 text-emerald-700'
                      when 'pending' then 'bg-amber-100 text-amber-700'
                      when 'failed' then 'bg-red-100 text-red-700'
                      else 'bg-stone-100 text-stone-700'
                    end %>">
                    <%= @order.payment_status.titleize %>
                  </span>
                </div>
              </div>
              
              <!-- Refund Information -->
              <% if @order.refund_status != 'not_refunded' %>
                <div class="p-3 bg-stone-50 rounded-lg border border-stone-200">
                  <div class="flex items-center justify-between mb-2">
                    <p class="text-xs font-medium text-stone-700">Refund</p>
                    <span class="px-2 py-0.5 rounded text-xs font-medium
                      <%= case @order.refund_status
                        when 'initiated' then 'bg-amber-100 text-amber-700'
                        when 'paid' then 'bg-emerald-100 text-emerald-700'
                        when 'failed' then 'bg-red-100 text-red-700'
                        else 'bg-stone-100 text-stone-700'
                      end %>">
                      <%= @order.refund_status.titleize %>
                    </span>
                  </div>
                  <div class="flex justify-between items-center">
                    <span class="text-sm text-stone-600">Amount</span>
                    <span class="text-sm font-bold text-stone-900"><%= format_price(@order.refund_amount) %></span>
                  </div>
                  <% if @order.refund_paid_at.present? %>
                    <p class="text-xs text-stone-500 mt-1">Processed: <%= @order.refund_paid_at.strftime('%b %d, %Y') %></p>
                  <% elsif @order.refund_initiated_at.present? %>
                    <p class="text-xs text-stone-500 mt-1">Initiated: <%= @order.refund_initiated_at.strftime('%b %d, %Y') %></p>
                  <% end %>
                </div>
              <% end %>
            </div>

            <% if @order.shipped_at.present? %>
              <div class="mt-5 pt-5 border-t border-stone-200">
                <p class="text-sm font-medium text-stone-700 mb-3">Shipment Details</p>
                <div class="space-y-2 text-sm">
                  <% if @order.shipping_carrier.present? %>
                    <div class="flex justify-between">
                      <span class="text-stone-500">Carrier</span>
                      <span class="text-stone-700"><%= @order.shipping_carrier %></span>
                    </div>
                  <% end %>
                  <% if @order.tracking_number.present? %>
                    <div class="flex justify-between">
                      <span class="text-stone-500">Tracking #</span>
                      <span class="text-stone-700"><%= @order.tracking_number %></span>
                    </div>
                  <% end %>
                  <% if @order.tracking_url.present? %>
                    <div class="flex justify-between">
                      <span class="text-stone-500">Tracking</span>
                      <%= link_to 'Track package', @order.tracking_url, target: '_blank', rel: 'noopener', class: 'text-rose-700 hover:text-rose-900 font-medium' %>
                    </div>
                  <% end %>
                  <div class="flex justify-between">
                    <span class="text-stone-500">Shipped</span>
                    <span class="text-stone-700"><%= @order.shipped_at.strftime('%B %d, %Y') %></span>
                  </div>
                </div>
              </div>
            <% end %>

            <% if @order.cancelled? && @order.cancellation_reason.present? %>
              <div class="mt-5 pt-5 border-t border-stone-200">
                <p class="text-sm font-medium text-stone-700 mb-1">Cancellation Reason</p>
                <p class="text-sm text-stone-600"><%= @order.cancellation_reason %></p>
                <% if @order.cancelled_at.present? %>
                  <p class="text-xs text-stone-400 mt-1">Cancelled on <%= @order.cancelled_at.strftime('%B %d, %Y at %I:%M %p') %></p>
                <% end %>
              </div>
            <% end %>

            <% if @order.can_cancel? %>
              <!-- Cancel Order Modal - Mobile Optimized -->
              <div id="cancel-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-3 sm:p-4">
                <div class="bg-white rounded-2xl shadow-xl max-w-md w-full max-h-[90vh] overflow-y-auto">
                  <div class="p-4 sm:p-6">
                    <div class="flex items-center justify-between mb-3 sm:mb-4">
                      <h3 class="text-base sm:text-lg font-semibold text-stone-900">Cancel Order</h3>
                      <button type="button" id="close-cancel-modal" class="text-stone-400 hover:text-stone-600 active:text-stone-700 p-1">
                        <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                      </button>
                    </div>

                    <p class="text-xs sm:text-sm text-stone-600 mb-3 sm:mb-4">Please tell us why you're cancelling this order:</p>

                    <%= form_with url: cancel_order_path(@order), method: :patch, id: "cancel-order-form" do |f| %>
                      <div class="mb-3 sm:mb-4">
                        <select name="cancellation_reason" id="cancellation_reason" required
                                class="w-full px-3 py-2.5 sm:py-3 text-xs sm:text-sm border border-stone-300 rounded-lg bg-white text-stone-700 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:border-rose-400">
                          <option value="" disabled selected>Select a reason...</option>
                          <% Order::CANCELLATION_REASONS.each do |reason| %>
                            <option value="<%= reason %>"><%= reason %></option>
                          <% end %>
                        </select>
                      </div>

                      <% if @order.payment_method == 'razorpay' && @order.payment_status == 'paid' %>
                        <div class="mb-3 sm:mb-4 p-3 sm:p-4 bg-amber-50 border border-amber-200 rounded-lg">
                          <div class="flex items-start gap-2 sm:gap-3">
                            <svg class="w-4 h-4 sm:w-5 sm:h-5 text-amber-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <div>
                              <p class="text-xs sm:text-sm font-medium text-amber-900">Refund Information</p>
                              <p class="text-[10px] sm:text-xs text-amber-700 mt-1 leading-relaxed">
                                Since you paid online (<%= format_price(@order.total_amount) %>), your refund will be processed to your original payment method within 5-7 business days after the order is cancelled.
                              </p>
                            </div>
                          </div>
                        </div>
                      <% end %>

                      <div class="flex gap-2 sm:gap-3">
                        <button type="button" id="cancel-modal-cancel"
                                class="flex-1 px-4 py-2.5 sm:py-3 bg-stone-100 text-stone-700 text-xs sm:text-sm font-medium rounded-lg hover:bg-stone-200 active:bg-stone-300 transition">
                          Go Back
                        </button>
                        <button type="submit"
                                class="flex-1 px-4 py-2.5 sm:py-3 bg-red-600 text-white text-xs sm:text-sm font-medium rounded-lg hover:bg-red-700 active:bg-red-800 transition">
                          Confirm
                        </button>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>

          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Pricing Breakdown Modal - Mobile Optimized -->
  <div id="order-breakdown-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen p-3 sm:p-4">
      <div class="bg-white rounded-2xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
        <!-- Header - Mobile Optimized -->
        <div class="sticky top-0 bg-white border-b border-gray-200 px-4 sm:px-6 py-3 sm:py-4 flex items-center justify-between rounded-t-2xl z-10">
          <h3 class="text-base sm:text-lg font-semibold text-gray-900">Pricing Breakdown</h3>
          <button type="button" id="close-order-breakdown-modal" class="text-gray-400 hover:text-gray-600 active:text-gray-700 p-1">
            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        
        <!-- Content - Mobile Optimized -->
        <div class="p-4 sm:p-6 space-y-3 sm:space-y-4">
          <!-- Order Summary - Mobile Optimized -->
          <div class="bg-gray-50 border rounded-xl p-3 sm:p-4">
            <h4 class="text-xs sm:text-sm font-semibold text-gray-700 mb-2 sm:mb-3">Order Summary</h4>
            <div class="space-y-2">
              <div class="flex justify-between text-xs sm:text-sm">
                <span class="text-gray-600">Subtotal</span>
                <span class="font-medium text-gray-900"><%= format_price(@order.subtotal) %></span>
              </div>
              <% if @order.discount_amount.to_f > 0 %>
                <div class="flex justify-between text-xs sm:text-sm text-emerald-600">
                  <span>Discount</span>
                  <span class="font-medium">-<%= format_price(@order.discount_amount) %></span>
                </div>
              <% end %>
              <div class="flex justify-between text-xs sm:text-sm">
                <span class="text-gray-600">Shipping</span>
                <span class="font-medium text-gray-900"><%= @order.shipping_amount.to_f > 0 ? format_price(@order.shipping_amount) : 'FREE' %></span>
              </div>
            </div>
          </div>
          
          <!-- Tax Details - Mobile Optimized -->
          <% tax_data = @order.tax_breakdown_display %>
          <% if tax_data.present? && tax_data["summary"].present? %>
            <div class="bg-blue-50 border border-blue-200 rounded-xl p-3 sm:p-4">
              <h4 class="text-xs sm:text-sm font-semibold text-blue-900 mb-2 sm:mb-3">Tax Details (GST)</h4>
              <% tax_data["summary"].each do |tax| %>
                <div class="flex justify-between items-start sm:items-center py-2 border-t border-blue-100 first:border-0 first:pt-0 gap-2">
                  <div class="flex-1 min-w-0">
                    <span class="text-xs sm:text-sm text-blue-800 block">GST @ <%= tax['rate'] %>% (<%= tax['item_count'] %> items)</span>
                    <span class="text-[10px] sm:text-xs text-blue-600 block mt-0.5">Taxable: <%= format_price(tax['total_taxable']) %></span>
                  </div>
                  <span class="text-xs sm:text-sm font-medium text-blue-900 flex-shrink-0"><%= format_price(tax['total_tax']) %></span>
                </div>
              <% end %>
            </div>
          <% end %>
          
          <!-- Payment Details (for online payments) - Mobile Optimized -->
          <% if @order.razorpay? && @order.paid? %>
            <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-3 sm:p-4">
              <h4 class="text-xs sm:text-sm font-semibold text-indigo-900 mb-2 sm:mb-3 flex items-center gap-2">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                </svg>
                Payment Details
              </h4>
              <div class="space-y-2 text-xs sm:text-sm">
                <div class="flex justify-between items-center">
                  <span class="text-indigo-700">Payment Method</span>
                  <span class="font-medium text-indigo-900">Online (Razorpay)</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-indigo-700">Payment Status</span>
                  <span class="px-2 py-0.5 rounded text-[10px] sm:text-xs font-medium bg-emerald-100 text-emerald-700">Paid</span>
                </div>
                <% if @order.razorpay_payment_id.present? %>
                  <div class="pt-2 border-t border-indigo-200">
                    <span class="text-[10px] sm:text-xs text-indigo-600 block mb-1">Razorpay Payment ID</span>
                    <span class="font-mono text-[10px] sm:text-xs text-indigo-900 bg-white px-2 py-1 rounded border border-indigo-200 block break-all"><%= @order.razorpay_payment_id %></span>
                  </div>
                <% end %>
                <% if @order.razorpay_order_id.present? %>
                  <div class="pt-1">
                    <span class="text-[10px] sm:text-xs text-indigo-600 block mb-1">Razorpay Order ID</span>
                    <span class="font-mono text-[10px] sm:text-xs text-indigo-700 bg-white px-2 py-1 rounded border border-indigo-200 block break-all"><%= @order.razorpay_order_id %></span>
                  </div>
                <% end %>
                <div class="pt-2 mt-2 border-t border-indigo-200">
                  <p class="text-[10px] sm:text-xs text-indigo-600 leading-relaxed">
                    <span class="font-medium">Note:</span> Please save the Payment ID for your records. This may be required for any payment-related queries or refund requests.
                  </p>
                </div>
              </div>
            </div>
          <% elsif @order.cod? %>
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 sm:p-4">
              <h4 class="text-xs sm:text-sm font-semibold text-amber-900 mb-2 flex items-center gap-2">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a1 1 0 11-2 0 1 1 0 012 0z"/>
                </svg>
                Payment Details
              </h4>
              <div class="space-y-2 text-xs sm:text-sm">
                <div class="flex justify-between items-center">
                  <span class="text-amber-700">Payment Method</span>
                  <span class="font-medium text-amber-900">Cash on Delivery</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-amber-700">Amount to Pay</span>
                  <span class="font-medium text-amber-900"><%= format_price(@order.total_amount) %></span>
                </div>
                <p class="text-[10px] sm:text-xs text-amber-700 pt-2 border-t border-amber-200 leading-relaxed">
                  <span class="font-medium">Note:</span> Please keep exact change ready. Payment will be collected at the time of delivery.
                </p>
              </div>
            </div>
          <% end %>
          
          <!-- Total - Mobile Optimized -->
          <div class="border-t-2 border-gray-200 pt-3 sm:pt-4">
            <div class="flex justify-between items-center">
              <span class="text-sm sm:text-base lg:text-lg font-semibold text-gray-900">Total Amount Paid</span>
              <span class="text-lg sm:text-xl lg:text-2xl font-bold text-gray-900"><%= format_price(@order.total_amount) %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Pricing Breakdown Modal JavaScript -->
  <script>
    function initOrderPageModals() {
      // Pricing breakdown modal
      const breakdownBtn = document.getElementById('view-order-breakdown-btn');
      const breakdownModal = document.getElementById('order-breakdown-modal');
      const closeBreakdownBtn = document.getElementById('close-order-breakdown-modal');
      
      if (breakdownBtn && breakdownModal) {
        breakdownBtn.addEventListener('click', function() {
          breakdownModal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        });
      }
      
      if (closeBreakdownBtn && breakdownModal) {
        closeBreakdownBtn.addEventListener('click', function() {
          breakdownModal.classList.add('hidden');
          document.body.style.overflow = '';
        });
      }
      
      if (breakdownModal) {
        breakdownModal.addEventListener('click', function(e) {
          if (e.target === breakdownModal) {
            breakdownModal.classList.add('hidden');
            document.body.style.overflow = '';
          }
        });
      }

      // Cancel modal
      const cancelBtns = document.querySelectorAll('[data-cancel-order]');
      const cancelModal = document.getElementById('cancel-modal');
      const closeCancelModal = document.getElementById('close-cancel-modal');
      const cancelModalBtn = document.getElementById('cancel-modal-cancel');

      cancelBtns.forEach(function(btn) {
        if (cancelModal) {
          btn.addEventListener('click', function() {
            cancelModal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
          });
        }
      });

      if (closeCancelModal && cancelModal) {
        closeCancelModal.addEventListener('click', function() {
          cancelModal.classList.add('hidden');
          document.body.style.overflow = '';
        });
      }

      if (cancelModalBtn && cancelModal) {
        cancelModalBtn.addEventListener('click', function() {
          cancelModal.classList.add('hidden');
          document.body.style.overflow = '';
        });
      }

      // Close cancel modal when clicking outside
      if (cancelModal) {
        cancelModal.addEventListener('click', function(e) {
          if (e.target === cancelModal) {
            cancelModal.classList.add('hidden');
            document.body.style.overflow = '';
          }
        });
      }
    }

    // Initialize on both initial load and Turbo navigation
    document.addEventListener('DOMContentLoaded', initOrderPageModals);
    document.addEventListener('turbo:load', initOrderPageModals);
  </script>
</div>
