<% content_for(:title) { "My Orders" } %>

<div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-4 sm:py-6 lg:py-8">
  <div class="flex flex-col md:flex-row gap-4 md:gap-6">
    <!-- Sidebar - Hidden on mobile, shown on tablet+ -->
    <div class="hidden md:block w-64 flex-shrink-0">
      <%= render 'shared/account_sidebar', active_page: 'orders' %>
    </div>

    <div class="flex-1">
      <!-- Mobile-optimized header -->
      <div class="mb-4 sm:mb-6">
        <h1 class="text-xl sm:text-2xl font-sans font-semibold text-stone-900">My Orders</h1>
        <p class="text-xs sm:text-sm text-stone-600 mt-1">Track your purchases and view order details</p>
      </div>

      <!-- Mobile-optimized filter tabs with horizontal scroll -->
      <div class="mb-4 sm:mb-6 -mx-3 sm:mx-0">
        <div class="flex items-center gap-2 overflow-x-auto scrollbar-hide px-3 sm:px-0 pb-2 sm:pb-0">
          <% active_class = 'px-3 sm:px-4 py-2 sm:py-2.5 rounded-lg text-xs sm:text-sm font-medium border transition bg-rose-800 text-white border-rose-800 whitespace-nowrap flex-shrink-0 shadow-sm' %>
          <% inactive_class = 'px-3 sm:px-4 py-2 sm:py-2.5 rounded-lg text-xs sm:text-sm font-medium border transition bg-white text-stone-700 border-stone-200 hover:border-stone-300 active:bg-stone-50 whitespace-nowrap flex-shrink-0' %>
          <%= link_to 'All', orders_path, class: (@status.blank? ? active_class : inactive_class) %>
          <%= link_to 'Not Shipped', orders_path(status: 'not_shipped'), class: (@status == 'not_shipped' ? active_class : inactive_class) %>
          <%= link_to 'Shipped', orders_path(status: 'shipped'), class: (@status == 'shipped' ? active_class : inactive_class) %>
          <%= link_to 'Delivered', orders_path(status: 'delivered'), class: (@status == 'delivered' ? active_class : inactive_class) %>
          <%= link_to 'Cancelled', orders_path(status: 'cancelled'), class: (@status == 'cancelled' ? active_class : inactive_class) %>
        </div>
      </div>

      <% if @orders.any? %>
        <div class="space-y-3 sm:space-y-4">
          <% @orders.each do |order| %>
            <!-- Mobile-optimized order card with better touch targets -->
            <div class="bg-white rounded-xl sm:rounded-2xl border border-stone-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow active:scale-[0.99] sm:active:scale-100">
              <!-- Header section with improved mobile layout -->
              <div class="p-4 sm:p-5 border-b border-stone-100">
                <div class="flex items-start justify-between gap-3 mb-2">
                  <div class="flex-1 min-w-0">
                    <p class="font-semibold text-sm sm:text-base text-stone-900 truncate"><%= order.order_number %></p>
                    <p class="text-xs sm:text-sm text-stone-500 mt-0.5">Placed <%= order.placed_at&.strftime('%b %d, %Y') %></p>
                  </div>
                  <span class="px-2.5 sm:px-3 py-1 rounded-full text-[10px] sm:text-xs font-medium <%= order_status_badge(order.status) %> flex-shrink-0">
                    <%= order.status.titleize %>
                  </span>
                </div>
              </div>
              
              <!-- Content section -->
              <div class="p-4 sm:p-5">
                <!-- Order Items Summary with better mobile typography -->
                <div class="mb-3">
                  <p class="text-xs sm:text-sm text-stone-600 line-clamp-2 leading-relaxed">
                    <% items_list = order.order_items.map { |item| "#{item.product_name} (#{item.quantity})" } %>
                    <%= items_list.join(", ") %>
                  </p>
                </div>
                
                <!-- Footer with price and CTA -->
                <div class="flex items-center justify-between pt-3 border-t border-stone-100">
                  <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-2">
                    <span class="text-[10px] sm:text-xs text-stone-500 bg-stone-100 px-2 py-1 rounded inline-block w-fit">
                      <%= order.order_items.sum(:quantity) %> item<%= order.order_items.sum(:quantity) > 1 ? 's' : '' %>
                    </span>
                    <p class="font-bold text-base sm:text-lg text-stone-900"><%= format_price(order.total_amount) %></p>
                  </div>
                  <%= link_to order_path(order), class: 'inline-flex items-center gap-1.5 px-4 py-2 bg-rose-800 hover:bg-rose-900 active:bg-rose-950 text-white text-xs sm:text-sm font-medium rounded-lg transition-colors flex-shrink-0' do %>
                    <span>View</span>
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Mobile-optimized pagination -->
        <div class="mt-6 sm:mt-8">
          <%== @pagy.series_nav if @pagy.last > 1 %>
        </div>
      <% else %>
        <!-- Empty state -->
        <div class="flex items-center justify-center min-h-[calc(100vh-16rem)] sm:min-h-0 sm:py-16 px-4">
          <div class="w-full max-w-sm mx-auto border-2 border-dashed border-stone-200 rounded-2xl p-8 sm:p-10 bg-white/50">
            <div class="text-center">
              <div class="w-20 h-20 mx-auto mb-5 bg-amber-50 rounded-2xl flex items-center justify-center border border-amber-100">
                <svg class="w-9 h-9 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
              </div>
              <h2 class="text-lg font-semibold text-stone-900 mb-1">No orders yet</h2>
              <p class="text-sm text-stone-500 mb-6 leading-relaxed">Start shopping to see your<br class="sm:hidden"> orders here</p>
              <%= link_to 'Browse Jewellery', products_path, class: 'inline-block w-full px-6 py-3 bg-rose-800 text-white text-sm font-medium rounded-xl hover:bg-rose-900 transition' %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
