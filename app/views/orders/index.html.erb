<% content_for(:title) { "My Orders" } %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <h1 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900 mb-6 sm:mb-8">My Orders</h1>

  <% if @orders.any? %>
    <div class="space-y-4">
      <% @orders.each do |order| %>
        <div class="bg-white rounded-xl border border-stone-200 overflow-hidden">
          <div class="p-4 sm:p-6 border-b border-stone-100">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div>
                <p class="font-semibold text-stone-900"><%= order.order_number %></p>
                <p class="text-sm text-stone-500">Placed on <%= order.placed_at&.strftime('%B %d, %Y') %></p>
              </div>
              <div class="flex items-center gap-3">
                <span class="px-3 py-1 rounded-full text-xs font-medium <%= order_status_badge(order.status) %>">
                  <%= order.status.titleize %>
                </span>
                <%= link_to 'View Details', order_path(order), class: 'text-rose-700 hover:text-rose-900 text-sm font-medium' %>
              </div>
            </div>
          </div>
          <div class="p-4 sm:p-6">
            <div class="flex items-center gap-3 overflow-x-auto">
              <% order.order_items.limit(4).each do |item| %>
                <div class="w-14 h-14 sm:w-16 sm:h-16 bg-stone-100 rounded-lg flex-shrink-0 overflow-hidden">
                  <% if item.product_variant&.product&.images&.attached? %>
                    <%= image_tag item.product_variant.product.images.first, class: 'w-full h-full object-cover' %>
                  <% end %>
                </div>
              <% end %>
              <% if order.order_items.count > 4 %>
                <div class="w-14 h-14 sm:w-16 sm:h-16 bg-stone-100 rounded-lg flex-shrink-0 flex items-center justify-center text-stone-500 text-sm font-medium">
                  +<%= order.order_items.count - 4 %>
                </div>
              <% end %>
            </div>
            <div class="mt-4 flex items-center justify-between">
              <p class="text-sm text-stone-500"><%= order.order_items.count %> item(s)</p>
              <p class="font-semibold text-stone-900">Total: <%= format_price(order.total_amount) %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-8">
      <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
    </div>
  <% else %>
    <div class="text-center py-12 sm:py-16 bg-white rounded-xl border border-stone-200">
      <div class="w-20 h-20 mx-auto mb-4 bg-rose-50 rounded-full flex items-center justify-center">
        <svg class="w-10 h-10 text-rose-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
      </div>
      <h2 class="text-lg font-serif font-medium text-stone-900 mb-2">No orders yet</h2>
      <p class="text-stone-500 text-sm mb-6">Start shopping to see your orders here</p>
      <%= link_to 'Browse Jewellery', products_path, class: 'inline-block px-6 py-2.5 bg-rose-800 text-white font-medium rounded-full hover:bg-rose-900 transition' %>
    </div>
  <% end %>
</div>
