<% content_for(:title) { "Shipping Address" } %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <h1 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900 mb-6 sm:mb-8">Shipping Address</h1>

  <% if @addresses.any? %>
    <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6 mb-6">
      <h2 class="text-base font-serif font-semibold text-stone-900 mb-4">Select an Address</h2>
      <div class="space-y-3">
        <% @addresses.each do |address| %>
          <%= form_with url: address_checkout_path, method: :post do |f| %>
            <%= f.hidden_field :address_id, value: address.id %>
            <button type="submit" class="w-full text-left p-4 border border-stone-200 rounded-lg hover:border-rose-400 hover:bg-rose-50 transition">
              <div class="flex items-start justify-between">
                <div>
                  <p class="font-medium text-stone-900"><%= address.full_name %></p>
                  <p class="text-sm text-stone-600 mt-1"><%= address.full_address %></p>
                  <% if address.phone.present? %>
                    <p class="text-sm text-stone-600"><%= address.phone %></p>
                  <% end %>
                </div>
                <% if address.is_default? %>
                  <span class="px-2 py-1 bg-rose-100 text-rose-800 text-xs font-medium rounded">Default</span>
                <% end %>
              </div>
            </button>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- New Address Form -->
  <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6">
    <h2 class="text-base font-serif font-semibold text-stone-900 mb-4">
      <%= @addresses.any? ? 'Or Add a New Address' : 'Add Shipping Address' %>
    </h2>

    <%= form_with model: @address, url: address_checkout_path, method: :post, class: 'space-y-4' do |f| %>
      <% if @address.errors.any? %>
        <div class="rounded-lg bg-red-50 border border-red-200 p-4 mb-4">
          <ul class="text-sm text-red-700 list-disc list-inside">
            <% @address.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :first_name, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
          <%= f.text_field :first_name, required: true, placeholder: 'First name',
              class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
        </div>
        <div>
          <%= f.label :last_name, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
          <%= f.text_field :last_name, required: true, placeholder: 'Last name',
              class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
        </div>
      </div>

      <div>
        <%= f.label :phone, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
        <%= f.telephone_field :phone, placeholder: 'Phone number',
            class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
      </div>

      <div>
        <%= f.label :street_address, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
        <%= f.text_field :street_address, required: true, placeholder: 'Street address',
            class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
      </div>

      <div>
        <%= f.label :apartment, 'Apartment, suite, etc. (optional)', class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
        <%= f.text_field :apartment, placeholder: 'Apartment, suite, etc.',
            class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :city, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
          <%= f.text_field :city, required: true, placeholder: 'City',
              class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
        </div>
        <div>
          <%= f.label :state, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
          <%= f.text_field :state, required: true, placeholder: 'State',
              class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :postal_code, 'PIN Code', class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
          <%= f.text_field :postal_code, required: true, placeholder: 'PIN code',
              class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
        </div>
        <div>
          <%= f.label :country, class: 'block text-sm font-medium text-stone-700 mb-1.5' %>
          <%= f.text_field :country, value: @address.country || 'India', required: true,
              class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
        </div>
      </div>

      <div class="flex items-center">
        <%= f.check_box :is_default, class: 'h-4 w-4 text-rose-700 focus:ring-rose-400 border-stone-300 rounded' %>
        <%= f.label :is_default, 'Set as default address', class: 'ml-2 text-sm text-stone-600' %>
      </div>

      <%= f.submit 'Continue', class: 'w-full py-3 px-4 bg-rose-800 text-white font-medium rounded-lg hover:bg-rose-900 transition cursor-pointer' %>
    <% end %>
  </div>
</div>
