<% content_for(:title) { "Shipping Address" } %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-8">Shipping Address</h1>

  <% if @addresses.any? %>
    <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Select an Address</h2>
      <div class="space-y-4">
        <% @addresses.each do |address| %>
          <%= form_with url: address_checkout_path, method: :post do |f| %>
            <%= f.hidden_field :address_id, value: address.id %>
            <button type="submit" class="w-full text-left p-4 border border-gray-200 rounded-lg hover:border-indigo-500 hover:bg-indigo-50 transition">
              <div class="flex items-start justify-between">
                <div>
                  <p class="font-medium text-gray-900"><%= address.full_name %></p>
                  <p class="text-sm text-gray-600"><%= address.full_address %></p>
                  <% if address.phone.present? %>
                    <p class="text-sm text-gray-600"><%= address.phone %></p>
                  <% end %>
                </div>
                <% if address.is_default? %>
                  <span class="px-2 py-1 bg-indigo-100 text-indigo-800 text-xs font-medium rounded">Default</span>
                <% end %>
              </div>
            </button>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- New Address Form -->
  <div class="bg-white rounded-lg shadow-sm p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">
      <%= @addresses.any? ? 'Or Add a New Address' : 'Add Shipping Address' %>
    </h2>

    <%= form_with model: @address, url: address_checkout_path, method: :post, class: 'space-y-4' do |f| %>
      <% if @address.errors.any? %>
        <div class="rounded-md bg-red-50 p-4 mb-4">
          <ul class="text-sm text-red-700 list-disc list-inside">
            <% @address.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :first_name, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :first_name, required: true, class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
        </div>
        <div>
          <%= f.label :last_name, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :last_name, required: true, class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
        </div>
      </div>

      <div>
        <%= f.label :phone, class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.telephone_field :phone, class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
      </div>

      <div>
        <%= f.label :street_address, class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.text_field :street_address, required: true, class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
      </div>

      <div>
        <%= f.label :apartment, 'Apartment, suite, etc. (optional)', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.text_field :apartment, class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :city, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :city, required: true, class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
        </div>
        <div>
          <%= f.label :state, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :state, required: true, class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :postal_code, 'ZIP / Postal Code', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :postal_code, required: true, class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
        </div>
        <div>
          <%= f.label :country, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :country, value: @address.country || 'US', required: true, class: 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent' %>
        </div>
      </div>

      <div class="flex items-center">
        <%= f.check_box :is_default, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
        <%= f.label :is_default, 'Set as default address', class: 'ml-2 text-sm text-gray-600' %>
      </div>

      <%= f.submit 'Continue', class: 'w-full py-3 px-4 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition cursor-pointer' %>
    <% end %>
  </div>
</div>
