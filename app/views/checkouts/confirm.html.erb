<% content_for(:title) { "Review Order" } %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <h1 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900 mb-6 sm:mb-8">Review Your Order</h1>

  <%= form_with url: checkout_path, method: :post do |f| %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
      <div class="lg:col-span-2 space-y-6">
        <!-- Shipping Address -->
        <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-serif font-semibold text-stone-900">Shipping Address</h2>
            <%= link_to 'Change', address_checkout_path, class: 'text-sm text-rose-700 hover:text-rose-900 font-medium' %>
          </div>
          <div class="p-4 bg-stone-50 rounded-lg">
            <p class="font-medium text-stone-900"><%= @address.full_name %></p>
            <p class="text-stone-600 text-sm mt-1"><%= @address.full_address %></p>
            <% if @address.phone.present? %>
              <p class="text-stone-600 text-sm"><%= @address.phone %></p>
            <% end %>
          </div>
        </div>

        <!-- Order Items -->
        <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6">
          <h2 class="text-base font-serif font-semibold text-stone-900 mb-4">Order Items</h2>
          <ul class="divide-y divide-stone-100">
            <% @cart.cart_items.each do |item| %>
              <li class="py-4 flex items-center gap-4">
                <div class="w-16 h-16 bg-stone-100 rounded-lg flex-shrink-0 overflow-hidden">
                  <% if item.product_variant.product.images.attached? %>
                    <%= image_tag item.product_variant.product.images.first, class: 'w-full h-full object-cover' %>
                  <% end %>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-stone-900"><%= item.product_variant.product.name %></p>
                  <p class="text-sm text-stone-500"><%= item.product_variant.name %> × <%= item.quantity %></p>
                </div>
                <p class="font-medium text-stone-900"><%= format_price(item.total_price) %></p>
              </li>
            <% end %>
          </ul>
        </div>

        <!-- Order Notes -->
        <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6">
          <h2 class="text-base font-serif font-semibold text-stone-900 mb-4">Order Notes (Optional)</h2>
          <%= f.text_area :notes, rows: 3, placeholder: 'Any special instructions for your order...', 
              class: 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:ring-2 focus:ring-rose-400 focus:border-transparent text-sm' %>
        </div>
      </div>

      <!-- Order Summary -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-xl border border-stone-200 p-5 sm:p-6 lg:sticky lg:top-24">
          <h2 class="text-base font-serif font-semibold text-stone-900 mb-4">Order Summary</h2>
          
          <div class="space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-stone-600">Subtotal</span>
              <span class="text-stone-900"><%= format_price(@subtotal) %></span>
            </div>
            <% if @discount > 0 %>
              <div class="flex justify-between text-emerald-600">
                <span>Discount (<%= @coupon.code %>)</span>
                <span>-<%= format_price(@discount) %></span>
              </div>
            <% end %>
            <div class="flex justify-between">
              <span class="text-stone-600">Shipping</span>
              <span class="text-emerald-600 font-medium">Free</span>
            </div>
            <div class="border-t border-stone-200 pt-2 flex justify-between">
              <span class="font-semibold text-stone-900">Total</span>
              <span class="font-semibold text-stone-900 text-lg"><%= format_price(@total) %></span>
            </div>
          </div>

          <div class="mt-5 p-4 bg-amber-50 border border-amber-200 rounded-lg">
            <p class="text-sm text-amber-800">
              <span class="font-medium">Cash on Delivery:</span> Pay when you receive your order
            </p>
          </div>

          <%= f.submit 'Place Order', class: 'mt-5 w-full py-3 px-4 bg-rose-800 text-white font-medium rounded-lg hover:bg-rose-900 transition cursor-pointer' %>
          
          <p class="mt-4 text-xs text-stone-500 text-center">
            By placing this order, you agree to our Terms of Service and Privacy Policy
          </p>
        </div>
      </div>
    </div>
  <% end %>
</div>
