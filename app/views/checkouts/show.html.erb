<% content_for(:title) { "Checkout" } %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-8">Checkout</h1>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">
      <!-- Shipping Address -->
      <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900">Shipping Address</h2>
          <%= link_to 'Change', address_checkout_path, class: 'text-sm text-indigo-600 hover:text-indigo-800' %>
        </div>

        <% if @selected_address %>
          <div class="p-4 bg-gray-50 rounded-lg">
            <p class="font-medium text-gray-900"><%= @selected_address.full_name %></p>
            <p class="text-gray-600"><%= @selected_address.full_address %></p>
            <% if @selected_address.phone.present? %>
              <p class="text-gray-600"><%= @selected_address.phone %></p>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500">No address selected.</p>
          <%= link_to 'Add Address', address_checkout_path, class: 'mt-2 inline-block text-indigo-600 hover:text-indigo-800' %>
        <% end %>
      </div>

      <!-- Payment Method -->
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Payment Method</h2>
        <div class="p-4 bg-gray-50 rounded-lg flex items-center gap-3">
          <svg class="w-8 h-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <div>
            <p class="font-medium text-gray-900">Cash on Delivery</p>
            <p class="text-sm text-gray-500">Pay when you receive your order</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Order Summary -->
    <div class="lg:col-span-1">
      <div class="bg-white rounded-lg shadow-sm p-6 sticky top-24">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Order Summary</h2>
        
        <div class="space-y-4 mb-6">
          <% current_cart.cart_items.each do |item| %>
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-gray-100 rounded flex-shrink-0">
                <% if item.product_variant.product.images.attached? %>
                  <%= image_tag item.product_variant.product.images.first, class: 'w-full h-full object-cover rounded' %>
                <% end %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate"><%= item.product_variant.product.name %></p>
                <p class="text-xs text-gray-500">x<%= item.quantity %></p>
              </div>
              <p class="text-sm font-medium"><%= format_price(item.total_price) %></p>
            </div>
          <% end %>
        </div>

        <% coupon = session[:coupon_id] ? Coupon.find_by(id: session[:coupon_id]) : nil %>
        <% subtotal = current_cart.subtotal %>
        <% discount = coupon&.calculate_discount(subtotal) || 0 %>
        <% total = subtotal - discount %>

        <div class="border-t border-gray-200 pt-4 space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-600">Subtotal</span>
            <span><%= format_price(subtotal) %></span>
          </div>
          <% if discount > 0 %>
            <div class="flex justify-between text-green-600">
              <span>Discount (<%= coupon.code %>)</span>
              <span>-<%= format_price(discount) %></span>
            </div>
          <% end %>
          <div class="flex justify-between">
            <span class="text-gray-600">Shipping</span>
            <span>Free</span>
          </div>
          <div class="border-t border-gray-200 pt-2 flex justify-between text-lg font-semibold">
            <span>Total</span>
            <span><%= format_price(total) %></span>
          </div>
        </div>

        <% if @selected_address %>
          <%= link_to 'Continue to Review', confirm_checkout_path, class: 'mt-6 block w-full py-3 px-4 bg-indigo-600 text-white text-center font-semibold rounded-lg hover:bg-indigo-700 transition' %>
        <% else %>
          <%= link_to 'Select Address', address_checkout_path, class: 'mt-6 block w-full py-3 px-4 bg-indigo-600 text-white text-center font-semibold rounded-lg hover:bg-indigo-700 transition' %>
        <% end %>
      </div>
    </div>
  </div>
</div>
