<!-- Razorpay Checkout Script -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  (function() {
    function initCheckout() {
      const form = document.getElementById('checkout-form');
      const submitBtn = document.getElementById('place-order-btn');
      const submitBtnMobile = document.getElementById('place-order-btn-mobile');
      const paymentCod = document.getElementById('payment_cod');
      const paymentRazorpay = document.getElementById('payment_razorpay');

      // --- Collapsible items section (mobile) ---
      const toggleItemsBtn = document.getElementById('toggle-items-btn');
      const itemsBody = document.getElementById('items-body');
      const itemsChevron = document.getElementById('items-chevron');
      const itemsThumbPreview = document.getElementById('items-thumb-preview');

      if (toggleItemsBtn && itemsBody) {
        toggleItemsBtn.addEventListener('click', function() {
          const isHidden = itemsBody.classList.contains('hidden');
          if (isHidden) {
            itemsBody.classList.remove('hidden');
            if (itemsChevron) itemsChevron.classList.add('rotate-180');
            if (itemsThumbPreview) itemsThumbPreview.classList.add('hidden');
          } else {
            itemsBody.classList.add('hidden');
            if (itemsChevron) itemsChevron.classList.remove('rotate-180');
            if (itemsThumbPreview) itemsThumbPreview.classList.remove('hidden');
          }
        });
      }
      
      // Address modal elements
      const changeAddressBtn = document.getElementById('change-address-btn');
      const closeAddressModal = document.getElementById('close-address-modal');
      const addressModal = document.getElementById('address-modal');
      const addressDisplay = document.getElementById('address-display');
      const addressOptions = document.querySelectorAll('.address-option');
      const addressDetails = document.getElementById('address-details');
      
      // Address modal toggle with bottom sheet animation
      const addressModalContent = document.getElementById('address-modal-content');
      
      // Swipe gesture variables
      let touchStartY = 0;
      let touchCurrentY = 0;
      let isDragging = false;
      
      if (changeAddressBtn && addressModal) {
        changeAddressBtn.addEventListener('click', function() {
          addressModal.classList.remove('hidden');
          if (addressDisplay) addressDisplay.classList.add('hidden');
          // Trigger animation after display
          setTimeout(() => {
            if (addressModalContent) {
              addressModalContent.classList.remove('translate-y-full');
            }
          }, 10);
          document.body.classList.add('overflow-hidden');
        });
      }
      
      function closeModal() {
        if (addressModalContent) {
          addressModalContent.classList.add('translate-y-full');
        }
        setTimeout(() => {
          if (addressModal) addressModal.classList.add('hidden');
          if (addressDisplay) addressDisplay.classList.remove('hidden');
          document.body.classList.remove('overflow-hidden');
        }, 300);
      }
      
      if (closeAddressModal) {
        closeAddressModal.addEventListener('click', closeModal);
      }
      
      // Close on backdrop click (mobile only)
      if (addressModal) {
        addressModal.addEventListener('click', function(e) {
          if (e.target === addressModal && window.innerWidth < 1024) {
            closeModal();
          }
        });
      }
      
      // Swipe-down gesture to close modal
      if (addressModalContent) {
        addressModalContent.addEventListener('touchstart', function(e) {
          touchStartY = e.touches[0].clientY;
          isDragging = false;
        }, { passive: true });
        
        addressModalContent.addEventListener('touchmove', function(e) {
          if (!touchStartY) return;
          
          touchCurrentY = e.touches[0].clientY;
          const deltaY = touchCurrentY - touchStartY;
          
          // Only allow dragging down
          if (deltaY > 0) {
            isDragging = true;
            
            // Check if content is scrolled to top
            const scrollableContent = addressModalContent.querySelector('#address-list');
            if (scrollableContent && scrollableContent.scrollTop > 0) {
              return; // Let the content scroll naturally
            }
            
            e.preventDefault();
            
            // Apply transform with resistance
            const resistance = 0.5;
            const translateY = deltaY * resistance;
            addressModalContent.style.transform = `translateY(${translateY}px)`;
            addressModalContent.style.transition = 'none';
          }
        }, { passive: false });
        
        addressModalContent.addEventListener('touchend', function(e) {
          if (!isDragging) return;
          
          const deltaY = touchCurrentY - touchStartY;
          const threshold = 100; // pixels to swipe down to close
          
          addressModalContent.style.transition = '';
          
          if (deltaY > threshold) {
            // Close the modal
            closeModal();
          } else {
            // Snap back to original position
            addressModalContent.style.transform = '';
          }
          
          touchStartY = 0;
          touchCurrentY = 0;
          isDragging = false;
        }, { passive: true });
      }
      
      // Address selection with loading state
      addressOptions.forEach(option => {
        option.addEventListener('click', function() {
          const token = this.dataset.addressToken;
          
          // Show loading state
          this.style.opacity = '0.5';
          this.style.pointerEvents = 'none';
          
          // Create a form and submit it to save the address
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = '/checkout/address';
          form.style.display = 'none';
          
          // Add CSRF token
          const csrfToken = document.querySelector('[name="csrf-token"]')?.content;
          if (csrfToken) {
            const csrfInput = document.createElement('input');
            csrfInput.type = 'hidden';
            csrfInput.name = 'authenticity_token';
            csrfInput.value = csrfToken;
            form.appendChild(csrfInput);
          }
          
          // Add address token
          const tokenInput = document.createElement('input');
          tokenInput.type = 'hidden';
          tokenInput.name = 'address_token';
          tokenInput.value = token;
          form.appendChild(tokenInput);
          
          document.body.appendChild(form);
          form.submit();
        });
      });
      
      if (!form || (!submitBtn && !submitBtnMobile)) return;

      // Helper to set value on both buttons
      function setButtonText(text) {
        if (submitBtn) submitBtn.value = text;
        if (submitBtnMobile) submitBtnMobile.value = text;
      }

      // Update UI based on payment selection
      function updatePaymentUI() {
        const paymentOptions = document.querySelectorAll('.payment-option');

        paymentOptions.forEach(option => {
          const radio = option.querySelector('input[type="radio"]');
          const checkIcon = option.querySelector('.check-icon');

          if (radio && radio.checked) {
            option.classList.add('border-rose-500', 'bg-rose-50', 'ring-2', 'ring-rose-200');
            option.classList.remove('border-stone-200');
            if (checkIcon) checkIcon.classList.remove('opacity-0');

            if (radio.id === 'payment_cod') {
              setButtonText('Place Order');
            } else if (radio.id === 'payment_razorpay') {
              setButtonText('Proceed to Payment');
            }
          } else {
            option.classList.remove('border-rose-500', 'bg-rose-50', 'ring-2', 'ring-rose-200');
            option.classList.add('border-stone-200');
            if (checkIcon) checkIcon.classList.add('opacity-0');
          }
        });
      }

      // Add event listeners to payment options
      if (paymentCod) {
        paymentCod.addEventListener('change', updatePaymentUI);
      }
      if (paymentRazorpay) {
        paymentRazorpay.addEventListener('change', updatePaymentUI);
      }

      // Helper to disable/enable all submit buttons
      function setButtonsLoading(loading) {
        [submitBtn, submitBtnMobile].forEach(btn => {
          if (!btn) return;
          btn.disabled = loading;
          if (loading) {
            btn.value = 'Processing...';
            btn.classList.add('opacity-75');
          } else {
            btn.classList.remove('opacity-75');
          }
        });
      }

      // Form submission handler
      form.addEventListener('submit', async function(e) {
        // Check if Razorpay is selected
        if (paymentRazorpay && paymentRazorpay.checked) {
          e.preventDefault();
          e.stopPropagation();

          setButtonsLoading(true);

          try {
            const formData = new FormData(form);

            const response = await fetch('/checkout', {
              method: 'POST',
              headers: {
                'X-CSRF-Token': document.querySelector('[name="csrf-token"]')?.content || '',
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
              },
              body: formData
            });

            const contentType = response.headers.get('content-type');

            if (!contentType || !contentType.includes('application/json')) {
              const text = await response.text();
              console.error('Non-JSON response:', text.substring(0, 500));
              throw new Error('Server returned an error. Please try again.');
            }

            const data = await response.json();

            if (!data.success) {
              throw new Error(data.error || 'Failed to create order');
            }

            if (!data.razorpay_key || !data.razorpay_order_id) {
              throw new Error('Invalid response from server');
            }

            const options = {
              key: data.razorpay_key,
              order_id: data.razorpay_order_id,
              amount: data.amount,
              currency: data.currency || 'INR',
              name: data.name || 'Noralooks',
              description: data.description || 'Order Payment',
              image: '/logo.png',
              prefill: data.prefill || {},
              notes: data.notes || {},
              theme: {
                color: '#9f1239'
              },
              modal: {
                ondismiss: function() {
                  setButtonsLoading(false);
                  setButtonText('Proceed to Payment');
                }
              },
              handler: function(response) {
                const params = new URLSearchParams({
                  razorpay_payment_id: response.razorpay_payment_id,
                  razorpay_order_id: response.razorpay_order_id,
                  razorpay_signature: response.razorpay_signature
                });
                window.location.href = `/razorpay/success?${params.toString()}`;
              }
            };

            const rzp = new Razorpay(options);

            rzp.on('payment.failed', function(response) {
              const params = new URLSearchParams({
                razorpay_order_id: response.error.metadata.order_id,
                error_description: response.error.description
              });
              window.location.href = `/razorpay/failure?${params.toString()}`;
            });

            rzp.open();

          } catch (error) {
            console.error('Payment Error:', error);
            alert('Error: ' + error.message);
            setButtonsLoading(false);
            setButtonText('Proceed to Payment');
          }
        }
        // If COD, let the form submit normally
      });

      // Initial UI update - ensure correct state on page load
      updatePaymentUI();
      
      // Force initial selection styling for Razorpay if it's the default
      if (paymentRazorpay && paymentRazorpay.checked) {
        const razorpayOption = document.querySelector('[data-payment-method="razorpay"]');
        if (razorpayOption) {
          razorpayOption.classList.add('border-rose-500', 'bg-rose-50', 'ring-2', 'ring-rose-200');
          razorpayOption.classList.remove('border-stone-200');
          const checkIcon = razorpayOption.querySelector('.check-icon');
          if (checkIcon) checkIcon.classList.remove('opacity-0');
        }
        setButtonText('Proceed to Payment');
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCheckout);
    } else {
      initCheckout();
    }
  })();
</script>

<!-- Pricing Breakdown Modal JavaScript -->
<script>
  (function() {
    const breakdownBtn = document.getElementById('view-breakdown-btn');
    const breakdownModal = document.getElementById('pricing-breakdown-modal');
    const closeBreakdownBtn = document.getElementById('close-breakdown-modal');
    
    // Prevent duplicate listeners on Turbo navigation
    if (breakdownBtn && breakdownBtn.dataset.initialized === 'true') return;
    if (breakdownBtn) breakdownBtn.dataset.initialized = 'true';
    
    if (breakdownBtn && breakdownModal) {
      breakdownBtn.addEventListener('click', function() {
        breakdownModal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });
    }
    
    if (closeBreakdownBtn && breakdownModal) {
      closeBreakdownBtn.addEventListener('click', function() {
        breakdownModal.classList.add('hidden');
        document.body.style.overflow = '';
      });
    }
    
    if (breakdownModal) {
      breakdownModal.addEventListener('click', function(e) {
        if (e.target === breakdownModal) {
          breakdownModal.classList.add('hidden');
          document.body.style.overflow = '';
        }
      });
    }
  })();
</script>
