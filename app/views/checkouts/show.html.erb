<% content_for(:title) { "Checkout" } %>
<% content_for(:native_title) { "Checkout" } %>
<%= stylesheet_link_tag "https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.19/css/intlTelInput.css", "data-turbo-track": "reload" %>
<% store_setting = StoreSetting.instance %>
<% enable_razorpay = store_setting.razorpay_enabled? %>
<% enable_cod = store_setting.cod_enabled? %>
<% any_payment_enabled = store_setting.any_payment_method_enabled? %>

<div class="max-w-7xl mx-auto px-3 sm:px-4 md:px-6 lg:px-8 py-3 sm:py-6 md:py-8">
  <div class="flex items-center gap-2 mb-3 sm:mb-6 md:mb-8">
    <%= link_to cart_path, class: 'inline-flex items-center justify-center w-8 h-8 -ml-1 rounded-full hover:bg-stone-100 transition text-stone-700' do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="text-base sm:text-xl md:text-2xl font-sans font-semibold text-stone-900">Checkout</h1>
  </div>

  <% if !@address %>
    <!-- No Address State - Show Address Selection First -->
    <%= render 'address_selection' %>
  <% else %>
    <!-- Full Checkout Form -->
    <%= form_with url: checkout_path, method: :post, id: "checkout-form", 
        data: { turbo: false },
        class: "contents" do |f| %>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 sm:gap-6 md:gap-8">
        <!-- Left Column: Address, Payment, Items -->
        <div class="md:col-span-2 space-y-3 sm:space-y-6 pb-[140px] md:pb-0">
          
          <!-- Delivery Address -->
          <div class="bg-white rounded-lg sm:rounded-xl border border-stone-200 p-3 sm:p-5 md:p-6" id="address-display">
            <div class="flex items-center justify-between mb-2 sm:mb-3">
              <h2 class="text-sm sm:text-base font-sans font-semibold text-stone-900">Deliver to</h2>
              <button type="button"
                      id="change-address-btn"
                      class="text-[11px] sm:text-xs text-stone-500 hover:text-rose-700 font-medium whitespace-nowrap flex-shrink-0 border border-stone-300 rounded px-2 py-0.5 transition">
                Change
              </button>
            </div>
            <div class="flex items-start gap-2">
              <div class="w-7 h-7 sm:w-10 sm:h-10 bg-emerald-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 sm:w-5 sm:h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div id="address-details" class="flex-1 min-w-0">
                <p class="text-xs sm:text-sm font-semibold text-stone-900"><%= @address.full_name %></p>
                <p class="text-xs sm:text-sm text-stone-600 mt-0.5 line-clamp-2"><%= @address.full_address %></p>
              </div>
            </div>
            <!-- Dispatch Info -->
            <div class="mt-2.5 sm:mt-3 pt-2.5 sm:pt-3 border-t border-stone-100 flex items-start gap-2.5">
              <div class="w-7 h-7 sm:w-8 sm:h-8 bg-emerald-50 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs sm:text-sm font-semibold text-emerald-700">24-Hour Dispatch</p>
                <p class="text-[11px] sm:text-xs text-stone-500 mt-0.5">Estimated delivery in 3–7 business days</p>
              </div>
            </div>
          </div>

          <!-- Address Selection Modal (Hidden by default) -->
          <div id="address-modal" class="hidden fixed inset-0 md:relative md:inset-auto bg-black/40 md:bg-transparent z-50 md:z-auto">
            <div class="fixed bottom-0 left-0 right-0 md:relative bg-white rounded-t-3xl md:rounded-xl border-2 border-rose-200 md:border-rose-200 p-4 sm:p-5 md:p-6 shadow-lg max-h-[85vh] md:max-h-none overflow-y-auto transform translate-y-full md:translate-y-0 transition-transform duration-300 ease-out" id="address-modal-content">
              <!-- Drag Handle (Mobile Only) -->
              <div class="md:hidden flex justify-center py-2 -mt-2 mb-2">
                <div class="w-12 h-1 bg-stone-300 rounded-full"></div>
              </div>
              
              <div class="flex items-center justify-between mb-3 sm:mb-4">
                <h2 class="text-base sm:text-lg font-sans font-semibold text-stone-900">Select Address</h2>
                <button type="button" 
                        id="close-address-modal"
                        class="text-stone-400 hover:text-stone-600">
                  <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                </button>
              </div>
            
            <div id="address-list" class="space-y-2 sm:space-y-3 mb-4 sm:mb-6 max-h-96 overflow-y-auto">
              <% current_customer.addresses.default_first.each do |addr| %>
                <% is_selected = addr.id == @address.id %>
                <button type="button"
                        data-address-id="<%= addr.id %>"
                        data-address-token="<%= addr.token %>"
                        class="address-option w-full text-left p-3 sm:p-4 border-2 rounded-lg sm:rounded-xl hover:border-rose-500 hover:bg-rose-50 transition group <%= is_selected ? 'border-rose-500 bg-rose-50 ring-2 ring-rose-100' : 'border-stone-200' %>">
                  <div class="flex items-start justify-between">
                    <div class="flex items-start gap-1.5 sm:gap-2 w-full">
                      <div class="w-8 h-8 sm:w-10 sm:h-10 <%= is_selected ? 'bg-rose-100' : 'bg-stone-100' %> rounded-full flex items-center justify-center flex-shrink-0">
                        <svg class="w-4 h-4 sm:w-5 sm:h-5 <%= is_selected ? 'text-rose-600' : 'text-stone-600' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between">
                          <div class="flex items-center gap-1.5 sm:gap-2">
                            <p class="text-sm sm:text-base font-semibold text-stone-900"><%= addr.full_name %></p>
                            <span class="current-badge text-[10px] sm:text-xs bg-rose-100 text-rose-700 px-1.5 sm:px-2 py-0.5 rounded <%= is_selected ? '' : 'hidden' %>">Selected</span>
                          </div>
                          <% if addr.is_default? %>
                            <span class="text-[10px] sm:text-xs bg-emerald-100 text-emerald-700 px-1.5 sm:px-2 py-0.5 sm:py-1 rounded flex-shrink-0">Default</span>
                          <% end %>
                        </div>
                        <p class="text-xs sm:text-sm text-stone-600 mt-0.5 sm:mt-1 break-words"><%= addr.full_address %></p>
                        <% if addr.phone.present? %>
                          <p class="text-xs sm:text-sm text-stone-500 mt-0.5 sm:mt-1">📞 <%= addr.full_phone %></p>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </button>
              <% end %>
            </div>
            
              <div class="border-t border-stone-200 pt-3 sm:pt-4">
                <%= link_to new_address_path(redirect_to: 'checkout'), class: "w-full py-3 px-4 bg-rose-800 text-white text-center font-medium rounded-lg hover:bg-rose-900 transition flex items-center justify-center gap-2" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                  </svg>
                  Add New Address
                <% end %>
              </div>
            </div>
          </div>

          <!-- Payment Method -->
          <div class="bg-white rounded-lg sm:rounded-xl border border-stone-200 p-3 sm:p-6" id="payment-section">
            <h2 class="text-sm sm:text-base font-sans font-semibold text-stone-900 mb-2 sm:mb-4">Payment</h2>
            
            <% if any_payment_enabled %>
              <div class="space-y-2 sm:space-y-3">
                <%# Razorpay First (Default when both enabled) %>
                <% if enable_razorpay %>
                  <label class="payment-option relative flex items-center p-2.5 sm:p-4 border-2 border-stone-200 rounded-lg sm:rounded-xl cursor-pointer transition-all hover:border-stone-300 <%= 'border-rose-500 bg-rose-50 ring-2 ring-rose-200' if enable_razorpay %>" data-payment-method="razorpay">
                    <%= f.radio_button :payment_method, 'razorpay', 
                        checked: true,
                        class: 'sr-only', 
                        id: 'payment_razorpay' %>
                    <div class="flex items-center gap-2 sm:gap-4 w-full">
                      <div class="w-8 h-8 sm:w-12 sm:h-12 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
                        <svg class="w-4 h-4 sm:w-6 sm:h-6 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                        </svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between gap-2">
                          <span class="text-sm sm:text-base font-semibold text-stone-900">Pay Online</span>
                          <span class="check-icon text-rose-600 opacity-0 transition-opacity">
                            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                            </svg>
                          </span>
                        </div>
                        <p class="hidden sm:block text-sm text-stone-600 mt-0.5">UPI, Cards, Netbanking</p>
                      </div>
                    </div>
                  </label>
                <% end %>

                <%# COD Second %>
                <% if enable_cod %>
                  <label class="payment-option relative flex items-center p-2.5 sm:p-4 border-2 border-stone-200 rounded-lg sm:rounded-xl cursor-pointer transition-all hover:border-stone-300 <%= 'border-rose-500 bg-rose-50 ring-2 ring-rose-200' if !enable_razorpay %>" data-payment-method="cod">
                    <%= f.radio_button :payment_method, 'cod', 
                        checked: !enable_razorpay,
                        class: 'sr-only', 
                        id: 'payment_cod' %>
                    <div class="flex items-center gap-2 sm:gap-4 w-full">
                      <div class="w-8 h-8 sm:w-12 sm:h-12 bg-amber-100 rounded-full flex items-center justify-center flex-shrink-0">
                        <svg class="w-4 h-4 sm:w-6 sm:h-6 text-amber-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a1 1 0 11-2 0 1 1 0 012 0z"/>
                        </svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between gap-2">
                          <span class="text-sm sm:text-base font-semibold text-stone-900">Cash on Delivery</span>
                          <span class="check-icon text-rose-600 opacity-0 transition-opacity">
                            <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                            </svg>
                          </span>
                        </div>
                        <p class="hidden sm:block text-sm text-stone-600 mt-0.5">Pay when delivered</p>
                      </div>
                    </div>
                  </label>
                <% end %>
              </div>
            <% else %>
              <!-- No Payment Methods Enabled -->
              <div class="p-6 bg-red-50 border-2 border-red-200 rounded-xl">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-red-900 text-lg">Checkout Temporarily Unavailable</h3>
                    <p class="text-red-700 mt-2">We're currently unable to process orders. Please try again later or contact our support team for assistance.</p>
                    <p class="text-sm text-red-600 mt-3">We apologize for any inconvenience this may cause.</p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

          <!-- Order Items (hidden on mobile) -->
          <div class="hidden sm:block bg-white rounded-lg sm:rounded-xl border border-stone-200 overflow-hidden">
            <!-- Header — tappable on mobile to expand/collapse -->
            <button type="button" id="toggle-items-btn"
                    class="w-full flex items-center justify-between p-3 sm:p-5 md:p-6 text-left cursor-pointer">
              <div class="flex items-center gap-2">
                <h2 class="text-sm sm:text-base font-semibold text-stone-900">
                  <%= "#{current_cart.cart_items.count} #{current_cart.cart_items.count == 1 ? 'Item' : 'Items'}" %>
                </h2>
                <!-- Tiny product thumbnails (collapsed preview) -->
                <div class="flex -space-x-1.5" id="items-thumb-preview">
                  <% current_cart.cart_items.first(3).each do |item| %>
                    <div class="w-6 h-6 rounded-full border-2 border-white bg-stone-100 overflow-hidden flex-shrink-0">
                      <% if item.product_variant.product.images.attached? %>
                        <%= image_tag item.product_variant.product.images.first, class: 'w-full h-full object-cover' %>
                      <% end %>
                    </div>
                  <% end %>
                  <% if current_cart.cart_items.count > 3 %>
                    <div class="w-6 h-6 rounded-full border-2 border-white bg-stone-200 flex items-center justify-center flex-shrink-0">
                      <span class="text-[8px] font-bold text-stone-600">+<%= current_cart.cart_items.count - 3 %></span>
                    </div>
                  <% end %>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <%= link_to cart_path, class: "hidden sm:inline-flex text-[11px] sm:text-xs text-stone-400 hover:text-stone-600 font-medium border border-stone-200 rounded px-2 py-0.5 transition", onclick: "event.stopPropagation()" do %>
                  Edit
                <% end %>
                <svg class="w-4 h-4 text-stone-400 transition-transform duration-200" id="items-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </div>
            </button>

            <!-- Collapsible items body — hidden by default, click to expand -->
            <div id="items-body" class="hidden border-t border-stone-100">
              <div class="p-3 sm:p-5 md:p-6 pt-3">
            <% if @vendor_estimates.size > 1 %>
              <!-- Multiple Vendors -->
              <div class="space-y-4">
                <% total_shipments = @vendor_estimates.size %>
                <% @vendor_estimates.each_with_index do |(vendor, estimate), index| %>
                  <div class="border border-stone-200 rounded-lg p-3 sm:p-4">
                    <!-- Shipment Header -->
                    <div class="flex items-center justify-between mb-2 sm:mb-3 pb-2 sm:pb-3 border-b border-stone-100">
                      <div class="flex items-center gap-2">
                        <div class="w-7 h-7 sm:w-8 sm:h-8 bg-emerald-100 rounded-full flex items-center justify-center">
                          <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                          </svg>
                        </div>
                        <div>
                          <p class="font-medium text-stone-900 text-xs sm:text-sm">Shipment <%= index + 1 %> of <%= total_shipments %></p>
                          <p class="text-[10px] sm:text-xs text-stone-500"><%= estimate[:item_count] %> <%= estimate[:item_count] == 1 ? 'item' : 'items' %></p>
                        </div>
                      </div>
                      <span class="text-xs sm:text-sm font-semibold text-stone-900"><%= format_price(estimate[:total]) %></span>
                    </div>

                    <!-- Vendor Items — compact on mobile -->
                    <div class="space-y-2 sm:space-y-3 mb-3">
                      <% estimate[:items].each do |item|
                        tax_rate = item.product_variant&.product&.hsn_code&.gst_rate || 3.0
                        item_tax = (item.total_price.to_f * tax_rate / 100.0).round(2)
                      %>
                        <div class="flex items-center gap-2 sm:gap-3 text-xs sm:text-sm">
                          <div class="w-8 h-8 sm:w-12 sm:h-12 bg-stone-100 rounded-lg flex-shrink-0 overflow-hidden">
                            <% if item.product_variant.product.images.attached? %>
                              <%= image_tag item.product_variant.product.images.first, class: 'w-full h-full object-cover' %>
                            <% end %>
                          </div>
                          <div class="flex-1 min-w-0">
                            <p class="text-stone-900 truncate text-xs sm:text-sm"><%= item.product_variant.product.name %></p>
                            <p class="text-stone-500 text-[10px] sm:text-xs">
                              <%= item.product_variant.name %> × <%= item.quantity %>
                              <span class="hidden sm:inline ml-1 px-1.5 py-0.5 bg-blue-100 text-blue-700 rounded text-[10px] font-medium"><%= tax_rate %>% GST</span>
                            </p>
                          </div>
                          <p class="font-medium text-stone-900 text-xs sm:text-sm flex-shrink-0"><%= format_price(item.total_price) %></p>
                        </div>
                      <% end %>
                    </div>

                    <!-- Vendor Estimate Summary -->
                    <div class="bg-stone-50 rounded-lg p-2.5 sm:p-3 text-[10px] sm:text-xs space-y-1">
                      <div class="flex justify-between">
                        <span class="text-stone-600">Subtotal</span>
                        <span class="text-stone-900"><%= format_price(estimate[:subtotal]) %></span>
                      </div>
                      <% if estimate[:discount] > 0 %>
                        <div class="flex justify-between text-emerald-600">
                          <span>Discount</span>
                          <span>-<%= format_price(estimate[:discount]) %></span>
                        </div>
                      <% end %>
                      <div class="flex justify-between">
                        <span class="text-stone-600">Shipping</span>
                        <span class="<%= estimate[:shipping] > 0 ? 'text-stone-900' : 'text-emerald-600 font-medium' %>">
                          <%= estimate[:shipping] > 0 ? format_price(estimate[:shipping]) : 'FREE' %>
                        </span>
                      </div>
                      <div class="flex justify-between">
                        <span class="text-stone-600">Tax</span>
                        <span class="text-stone-900"><%= format_price(estimate[:tax]) %></span>
                      </div>
                      <div class="flex justify-between pt-1 border-t border-stone-200">
                        <span class="font-medium text-stone-900">Shipment Total</span>
                        <span class="font-semibold text-stone-900"><%= format_price(estimate[:total]) %></span>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>

              <!-- Combined Total Notice -->
              <div class="mt-3 sm:mt-4 p-2.5 sm:p-3 bg-emerald-50 border border-emerald-200 rounded-lg">
                <div class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <div>
                    <p class="text-xs font-semibold text-emerald-900">One Simple Payment</p>
                    <p class="text-[10px] sm:text-xs text-emerald-700 mt-0.5">Pay <%= format_price(@total) %> once. We'll handle delivery for all shipments.</p>
                  </div>
                </div>
              </div>
            <% else %>
              <!-- Single Vendor - Compact Item List -->
              <div class="space-y-2.5 sm:space-y-4 mb-3 sm:mb-4">
                <% current_cart.cart_items.each do |item|
                  tax_rate = item.product_variant&.product&.hsn_code&.gst_rate || 3.0
                  item_tax = (item.total_price.to_f * tax_rate / 100.0).round(2)
                %>
                  <div class="flex items-center gap-2.5 sm:gap-4">
                    <div class="w-10 h-10 sm:w-16 sm:h-16 bg-stone-100 rounded-lg flex-shrink-0 overflow-hidden">
                      <% if item.product_variant.product.images.attached? %>
                        <%= image_tag item.product_variant.product.images.first, class: 'w-full h-full object-cover' %>
                      <% end %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="font-medium text-stone-900 truncate text-xs sm:text-sm"><%= item.product_variant.product.name %></p>
                      <p class="text-[10px] sm:text-sm text-stone-500">
                        <%= item.product_variant.name %> × <%= item.quantity %>
                        <span class="hidden sm:inline ml-1 px-1.5 py-0.5 bg-blue-100 text-blue-700 rounded text-[10px] font-medium"><%= tax_rate %>% GST</span>
                      </p>
                    </div>
                    <div class="text-right flex-shrink-0">
                      <p class="font-semibold text-stone-900 text-xs sm:text-sm"><%= format_price(item.total_price) %></p>
                      <p class="hidden sm:block text-xs text-stone-500">+ <%= format_price(item_tax) %> tax</p>
                    </div>
                  </div>
                <% end %>
              </div>

              <!-- Single Vendor Estimate Summary -->
              <div class="bg-stone-50 rounded-lg p-2.5 sm:p-3 text-[10px] sm:text-xs space-y-1">
                <div class="flex justify-between">
                  <span class="text-stone-600">Subtotal</span>
                  <span class="text-stone-900"><%= format_price(@subtotal) %></span>
                </div>
                <% if @discount > 0 %>
                  <div class="flex justify-between text-emerald-600">
                    <span>Discount</span>
                    <span>-<%= format_price(@discount) %></span>
                  </div>
                <% end %>
                <div class="flex justify-between">
                  <span class="text-stone-600">Shipping</span>
                  <span class="<%= @shipping.to_f > 0 ? 'text-stone-900' : 'text-emerald-600 font-medium' %>">
