<!-- No Address State - Show Address Selection First -->
<div class="max-w-2xl mx-auto">
  <div class="bg-white rounded-xl border border-stone-200 p-6 sm:p-8">
    <div class="text-center mb-8">
      <div class="w-16 h-16 bg-rose-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-rose-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <h2 class="text-xl font-serif font-semibold text-stone-900">Where should we deliver?</h2>
      <p class="text-stone-600 mt-2">Please select or add a delivery address to continue</p>
    </div>
    
    <% if current_customer.addresses.any? %>
      <div class="space-y-3 mb-6">
        <% current_customer.addresses.default_first.each do |addr| %>
          <%= button_to save_address_checkout_path(address_token: addr.token), 
              method: :post,
              class: "w-full text-left p-4 border-2 border-stone-200 rounded-xl hover:border-rose-500 hover:bg-rose-50 transition group" do %>
            <div class="flex items-start justify-between">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-stone-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-stone-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                </div>
                <div>
                  <div class="flex items-center gap-2">
                    <p class="font-semibold text-stone-900"><%= addr.full_name %></p>
                    <% if addr.is_default? %>
                      <span class="text-xs bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded">Default</span>
                    <% end %>
                  </div>
                  <p class="text-sm text-stone-600 mt-1"><%= addr.full_address %></p>
                  <% if addr.phone.present? %>
                    <p class="text-sm text-stone-500 mt-1">📞 <%= addr.phone %></p>
                  <% end %>
                </div>
              </div>
              <div class="text-rose-600 opacity-0 group-hover:opacity-100 transition-opacity">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
    
    <div class="border-t-2 border-stone-100 pt-6">
      <p class="text-sm text-stone-600 mb-4 text-center">Or add a new delivery address:</p>
      <%= link_to address_checkout_path, class: "w-full py-4 px-4 bg-rose-800 text-white text-center font-semibold rounded-xl hover:bg-rose-900 transition flex items-center justify-center gap-2 shadow-lg shadow-rose-100" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add New Address
      <% end %>
    </div>
  </div>
</div>
