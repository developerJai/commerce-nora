<% content_for(:title) { "#{@vendor.business_name} - Shop Online" } %>
<% content_for(:native_title) { @vendor.business_name } %>
<% content_for(:meta_description) { "Shop #{@vendor.business_name}'s collection online. Browse #{@pagy.count}+ products with free shipping above #{format_price(free_delivery_threshold)}. Shop now at Noralooks!" } %>

<% content_for(:head) do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="min-h-screen bg-stone-50" data-controller="filter-drawer">

  <!-- ═══════════════ Vendor Header ═══════════════ -->
  <%= render 'vendor_header' %>

  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">

    <!-- ═══════════════ Category Chips (Sticky on mobile) ═══════════════ -->
    <div class="sticky top-12 z-40 bg-stone-50/95 backdrop-blur-sm py-2 -mx-3 px-3 sm:-mx-0 sm:px-0 sm:top-[60px]">
      <%= render 'category_chips' %>
    </div>

    <!-- ═══════════════ Sort + Results Bar ═══════════════ -->
    <div class="flex items-center justify-between gap-3 py-2 sm:py-3">
      <div id="results-counter" class="flex items-center">
        <p class="text-sm text-stone-600">
          <span class="font-medium text-stone-900"><%= number_with_delimiter(@pagy.count) %></span>
          <span class="text-stone-500">products</span>
        </p>
      </div>

      <!-- Desktop Sort -->
      <div class="hidden sm:flex items-center gap-2">
        <label class="text-xs font-medium text-stone-500 flex-shrink-0">Sort:</label>
        <%= render 'compact_sort' %>
      </div>

      <!-- Mobile Sort Button -->
      <button type="button" data-action="click->filter-drawer#openSort"
              class="sm:hidden inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-stone-200 rounded-full text-xs font-medium text-stone-700 active:bg-stone-50">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"/>
        </svg>
        Sort
      </button>
    </div>

    <!-- ═══════════════ Mobile Sort Drawer (Bottom Sheet) ═══════════════ -->
    <div data-filter-drawer-target="overlay" class="hidden fixed inset-0 bg-black/40 z-40 sm:hidden" data-action="click->filter-drawer#closeAny"></div>
    <div data-filter-drawer-target="sortDrawer" class="fixed left-0 right-0 bottom-0 max-h-[80vh] bg-white z-50 shadow-2xl transform translate-y-full transition-transform duration-300 ease-out sm:hidden overflow-hidden rounded-t-3xl flex flex-col pb-[max(env(safe-area-inset-bottom),16px)]">
      <div class="flex-shrink-0 px-4 py-3">
        <div class="w-12 h-1 bg-stone-300 rounded-full mx-auto mb-3"></div>
        <div class="flex items-center justify-between">
          <h2 class="font-sans font-semibold text-stone-900 text-lg">Sort By</h2>
          <button type="button" data-action="click->filter-drawer#closeSort" class="p-2 text-stone-400 hover:text-stone-600">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      </div>
      <div class="flex-1 overflow-y-auto overscroll-contain px-4 pb-4">
        <div class="space-y-2">
          <% sort_options = [
            ['Popularity', 'rating'],
            ['Price: Low to High', 'price_low'],
            ['Price: High to Low', 'price_high'],
            ['Newest First', 'newest']
          ] %>
          <% sort_options.each do |label, value| %>
            <% active = (@sort == value) || (@sort.blank? && value == 'rating') %>
            <%= link_to label,
                vendor_storefront_path(@vendor.slug, **request.query_parameters.except("page").merge(sort: value)),
                data: { turbo_frame: '_top', action: 'click->filter-drawer#closeSort' },
                class: "block px-4 py-3 rounded-xl border transition #{active ? 'bg-rose-50 border-rose-800 text-rose-900 font-semibold' : 'bg-white border-stone-200 text-stone-700 hover:bg-stone-50'}" %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- ═══════════════ Active Filter Chips ═══════════════ -->
    <% if @active_filters.any? %>
      <div class="flex flex-wrap items-center gap-2 pb-2 sm:pb-3">
        <% @active_filters.each do |filter| %>
          <%
            new_params = request.query_parameters.except("page")
            if new_params[filter[:param]].is_a?(Array)
              new_params[filter[:param]] = new_params[filter[:param]].reject { |v| v.to_s == filter[:value].to_s }
              new_params.delete(filter[:param]) if new_params[filter[:param]].empty?
            else
              new_params.delete(filter[:param])
            end
          %>
          <%= link_to vendor_storefront_path(@vendor.slug, **new_params),
              class: "inline-flex items-center gap-1 px-2.5 py-1 bg-rose-50 text-rose-800 text-xs font-medium rounded-full hover:bg-rose-100 transition" do %>
            <%= filter[:label] %>
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          <% end %>
        <% end %>
        <%= link_to 'Clear all', vendor_storefront_path(@vendor.slug), class: 'text-xs text-stone-400 hover:text-rose-700 underline ml-1' %>
      </div>
    <% end %>

    <!-- ═══════════════ Products Grid ═══════════════ -->
    <%= turbo_frame_tag "vendor-products-content", data: { turbo_action: "advance" } do %>
      <% if @products.any? %>
        <div id="infinite-scroll-wrapper" data-controller="infinite-scroll">
          <div id="products-grid" class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 sm:gap-3 md:gap-4 pb-6">
            <% @products.each do |product| %>
              <%= render 'shared/product_card', product: product, in_stock_filter: @in_stock %>
            <% end %>
          </div>

          <div id="infinite-scroll-pagination"
               data-next-url="<%= @pagy.next ? vendor_storefront_path(@vendor.slug, **request.query_parameters.merge(page: @pagy.next)) : '' %>"
               data-has-next="<%= @pagy.next.present? %>"
               data-updated="<%= Time.current.to_i %>"
               data-infinite-scroll-target="pagination"
               style="display: none;"></div>
        </div>
      <% else %>
        <div class="flex items-center justify-center min-h-[50vh] sm:min-h-0 sm:py-16 bg-white rounded-xl border border-stone-200 mb-6">
          <div class="text-center px-4">
            <div class="w-16 h-16 mx-auto mb-4 bg-rose-50 rounded-full flex items-center justify-center">
              <svg class="w-8 h-8 text-rose-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
              </svg>
            </div>
            <h3 class="text-lg font-sans font-medium text-stone-900 mb-2">No products found</h3>
            <p class="text-stone-500 text-sm mb-4">Try a different category or browse all products</p>
            <div class="flex flex-col sm:flex-row gap-2 justify-center">
              <%= link_to 'View All', vendor_storefront_path(@vendor.slug), class: 'inline-block px-5 py-2 bg-rose-800 text-white text-sm font-medium rounded-full hover:bg-rose-900 transition' %>
              <%= link_to 'Browse All Collections', products_path, class: 'inline-block px-5 py-2 bg-white border border-stone-300 text-stone-700 text-sm font-medium rounded-full hover:bg-stone-50 transition' %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
