<%# locals: (message:, variant: :success) %>
<% 
  if variant.to_s == 'error'
    bg_color = 'bg-white'
    border_color = 'border-red-200'
    text_color = 'text-stone-900'
    icon_color = 'text-red-600'
    progress_color = 'bg-red-500'
  else
    bg_color = 'bg-white'
    border_color = 'border-emerald-200'
    text_color = 'text-stone-900'
    icon_color = 'text-emerald-600'
    progress_color = 'bg-emerald-500'
  end
%>

<div class="pointer-events-auto w-full max-w-sm <%= bg_color %> shadow-lg rounded-lg border <%= border_color %> overflow-hidden transition-all duration-300 ease-out opacity-0 scale-95 translate-y-2" 
     data-controller="toast" 
     data-toast-timeout-value="4000"
     role="alert"
     aria-live="assertive">
  <div class="p-4">
    <div class="flex items-start gap-3">
      <!-- Icon -->
      <div class="flex-shrink-0 <%= icon_color %>">
        <% if variant.to_s == 'error' %>
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
        <% else %>
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
        <% end %>
      </div>

      <!-- Message -->
      <p class="text-sm <%= text_color %> flex-1 leading-relaxed font-medium"><%= message %></p>

      <!-- Close Button -->
      <button type="button" 
              class="flex-shrink-0 text-stone-400 hover:text-stone-600 transition-colors"
              data-action="click->toast#close" 
              aria-label="Dismiss">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
  
  <!-- Progress Bar -->
  <div class="h-1 bg-stone-100">
    <div class="h-full <%= progress_color %> transition-all duration-[4000ms] ease-linear" 
         data-toast-target="progress"
         style="width: 100%"></div>
  </div>
</div>
