<%# locals: (active_page:) %>
<aside class="lg:sticky lg:top-[120px]">
  <!-- Mobile Account Menu -->
  <div class="lg:hidden mb-4">
    <button type="button"
            onclick="document.getElementById('account-nav').classList.toggle('hidden')"
            class="w-full flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-stone-200">
      <span class="font-medium text-stone-900"><%= active_page.titleize %></span>
      <svg class="w-5 h-5 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>
  </div>

  <!-- Account Navigation -->
  <nav id="account-nav" class="hidden lg:block bg-white rounded-lg border border-stone-200 overflow-hidden">
    <%= link_to account_path, class: "flex items-center gap-3 px-4 py-3 text-sm font-medium border-b border-stone-100 transition #{active_page == 'profile' ? 'bg-rose-50 text-rose-800' : 'text-stone-700 hover:bg-stone-50'}" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      Profile
    <% end %>
    
    <%= link_to orders_path, class: "flex items-center gap-3 px-4 py-3 text-sm font-medium border-b border-stone-100 transition #{active_page == 'orders' ? 'bg-rose-50 text-rose-800' : 'text-stone-700 hover:bg-stone-50'}" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
      </svg>
      Orders
    <% end %>
    
    <%= link_to addresses_path, class: "flex items-center gap-3 px-4 py-3 text-sm font-medium border-b border-stone-100 transition #{active_page == 'addresses' ? 'bg-rose-50 text-rose-800' : 'text-stone-700 hover:bg-stone-50'}" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      Addresses
    <% end %>
    
    <%= link_to wishlists_path, class: "flex items-center gap-3 px-4 py-3 text-sm font-medium border-b border-stone-100 transition #{active_page == 'wishlist' ? 'bg-rose-50 text-rose-800' : 'text-stone-700 hover:bg-stone-50'}" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
      </svg>
      Wishlist
    <% end %>
    
    <% unread_support_count = current_customer&.unread_support_tickets_count.to_i %>
    <%= link_to support_tickets_path, class: "flex items-center gap-3 px-4 py-3 text-sm font-medium border-b border-stone-100 transition #{active_page == 'support' ? 'bg-rose-50 text-rose-800' : 'text-stone-700 hover:bg-stone-50'}" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
      </svg>
      <span class="flex-1">Support</span>
      <% if unread_support_count > 0 %>
        <span class="inline-flex items-center justify-center min-w-[20px] h-5 px-2 text-[11px] font-semibold rounded-full bg-rose-700 text-white">
          <%= unread_support_count %>
        </span>
      <% end %>
    <% end %>
    
    <%= link_to edit_account_password_path, class: "flex items-center gap-3 px-4 py-3 text-sm font-medium border-b border-stone-100 transition #{active_page == 'password' ? 'bg-rose-50 text-rose-800' : 'text-stone-700 hover:bg-stone-50'}" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
      </svg>
      Change Password
    <% end %>
    
    <%= button_to logout_path, method: :delete, class: "w-full flex items-center gap-3 px-4 py-3 text-sm font-medium text-red-600 hover:bg-red-50 transition" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
      Sign Out
    <% end %>
  </nav>
</aside>
