<% variant = product.default_variant %>
<% cart_item = current_cart.cart_items.find_by(product_variant_id: variant&.id) if variant %>

<div class="group bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-md hover:border-gray-300 transition-all duration-200 flex flex-col"
     id="product-card-<%= product.id %>">
  <%= link_to product_path(product.slug) do %>
    <div class="aspect-square bg-gray-50 relative overflow-hidden">
      <% if product.images.attached? %>
        <%= image_tag product.images.first, class: 'w-full h-full object-cover group-hover:scale-105 transition duration-300', loading: 'lazy' %>
      <% else %>
        <div class="w-full h-full flex items-center justify-center">
          <svg class="w-12 h-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
      <% end %>
      
      <!-- Badges -->
      <div class="absolute top-2 left-2 flex flex-col gap-1">
        <% if product.featured? %>
          <span class="px-2 py-0.5 bg-teal-500 text-white text-[10px] font-medium rounded">Bestseller</span>
        <% end %>
        <% if variant&.on_sale? %>
          <span class="px-2 py-0.5 bg-rose-500 text-white text-[10px] font-medium rounded">-<%= variant.discount_percentage %>%</span>
        <% end %>
      </div>

      <!-- Stock Badge -->
      <% if variant %>
        <div class="absolute top-2 right-2">
          <% if variant.out_of_stock? %>
            <span class="px-2 py-0.5 bg-gray-100 text-gray-500 text-[10px] font-medium rounded-full">Sold Out</span>
          <% elsif variant.low_stock? %>
            <span class="px-2 py-0.5 bg-amber-100 text-amber-600 text-[10px] font-medium rounded-full">Low Stock</span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="p-3 flex flex-col flex-1">
    <!-- Product Name -->
    <%= link_to product_path(product.slug), class: 'block' do %>
      <h3 class="text-xs sm:text-sm font-medium text-gray-900 group-hover:text-teal-600 line-clamp-2 min-h-[2rem] sm:min-h-[2.5rem] transition"><%= product.name %></h3>
    <% end %>

    <!-- Rating -->
    <% if product.average_rating > 0 %>
      <div class="flex items-center gap-1 mt-1">
        <div class="flex items-center text-amber-400">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        </div>
        <span class="text-[10px] text-gray-500"><%= product.average_rating.round(1) %> (<%= product.ratings_count %>)</span>
      </div>
    <% end %>

    <!-- Price -->
    <div class="mt-2 flex items-baseline gap-1.5 flex-wrap">
      <span class="text-base sm:text-lg font-bold text-gray-900"><%= format_price(product.min_price) %></span>
      <% if variant&.on_sale? %>
        <span class="text-xs text-gray-400 line-through"><%= format_price(variant.compare_at_price) %></span>
      <% end %>
    </div>

    <!-- Free delivery -->
    <% if product.min_price && product.min_price >= 50 %>
      <p class="text-[10px] text-teal-600 mt-1">Free Delivery</p>
    <% end %>

    <!-- Spacer -->
    <div class="flex-1"></div>

    <!-- Add to Cart -->
    <div class="mt-3">
      <% if variant.nil? %>
        <button disabled class="w-full py-2 px-3 bg-gray-100 text-gray-400 text-xs sm:text-sm font-medium rounded-lg cursor-not-allowed">
          Out of Stock
        </button>
      <% else %>
        <%= render 'shared/cart_controls', variant: variant, cart_item: cart_item %>
      <% end %>
    </div>
  </div>
</div>
