<% 
  # Check if variant is explicitly passed (from wishlist)
  explicit_variant = local_assigns.fetch(:variant, nil)
  show_variant_info = local_assigns.fetch(:show_variant, false)
  
  # Use in-stock variant when in-stock filter is active
  in_stock_filter_active = local_assigns.fetch(:in_stock_filter, false)
  
  # Determine which variant to display
  # Use cheapest_variant so displayed price matches MIN(price) sort order
  variant = if explicit_variant.present?
    explicit_variant
  elsif in_stock_filter_active
    product.first_in_stock_variant || product.cheapest_variant
  else
    product.cheapest_variant
  end
  
  cart_item = current_cart.cart_items.find_by(product_variant_id: variant&.id) if variant
  badge_side = local_assigns.fetch(:badge_side, :right)
  
  # Build product path with variant parameter if specific variant is selected
  product_path_url = if explicit_variant.present?
    product_path(product.slug, variant: explicit_variant.name.parameterize)
  else
    product_path(product.slug)
  end
%>

<div class="group bg-white rounded-md sm:rounded-lg border border-stone-200 overflow-hidden hover:shadow-lg hover:border-stone-300 transition-all duration-200 flex flex-col"
     id="product-card-<%= product.id %>-<%= variant&.id || 'default' %>">
  <%= link_to product_path_url, data: { turbo_frame: '_top' } do %>
    <div class="aspect-square bg-stone-50 relative overflow-hidden">
      <% if variant&.image&.attached? %>
        <%= image_tag variant.image, alt: "Buy #{product.name} online at Noralooks - #{product.category&.name || 'Artificial Jewellery'}", class: 'w-full h-full object-cover group-hover:scale-105 transition duration-500', loading: 'lazy' %>
      <% elsif product.images.attached? %>
        <%= image_tag product.images.first, alt: "Buy #{product.name} online at Noralooks - #{product.category&.name || 'Artificial Jewellery'}", class: 'w-full h-full object-cover group-hover:scale-105 transition duration-500', loading: 'lazy' %>
      <% else %>
        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-rose-50 to-amber-50">
          <svg class="w-12 h-12 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
          </svg>
        </div>
      <% end %>
      
      <!-- Badges -->
      <div class="absolute top-1.5 sm:top-2 left-1.5 sm:left-2 flex flex-col gap-0.5 sm:gap-1">
        <% if product.featured? %>
          <span class="px-1.5 sm:px-2 py-0.5 bg-rose-800 text-white text-[9px] sm:text-[10px] font-medium rounded">Bestseller</span>
        <% end %>
        <% if variant&.on_sale? %>
          <span class="px-1.5 sm:px-2 py-0.5 bg-amber-600 text-white text-[9px] sm:text-[10px] font-bold rounded"><%= variant.discount_percentage %>% OFF</span>
        <% end %>
      </div>

      <!-- Stock Badge -->
      <% if variant %>
        <div class="absolute top-1.5 sm:top-2 <%= badge_side.to_s == 'left' ? 'left-1.5 sm:left-2 mt-5 sm:mt-6 items-start' : 'right-1.5 sm:right-2 items-end' %> flex flex-col gap-0.5 sm:gap-1">
          <% if customer_logged_in? && current_customer.product_in_wishlist?(product) %>
            <span class="px-1.5 sm:px-2 py-0.5 bg-rose-100 text-rose-800 text-[9px] sm:text-[10px] font-medium rounded-full">
              <svg class="w-2.5 h-2.5 sm:w-3 sm:h-3 inline mr-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
              In Wishlist
            </span>
          <% end %>
          <%# Only show 'Sold Out' if ALL variants are out of stock %>
          <% if !product.in_stock? %>
            <span class="px-1.5 sm:px-2 py-0.5 bg-stone-800/80 text-white text-[9px] sm:text-[10px] font-medium rounded-full">Sold Out</span>
          <% elsif variant.low_stock? %>
            <span class="px-1.5 sm:px-2 py-0.5 bg-amber-100 text-amber-800 text-[9px] sm:text-[10px] font-medium rounded-full">Few Left</span>
          <% end %>
        </div>
      <% end %>

    </div>
  <% end %>

  <div class="p-2 sm:p-3 flex flex-col flex-1">
    <!-- Product Name -->
    <%= link_to product_path_url, data: { turbo_frame: '_top' }, class: 'block' do %>
      <h3 class="text-xs sm:text-sm font-medium text-stone-800 group-hover:text-rose-800 line-clamp-2 h-[2.25rem] sm:h-[2.5rem] transition"><%= product.name %></h3>
    <% end %>
    
    <!-- Variant Name (when showing from wishlist) -->
    <% if show_variant_info && variant&.name.present? %>
      <p class="text-[10px] sm:text-xs text-stone-500 mt-0.5"><%= variant.name %></p>
    <% end %>

    <!-- Rating -->
    <div class="flex items-center gap-1.5 sm:gap-2 mt-1 sm:mt-1.5">
      <% if product.average_rating.to_f > 0 %>
        <div class="flex items-center gap-0.5">
          <% 5.times do |i| %>
            <svg class="w-2.5 h-2.5 sm:w-3 sm:h-3 <%= i < product.average_rating.round ? 'text-amber-400' : 'text-stone-200' %>" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          <% end %>
        </div>
        <span class="text-[9px] sm:text-[10px] font-medium text-stone-700"><%= product.average_rating.round(1) %></span>
        <span class="text-[9px] sm:text-[10px] text-stone-500">(<%= product.ratings_count %>)</span>
      <% else %>
        <span class="text-[9px] sm:text-[10px] text-stone-400">No reviews yet</span>
      <% end %>
    </div>

    <!-- Price -->
    <div class="mt-1.5 sm:mt-2">
      <% if variant&.on_sale? && variant.compare_at_price.present? %>
        <div class="flex items-baseline gap-1.5 sm:gap-2 flex-wrap">
          <span class="text-sm sm:text-base font-semibold text-rose-800"><%= format_price(variant.price) %></span>
          <span class="text-[10px] sm:text-xs text-stone-400 line-through"><%= format_price(variant.compare_at_price) %></span>
        </div>
      <% else %>
        <span class="text-sm sm:text-base font-semibold text-stone-900"><%= format_price(variant&.price || product.min_price) %></span>
      <% end %>
    </div>

    <!-- Spacer -->
    <div class="flex-1"></div>

    <!-- Add to Cart -->
    <div class="mt-1 sm:mt-3">
      <%# Show 'Sold Out' only if ALL variants are out of stock %>
      <% if !product.in_stock? %>
        <button disabled class="w-full py-1.5 sm:py-2 px-2 sm:px-3 bg-stone-100 text-stone-400 text-xs sm:text-sm font-medium rounded-md sm:rounded-lg cursor-not-allowed">
          Sold Out
        </button>
      <% elsif variant %>
        <%= render 'shared/cart_controls', variant: variant, cart_item: cart_item %>
      <% else %>
        <button disabled class="w-full py-1.5 sm:py-2 px-2 sm:px-3 bg-stone-100 text-stone-400 text-xs sm:text-sm font-medium rounded-md sm:rounded-lg cursor-not-allowed">
          Unavailable
        </button>
      <% end %>
    </div>
  </div>
</div>
