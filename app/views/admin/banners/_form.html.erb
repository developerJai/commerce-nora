<%= form_with model: [:admin, banner], class: 'space-y-6' do |f| %>
  <% if banner.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% banner.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-lg shadow-sm p-6 space-y-6">
    <div>
      <%= f.label :title, class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.text_field :title, required: true, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
    </div>

    <div>
      <%= f.label :subtitle, class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.text_field :subtitle, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
    </div>

    <div>
      <%= f.label :link_url, 'Link URL', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.url_field :link_url, placeholder: 'https://...', class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
    </div>

    <div>
      <%= f.label :image, class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <% if banner.image.attached? %>
        <div class="mb-2">
          <%= image_tag banner.image, class: 'h-32 object-cover rounded' %>
        </div>
      <% end %>
      <%= f.file_field :image, accept: 'image/*', class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :starts_at, 'Start Date', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.datetime_local_field :starts_at, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
      </div>
      <div>
        <%= f.label :ends_at, 'End Date', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.datetime_local_field :ends_at, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
      </div>
    </div>

    <div>
      <%= f.label :position, class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.number_field :position, min: 0, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
    </div>

    <div class="flex items-center">
      <label class="flex items-center">
        <%= f.check_box :active, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
        <span class="ml-2 text-sm text-gray-700">Active</span>
      </label>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to 'Cancel', admin_banners_path, class: 'px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50' %>
    <%= f.submit 'Save Banner', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
  </div>
<% end %>
