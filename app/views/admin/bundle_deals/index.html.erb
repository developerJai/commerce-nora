<% content_for(:title) { "Bundle Deals" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Bundle Deals</h1>
    <%= link_to 'Add Bundle Deal', new_admin_bundle_deal_path, class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700' %>
  </div>

  <div class="bg-white rounded-lg shadow-sm overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Deal</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pricing</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Products</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Position</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @bundle_deals.each do |deal| %>
          <tr>
            <td class="px-6 py-4">
              <div class="flex items-center">
                <div class="h-12 w-12 flex-shrink-0 bg-gray-100 rounded-lg overflow-hidden mr-3">
                  <% if deal.image.attached? %>
                    <%= image_tag deal.image, class: 'h-full w-full object-cover' %>
                  <% else %>
                    <div class="h-full w-full flex items-center justify-center bg-gradient-to-br from-rose-100 to-amber-100">
                      <svg class="w-6 h-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                    </div>
                  <% end %>
                </div>
                <div>
                  <div class="text-sm font-medium text-gray-900"><%= deal.title %></div>
                  <div class="text-sm text-gray-500"><%= deal.description %></div>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-gray-900">
                <span class="font-bold text-rose-700"><%= deal.formatted_discounted_price %></span>
                <span class="text-gray-400 line-through ml-2"><%= deal.formatted_original_price %></span>
              </div>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800 mt-1">
                <%= deal.savings_display %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= deal.position %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= deal.bundle_deal_items.count %> products
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full <%= deal.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                <%= deal.active? ? 'Active' : 'Inactive' %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= link_to 'Edit', edit_admin_bundle_deal_path(deal), class: 'text-indigo-600 hover:text-indigo-900 mr-3' %>
              <%= link_to 'Delete', admin_bundle_deal_path(deal), 
                  data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' },
                  class: 'text-red-600 hover:text-red-900' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @bundle_deals.empty? %>
    <div class="text-center py-12 bg-white rounded-lg shadow-sm">
      <p class="text-gray-500 mb-4">No bundle deals created yet</p>
      <%= link_to 'Create your first bundle deal', new_admin_bundle_deal_path, class: 'text-indigo-600 hover:text-indigo-800' %>
    </div>
  <% end %>
</div>
