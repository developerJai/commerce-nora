<%# Variant form - attribute options are driven by product's category config %>
<% category = @product.category %>
<% variant_defs = category&.variant_attribute_definitions || [] %>

<%= form_with model: @variant,
              url: (@variant.persisted? ? admin_product_variant_path(@product, @variant) : admin_product_variants_path(@product)),
              class: 'space-y-6' do |f| %>
  <% if @variant.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% @variant.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6" data-controller="image-preview">
    <div class="lg:col-span-7">
      <div class="bg-white rounded-lg shadow-sm p-6 space-y-6">

        <!-- Dynamic variant attributes from category config -->
        <% if variant_defs.any? %>
          <div class="grid grid-cols-2 gap-4">
            <% variant_defs.each do |defn| %>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1"><%= defn[:label] %></label>
                <%
                  key = defn[:key]
                  is_column = Category::VARIANT_COLUMN_ATTRIBUTES.include?(key)
                  current_value = is_column ? @variant.send(key) : @variant.properties&.dig(key)
                  options = defn[:options] || []
                %>
                <% if options.any? %>
                  <% if is_column %>
                    <%= f.select key.to_sym, options, { include_blank: "Select #{defn[:label].downcase}..." }, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
                  <% else %>
                    <select name="product_variant[properties][<%= key %>]"
                            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500">
                      <option value="">Select <%= defn[:label].downcase %>...</option>
                      <% options.each do |opt| %>
                        <option value="<%= opt %>" <%= 'selected' if current_value == opt %>><%= opt %></option>
                      <% end %>
                    </select>
                  <% end %>
                <% else %>
                  <% if is_column %>
                    <%= f.text_field key.to_sym, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
                  <% else %>
                    <input type="text" name="product_variant[properties][<%= key %>]"
                           value="<%= current_value %>"
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500">
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <div>
          <%= f.label :name, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :name, required: true, placeholder: 'e.g. Gold / Free Size (auto-generated from attributes if blank)', class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :sku, 'SKU', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :sku, placeholder: 'Auto-generated if blank', class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <div>
            <%= f.label :position, class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.number_field :position, min: 0, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4" data-controller="price-validation" data-action="submit->price-validation#submit">
          <div>
            <%= f.label :price, 'Selling Price (₹)', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.number_field :price, step: 0.01, min: 0,
                data: { "price-validation-target": "sellingPrice", action: "input->price-validation#validatePrices" },
                class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <div>
            <%= f.label :compare_at_price, 'MRP / Compare Price (₹)', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.number_field :compare_at_price, step: 0.01, min: 0,
                data: { "price-validation-target": "mrp", action: "input->price-validation#validatePrices" },
                class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
            <p class="mt-1 text-xs text-gray-500">Shown as struck-through if higher than selling price</p>
          </div>
          <div class="col-span-2 hidden" data-price-validation-target="errorMessage">
            <p class="text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :stock_quantity, 'Stock Quantity', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.number_field :stock_quantity, min: 0, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <div>
            <%= f.label :weight, 'Weight (g)', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.number_field :weight, step: 0.01, min: 0, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
        </div>

        <!-- Inventory Management Settings -->
        <div class="border-t border-gray-200 pt-6 mt-6">
          <h4 class="text-sm font-semibold text-gray-900 mb-4">Inventory Management</h4>
          
          <div class="space-y-4">
            <label class="flex items-center">
              <%= f.check_box :track_inventory, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
              <span class="ml-2 text-sm text-gray-700">Track Inventory</span>
            </label>
            <p class="text-xs text-gray-500 ml-6">When enabled, stock will be automatically adjusted when orders are placed.</p>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <%= f.label :reorder_point, 'Reorder Point', class: 'block text-sm font-medium text-gray-700 mb-1' %>
                <%= f.number_field :reorder_point, min: 0, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
                <p class="mt-1 text-xs text-gray-500">Alert when stock falls below this level (default: 10)</p>
              </div>
              <div>
                <%= f.label :reorder_quantity, 'Reorder Quantity', class: 'block text-sm font-medium text-gray-700 mb-1' %>
                <%= f.number_field :reorder_quantity, min: 0, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
                <p class="mt-1 text-xs text-gray-500">Suggested quantity to reorder (default: 50)</p>
              </div>
            </div>
          </div>
        </div>

        <div>
          <%= f.label :image, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.file_field :image,
                           class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500',
                           accept: 'image/*',
                           data: { "image-preview-target": "input", action: "change->image-preview#change" } %>
        </div>

        <label class="flex items-center">
          <%= f.check_box :active, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
          <span class="ml-2 text-sm text-gray-700">Active</span>
        </label>
      </div>
    </div>

    <div class="lg:col-span-5">
      <div class="bg-white rounded-lg shadow-sm p-6 lg:sticky lg:top-24">
        <div class="flex items-start justify-between">
          <h3 class="text-sm font-semibold text-gray-900">Storefront Preview</h3>
          <span class="text-xs text-gray-500">Card thumbnail</span>
        </div>

        <div class="mt-4 aspect-square bg-stone-50 rounded-xl overflow-hidden border border-stone-200">
          <% preview_src = @variant.image.attached? ? url_for(@variant.image) : '' %>
          <img src="<%= preview_src %>" class="w-full h-full object-cover <%= preview_src.present? ? '' : 'hidden' %>" data-image-preview-target="preview" alt="">
          <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-rose-50 to-amber-50 <%= preview_src.present? ? 'hidden' : '' %>" data-image-preview-target="placeholder">
            <svg class="w-16 h-16 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
            </svg>
          </div>
        </div>

        <p class="mt-3 text-xs text-gray-500">Variant image is shown on storefront cards when available.</p>
      </div>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to 'Cancel', admin_product_path(@product), class: 'px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50' %>
    <%= f.submit 'Save Variant', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
  </div>
<% end %>
