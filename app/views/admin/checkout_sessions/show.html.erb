<% content_for(:title) { "Checkout Session #{@checkout_session.batch_id.first(8)}" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Checkout Session</h1>
      <p class="text-sm text-gray-500">ID: <%= @checkout_session.batch_id %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Back to Sessions", admin_checkout_sessions_path, class: "px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Orders in this Session</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Order #</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Vendor</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Amount</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @orders.each do |order| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                    <%= order.order_number %>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= order.vendor&.business_name || "N/A" %>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= number_to_currency(order.total_amount, unit: "₹") %>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= order_status_class(order.status) %>">
                      <%= order.status.titleize %>
                    </span>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= link_to "View", admin_order_path(order), class: "text-blue-600 hover:text-blue-900" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="text-sm font-medium text-gray-900 mb-4">Payment Summary</h3>
        <div class="space-y-3">
          <div class="flex justify-between">
            <span class="text-gray-500">Total Amount</span>
            <span class="font-medium text-gray-900"><%= number_to_currency(@checkout_session.total_amount, unit: "₹") %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Status</span>
            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_badge_class(@checkout_session.status) %>">
              <%= @checkout_session.status.titleize %>
            </span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Payment Method</span>
            <span class="font-medium text-gray-900"><%= @checkout_session.payment_method&.upcase %></span>
          </div>
          <% if @checkout_session.paid_at %>
            <div class="flex justify-between">
              <span class="text-gray-500">Paid At</span>
              <span class="font-medium text-gray-900"><%= @checkout_session.paid_at.strftime("%b %d, %Y %I:%M %p") %></span>
            </div>
          <% end %>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="text-sm font-medium text-gray-900 mb-4">Customer</h3>
        <% if @checkout_session.customer %>
          <div class="text-sm text-gray-700">
            <p class="font-medium"><%= @checkout_session.customer.full_name %></p>
            <p><%= @checkout_session.customer.email %></p>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">Guest checkout</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
