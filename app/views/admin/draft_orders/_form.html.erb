<%= form_with model: [:admin, order], url: order.new_record? ? admin_draft_orders_path : admin_draft_order_path(order), class: 'space-y-6', data: { controller: 'draft-order' } do |f| %>
  <% if order.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% order.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Customer Selection -->
  <div class="bg-white rounded-lg shadow-sm p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Customer</h2>
    <div>
      <%= f.label :customer_id, class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.collection_select :customer_id, Customer.active.order(:first_name, :last_name), :id, :full_name, 
          { include_blank: 'Select a customer...' },
          class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
    </div>
  </div>

  <!-- Order Items -->
  <div class="bg-white rounded-lg shadow-sm p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-medium text-gray-900">Order Items</h2>
    </div>

    <div id="order-items" data-draft-order-target="itemsContainer">
      <%= f.fields_for :order_items do |item_form| %>
        <div class="flex gap-4 items-start mb-4 p-4 bg-gray-50 rounded-lg order-item-row">
          <div class="flex-1">
            <%= item_form.label :product_variant_id, 'Product', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= item_form.select :product_variant_id, 
                options_for_select(
                  ProductVariant.active.includes(:product).map { |v| [v.display_name, v.id, { 'data-price' => v.price }] },
                  item_form.object.product_variant_id
                ),
                { include_blank: 'Select product...' },
                { class: 'variant-select w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500',
                  data: { action: 'change->draft-order#updatePrice' } } %>
          </div>
          <div class="w-24">
            <%= item_form.label :quantity, class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= item_form.number_field :quantity, min: 1, value: item_form.object.quantity || 1,
                class: 'quantity-input w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500',
                data: { action: 'change->draft-order#calculateTotal' } %>
          </div>
          <div class="w-32">
            <%= item_form.label :unit_price, 'Price', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= item_form.number_field :unit_price, step: 0.01, min: 0,
                class: 'price-input w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500',
                data: { action: 'change->draft-order#calculateTotal' } %>
          </div>
          <div class="w-28">
            <label class="block text-sm font-medium text-gray-700 mb-1">Line Total</label>
            <div class="line-total px-3 py-2 bg-gray-100 rounded-md text-sm font-medium text-gray-900">
              <%= format_price((item_form.object.quantity || 1) * (item_form.object.unit_price || 0)) %>
            </div>
          </div>
          <div class="pt-6">
            <%= item_form.check_box :_destroy, class: 'hidden destroy-checkbox' %>
            <button type="button" data-action="click->draft-order#removeItem" 
                    class="text-red-600 hover:text-red-900">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </button>
          </div>
        </div>
      <% end %>
    </div>

    <template id="order-item-template">
      <div class="flex gap-4 items-start mb-4 p-4 bg-gray-50 rounded-lg order-item-row">
        <div class="flex-1">
          <label class="block text-sm font-medium text-gray-700 mb-1">Product</label>
          <select name="order[order_items_attributes][NEW_INDEX][product_variant_id]" 
                  class="variant-select w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500"
                  data-action="change->draft-order#updatePrice">
            <option value="">Select product...</option>
            <% ProductVariant.active.includes(:product).each do |v| %>
              <option value="<%= v.id %>" data-price="<%= v.price %>"><%= v.display_name %></option>
            <% end %>
          </select>
        </div>
        <div class="w-24">
          <label class="block text-sm font-medium text-gray-700 mb-1">Qty</label>
          <input type="number" name="order[order_items_attributes][NEW_INDEX][quantity]" min="1" value="1" 
                 class="quantity-input w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500"
                 data-action="change->draft-order#calculateTotal">
        </div>
        <div class="w-32">
          <label class="block text-sm font-medium text-gray-700 mb-1">Price</label>
          <input type="number" name="order[order_items_attributes][NEW_INDEX][unit_price]" step="0.01" min="0" 
                 class="price-input w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500"
                 data-action="change->draft-order#calculateTotal">
        </div>
        <div class="w-28">
          <label class="block text-sm font-medium text-gray-700 mb-1">Line Total</label>
          <div class="line-total px-3 py-2 bg-gray-100 rounded-md text-sm font-medium text-gray-900">₹0.00</div>
        </div>
        <div class="pt-6">
          <button type="button" data-action="click->draft-order#removeItem" class="text-red-600 hover:text-red-900">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
          </button>
        </div>
      </div>
    </template>

    <button type="button" data-action="click->draft-order#addItem" 
            class="mt-4 px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Add Item
    </button>
  </div>

  <!-- Order Summary -->
  <div class="bg-white rounded-lg shadow-sm p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Order Summary</h2>
    <div class="space-y-2 text-sm">
      <div class="flex justify-between">
        <span class="text-gray-600">Subtotal:</span>
        <span class="font-medium" data-draft-order-target="subtotal">₹0.00</span>
      </div>
      <div class="flex justify-between text-emerald-600">
        <span>Discount:</span>
        <span data-draft-order-target="discountDisplay">-₹0.00</span>
      </div>
      <div class="flex justify-between">
        <span class="text-gray-600">Shipping:</span>
        <span data-draft-order-target="shippingDisplay">₹0.00</span>
      </div>
      <div class="flex justify-between text-lg font-bold pt-2 border-t">
        <span>Total:</span>
        <span data-draft-order-target="total">₹0.00</span>
      </div>
    </div>
  </div>

  <!-- Discount & Shipping -->
  <div class="bg-white rounded-lg shadow-sm p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Discount & Shipping</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <%= f.label :coupon_id, 'Coupon', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <select name="order[coupon_id]" id="order_coupon_id"
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500"
                data-action="change->draft-order#applyCoupon"
                data-draft-order-target="couponSelect">
          <option value="">None</option>
          <% Coupon.active.each do |coupon| %>
            <option value="<%= coupon.id %>" 
                    data-discount-type="<%= coupon.discount_type %>"
                    data-discount-value="<%= coupon.discount_value %>"
                    <%= 'selected' if order.coupon_id == coupon.id %>>
              <%= coupon.code %> (<%= coupon.display_value %>)
            </option>
          <% end %>
        </select>
        <p class="mt-1 text-xs text-gray-500" data-draft-order-target="couponInfo"></p>
      </div>
      <div>
        <%= f.label :discount_amount, 'Manual Discount (₹)', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.number_field :discount_amount, step: 0.01, min: 0, value: order.discount_amount || 0,
            class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500',
            data: { action: 'input->draft-order#calculateTotal', draft_order_target: 'discountInput' } %>
      </div>
      <div>
        <%= f.label :shipping_amount, class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.number_field :shipping_amount, step: 0.01, min: 0, value: order.shipping_amount || 0,
            class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500',
            data: { action: 'input->draft-order#calculateTotal', draft_order_target: 'shippingInput' } %>
      </div>
    </div>
  </div>

  <!-- Notes -->
  <div class="bg-white rounded-lg shadow-sm p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Notes</h2>
    <%= f.text_area :notes, rows: 3, placeholder: 'Internal notes about this order...',
        class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to 'Cancel', admin_draft_orders_path, class: 'px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50' %>
    <%= f.submit 'Save Draft Order', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
  </div>
<% end %>
