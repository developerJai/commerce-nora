<% content_for(:title) { "My Earnings" } %>

<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">My Earnings</h1>
    <p class="mt-1 text-sm text-gray-500">Track your sales, fees, and payouts</p>
  </div>

  <!-- Earnings Overview Cards -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="bg-white rounded-lg shadow p-6">
      <div class="text-sm font-medium text-gray-500">Total Earnings</div>
      <div class="mt-2 text-3xl font-bold text-gray-900">₹<%= number_with_precision(@total_earnings, precision: 2) %></div>
      <div class="mt-1 text-xs text-gray-500">Lifetime earnings</div>
    </div>

    <div class="bg-green-50 rounded-lg shadow p-6 border border-green-200">
      <div class="text-sm font-medium text-green-800">Available for Payout</div>
      <div class="mt-2 text-3xl font-bold text-green-900">₹<%= number_with_precision(@available_for_payout, precision: 2) %></div>
      <div class="mt-1 text-xs text-green-700">
        <% if @vendor.has_pending_payout_request? %>
          Payout request pending
        <% elsif @available_for_payout >= @config.minimum_payout_amount %>
          <%= link_to "Request Payout →", new_payout_admin_vendor_earnings_path, class: "text-green-700 hover:text-green-900 font-medium" %>
        <% else %>
          Min ₹<%= @config.minimum_payout_amount %> to payout
        <% end %>
      </div>
    </div>

    <div class="bg-blue-50 rounded-lg shadow p-6 border border-blue-200">
      <div class="text-sm font-medium text-blue-800">Pending Orders</div>
      <div class="mt-2 text-3xl font-bold text-blue-900">₹<%= number_with_precision(@pending_earnings, precision: 2) %></div>
      <div class="mt-1 text-xs text-blue-700">Orders in progress</div>
    </div>

    <div class="bg-purple-50 rounded-lg shadow p-6 border border-purple-200">
      <div class="text-sm font-medium text-purple-800">Paid Out</div>
      <div class="mt-2 text-3xl font-bold text-purple-900">₹<%= number_with_precision(@paid_out_total, precision: 2) %></div>
      <div class="mt-1 text-xs text-purple-700">
        <%= link_to "View History →", admin_payouts_vendor_earnings_path, class: "text-purple-700 hover:text-purple-900" %>
      </div>
    </div>
  </div>

  <!-- Fee Structure Info -->
  <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
    <div class="flex items-center gap-2 mb-4">
      <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
      </svg>
      <h3 class="text-base font-medium text-gray-900">Fee Structure</h3>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="bg-blue-50 rounded-lg p-4 border border-blue-100">
        <p class="text-xs text-blue-600 uppercase tracking-wide mb-1">Platform Commission</p>
        <p class="text-2xl font-bold text-blue-900"><%= @config.platform_commission_percent %>%</p>
        <p class="text-xs text-blue-600 mt-1">Deducted from each order</p>
      </div>
      <div class="bg-amber-50 rounded-lg p-4 border border-amber-100">
        <p class="text-xs text-amber-600 uppercase tracking-wide mb-1">Payment Gateway Fee</p>
        <p class="text-2xl font-bold text-amber-900"><%= @config.gateway_fee_percent %>%</p>
        <p class="text-xs text-amber-600 mt-1">+ <%= @config.gateway_gst_percent %>% GST</p>
      </div>
      <div class="bg-purple-50 rounded-lg p-4 border border-purple-100">
        <p class="text-xs text-purple-600 uppercase tracking-wide mb-1">Payout Range</p>
        <p class="text-lg font-bold text-purple-900">₹<%= @config.minimum_payout_amount %> - ₹<%= @config.maximum_payout_amount %></p>
        <p class="text-xs text-purple-600 mt-1">Per payout request</p>
      </div>
    </div>
    <div class="mt-4 pt-4 border-t border-gray-100">
      <p class="text-xs text-gray-500">
        <span class="font-medium">Note:</span> Platform commission and gateway fees are automatically deducted from your earnings before payout. 
        <span class="text-gray-600">Effective earnings = Order Total - Platform Fee (<%= @config.platform_commission_percent %>%) - Gateway Fee (<%= @config.gateway_fee_percent %>% + GST)</span>
      </p>
    </div>
  </div>

  <!-- Ready Orders for Payout -->
  <% if @ready_orders.any? %>
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200 flex justify-between items-center">
        <div>
          <h3 class="text-lg font-medium text-gray-900">Orders Ready for Payout</h3>
          <p class="mt-1 text-sm text-gray-500">Select orders to request a payout</p>
        </div>
        <% if @available_for_payout >= @config.minimum_payout_amount && !@vendor.has_pending_payout_request? %>
          <%= link_to new_payout_admin_vendor_earnings_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700" do %>
            Request Payout
          <% end %>
        <% end %>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Order</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Delivered</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Order Total</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Platform Fee</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Gateway Fee</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Your Earnings</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @ready_orders.each do |order| %>
              <% 
                # Calculate fees if not already stored
                if order.vendor_earnings.present? && order.vendor_earnings > 0
                  platform_fee = order.platform_fee_amount || 0
                  gateway_fee = order.gateway_fee_amount || 0
                  gateway_gst = order.gateway_gst_amount || 0
                  vendor_earnings = order.vendor_earnings
                else
                  # Calculate projected fees
                  config = PlatformFeeConfig.current
                  fees = config.calculate_fees(order.total_amount)
                  platform_fee = fees[:platform_fee]
                  gateway_fee = fees[:gateway_fee]
                  gateway_gst = fees[:gateway_gst]
                  vendor_earnings = fees[:vendor_earnings]
                end
              %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= link_to order.order_number, admin_order_path(order), class: "text-indigo-600 hover:text-indigo-900" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= order.delivered_at&.strftime("%d %b %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
                  ₹<%= number_with_precision(order.total_amount, precision: 2) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right">
                  ₹<%= number_with_precision(platform_fee, precision: 2) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right">
                  ₹<%= number_with_precision(gateway_fee + gateway_gst, precision: 2) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-green-600 text-right">
                  ₹<%= number_with_precision(vendor_earnings, precision: 2) %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @ready_orders.count > 10 %>
        <div class="px-4 py-3 border-t border-gray-200 text-center">
          <%= link_to new_payout_admin_vendor_earnings_path, class: "text-indigo-600 hover:text-indigo-900 text-sm font-medium" do %>
            View all <%= @vendor.ready_orders_for_payout.count %> orders →
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white shadow rounded-lg p-8 text-center">
      <div class="text-gray-500">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No orders ready for payout</h3>
        <p class="mt-1 text-sm text-gray-500">Orders will appear here once they are delivered and payment is confirmed.</p>
      </div>
    </div>
  <% end %>

  <!-- Recent Payouts -->
  <% if @recent_payouts.any? %>
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200 flex justify-between items-center">
        <div>
          <h3 class="text-lg font-medium text-gray-900">Recent Payouts</h3>
          <p class="mt-1 text-sm text-gray-500">Your latest payout requests</p>
        </div>
        <%= link_to payouts_vendor_earnings_path, class: "text-indigo-600 hover:text-indigo-900 text-sm font-medium" do %>
          View All →
        <% end %>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Net Payout</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @recent_payouts.each do |payout| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= payout.created_at.strftime("%d %b %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% case payout.status %>
                  <% when 'pending' %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                      Pending Review
                    </span>
                  <% when 'approved' %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                      Approved - Awaiting Payment
                    </span>
                  <% when 'paid' %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Paid
                    </span>
                  <% when 'rejected' %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                      Rejected
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
                  ₹<%= number_with_precision(payout.total_amount, precision: 2) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 text-right">
                  ₹<%= number_with_precision(payout.net_payout, precision: 2) %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
