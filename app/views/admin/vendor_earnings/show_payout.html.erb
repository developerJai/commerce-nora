<% content_for(:title) { "Payout Details" } %>

<div class="space-y-6">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Payout Details</h1>
      <p class="mt-1 text-sm text-gray-500">
        Requested on <%= @payout.created_at.strftime("%d %b %Y at %I:%M %p") %>
      </p>
    </div>
    <%= link_to admin_payouts_vendor_earnings_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
      ← Back to History
    <% end %>
  </div>

  <!-- Status Banner -->
  <div class="rounded-lg p-4 <%= 
    case @payout.status
    when 'pending' then 'bg-yellow-50 border border-yellow-200'
    when 'approved' then 'bg-blue-50 border border-blue-200'
    when 'paid' then 'bg-green-50 border border-green-200'
    when 'rejected' then 'bg-red-50 border border-red-200'
    end 
  %>">
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <% case @payout.status %>
        <% when 'pending' %>
          <svg class="h-6 w-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        <% when 'approved' %>
          <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        <% when 'paid' %>
          <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        <% when 'rejected' %>
          <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        <% end %>
      </div>
      <div class="ml-3">
        <h3 class="text-sm font-medium <%= 
          case @payout.status
          when 'pending' then 'text-yellow-800'
          when 'approved' then 'text-blue-800'
          when 'paid' then 'text-green-800'
          when 'rejected' then 'text-red-800'
          end
        %>">
          Status: <%= @payout.status.titleize %>
        </h3>
        <div class="mt-1 text-sm <%= 
          case @payout.status
          when 'pending' then 'text-yellow-700'
          when 'approved' then 'text-blue-700'
          when 'paid' then 'text-green-700'
          when 'rejected' then 'text-red-700'
          end
        %>">
          <% case @payout.status %>
          <% when 'pending' %>
            Your payout is pending admin review. You'll be notified once it's approved.
          <% when 'approved' %>
            Payout approved on <%= @payout.approved_at.strftime("%d %b %Y") %>. Payment will be processed shortly.
          <% when 'paid' %>
            Payout completed on <%= @payout.paid_at.strftime("%d %b %Y") %>.
            <% if @payout.transaction_reference.present? %>
              Reference: <span class="font-mono font-medium"><%= @payout.transaction_reference %></span>
            <% end %>
          <% when 'rejected' %>
            Payout was rejected on <%= @payout.rejected_at&.strftime("%d %b %Y") %>.
            <% if @payout.admin_notes.present? %>
              Reason: <%= @payout.admin_notes %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Payout Summary -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Payout Summary</h3>
    </div>
    <div class="p-6">
      <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-3">
        <div class="sm:col-span-1">
          <dt class="text-sm font-medium text-gray-500">Total Amount</dt>
          <dd class="mt-1 text-2xl font-semibold text-gray-900">₹<%= number_with_precision(@payout.total_amount, precision: 2) %></dd>
        </div>
        <div class="sm:col-span-1">
          <dt class="text-sm font-medium text-gray-500">Platform Fee (<%= @config.platform_commission_percent %>%)</dt>
          <dd class="mt-1 text-xl font-semibold text-red-600">-₹<%= number_with_precision(@payout.platform_fee_total, precision: 2) %></dd>
        </div>
        <div class="sm:col-span-1">
          <dt class="text-sm font-medium text-gray-500">Gateway Fee + GST</dt>
          <dd class="mt-1 text-xl font-semibold text-red-600">-₹<%= number_with_precision(@payout.gateway_fee_total + @payout.gateway_gst_total, precision: 2) %></dd>
        </div>
        <div class="sm:col-span-3 pt-4 border-t border-gray-200">
          <dt class="text-sm font-medium text-gray-900">Net Payout</dt>
          <dd class="mt-1 text-3xl font-bold text-green-600">₹<%= number_with_precision(@payout.net_payout, precision: 2) %></dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Orders in this Payout -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Orders in this Payout (<%= @orders.count %>)</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Order</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Delivered</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Order Total</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Platform Fee</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Gateway Fee</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Your Earnings</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @orders.each do |order| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= link_to order.order_number, admin_order_path(order), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= order.delivered_at&.strftime("%d %b %Y") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
                ₹<%= number_with_precision(order.total_amount, precision: 2) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right">
                ₹<%= number_with_precision(order.platform_fee_amount, precision: 2) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right">
                ₹<%= number_with_precision(order.gateway_fee_amount + order.gateway_gst_amount, precision: 2) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-green-600 text-right">
                ₹<%= number_with_precision(order.vendor_earnings, precision: 2) %>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="bg-gray-50">
          <tr>
            <td colspan="3" class="px-6 py-3 text-right text-sm font-medium text-gray-900">Totals</td>
            <td class="px-6 py-3 text-right text-sm font-medium text-gray-900">₹<%= number_with_precision(@orders.sum(:platform_fee_amount), precision: 2) %></td>
            <td class="px-6 py-3 text-right text-sm font-medium text-gray-900">₹<%= number_with_precision(@orders.sum(:gateway_fee_amount) + @orders.sum(:gateway_gst_amount), precision: 2) %></td>
            <td class="px-6 py-3 text-right text-sm font-bold text-green-700">₹<%= number_with_precision(@orders.sum(:vendor_earnings), precision: 2) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>
