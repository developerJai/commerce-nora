<% content_for(:title) { "Request Payout" } %>

<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Request Payout</h1>
    <p class="mt-1 text-sm text-gray-500">Select orders to include in your payout request</p>
  </div>

  <% if @selected_orders.any? %>
    <!-- Payout Summary -->
    <div class="bg-indigo-50 rounded-lg p-6 border border-indigo-200">
      <h3 class="text-lg font-medium text-indigo-900 mb-4">Payout Summary</h3>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div>
          <div class="text-sm text-indigo-700">Total Amount</div>
          <div class="text-2xl font-bold text-indigo-900">₹<%= number_with_precision(@total_amount, precision: 2) %></div>
        </div>
        <div>
          <div class="text-sm text-red-700">Platform Fee</div>
          <div class="text-lg font-semibold text-red-900">-₹<%= number_with_precision(@platform_fee, precision: 2) %></div>
        </div>
        <div>
          <div class="text-sm text-red-700">Gateway Fee + GST</div>
          <div class="text-lg font-semibold text-red-900">-₹<%= number_with_precision(@gateway_fee + @gateway_gst, precision: 2) %></div>
        </div>
        <div class="bg-white rounded p-3 border border-indigo-300">
          <div class="text-sm text-indigo-800 font-medium">Net Payout</div>
          <div class="text-2xl font-bold text-indigo-900">₹<%= number_with_precision(@net_payout, precision: 2) %></div>
        </div>
      </div>

      <%= form_with url: create_payout_admin_vendor_earnings_path, method: :post, class: "mt-6" do |form| %>
        <% @selected_orders.each do |order| %>
          <%= hidden_field_tag "order_ids[]", order.id %>
        <% end %>
        
        <div class="flex gap-4">
          <%= form.submit "Confirm & Submit Payout Request", class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
          <%= link_to "Back to Selection", new_payout_admin_vendor_earnings_path, class: "inline-flex items-center px-6 py-3 border border-gray-300 text-base font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
        </div>
      <% end %>
    </div>

    <!-- Selected Orders Table -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium text-gray-900">Selected Orders (<%= @selected_orders.count %>)</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Order</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Delivered</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Order Total</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Your Earnings</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @selected_orders.each do |order| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= link_to order.order_number, admin_order_path(order), class: "text-indigo-600 hover:text-indigo-900" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= order.delivered_at&.strftime("%d %b %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
                  ₹<%= number_with_precision(order.total_amount, precision: 2) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-green-600 text-right">
                  ₹<%= number_with_precision(order.vendor_earnings, precision: 2) %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <!-- Order Selection Form -->
    <%= form_with url: new_payout_admin_vendor_earnings_path, method: :get, local: true, id: "order-selection-form" do |form| %>
      <div class="bg-white shadow rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200 flex justify-between items-center">
          <div>
            <h3 class="text-lg font-medium text-gray-900">Available Orders</h3>
            <p class="mt-1 text-sm text-gray-500">Select orders to include in your payout request</p>
          </div>
          <div class="text-sm text-gray-600">
            Selected: <span id="selected-count" class="font-medium text-indigo-600">0</span> orders
          </div>
        </div>
        
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left">
                  <input type="checkbox" id="select-all" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                </th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Order</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Delivered</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Order Total</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Platform Fee</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Gateway Fee</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Your Earnings</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @ready_orders.each do |order| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <%= check_box_tag "order_ids[]", order.id, false, class: "order-checkbox rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                    <%= link_to order.order_number, admin_order_path(order), class: "text-indigo-600 hover:text-indigo-900" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= order.delivered_at&.strftime("%d %b %Y") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
                    ₹<%= number_with_precision(order.total_amount, precision: 2) %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right">
                    ₹<%= number_with_precision(order.platform_fee_amount, precision: 2) %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right">
                    ₹<%= number_with_precision(order.gateway_fee_amount + order.gateway_gst_amount, precision: 2) %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-green-600 text-right">
                    ₹<%= number_with_precision(order.vendor_earnings, precision: 2) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        
        <div class="px-4 py-4 border-t border-gray-200 bg-gray-50 flex justify-between items-center">
          <div class="text-sm text-gray-600">
            <span id="total-selected" class="font-medium">₹0.00</span> selected
          </div>
          <%= form.submit "Review Payout", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed", disabled: true, id: "review-btn" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const selectAllCheckbox = document.getElementById('select-all');
    const orderCheckboxes = document.querySelectorAll('.order-checkbox');
    const selectedCount = document.getElementById('selected-count');
    const totalSelected = document.getElementById('total-selected');
    const reviewBtn = document.getElementById('review-btn');
    
    const orderEarnings = {};
    <% @ready_orders.each do |order| %>
      orderEarnings[<%= order.id %>] = <%= order.vendor_earnings %>;
    <% end %>
    
    function updateSummary() {
      const checked = document.querySelectorAll('.order-checkbox:checked');
      const count = checked.length;
      let total = 0;
      
      checked.forEach(function(checkbox) {
        const orderId = parseInt(checkbox.value);
        total += orderEarnings[orderId] || 0;
      });
      
      selectedCount.textContent = count;
      totalSelected.textContent = '₹' + total.toFixed(2);
      reviewBtn.disabled = count === 0;
    }
    
    selectAllCheckbox.addEventListener('change', function() {
      orderCheckboxes.forEach(function(checkbox) {
        checkbox.checked = selectAllCheckbox.checked;
      });
      updateSummary();
    });
    
    orderCheckboxes.forEach(function(checkbox) {
      checkbox.addEventListener('change', function() {
        const allChecked = document.querySelectorAll('.order-checkbox:checked').length === orderCheckboxes.length;
        selectAllCheckbox.checked = allChecked;
        updateSummary();
      });
    });
  });
</script>
