<tr id="<%= dom_id(coupon) %>">
  <td class="px-6 py-4 whitespace-nowrap">
    <span class="font-mono text-sm font-medium text-gray-900"><%= coupon.code %></span>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= coupon.name %></td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
    <%= coupon.display_value %>
    <% if coupon.minimum_order_amount.to_i > 0 %>
      <span class="text-gray-500">(min <%= format_price(coupon.minimum_order_amount) %>)</span>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
    <%= coupon.usage_count %><%= coupon.usage_limit ? " / #{coupon.usage_limit}" : '' %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap">
    <span class="px-2 py-1 text-xs font-medium rounded-full <%= coupon.active? && coupon.valid_for_use? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
      <%= coupon.active? && coupon.valid_for_use? ? 'Active' : 'Inactive' %>
    </span>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
    <%= link_to 'Edit', edit_admin_coupon_path(coupon), class: 'text-indigo-600 hover:text-indigo-900 mr-3' %>
    <%= button_to coupon.active? ? 'Disable' : 'Enable', toggle_status_admin_coupon_path(coupon), 
        method: :patch, 
        class: coupon.active? ? 'text-red-600 hover:text-red-900 mr-3' : 'text-green-600 hover:text-green-900 mr-3',
        form: { data: { turbo_frame: dom_id(coupon) } } %>
    <%= button_to 'Delete', admin_coupon_path(coupon), method: :delete, 
        class: 'text-red-600 hover:text-red-900',
        form: { data: { turbo_confirm: 'Are you sure you want to delete this coupon?' } } %>
  </td>
</tr>
