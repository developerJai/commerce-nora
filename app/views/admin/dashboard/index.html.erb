<% content_for(:title) { "Dashboard" } %>

<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="mt-1 text-sm text-gray-500">Welcome back, <%= current_admin.name %>!</p>
  </div>

  <% if vendor_context? && current_vendor.slug.present? %>
    <div class="bg-gradient-to-r from-indigo-50 to-purple-50 border border-indigo-200 rounded-lg p-4 sm:p-5">
      <div class="flex items-center justify-between gap-4 flex-wrap">
        <div>
          <h3 class="text-sm font-semibold text-indigo-900">Your Storefront</h3>
          <p class="text-xs text-indigo-600 mt-0.5">Share this link with your customers to browse your catalog</p>
        </div>
        <div class="flex items-center gap-2 flex-1 sm:flex-initial min-w-0">
          <code id="vendor-storefront-url" class="flex-1 sm:flex-initial bg-white/80 px-3 py-1.5 rounded-md text-xs font-mono text-gray-800 truncate border border-indigo-200 select-all"><%= vendor_storefront_url(current_vendor.slug) %></code>
          <button type="button" onclick="copyVendorStorefrontUrl()" id="copy-vendor-url-btn"
                  class="flex-shrink-0 px-3 py-1.5 bg-indigo-600 text-white text-xs font-medium rounded-md hover:bg-indigo-700 transition cursor-pointer">
            Copy Link
          </button>
          <%= link_to vendor_storefront_path(current_vendor.slug), target: "_blank", class: "flex-shrink-0 px-3 py-1.5 bg-white border border-indigo-300 text-indigo-700 text-xs font-medium rounded-md hover:bg-indigo-50 transition" do %>
            Preview
          <% end %>
        </div>
      </div>
      <script>
        function copyVendorStorefrontUrl() {
          const url = document.getElementById('vendor-storefront-url').textContent;
          navigator.clipboard.writeText(url).then(() => {
            const btn = document.getElementById('copy-vendor-url-btn');
            btn.textContent = 'Copied!';
            btn.classList.replace('bg-indigo-600', 'bg-green-600');
            setTimeout(() => { btn.textContent = 'Copy Link'; btn.classList.replace('bg-green-600', 'bg-indigo-600'); }, 2000);
          });
        }
      </script>
    </div>
  <% end %>

  <% if vendor_context? && ((@out_of_stock_variants_count.to_i > 0) || (@low_stock_variants_count.to_i > 0)) %>
    <div class="bg-white shadow rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
        <h3 class="text-lg font-medium text-gray-900">Inventory Alerts</h3>
        <p class="mt-1 text-sm text-gray-500">Variants that need restock attention</p>
      </div>
      <div class="p-4 sm:p-6">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <%= link_to admin_inventory_index_path(filter: 'out_of_stock'), class: 'block rounded-lg border border-red-200 bg-red-50 p-4 hover:bg-red-100 transition' do %>
            <div class="text-xs font-medium text-red-800">Out of Stock</div>
            <div class="mt-2 text-2xl font-semibold text-red-900"><%= @out_of_stock_variants_count.to_i %></div>
            <div class="mt-1 text-xs text-red-700">View out of stock inventory</div>
          <% end %>

          <%= link_to admin_inventory_index_path(filter: 'low_stock'), class: 'block rounded-lg border border-yellow-200 bg-yellow-50 p-4 hover:bg-yellow-100 transition' do %>
            <div class="text-xs font-medium text-yellow-800">Low Stock</div>
            <div class="mt-2 text-2xl font-semibold text-yellow-900"><%= @low_stock_variants_count.to_i %></div>
            <div class="mt-1 text-xs text-yellow-700">View low stock inventory</div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Priority Actions -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Priority Actions</h3>
      <p class="mt-1 text-sm text-gray-500">Quick links to operational items that need attention</p>
    </div>
    <div class="p-4 sm:p-6">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-5">
        <%= link_to admin_orders_path(status: 'pending'), class: 'block rounded-lg border border-yellow-200 bg-yellow-50 p-4 hover:bg-yellow-100 transition' do %>
          <div class="text-xs font-medium text-yellow-800">Orders Need Confirmation</div>
          <div class="mt-2 text-2xl font-semibold text-yellow-900"><%= @pending_orders %></div>
          <div class="mt-1 text-xs text-yellow-700">Pending Orders wait to confirm</div>
        <% end %>

        <%= link_to admin_orders_path(not_shipped: 1), class: 'block rounded-lg border border-orange-200 bg-orange-50 p-4 hover:bg-orange-100 transition' do %>
          <div class="text-xs font-medium text-orange-800">Orders Need shipping</div>
          <div class="mt-2 text-2xl font-semibold text-orange-900"><%= @confirmed_not_shipped_orders %></div>
          <div class="mt-1 text-xs text-orange-700">Confirmed orders wait to ship</div>
        <% end %>

        <%= link_to admin_inventory_index_path(filter: 'low_stock'), class: 'block rounded-lg border border-red-200 bg-red-50 p-4 hover:bg-red-100 transition' do %>
          <div class="text-xs font-medium text-red-800">Low Stock Inventory</div>
          <div class="mt-2 text-2xl font-semibold text-red-900"><%= @low_stock_products %></div>
          <div class="mt-1 text-xs text-red-700">View low stock variants</div>
        <% end %>

        <%= link_to admin_support_tickets_path(unread: 1, status: ''), class: 'block rounded-lg border border-blue-200 bg-blue-50 p-4 hover:bg-blue-100 transition' do %>
          <div class="text-xs font-medium text-blue-800">Open Tickets (Unread)</div>
          <div class="mt-2 text-2xl font-semibold text-blue-900"><%= @unread_open_tickets %></div>
          <div class="mt-1 text-xs text-blue-700">View tickets not seen</div>
        <% end %>

        <%= link_to admin_reviews_path(status: 'pending'), class: 'block rounded-lg border border-indigo-200 bg-indigo-50 p-4 hover:bg-indigo-100 transition' do %>
          <div class="text-xs font-medium text-indigo-800">Pending Reviews</div>
          <div class="mt-2 text-2xl font-semibold text-indigo-900"><%= @pending_reviews %></div>
          <div class="mt-1 text-xs text-indigo-700">Moderate reviews</div>
        <% end %>
      </div>
    </div>

    <% if admin_role? && !vendor_context? %>
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Low Inventory Vendors</dt>
                <dd class="text-lg font-semibold text-gray-900"><%= @low_inventory_vendors.to_i %> / <%= @total_vendors.to_i %></dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-5 py-3">
          <div class="text-sm">
            <%= link_to 'View inventory', admin_inventory_index_path(filter: 'needs_reorder'), class: 'font-medium text-indigo-600 hover:text-indigo-500' %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Stats cards -->
  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Total Revenue</dt>
              <dd class="text-lg font-semibold text-gray-900"><%= format_price(@total_revenue.to_f.round(2)) %></dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <span class="font-medium text-indigo-600"><%= format_price(@revenue_today.to_f.round(2)) %></span>
          <span class="text-gray-500"> today</span>
        </div>
      </div>
    </div>

    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Total Orders</dt>
              <dd class="text-lg font-semibold text-gray-900"><%= number_with_delimiter(@total_orders) %></dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <span class="font-medium text-indigo-600"><%= @orders_today %></span>
          <span class="text-gray-500"> orders today</span>
        </div>
      </div>
    </div>

    <% if admin_role? && !vendor_context? %>
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Total Customers</dt>
                <dd class="text-lg font-semibold text-gray-900"><%= number_with_delimiter(@total_customers) %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="bg-white overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate">Total Products</dt>
              <dd class="text-lg font-semibold text-gray-900"><%= number_with_delimiter(@total_products) %></dd>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick stats -->
  

  <!-- Recent orders -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Recent Orders</h3>
    </div>
    <ul role="list" class="divide-y divide-gray-200">
      <% if @recent_orders.any? %>
        <% @recent_orders.each do |order| %>
          <li class="px-4 py-4 sm:px-6">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="flex-shrink-0">
                  <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-indigo-100">
                    <span class="text-sm font-medium text-indigo-800">
                      <%= order.customer&.first_name&.first&.upcase || 'G' %>
                    </span>
                  </span>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-900"><%= order.order_number %></p>
                  <p class="text-sm text-gray-500"><%= order.customer&.full_name || 'Guest' %></p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= order_status_class(order.status) %>">
                  <%= order.status.titleize %>
                </span>
                <span class="text-sm font-medium text-gray-900"><%= format_price(order.total_amount.to_f.round(2)) %></span>
                <%= link_to 'View', admin_order_path(order), class: 'text-sm text-indigo-600 hover:text-indigo-900' %>
              </div>
            </div>
          </li>
        <% end %>
      <% else %>
        <li class="px-4 py-8 text-center text-gray-500">
          No orders yet
        </li>
      <% end %>
    </ul>
    <% if @recent_orders.any? %>
      <div class="px-4 py-3 bg-gray-50 text-right sm:px-6">
        <%= link_to 'View all orders', admin_orders_path, class: 'text-sm font-medium text-indigo-600 hover:text-indigo-500' %>
      </div>
    <% end %>
  </div>
</div>
