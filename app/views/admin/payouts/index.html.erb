<% content_for(:title) { "Vendor Payouts" } %>

<div class="space-y-6">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Vendor Payouts</h1>
      <p class="mt-1 text-sm text-gray-500">Manage and process vendor payout requests</p>
    </div>
    <%= link_to admin_platform_fee_config_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
      ⚙️ Fee Settings
    <% end %>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
    <div class="bg-yellow-50 rounded-lg p-6 border border-yellow-200">
      <div class="text-sm font-medium text-yellow-800">Pending Requests</div>
      <div class="mt-2 text-3xl font-bold text-yellow-900"><%= @pending_count %></div>
      <div class="mt-1 text-sm text-yellow-700">Awaiting approval</div>
    </div>

    <div class="bg-blue-50 rounded-lg p-6 border border-blue-200">
      <div class="text-sm font-medium text-blue-800">Approved & Unpaid</div>
      <div class="mt-2 text-3xl font-bold text-blue-900"><%= @approved_count %></div>
      <div class="mt-1 text-sm text-blue-700">Ready for payment</div>
    </div>

    <div class="bg-green-50 rounded-lg p-6 border border-green-200">
      <div class="text-sm font-medium text-green-800">Total Pending Amount</div>
      <div class="mt-2 text-3xl font-bold text-green-900">₹<%= number_with_precision(@total_pending_amount, precision: 2) %></div>
      <div class="mt-1 text-sm text-green-700">To be paid out</div>
    </div>
  </div>

  <!-- Status Filter Tabs -->
  <div class="border-b border-gray-200">
    <nav class="-mb-px flex space-x-8">
      <%= link_to admin_payouts_path(status: 'pending'), class: "py-4 px-1 border-b-2 font-medium text-sm #{@status == 'pending' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" do %>
        Pending
        <span class="ml-2 px-2 py-0.5 rounded-full text-xs <%= @status == 'pending' ? 'bg-indigo-100 text-indigo-600' : 'bg-gray-100 text-gray-600' %>"><%= VendorPayout.pending.count %></span>
      <% end %>
      <%= link_to admin_payouts_path(status: 'approved'), class: "py-4 px-1 border-b-2 font-medium text-sm #{@status == 'approved' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" do %>
        Approved
        <span class="ml-2 px-2 py-0.5 rounded-full text-xs <%= @status == 'approved' ? 'bg-indigo-100 text-indigo-600' : 'bg-gray-100 text-gray-600' %>"><%= VendorPayout.approved.count %></span>
      <% end %>
      <%= link_to admin_payouts_path(status: 'paid'), class: "py-4 px-1 border-b-2 font-medium text-sm #{@status == 'paid' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" do %>
        Paid
        <span class="ml-2 px-2 py-0.5 rounded-full text-xs <%= @status == 'paid' ? 'bg-indigo-100 text-indigo-600' : 'bg-gray-100 text-gray-600' %>"><%= VendorPayout.paid.count %></span>
      <% end %>
      <%= link_to admin_payouts_path(status: 'rejected'), class: "py-4 px-1 border-b-2 font-medium text-sm #{@status == 'rejected' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" do %>
        Rejected
        <span class="ml-2 px-2 py-0.5 rounded-full text-xs <%= @status == 'rejected' ? 'bg-indigo-100 text-indigo-600' : 'bg-gray-100 text-gray-600' %>"><%= VendorPayout.rejected.count %></span>
      <% end %>
    </nav>
  </div>

  <!-- Payouts Table -->
  <div class="bg-white shadow rounded-lg">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Request Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Vendor</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Fees</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Net Payout</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @payouts.any? %>
            <% @payouts.each do |payout| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= payout.created_at.strftime("%d %b %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= link_to payout.vendor.business_name, admin_vendor_path(payout.vendor), class: "text-indigo-600 hover:text-indigo-900" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% case payout.status %>
                  <% when 'pending' %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                      Pending Review
                    </span>
                  <% when 'approved' %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                      Approved
                    </span>
                  <% when 'paid' %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      Paid
                    </span>
                  <% when 'rejected' %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                      Rejected
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
                  ₹<%= number_with_precision(payout.total_amount, precision: 2) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600 text-right">
                  -₹<%= number_with_precision(payout.platform_fee_total + payout.gateway_fee_total + payout.gateway_gst_total, precision: 2) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900 text-right">
                  ₹<%= number_with_precision(payout.net_payout, precision: 2) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <%= link_to "View", admin_payout_path(payout), class: "text-indigo-600 hover:text-indigo-900 mr-3" %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-sm text-gray-500">
                <div class="flex flex-col items-center">
                  <svg class="h-12 w-12 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <p class="font-medium text-gray-900">No <%= @status %> payouts</p>
                  <p class="mt-1">There are no <%= @status %> payout requests at this time.</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    
    <% if @pagy && @pagy.pages > 1 %>
      <div class="px-4 py-3 border-t border-gray-200">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  </div>
</div>
