<% content_for(:title) { "Reorder Report" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Reorder Report</h1>
      <p class="text-sm text-gray-500">Items that need to be reordered from suppliers</p>
    </div>
    <div class="flex gap-3">
      <%= link_to 'Download CSV', reorder_report_admin_inventory_index_path(format: :csv), class: 'px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700' %>
      <%= link_to '← Back to Inventory', admin_inventory_index_path, class: 'px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50' %>
    </div>
  </div>

  <% if @variants.any? %>
    <div class="bg-white rounded-lg shadow-sm overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">SKU</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Product / Variant</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Current Stock</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Reorder Point</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Suggested Order Qty</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Estimated Cost</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% total_units = 0 %>
          <% @variants.each do |variant| %>
            <% total_units += variant.reorder_quantity %>
            <tr class="<%= variant.out_of_stock? ? 'bg-red-50' : 'bg-yellow-50' %>">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-900"><%= variant.sku %></td>
              <td class="px-6 py-4">
                <div class="text-sm font-medium text-gray-900"><%= variant.product.name %></div>
                <div class="text-sm text-gray-500"><%= variant.name %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-center">
                <span class="<%= variant.out_of_stock? ? 'text-red-600' : 'text-yellow-600' %> font-bold">
                  <%= variant.stock_quantity %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500">
                <%= variant.reorder_point %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium text-gray-900">
                <%= variant.reorder_quantity %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-900">
                <%= format_price(variant.price * variant.reorder_quantity * 0.6) %>
                <span class="text-xs text-gray-500">(est.)</span>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="bg-gray-100">
          <tr>
            <td colspan="4" class="px-6 py-4 text-sm font-medium text-gray-900">Total</td>
            <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-bold text-gray-900">
              <%= total_units %> units
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-500">
              Contact suppliers for quotes
            </td>
          </tr>
        </tfoot>
      </table>
    </div>

    <div class="bg-blue-50 rounded-lg p-4">
      <h3 class="font-medium text-blue-900 mb-2">Tips for Reordering</h3>
      <ul class="text-sm text-blue-800 space-y-1">
        <li>• Review seasonal demand before placing orders</li>
        <li>• Consider lead times from suppliers</li>
        <li>• Check for bulk discounts on larger orders</li>
        <li>• Update reorder quantities based on sales velocity</li>
      </ul>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow-sm p-12 text-center">
      <svg class="mx-auto h-16 w-16 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">No Reorders Needed</h3>
      <p class="mt-2 text-gray-500">All inventory levels are above reorder points.</p>
    </div>
  <% end %>
</div>
