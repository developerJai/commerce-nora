<% content_for(:title) { "Inventory Management" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-4">
      <h1 class="text-2xl font-bold text-gray-900">Inventory Management</h1>
      <%= render 'help_modal' %>
    </div>
    <div class="flex gap-3">
      <%= link_to 'Bulk Restock', bulk_adjust_admin_inventory_index_path, class: 'px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700' %>
      <%= link_to 'Reorder Report', reorder_report_admin_inventory_index_path, class: 'px-4 py-2 bg-gray-600 text-white rounded-md hover:bg-gray-700' %>
      <%= link_to 'Adjustment History', adjustments_admin_inventory_index_path, class: 'px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50' %>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <%= link_to admin_inventory_index_path(filter: 'all'), class: "block bg-white rounded-lg shadow-sm p-6 hover:shadow-md transition #{@filter == 'all' ? 'ring-2 ring-indigo-500' : ''}" do %>
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Total Items</p>
          <p class="text-2xl font-bold text-gray-900"><%= @total_variants %></p>
        </div>
        <div class="p-3 bg-indigo-100 rounded-full">
          <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
          </svg>
        </div>
      </div>
    <% end %>

    <%= link_to admin_inventory_index_path(filter: 'out_of_stock'), class: "block bg-white rounded-lg shadow-sm p-6 hover:shadow-md transition #{@filter == 'out_of_stock' ? 'ring-2 ring-red-500' : ''}" do %>
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Out of Stock</p>
          <p class="text-2xl font-bold <%= @out_of_stock_count > 0 ? 'text-red-600' : 'text-gray-900' %>"><%= @out_of_stock_count %></p>
        </div>
        <div class="p-3 bg-red-100 rounded-full">
          <svg class="w-6 h-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
      </div>
    <% end %>

    <%= link_to admin_inventory_index_path(filter: 'low_stock'), class: "block bg-white rounded-lg shadow-sm p-6 hover:shadow-md transition #{@filter == 'low_stock' ? 'ring-2 ring-yellow-500' : ''}" do %>
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Low Stock</p>
          <p class="text-2xl font-bold <%= @low_stock_count > 0 ? 'text-yellow-600' : 'text-gray-900' %>"><%= @low_stock_count %></p>
        </div>
        <div class="p-3 bg-yellow-100 rounded-full">
          <svg class="w-6 h-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
      </div>
    <% end %>

    <%= link_to admin_inventory_index_path(filter: 'needs_reorder'), class: "block bg-white rounded-lg shadow-sm p-6 hover:shadow-md transition #{@filter == 'needs_reorder' ? 'ring-2 ring-orange-500' : ''}" do %>
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">Needs Reorder</p>
          <p class="text-2xl font-bold <%= @needs_reorder_count > 0 ? 'text-orange-600' : 'text-gray-900' %>"><%= @needs_reorder_count %></p>
        </div>
        <div class="p-3 bg-orange-100 rounded-full">
          <svg class="w-6 h-6 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Search -->
  <div class="bg-white rounded-lg shadow-sm p-4">
    <%= form_with url: admin_inventory_index_path, method: :get, class: 'flex gap-4' do |f| %>
      <%= f.hidden_field :filter, value: @filter %>
      <%= f.search_field :q, value: params[:q], placeholder: 'Search by product name, variant, or SKU...', 
          class: 'flex-1 px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
      <%= f.submit 'Search', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
    <% end %>
  </div>

  <!-- Inventory Table -->
  <div class="bg-white rounded-lg shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Product / Variant</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">SKU</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Current Stock</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Reorder Point</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @variants.each do |variant| %>
            <tr class="<%= variant.out_of_stock? ? 'bg-red-50' : variant.low_stock? ? 'bg-yellow-50' : '' %>">
              <td class="px-6 py-4">
                <div class="flex items-center">
                  <% if variant.image.attached? %>
                    <%= image_tag variant.image, class: 'h-10 w-10 rounded object-cover mr-3' %>
                  <% elsif variant.product.images.attached? %>
                    <%= image_tag variant.product.images.first, class: 'h-10 w-10 rounded object-cover mr-3' %>
                  <% end %>
                  <div>
                    <div class="text-sm font-medium text-gray-900"><%= variant.product.name %></div>
                    <div class="text-sm text-gray-500"><%= variant.name %></div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-500"><%= variant.sku %></td>
              <td class="px-6 py-4 whitespace-nowrap text-center">
                <span class="text-lg font-bold <%= variant.out_of_stock? ? 'text-red-600' : variant.low_stock? ? 'text-yellow-600' : 'text-gray-900' %>">
                  <%= variant.stock_quantity %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500">
                <%= variant.reorder_point %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% case variant.stock_status %>
                <% when :out_of_stock %>
                  <span class="px-2 py-1 text-xs font-medium rounded-full bg-red-100 text-red-800">Out of Stock</span>
                <% when :low_stock %>
                  <span class="px-2 py-1 text-xs font-medium rounded-full bg-yellow-100 text-yellow-800">Low Stock</span>
                <% else %>
                  <span class="px-2 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800">In Stock</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                <%= link_to 'Adjust', adjust_admin_inventory_path(variant), class: 'text-indigo-600 hover:text-indigo-900' %>
                <%= link_to 'History', adjustments_admin_inventory_index_path(id: variant.id), class: 'text-gray-600 hover:text-gray-900' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
