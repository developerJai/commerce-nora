<% content_for(:title) { "Edit Item" } %>

<div>
  <div class="flex items-center gap-3 mb-6">
    <%= link_to admin_homepage_collection_path(@collection), class: "text-gray-400 hover:text-gray-600" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-gray-900">Edit Item in "<%= @collection.name %>"</h1>
  </div>
  <%= render "form", collection: @collection, item: @item %>
</div>
