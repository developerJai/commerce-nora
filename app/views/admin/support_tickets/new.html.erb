<% content_for(:title) { "New Support Ticket" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">New Support Ticket</h1>
  </div>

  <% if @support_ticket.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <ul class="list-disc list-inside text-sm text-red-700">
        <% @support_ticket.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: [:admin, @support_ticket], class: 'space-y-6' do |f| %>
    <div class="bg-white rounded-lg shadow-sm p-6 space-y-6">
      <div>
        <%= f.label :subject, class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.text_field :subject, required: true, placeholder: 'Describe your issue briefly...',
            class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
      </div>

      <div>
        <%= f.label :priority, class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= f.select :priority, SupportTicket::PRIORITIES.map { |p| [p.capitalize, p] },
            {}, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
      </div>

      <div>
        <%= label_tag :message, 'Message', class: 'block text-sm font-medium text-gray-700 mb-1' %>
        <%= text_area_tag :message, nil, rows: 6, required: true, placeholder: 'Describe your issue in detail...',
            class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
      </div>
    </div>

    <div class="flex justify-end gap-3">
      <%= link_to 'Cancel', admin_support_tickets_path, class: 'px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50' %>
      <%= f.submit 'Create Ticket', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 text-sm font-medium cursor-pointer' %>
    </div>
  <% end %>
</div>
