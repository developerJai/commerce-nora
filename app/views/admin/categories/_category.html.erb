<tr id="<%= dom_id(category) %>" class="<%= category.parent_id ? 'bg-gray-50/50' : '' %>">
  <td class="px-6 py-4 whitespace-nowrap">
    <div class="flex items-center gap-3 text-sm font-medium text-gray-900">
      <% if category.parent_id %>
        <span class="text-gray-400 ml-4">└</span>
      <% end %>
      <% if category.image.attached? %>
        <%= image_tag category.image, class: 'h-8 w-8 rounded-full object-cover border border-gray-200' %>
      <% end %>
      <div>
        <%= category.name %>
        <% if category.root? && category.children.any? %>
          <span class="text-xs text-gray-400 ml-1">(<%= category.children.count %> subcategories)</span>
        <% end %>
      </div>
    </div>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono"><%= category.slug %></td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= category.products.count %></td>
  <td class="px-6 py-4 whitespace-nowrap">
    <span class="px-2 py-1 text-xs font-medium rounded-full <%= category.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
      <%= category.active? ? 'Active' : 'Inactive' %>
    </span>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
    <%= link_to 'Edit', edit_admin_category_path(category), class: 'text-indigo-600 hover:text-indigo-900 mr-3' %>
    <%= button_to category.active? ? 'Disable' : 'Enable', toggle_status_admin_category_path(category), 
        method: :patch, 
        class: category.active? ? 'text-red-600 hover:text-red-900 mr-3' : 'text-green-600 hover:text-green-900 mr-3',
        form: { data: { turbo_frame: dom_id(category) } } %>
    <%= button_to 'Delete', admin_category_path(category), method: :delete, 
        class: 'text-red-600 hover:text-red-900',
        form: { data: { turbo_confirm: 'Are you sure you want to delete this category?' } } %>
  </td>
</tr>
