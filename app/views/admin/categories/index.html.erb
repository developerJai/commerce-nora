<% content_for(:title) { "Categories" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Categories</h1>
      <p class="text-sm text-gray-500 mt-1">Manage your category hierarchy (2 levels: Parent > Subcategory)</p>
    </div>
    <%= link_to 'Add Category', new_admin_category_path, class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700' %>
  </div>

  <div class="bg-white rounded-lg shadow-sm overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Slug</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Products</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @categories.select(&:root?).each do |category| %>
          <%= render category %>
          <% category.children.order(:position, :name).each do |child| %>
            <%= render child %>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
