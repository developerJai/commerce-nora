<% content_for(:title) { "Refund Management" } %>

<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Refund Management</h1>
      <p class="text-sm text-gray-500 mt-1">Manage customer refunds and track payment status</p>
    </div>
    <%= link_to "Back to Orders", admin_orders_path, class: "text-sm text-indigo-600 hover:text-indigo-900 font-medium" %>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs text-yellow-600 uppercase font-medium">Initiated</p>
          <p class="text-2xl font-bold text-yellow-900"><%= @refund_counts[:initiated] %></p>
        </div>
        <svg class="w-8 h-8 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <p class="text-xs text-yellow-700 mt-2">Waiting for payment</p>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs text-green-600 uppercase font-medium">Paid</p>
          <p class="text-2xl font-bold text-green-900"><%= @refund_counts[:paid] %></p>
        </div>
        <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <p class="text-xs text-green-700 mt-2">Refunds completed</p>
    </div>

    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs text-red-600 uppercase font-medium">Failed</p>
          <p class="text-2xl font-bold text-red-900"><%= @refund_counts[:failed] %></p>
        </div>
        <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <p class="text-xs text-red-700 mt-2">Needs attention</p>
    </div>

    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs text-gray-600 uppercase font-medium">Total</p>
          <p class="text-2xl font-bold text-gray-900"><%= @refund_counts[:all] %></p>
        </div>
        <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
      </div>
      <p class="text-xs text-gray-700 mt-2">All refund requests</p>
    </div>
  </div>

  <!-- Filter Tabs -->
  <div class="bg-white rounded-lg shadow-sm p-4">
    <div class="flex flex-wrap gap-2">
      <% active_class = 'px-4 py-2 rounded-lg text-sm font-medium border transition bg-indigo-600 text-white border-indigo-600' %>
      <% inactive_class = 'px-4 py-2 rounded-lg text-sm font-medium border transition bg-white text-gray-700 border-gray-200 hover:border-gray-300' %>
      
      <%= link_to 'All Refunds', refunds_admin_orders_path, class: (params[:status].blank? ? active_class : inactive_class) %>
      <%= link_to refunds_admin_orders_path(status: 'initiated'), class: (params[:status] == 'initiated' ? active_class : inactive_class) do %>
        <span class="flex items-center gap-2">
          Initiated
          <% if @refund_counts[:initiated] > 0 %>
            <span class="bg-yellow-500 text-white text-xs px-2 py-0.5 rounded-full"><%= @refund_counts[:initiated] %></span>
          <% end %>
        </span>
      <% end %>
      <%= link_to 'Paid', refunds_admin_orders_path(status: 'paid'), class: (params[:status] == 'paid' ? active_class : inactive_class) %>
      <%= link_to 'Failed', refunds_admin_orders_path(status: 'failed'), class: (params[:status] == 'failed' ? active_class : inactive_class) %>
    </div>
  </div>

  <!-- Orders Table -->
  <div class="bg-white rounded-lg shadow-sm overflow-hidden">
    <% if @orders.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Order</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Customer</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Vendor</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Refund Amount</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Initiated</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @orders.each do |order| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to order.order_number, admin_order_path(order), class: "text-sm font-medium text-indigo-600 hover:text-indigo-900" %>
                <p class="text-xs text-gray-500"><%= order.placed_at&.strftime('%b %d, %Y') %></p>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if order.customer %>
                  <div class="text-sm text-gray-900"><%= order.customer.full_name %></div>
                  <div class="text-xs text-gray-500"><%= order.customer.email %></div>
                <% else %>
                  <span class="text-sm text-gray-500">Guest</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if order.vendor %>
                  <div class="text-sm text-gray-900"><%= order.vendor.business_name %></div>
                <% else %>
                  <span class="text-sm text-gray-500">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <span class="text-sm font-medium text-gray-900"><%= format_price(order.refund_amount) %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-center">
                <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full <%= refund_status_class(order.refund_status) %>">
                  <%= order.refund_status.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= order.refund_initiated_at&.strftime('%b %d, %Y') || '-' %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to 'View', admin_order_path(order), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <div class="px-6 py-4 border-t border-gray-200">
        <%== @pagy.series_nav if @pagy.last > 1 %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No refunds found</h3>
        <p class="mt-1 text-sm text-gray-500">
          <% if params[:status].present? %>
            No <%= params[:status] %> refunds at the moment.
          <% else %>
            No refund requests have been made yet.
          <% end %>
        </p>
      </div>
    <% end %>
  </div>
</div>
