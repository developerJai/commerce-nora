<% content_for(:title) { "Order #{@order.order_number}" } %>

<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @order.order_number %></h1>
      <p class="text-sm text-gray-500">Placed on <%= @order.created_at.strftime('%b %d, %Y at %I:%M %p') %></p>
    </div>
    <div class="flex items-center gap-3">
      <span class="px-3 py-1 text-sm font-medium rounded-full <%= order_status_class(@order.status) %>">
        <%= @order.status.titleize %>
      </span>
      <span class="px-3 py-1 text-sm font-medium rounded-full <%= payment_status_class(@order.payment_status) %>">
        <%= @order.payment_status.titleize %>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Order Items - Card Based Layout -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
          <div class="flex items-center justify-between">
            <h2 class="text-lg font-semibold text-gray-900 flex items-center gap-2">
              <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
              Order Items
              <span class="text-sm font-normal text-gray-500">(<%= @order.order_items.sum(:quantity) %> items)</span>
            </h2>
          </div>
        </div>
        
        <!-- Order Items Cards -->
        <div class="divide-y divide-gray-200">
          <% @order.order_items.each do |item|
            tax_rate = item.product_variant&.product&.hsn_code&.gst_rate || 3.0
            item_tax = (item.total_price.to_f * tax_rate / 100.0).round(2)
            final_price = item.total_price + item_tax
          %>
            <div class="p-4 hover:bg-gray-50 transition-colors">
              <div class="flex gap-4">
                <!-- Product Image -->
                <div class="flex-shrink-0 w-20 h-20 bg-gray-100 rounded-lg overflow-hidden border border-gray-200">
                  <% if item.product_variant&.product&.images&.attached? %>
                    <%= image_tag item.product_variant.product.images.first, class: 'w-full h-full object-cover' %>
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center text-gray-400">
                      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                    </div>
                  <% end %>
                </div>
                
                <!-- Product Details -->
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1">
                      <h3 class="text-sm font-semibold text-gray-900"><%= item.product_name %></h3>
                      <p class="text-xs text-gray-500 mt-0.5"><%= item.variant_name %></p>
                      <div class="flex items-center gap-2 mt-2">
                        <code class="text-xs font-mono text-gray-600 bg-gray-100 px-2 py-0.5 rounded"><%= item.sku || '-' %></code>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200">
                          <%= tax_rate %>% GST
                        </span>
                      </div>
                    </div>
                    
                    <!-- Quantity Badge -->
                    <div class="flex-shrink-0">
                      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 text-sm font-semibold text-gray-900">
                        × <%= item.quantity %>
                      </span>
                    </div>
                  </div>
                  
                  <!-- Pricing Details -->
                  <div class="mt-3 pt-3 border-t border-gray-100">
                    <div class="flex flex-wrap items-center justify-between gap-2">
                      <div class="flex items-center gap-4 text-sm">
                        <div>
                          <span class="text-gray-500">Unit Price:</span>
                          <span class="font-medium text-gray-900 ml-1"><%= format_price(item.unit_price) %></span>
                        </div>
                        <div>
                          <span class="text-gray-500">Subtotal:</span>
                          <span class="font-medium text-gray-900 ml-1"><%= format_price(item.total_price) %></span>
                        </div>
                        <div>
                          <span class="text-gray-500">Tax:</span>
                          <span class="text-xs text-gray-500 ml-1">+ <%= format_price(item_tax) %></span>
                        </div>
                      </div>
                      <div class="text-right">
                        <span class="text-xs text-gray-500">Total</span>
                        <p class="text-base font-bold text-gray-900"><%= format_price(final_price) %></p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        
        <!-- Order Totals -->
        <div class="bg-gray-50 border-t-2 border-gray-200 px-4 py-4">
          <div class="flex flex-col items-end gap-1">
            <div class="flex items-center justify-between w-full max-w-xs">
              <span class="text-sm font-medium text-gray-600">Subtotal:</span>
              <span class="text-sm font-bold text-gray-900"><%= format_price(@order.subtotal) %></span>
            </div>
            <% if @order.tax_amount.to_f > 0 %>
              <div class="flex items-center justify-between w-full max-w-xs">
                <span class="text-sm font-medium text-gray-600">Tax:</span>
                <span class="text-sm font-bold text-gray-900"><%= format_price(@order.tax_amount) %></span>
              </div>
            <% end %>
            <% if @order.shipping_amount.to_f > 0 %>
              <div class="flex items-center justify-between w-full max-w-xs">
                <span class="text-sm font-medium text-gray-600">Shipping:</span>
                <span class="text-sm font-bold text-gray-900"><%= format_price(@order.shipping_amount) %></span>
              </div>
            <% end %>
            <% if @order.discount_amount.to_f > 0 %>
              <div class="flex items-center justify-between w-full max-w-xs">
                <span class="text-sm font-medium text-emerald-600">Discount:</span>
                <span class="text-sm font-bold text-emerald-600">-<%= format_price(@order.discount_amount) %></span>
              </div>
            <% end %>
            <div class="flex items-center justify-between w-full max-w-xs border-t border-gray-300 pt-2 mt-1">
              <span class="text-base font-bold text-gray-900">Order Total:</span>
              <span class="text-lg font-bold text-gray-900"><%= format_price(@order.total_amount) %></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Payment Details Section -->
      <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b flex justify-between items-center">
          <h2 class="text-lg font-medium text-gray-900">Payment Details</h2>
          <% if @order.refunded? %>
            <span class="px-3 py-1 text-sm font-medium rounded-full bg-purple-100 text-purple-800">
              Refunded
            </span>
          <% elsif @order.refund_initiated? %>
            <span class="px-3 py-1 text-sm font-medium rounded-full bg-yellow-100 text-yellow-800">
              Refund Initiated
            </span>
          <% end %>
        </div>
        
        <div class="p-6 space-y-6">
          <!-- Payment Method & Status -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="bg-gray-50 rounded-lg p-4">
              <p class="text-xs text-gray-500 uppercase">Payment Method</p>
              <p class="text-sm font-medium text-gray-900 mt-1">
                <% case @order.payment_method %>
                <% when 'razorpay' %>
                  <span class="inline-flex items-center gap-1">
                    <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                    </svg>
                    Razorpay (Online)
                  </span>
                <% when 'cod' %>
                  Cash on Delivery
                <% else %>
                  <%= @order.payment_method&.titleize %>
                <% end %>
              </p>
            </div>
            <div class="bg-gray-50 rounded-lg p-4">
              <p class="text-xs text-gray-500 uppercase">Payment Status</p>
              <p class="text-sm font-medium mt-1">
                <span class="px-2 py-1 rounded text-xs <%= payment_status_class(@order.payment_status) %>">
                  <%= @order.payment_status.titleize %>
                </span>
              </p>
            </div>
            <% if @order.razorpay? %>
              <div class="bg-gray-50 rounded-lg p-4">
                <p class="text-xs text-gray-500 uppercase">Razorpay Order ID</p>
                <p class="text-sm font-medium text-gray-900 mt-1 font-mono"><%= @order.razorpay_order_id || 'N/A' %></p>
              </div>
            <% end %>
          </div>

          <% if @order.razorpay? && @order.paid? %>
            <!-- Transaction Details -->
            <div class="border-t pt-4">
              <h4 class="text-sm font-medium text-gray-900 mb-3">Transaction Details</h4>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-blue-50 rounded-lg p-4 border border-blue-200">
                  <p class="text-xs text-blue-600 uppercase">Razorpay Payment ID</p>
                  <p class="text-sm font-medium text-blue-900 mt-1 font-mono"><%= @order.razorpay_payment_id || 'N/A' %></p>
                </div>
                <div class="bg-blue-50 rounded-lg p-4 border border-blue-200">
                  <p class="text-xs text-blue-600 uppercase">Payment Signature</p>
                  <p class="text-sm font-medium text-blue-900 mt-1 font-mono truncate" title="<%= @order.payment_signature %>">
                    <%= @order.payment_signature ? @order.payment_signature[0..20] + '...' : 'N/A' %>
                  </p>
                </div>
              </div>
            </div>

            <!-- Fee Breakdown -->
            <% fee_data = @order.fee_breakdown_display %>
            <% if fee_data.present? %>
              <div class="border-t pt-4">
                <h4 class="text-sm font-medium text-gray-900 mb-3">Fee Breakdown</h4>
                <div class="bg-amber-50 rounded-lg p-4 border border-amber-200">
                  <div class="space-y-3">
                    <!-- Customer Paid -->
                    <div class="flex justify-between items-center pb-3 border-b border-amber-200">
                      <span class="text-amber-800 font-medium">Customer Paid</span>
                      <span class="text-lg font-bold text-amber-900"><%= format_price(@order.total_amount) %></span>
                    </div>
                    
                    <!-- Platform Fee -->
                    <% if fee_data.dig('platform_fee', 'commission_amount').to_f > 0 %>
                      <div class="flex justify-between text-sm">
                        <span class="text-amber-700">
                          Platform Commission (<%= fee_data.dig('platform_fee', 'commission_rate') %>%)
                        </span>
                        <span class="text-amber-900 font-medium">-<%= format_price(fee_data.dig('platform_fee', 'commission_amount')) %></span>
                      </div>
                    <% end %>
                    
                    <!-- Gateway Fee -->
                    <% if fee_data.dig('gateway_fee', 'base_gateway_fee').to_f > 0 %>
                      <div class="flex justify-between text-sm">
                        <span class="text-amber-700">
                          Gateway Fee (<%= fee_data.dig('gateway_fee', 'gateway_rate') %>%)
                        </span>
                        <span class="text-amber-900 font-medium">-<%= format_price(fee_data.dig('gateway_fee', 'base_gateway_fee')) %></span>
                      </div>
                      <div class="flex justify-between text-sm">
                        <span class="text-amber-700">
                          GST on Gateway (<%= fee_data.dig('gateway_fee', 'gst_rate') %>%)
                        </span>
                        <span class="text-amber-900 font-medium">-<%= format_price(fee_data.dig('gateway_fee', 'gst_on_gateway_fee')) %></span>
                      </div>
                    <% end %>
                    
                    <!-- Total Deductions -->
                    <div class="flex justify-between items-center pt-2 border-t border-amber-200">
                      <span class="text-amber-800 font-medium">Total Fees Deducted</span>
                      <span class="text-amber-900 font-bold">-<%= format_price(fee_data.dig('total_deductions')) %></span>
                    </div>
                    
                    <!-- Net Amount -->
                    <% if @order.vendor.present? %>
                      <div class="flex justify-between items-center pt-2 border-t-2 border-amber-300">
                        <span class="text-emerald-800 font-bold">Vendor Earnings</span>
                        <span class="text-emerald-700 font-bold text-lg"><%= format_price(@order.vendor_earnings) %></span>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>

          <!-- Refund Details -->
          <% if @order.refund_status != 'not_refunded' %>
            <div class="border-t pt-4">
              <h4 class="text-sm font-medium text-gray-900 mb-3">Refund Details</h4>
              <div class="bg-purple-50 rounded-lg p-4 border border-purple-200">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                  <div>
                    <p class="text-xs text-purple-600 uppercase">Refund Status</p>
                    <p class="text-sm font-medium text-purple-900 mt-1">
                      <span class="px-2 py-1 rounded text-xs
                        <%= case @order.refund_status
                          when 'initiated' then 'bg-yellow-100 text-yellow-800'
                          when 'paid' then 'bg-green-100 text-green-800'
                          when 'failed' then 'bg-red-100 text-red-800'
                          else 'bg-gray-100 text-gray-800'
                        end %>">
                        <%= @order.refund_status.titleize %>
                      </span>
                    </p>
                  </div>
                  <div>
                    <p class="text-xs text-purple-600 uppercase">Refund Amount</p>
                    <p class="text-sm font-medium text-purple-900 mt-1"><%= format_price(@order.refund_amount) %></p>
                  </div>
                </div>
                
                <% if @order.refund_transaction_id.present? %>
                  <div class="mb-3">
                    <p class="text-xs text-purple-600 uppercase">Refund Transaction ID</p>
                    <p class="text-sm font-medium text-purple-900 mt-1 font-mono"><%= @order.refund_transaction_id %></p>
                  </div>
                <% end %>
                
                <% if @order.refund_remarks.present? %>
                  <div class="mb-3">
                    <p class="text-xs text-purple-600 uppercase">Refund Remarks</p>
                    <p class="text-sm text-purple-800 mt-1"><%= @order.refund_remarks %></p>
                  </div>
                <% end %>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs text-purple-600">
                  <% if @order.refund_initiated_at.present? %>
                    <div>
                      <span class="font-medium">Initiated:</span> <%= @order.refund_initiated_at.strftime('%b %d, %Y at %I:%M %p') %>
                    </div>
                  <% end %>
                  <% if @order.refund_paid_at.present? %>
                    <div>
                      <span class="font-medium">Paid:</span> <%= @order.refund_paid_at.strftime('%b %d, %Y at %I:%M %p') %>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Addresses -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg shadow-sm p-6">
          <h3 class="text-sm font-medium text-gray-900 mb-3">Shipping Address</h3>
          <% if @order.shipping_address %>
            <div class="text-sm text-gray-700">
              <p class="font-medium"><%= @order.shipping_address.full_name %></p>
              <p><%= @order.shipping_address.street_address %></p>
              <% if @order.shipping_address.apartment.present? %>
                <p><%= @order.shipping_address.apartment %></p>
              <% end %>
              <p><%= @order.shipping_address.city %>, <%= @order.shipping_address.state %> <%= @order.shipping_address.postal_code %></p>
              <p><%= @order.shipping_address.country %></p>
              <% if @order.shipping_address.phone.present? %>
                <p class="mt-2"><%= @order.shipping_address.phone %></p>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500">No shipping address</p>
          <% end %>
        </div>

        <div class="bg-white rounded-lg shadow-sm p-6">
          <h3 class="text-sm font-medium text-gray-900 mb-3">Billing Address</h3>
          <% if @order.billing_address %>
            <div class="text-sm text-gray-700">
              <p class="font-medium"><%= @order.billing_address.full_name %></p>
              <p><%= @order.billing_address.street_address %></p>
              <% if @order.billing_address.apartment.present? %>
                <p><%= @order.billing_address.apartment %></p>
              <% end %>
              <p><%= @order.billing_address.city %>, <%= @order.billing_address.state %> <%= @order.billing_address.postal_code %></p>
              <p><%= @order.billing_address.country %></p>
            </div>
          <% else %>
            <p class="text-sm text-gray-500">Same as shipping</p>
          <% end %>
        </div>
      </div>

      <!-- Refund Management & Invoices Row -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Refund Management -->
        <% if admin_role? && !vendor_context? && @order.razorpay? && @order.paid? %>
          <div class="bg-white rounded-lg shadow-sm p-4 border-l-4 border-purple-400">
            <h3 class="text-sm font-medium text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Refund Management
            </h3>
            <div class="space-y-2">
              <% if @order.eligible_for_refund_initiation? %>
                <button type="button" 
                        data-modal-target="initiate-refund-modal"
                        class="w-full px-4 py-2 text-sm bg-purple-600 text-white rounded hover:bg-purple-700">
                  Initiate Refund
                </button>
              <% elsif @order.eligible_for_mark_refund_paid? %>
                <button type="button" 
                        data-modal-target="mark-refund-paid-modal"
                        class="w-full px-4 py-2 text-sm bg-green-600 text-white rounded hover:bg-green-700">
                  Mark Refund as Paid
                </button>
                <button type="button" 
                        data-modal-target="mark-refund-failed-modal"
                        class="w-full px-4 py-2 text-sm bg-red-100 text-red-800 rounded hover:bg-red-200">
                  Mark Refund as Failed
                </button>
              <% end %>
              
              <% if @order.refund_status == 'not_refunded' && !@order.eligible_for_refund_initiation? %>
                <p class="text-xs text-gray-500 text-center">Order must be cancelled to initiate refund</p>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Invoice Downloads -->
        <% if admin_role? || (vendor_context? && @order.vendor == current_vendor) %>
          <div class="bg-white rounded-lg shadow-sm p-4 border-l-4 border-indigo-400">
            <h3 class="text-sm font-medium text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              Invoices
            </h3>
            <div class="space-y-2">
              <%= link_to invoice_path(@order.order_number), 
                  target: '_blank',
                  class: 'w-full px-4 py-2 text-sm bg-indigo-50 text-indigo-700 rounded border border-indigo-200 hover:bg-indigo-100 flex items-center justify-center gap-2' do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Customer Invoice
              <% end %>
              
              <% if @order.vendor.present? %>
                <%= link_to invoice_path(@order.order_number, view_as_vendor: true), 
                    target: '_blank',
                    class: 'w-full px-4 py-2 text-sm bg-amber-50 text-amber-700 rounded border border-amber-200 hover:bg-amber-100 flex items-center justify-center gap-2' do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/>
                  </svg>
                  <%= vendor_context? ? 'Your Vendor Invoice' : 'Vendor Invoice' %>
                <% end %>
              <% end %>
            </div>
            <p class="text-xs text-gray-500 mt-3 text-center">PDF invoices open in new tab</p>
          </div>
        <% end %>
      </div>

      <% if @order.notes.present? %>
        <div class="bg-white rounded-lg shadow-sm p-6">
          <h3 class="text-sm font-medium text-gray-900 mb-3">Order Notes</h3>
          <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= @order.notes %></p>
        </div>
      <% end %>

      <% if @order.cancelled? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-6">
          <h3 class="text-sm font-medium text-red-800 mb-3">Cancellation Details</h3>
          <% if @order.cancellation_reason.present? %>
            <p class="text-sm text-red-700"><span class="font-medium">Reason:</span> <%= @order.cancellation_reason %></p>
          <% end %>
          <% if @order.cancelled_at.present? %>
            <p class="text-sm text-red-600 mt-1"><span class="font-medium">Cancelled at:</span> <%= @order.cancelled_at.strftime('%b %d, %Y at %I:%M %p') %></p>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Customer -->
      <div class="bg-white rounded-lg shadow-sm p-4">
        <h3 class="text-sm font-medium text-gray-900 mb-4">Customer</h3>
        <% if @order.customer %>
          <div class="flex items-center mb-3">
            <span class="h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center">
              <span class="text-sm font-medium text-indigo-800"><%= @order.customer.first_name.first.upcase %></span>
            </span>
            <div class="ml-3">
              <div class="text-sm font-medium text-gray-900"><%= @order.customer.full_name %></div>
              <div class="text-sm text-gray-500"><%= @order.customer.email %></div>
            </div>
          </div>
          <% if admin_role? %>
            <%= link_to 'View Customer', admin_customer_path(@order.customer), class: 'text-indigo-600 hover:underline text-sm' %>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-500">Guest checkout</p>
        <% end %>
      </div>

      <!-- Vendor Information (Admin View Only - vendors see this in sidebar) -->
      <% if @order.vendor.present? && admin_role? && !vendor_context? %>
        <div class="bg-white rounded-lg shadow-sm p-4 border-l-4 border-amber-400">
          <h3 class="text-sm font-medium text-gray-900 mb-4">Vendor</h3>
          <div class="flex items-center mb-3">
            <span class="h-10 w-10 rounded-full bg-amber-100 flex items-center justify-center">
              <span class="text-sm font-medium text-amber-800"><%= @order.vendor.business_name.first.upcase %></span>
            </span>
            <div class="ml-3">
              <div class="text-sm font-medium text-gray-900"><%= @order.vendor.business_name %></div>
              <% if @order.vendor.email.present? %>
                <div class="text-sm text-gray-500"><%= @order.vendor.email %></div>
              <% end %>
            </div>
          </div>
          <%= link_to 'View Vendor', admin_vendor_path(@order.vendor), class: 'text-amber-600 hover:underline text-sm' %>
          
          <!-- Vendor Earnings with Fee Breakdown (Admin View) -->
          <div class="mt-4 pt-4 border-t border-gray-100">
            <% fee_config = PlatformFeeConfig.current %>
            <% projected_fees = fee_config.calculate_fees(@order.total_amount) %>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between items-center">
                <span class="text-gray-500">Order Total</span>
                <span class="text-gray-900 font-bold text-base"><%= format_price(@order.total_amount) %></span>
              </div>
              
              <!-- Fee Breakdown Section -->
              <div class="py-2 border-t border-gray-100">
                <div class="flex justify-between items-center mb-2">
                  <p class="text-xs text-gray-400 uppercase tracking-wider">Fee Deductions</p>
                  <% unless @order.delivered? && @order.paid? %>
                    <span class="text-xs text-amber-600 italic">(Projected)</span>
                  <% end %>
                </div>
                
                <!-- Platform Fee -->
                <% platform_fee = @order.platform_fee_amount.to_f > 0 ? @order.platform_fee_amount : projected_fees[:platform_fee] %>
                <div class="flex justify-between text-red-600 py-1">
                  <span class="flex items-center gap-1">
                    Platform Fee 
                    <span class="text-xs text-gray-500">(<%= fee_config.platform_commission_percent %>%)</span>
                  </span>
                  <span class="font-medium">-<%= format_price(platform_fee) %></span>
                </div>
                
                <!-- Gateway Fee (only for online payments) -->
                <% if @order.razorpay? %>
                  <% gateway_fee = @order.gateway_fee_amount.to_f > 0 ? @order.gateway_fee_amount : projected_fees[:gateway_fee] %>
                  <div class="flex justify-between text-red-600 py-1">
                    <span class="flex items-center gap-1">
                      Gateway Fee
                      <span class="text-xs text-gray-500">(<%= fee_config.gateway_fee_percent %>%)</span>
                    </span>
                    <span class="font-medium">-<%= format_price(gateway_fee) %></span>
                  </div>
                  
                  <% gateway_gst = @order.gateway_gst_amount.to_f > 0 ? @order.gateway_gst_amount : projected_fees[:gateway_gst] %>
                  <div class="flex justify-between text-red-600 py-1">
                    <span class="flex items-center gap-1">
                      GST on Gateway
                      <span class="text-xs text-gray-500">(<%= fee_config.gateway_gst_percent %>%)</span>
                    </span>
                    <span class="font-medium">-<%= format_price(gateway_gst) %></span>
                  </div>
                <% end %>
                
                <!-- Total Fees Deducted -->
                <% total_fees = @order.platform_fee_amount.to_f + @order.gateway_fee_amount.to_f + @order.gateway_gst_amount.to_f %>
                <% projected_total_fees = projected_fees[:total_fees] %>
                <% display_total_fees = total_fees > 0 ? total_fees : projected_total_fees %>
                <div class="flex justify-between font-semibold pt-2 border-t border-gray-200 mt-2">
                  <span class="text-red-700">Total Fees Deducted</span>
                  <span class="text-red-700 font-bold">-<%= format_price(display_total_fees) %></span>
                </div>
              </div>
              
              <!-- Net Earnings -->
              <% vendor_earnings = @order.vendor_earnings.to_f > 0 ? @order.vendor_earnings : projected_fees[:vendor_earnings] %>
              <div class="flex justify-between items-center pt-2 border-t-2 border-emerald-200 mt-2">
                <span class="text-emerald-700 font-bold">Vendor Earnings</span>
                <span class="text-emerald-700 font-bold text-lg"><%= format_price(vendor_earnings) %></span>
              </div>
            </div>
            
            <!-- GST Information Note -->
            <% if @order.tax_amount.to_f > 0 %>
              <div class="mt-3 p-2 bg-blue-50 border border-blue-200 rounded">
                <div class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-blue-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <div class="text-xs text-blue-800">
                    <span class="font-medium">GST Collected:</span> <%= format_price(@order.tax_amount) %> (included in Order Total above). This is your tax liability to remit to the government. Platform fees are deducted separately.
                  </div>
                </div>
              </div>
            <% end %>
            
            <% if @order.ready_for_payout? %>
              <div class="mt-3 p-2 bg-emerald-50 rounded text-xs text-emerald-800 text-center font-medium">
                Ready for payout
              </div>
            <% elsif @order.payout_status == 'requested' %>
              <div class="mt-3 p-2 bg-amber-50 rounded text-xs text-amber-800 text-center">
                Payout requested
              </div>
            <% elsif @order.payout_status == 'paid' %>
              <div class="mt-3 p-2 bg-green-50 rounded text-xs text-green-800 text-center">
                Payout completed
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Summary -->
      <div class="bg-white rounded-lg shadow-sm p-4">
        <h3 class="text-sm font-medium text-gray-900 mb-4">Order Summary</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-500">Subtotal</span>
            <span class="text-gray-900 font-medium"><%= format_price(@order.subtotal) %></span>
          </div>
          <% if @order.discount_amount.to_f > 0 %>
            <div class="flex justify-between text-green-600">
              <span>Discount<%= @order.coupon ? " (#{@order.coupon.code})" : '' %></span>
              <span class="font-medium">-<%= format_price(@order.discount_amount) %></span>
            </div>
          <% end %>
          <div class="flex justify-between">
            <span class="text-gray-500">Shipping</span>
            <span class="text-gray-900 font-medium"><%= format_price(@order.shipping_amount) %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Tax</span>
            <span class="text-gray-900 font-medium"><%= format_price(@order.tax_amount) %></span>
          </div>
          
          <!-- Fee Breakdown (only for online payments) -->
          <% if @order.razorpay? && @order.paid? %>
            <% fee_data = @order.fee_breakdown_display %>
            <% if fee_data.present? %>
              <div class="py-2 border-t border-gray-100">
                <p class="text-xs text-gray-500 mb-2">Fee Breakdown</p>
                <% if fee_data.dig('platform_fee', 'commission_amount').to_f > 0 %>
                  <div class="flex justify-between text-sm py-1">
                    <span class="text-gray-600">Platform Fee (<%= fee_data.dig('platform_fee', 'commission_rate') %>%)</span>
                    <span class="text-red-600 font-medium">-<%= format_price(fee_data.dig('platform_fee', 'commission_amount')) %></span>
                  </div>
                <% end %>
                <% if fee_data.dig('gateway_fee', 'base_gateway_fee').to_f > 0 %>
                  <div class="flex justify-between text-sm py-1">
                    <span class="text-gray-600">Gateway Fee (<%= fee_data.dig('gateway_fee', 'gateway_rate') %>%)</span>
                    <span class="text-red-600 font-medium">-<%= format_price(fee_data.dig('gateway_fee', 'base_gateway_fee')) %></span>
                  </div>
                  <div class="flex justify-between text-sm py-1">
                    <span class="text-gray-600">GST on Gateway (<%= fee_data.dig('gateway_fee', 'gst_rate') %>%)</span>
                    <span class="text-red-600 font-medium">-<%= format_price(fee_data.dig('gateway_fee', 'gst_on_gateway_fee')) %></span>
                  </div>
                <% end %>
                <div class="flex justify-between text-sm py-1 pt-2 border-t border-gray-100">
                  <span class="text-gray-700 font-medium">Total Fees</span>
                  <span class="text-red-700 font-bold">-<%= format_price(fee_data.dig('total_deductions')) %></span>
                </div>
              </div>
            <% end %>
          <% end %>
          
          <div class="flex justify-between font-medium pt-2 border-t-2 border-gray-200">
            <span class="text-gray-900">Total</span>
            <span class="text-gray-900 text-lg font-bold"><%= format_price(@order.total_amount) %></span>
          </div>
          <p class="text-xs text-gray-500 text-right">Inclusive of all taxes</p>
        </div>
        
        <!-- Checkout Session Link -->
        <% if @order.checkout_session.present? %>
          <div class="mt-4 pt-4 border-t border-gray-200">
            <%= link_to admin_checkout_session_path(@order.checkout_session), 
                class: "flex items-center justify-between p-3 bg-blue-50 rounded-lg hover:bg-blue-100 transition" do %>
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a1 1 0 11-2 0 1 1 0 012 0z"/>
                </svg>
                <div>
                  <p class="text-sm font-medium text-blue-900">Part of Multi-Order Payment</p>
                  <p class="text-xs text-blue-700">
                    <%= @order.checkout_session.orders.count %> orders • 
                    <%= number_to_currency(@order.checkout_session.total_amount, unit: "₹") %>
                  </p>
                </div>
              </div>
              <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- Vendor Earnings Summary (for vendor users) -->
      <% if vendor_context? && @order.vendor == current_vendor %>
        <% fee_breakdown = @order.fee_breakdown_display || {} %>
        <% fee_config = PlatformFeeConfig.current %>
        <% is_estimated = @order.vendor_earnings.nil? || @order.vendor_earnings.to_f == 0 %>
        
        <% if is_estimated %>
          <% projected_fees = fee_config.calculate_fees(@order.total_amount) %>
          <% platform_fee = projected_fees[:platform_fee] %>
          <% gateway_fee = projected_fees[:gateway_fee] %>
          <% gateway_gst = projected_fees[:gateway_gst] %>
          <% vendor_earnings = projected_fees[:vendor_earnings] %>
        <% else %>
          <% platform_fee = @order.platform_fee_amount || 0 %>
          <% gateway_fee = @order.gateway_fee_amount || 0 %>
          <% gateway_gst = @order.gateway_gst_amount || 0 %>
          <% vendor_earnings = @order.vendor_earnings %>
        <% end %>
        
        <div class="bg-emerald-50 rounded-lg shadow-sm p-4 border border-emerald-200">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-sm font-medium text-emerald-900">Your Earnings</h3>
            <% if is_estimated %>
              <span class="text-xs px-2 py-0.5 bg-amber-100 text-amber-800 rounded-full">Estimated</span>
            <% end %>
          </div>
          
          <div class="space-y-2 text-sm">
            <div class="flex justify-between items-center">
              <span class="text-emerald-700">Order Total</span>
              <span class="text-emerald-900 font-medium text-base"><%= format_price(@order.total_amount) %></span>
            </div>
            
            <!-- Fee Deductions Section -->
            <div class="py-2 border-t border-emerald-200">
              <div class="flex justify-between items-center mb-2">
                <p class="text-xs text-emerald-600 uppercase tracking-wider">Fee Deductions</p>
                <% if is_estimated %>
                  <span class="text-xs text-amber-600 italic">(Projected)</span>
                <% end %>
              </div>
              
              <!-- Platform Fee with Percentage -->
              <div class="flex justify-between text-red-600 py-1">
                <span class="flex items-center gap-1">
                  Platform Fee
                  <span class="text-xs text-emerald-600">(<%= fee_config.platform_commission_percent %>%)</span>
                </span>
                <span class="font-medium">-<%= format_price(platform_fee) %></span>
              </div>
              
              <!-- Gateway Fee with Percentage (only for online payments) -->
              <% if @order.razorpay? %>
                <div class="flex justify-between text-red-600 py-1">
                  <span class="flex items-center gap-1">
                    Gateway Fee
                    <span class="text-xs text-emerald-600">(<%= fee_config.gateway_fee_percent %>%)</span>
                  </span>
                  <span class="font-medium">-<%= format_price(gateway_fee) %></span>
                </div>
                
                <!-- GST on Gateway with Percentage -->
                <div class="flex justify-between text-red-600 py-1">
                  <span class="flex items-center gap-1">
                    GST on Gateway
                    <span class="text-xs text-emerald-600">(<%= fee_config.gateway_gst_percent %>%)</span>
                  </span>
                  <span class="font-medium">-<%= format_price(gateway_gst) %></span>
                </div>
              <% end %>
              
              <!-- Total Fees Deducted -->
              <% total_fees = platform_fee + gateway_fee + gateway_gst %>
              <div class="flex justify-between font-semibold pt-2 border-t border-emerald-200 mt-2">
                <span class="text-red-700">Total Fees Deducted</span>
                <span class="text-red-700 font-bold">-<%= format_price(total_fees) %></span>
              </div>
            </div>
            
            <!-- Net Earnings -->
            <div class="flex justify-between items-center pt-2 border-t-2 border-emerald-300">
              <span class="text-emerald-900 font-bold">Net Earnings</span>
              <span class="text-emerald-700 font-bold text-lg"><%= format_price(vendor_earnings) %></span>
            </div>
          </div>
          
          <!-- GST Liability Note -->
          <% if @order.tax_amount.to_f > 0 %>
            <div class="mt-3 p-2 bg-blue-50 border border-blue-200 rounded text-xs text-blue-800">
              <span class="font-medium">Tax Note:</span> GST of <%= format_price(@order.tax_amount) %> is included in the Order Total. You are responsible for remitting this to the government.
            </div>
          <% end %>
          
          <% if @order.ready_for_payout? %>
            <div class="mt-3 p-2 bg-emerald-100 rounded text-xs text-emerald-800 text-center font-medium">
              ✓ Ready for payout
            </div>
          <% elsif @order.payout_status == 'requested' %>
            <div class="mt-3 p-2 bg-yellow-50 rounded text-xs text-yellow-800 text-center">
              ⏳ Payout requested
            </div>
          <% elsif @order.payout_status == 'paid' %>
            <div class="mt-3 p-2 bg-emerald-100 rounded text-xs text-emerald-800 text-center">
              ✓ Paid on <%= @order.payout_paid_at&.strftime('%b %d, %Y') %>
            </div>
          <% elsif @order.payout_status == 'rejected' %>
            <div class="mt-3 p-2 bg-red-50 rounded text-xs text-red-800 text-center">
              ✗ Payout rejected
            </div>
          <% end %>
          
          <!-- Refund Alert for Vendors -->
          <% if @order.refund_status != 'not_refunded' %>
            <div class="mt-3 p-3 bg-purple-50 border border-purple-200 rounded">
              <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-purple-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                </svg>
                <div class="text-xs">
                  <p class="font-semibold text-purple-900">Refund <%= @order.refund_status.titleize %></p>
                  <p class="text-purple-700 mt-0.5">
                    Amount: <%= format_price(@order.refund_amount) %>
                    <% if @order.refund_status == 'initiated' %>
                      <br><span class="text-amber-600">Processing - will be deducted from earnings</span>
                    <% elsif @order.refund_status == 'paid' %>
                      <br><span class="text-emerald-600">Completed - deducted from earnings</span>
                    <% end %>
                  </p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @order.shipped_at.present? %>
        <div class="bg-white rounded-lg shadow-sm p-4">
          <h3 class="text-sm font-medium text-gray-900 mb-4">Shipment Details</h3>
          <div class="space-y-2 text-sm">
            <% if @order.shipper_name.present? %>
              <div class="flex justify-between">
                <span class="text-gray-500">Shipper</span>
                <span class="text-gray-900"><%= @order.shipper_name %></span>
              </div>
            <% end %>
            <% if @order.shipping_carrier.present? %>
              <div class="flex justify-between">
                <span class="text-gray-500">Carrier</span>
                <span class="text-gray-900"><%= @order.shipping_carrier %></span>
              </div>
            <% end %>
            <% if @order.tracking_number.present? %>
              <div class="flex justify-between">
                <span class="text-gray-500">Tracking #</span>
                <span class="text-gray-900"><%= @order.tracking_number %></span>
              </div>
            <% end %>
            <% if @order.tracking_url.present? %>
              <div class="flex justify-between">
                <span class="text-gray-500">Tracking Link</span>
                <%= link_to 'Open', @order.tracking_url, target: '_blank', rel: 'noopener', class: 'text-indigo-600 hover:underline' %>
              </div>
            <% end %>
            <div class="flex justify-between">
              <span class="text-gray-500">Shipped At</span>
              <span class="text-gray-900"><%= @order.shipped_at.strftime('%b %d, %Y %I:%M %p') %></span>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Actions (Available for both admin and vendor on their own orders) -->
      <% if (admin_role? && !vendor_context?) || (vendor_context? && @order.vendor == current_vendor) %>
        <div class="bg-white rounded-lg shadow-sm p-4">
          <h3 class="text-sm font-medium text-gray-900 mb-4">Actions</h3>
          <div class="space-y-2">
            <% case @order.status %>
            <% when 'pending' %>
              <%= button_to 'Confirm Order', confirm_admin_order_path(@order), method: :patch, 
                  class: 'w-full px-4 py-2 text-sm bg-blue-600 text-white rounded hover:bg-blue-700' %>
            <% when 'confirmed' %>
              <%= button_to 'Process Order', process_order_admin_order_path(@order), method: :patch, 
                  class: 'w-full px-4 py-2 text-sm bg-blue-600 text-white rounded hover:bg-blue-700' %>
              <% if @order.can_rollback? %>
                <%= button_to 'Move Back', rollback_admin_order_path(@order), method: :patch,
                    class: 'w-full px-4 py-2 text-sm bg-gray-100 text-gray-800 rounded hover:bg-gray-200' %>
              <% elsif @order.razorpay? && @order.paid? %>
                <div class="w-full px-4 py-2 text-sm bg-gray-50 text-gray-500 rounded border border-gray-200 text-center">
                  Cannot rollback - Online payment processed
                </div>
              <% end %>
            <% when 'processing' %>
              <div class="rounded border border-gray-200 p-3">
                <%= form_with model: @order, url: ship_admin_order_path(@order), method: :patch, class: 'space-y-2' do |f| %>
                  <%= f.text_field :shipper_name, required: true, placeholder: 'Shipper name', class: 'w-full px-3 py-2 text-sm border border-gray-300 rounded' %>
                  <%= f.text_field :shipping_carrier, required: true, placeholder: 'Carrier (e.g. Delhivery)', class: 'w-full px-3 py-2 text-sm border border-gray-300 rounded' %>
                  <%= f.text_field :tracking_number, required: true, placeholder: 'Tracking / AWB number', class: 'w-full px-3 py-2 text-sm border border-gray-300 rounded' %>
                  <%= f.url_field :tracking_url, placeholder: 'Tracking URL (optional)', class: 'w-full px-3 py-2 text-sm border border-gray-300 rounded' %>
                  <%= f.submit 'Mark as Shipped', class: 'w-full px-4 py-2 text-sm bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer' %>
                <% end %>
              </div>
              <% if @order.can_rollback? %>
                <%= button_to 'Move Back', rollback_admin_order_path(@order), method: :patch,
                    class: 'w-full px-4 py-2 text-sm bg-gray-100 text-gray-800 rounded hover:bg-gray-200' %>
              <% end %>
            <% when 'shipped' %>
              <%= button_to 'Mark as Delivered', deliver_admin_order_path(@order), method: :patch, 
                  class: 'w-full px-4 py-2 text-sm bg-green-600 text-white rounded hover:bg-green-700' %>
              <% if @order.can_rollback? %>
                <%= button_to 'Move Back', rollback_admin_order_path(@order), method: :patch,
                    class: 'w-full px-4 py-2 text-sm bg-gray-100 text-gray-800 rounded hover:bg-gray-200' %>
              <% end %>
            <% when 'delivered' %>
              <% if @order.can_rollback? %>
                <%= button_to 'Move Back', rollback_admin_order_path(@order), method: :patch,
                    class: 'w-full px-4 py-2 text-sm bg-gray-100 text-gray-800 rounded hover:bg-gray-200' %>
              <% end %>
            <% when 'cancelled' %>
              <div class="w-full px-4 py-3 text-sm bg-red-50 text-red-700 rounded border border-red-200 text-center">
                <div class="font-medium mb-1">Order Cancelled</div>
                <div class="text-xs text-red-600">No actions available for cancelled orders</div>
              </div>
            <% end %>
            
            <% if @order.can_cancel? %>
              <button type="button" 
                      data-modal-target="cancel-modal"
                      class="w-full px-4 py-2 text-sm bg-red-100 text-red-800 rounded hover:bg-red-200">
                Cancel Order
              </button>
            <% end %>
          </div>
        </div>
      <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Cancel Order Modal -->
<% if @order.can_cancel? %>
  <div id="cancel-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg max-w-md w-full p-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Cancel Order</h3>
      <p class="text-sm text-gray-600 mb-4">Please provide a reason for cancelling this order. This will help us improve our service.</p>
      
      <%= form_with url: cancel_admin_order_path(@order), method: :patch, class: 'space-y-4' do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Cancellation Reason</label>
          <select name="cancellation_reason" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500">
            <option value="">Select a reason...</option>
            <% Order::CANCELLATION_REASONS.each do |reason| %>
              <option value="<%= reason %>"><%= reason %></option>
            <% end %>
          </select>
        </div>
        
        <% if @order.razorpay? && @order.paid? %>
          <div class="p-3 bg-amber-50 border border-amber-200 rounded-lg">
            <p class="text-xs text-amber-800">
              <span class="font-medium">Note:</span> Customer paid online. After cancellation, you'll need to manually initiate a refund from the Refund Management section.
            </p>
          </div>
        <% end %>
        
        <div class="flex gap-3 pt-2">
          <button type="button" 
                  data-modal-close="cancel-modal"
                  class="flex-1 px-4 py-2 text-sm bg-gray-100 text-gray-800 rounded hover:bg-gray-200">
            Go Back
          </button>
          <button type="submit"
                  class="flex-1 px-4 py-2 text-sm bg-red-600 text-white rounded hover:bg-red-700">
            Confirm Cancellation
          </button>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Initiate Refund Modal -->
<% if admin_role? && !vendor_context? && @order.eligible_for_refund_initiation? %>
  <div id="initiate-refund-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg max-w-md w-full p-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Initiate Refund</h3>
      <p class="text-sm text-gray-600 mb-4">Refund details for order <%= @order.order_number %></p>
      
      <%= form_with url: initiate_refund_admin_order_path(@order), method: :post, class: 'space-y-4' do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Refund Amount</label>
          <%= f.number_field :refund_amount, 
              value: @order.total_amount, 
              step: 0.01,
              min: 0,
              max: @order.total_amount,
              class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500' %>
          <p class="text-xs text-gray-500 mt-1">Maximum: <%= format_price(@order.total_amount) %></p>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Transaction ID (Optional)</label>
          <%= f.text_field :refund_transaction_id, 
              placeholder: 'Refund transaction ID from Razorpay',
              class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500' %>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Remarks (Optional)</label>
          <%= f.text_area :refund_remarks, 
              rows: 3,
              placeholder: 'Add any notes about this refund...',
              class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500' %>
        </div>
        
        <div class="p-3 bg-blue-50 border border-blue-200 rounded-lg">
          <p class="text-xs text-blue-800">
            <span class="font-medium">Next Step:</span> After initiating, you'll need to process the refund via Razorpay dashboard, then return here to mark it as "Paid" with the transaction details.
          </p>
        </div>
        
        <div class="flex gap-3 pt-2">
          <button type="button" 
                  data-modal-close="initiate-refund-modal"
                  class="flex-1 px-4 py-2 text-sm bg-gray-100 text-gray-800 rounded hover:bg-gray-200">
            Cancel
          </button>
          <button type="submit"
                  class="flex-1 px-4 py-2 text-sm bg-purple-600 text-white rounded hover:bg-purple-700">
            Initiate Refund
          </button>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Mark Refund as Paid Modal -->
<% if admin_role? && !vendor_context? && @order.eligible_for_mark_refund_paid? %>
  <div id="mark-refund-paid-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg max-w-md w-full p-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Mark Refund as Paid</h3>
      <p class="text-sm text-gray-600 mb-4">Confirm the refund has been successfully processed.</p>
      
      <%= form_with url: mark_refund_paid_admin_order_path(@order), method: :post, class: 'space-y-4' do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Refund Transaction ID</label>
          <%= f.text_field :refund_transaction_id, 
              value: @order.refund_transaction_id,
              required: true,
              placeholder: 'Enter Razorpay refund ID',
              class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500' %>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Remarks</label>
          <%= f.text_area :refund_remarks, 
              value: @order.refund_remarks,
              rows: 2,
              placeholder: 'Any additional notes...',
              class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500' %>
        </div>
        
        <div class="p-3 bg-green-50 border border-green-200 rounded-lg">
          <p class="text-xs text-green-800">
            <span class="font-medium">Current Refund Amount:</span> <%= format_price(@order.refund_amount) %>
          </p>
        </div>
        
        <div class="flex gap-3 pt-2">
          <button type="button" 
                  data-modal-close="mark-refund-paid-modal"
                  class="flex-1 px-4 py-2 text-sm bg-gray-100 text-gray-800 rounded hover:bg-gray-200">
            Cancel
          </button>
          <button type="submit"
                  class="flex-1 px-4 py-2 text-sm bg-green-600 text-white rounded hover:bg-green-700">
            Mark as Paid
          </button>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Mark Refund as Failed Modal -->
<% if admin_role? && !vendor_context? && @order.refund_initiated? %>
  <div id="mark-refund-failed-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg max-w-md w-full p-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Mark Refund as Failed</h3>
      <p class="text-sm text-gray-600 mb-4">Report that the refund could not be processed.</p>
      
      <%= form_with url: mark_refund_failed_admin_order_path(@order), method: :post, class: 'space-y-4' do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Error Message / Reason</label>
          <%= f.text_area :error_message, 
              rows: 3,
              required: true,
              placeholder: 'Explain why the refund failed...',
              class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500' %>
        </div>
        
        <div class="p-3 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-xs text-red-800">
            <span class="font-medium">Warning:</span> This will mark the refund as failed. You may need to contact the customer and process the refund through alternative means.
          </p>
        </div>
        
        <div class="flex gap-3 pt-2">
          <button type="button" 
                  data-modal-close="mark-refund-failed-modal"
                  class="flex-1 px-4 py-2 text-sm bg-gray-100 text-gray-800 rounded hover:bg-gray-200">
            Cancel
          </button>
          <button type="submit"
                   class="flex-1 px-4 py-2 text-sm bg-red-600 text-white rounded hover:bg-red-700">
            Mark as Failed
          </button>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Modal JavaScript for Turbo compatibility -->
<script>
  function initAdminOrderModals() {
    // Cancel Order Modal
    const cancelBtn = document.querySelector('[data-modal-target="cancel-modal"]');
    const cancelModal = document.getElementById('cancel-modal');
    if (cancelBtn && cancelModal) {
      cancelBtn.addEventListener('click', () => cancelModal.classList.remove('hidden'));
    }
    const cancelCloseBtns = document.querySelectorAll('[data-modal-close="cancel-modal"]');
    cancelCloseBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const modal = document.getElementById('cancel-modal');
        if (modal) modal.classList.add('hidden');
      });
    });

    // Initiate Refund Modal
    const initiateRefundBtn = document.querySelector('[data-modal-target="initiate-refund-modal"]');
    const initiateRefundModal = document.getElementById('initiate-refund-modal');
    if (initiateRefundBtn && initiateRefundModal) {
      initiateRefundBtn.addEventListener('click', () => initiateRefundModal.classList.remove('hidden'));
    }
    const initiateCloseBtns = document.querySelectorAll('[data-modal-close="initiate-refund-modal"]');
    initiateCloseBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const modal = document.getElementById('initiate-refund-modal');
        if (modal) modal.classList.add('hidden');
      });
    });

    // Mark Refund Paid Modal
    const markPaidBtn = document.querySelector('[data-modal-target="mark-refund-paid-modal"]');
    const markPaidModal = document.getElementById('mark-refund-paid-modal');
    if (markPaidBtn && markPaidModal) {
      markPaidBtn.addEventListener('click', () => markPaidModal.classList.remove('hidden'));
    }
    const markPaidCloseBtns = document.querySelectorAll('[data-modal-close="mark-refund-paid-modal"]');
    markPaidCloseBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const modal = document.getElementById('mark-refund-paid-modal');
        if (modal) modal.classList.add('hidden');
      });
    });

    // Mark Refund Failed Modal
    const markFailedBtn = document.querySelector('[data-modal-target="mark-refund-failed-modal"]');
    const markFailedModal = document.getElementById('mark-refund-failed-modal');
    if (markFailedBtn && markFailedModal) {
      markFailedBtn.addEventListener('click', () => markFailedModal.classList.remove('hidden'));
    }
    const markFailedCloseBtns = document.querySelectorAll('[data-modal-close="mark-refund-failed-modal"]');
    markFailedCloseBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const modal = document.getElementById('mark-refund-failed-modal');
        if (modal) modal.classList.add('hidden');
      });
    });

    // Close modals when clicking outside
    document.querySelectorAll('[id$="-modal"]').forEach(modal => {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.add('hidden');
        }
      });
    });
  }

  // Initialize on both initial load and Turbo navigation
  document.addEventListener('DOMContentLoaded', initAdminOrderModals);
  document.addEventListener('turbo:load', initAdminOrderModals);
</script>
