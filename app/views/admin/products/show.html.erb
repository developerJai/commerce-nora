<% content_for(:title) { @product.name } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @product.name %></h1>
      <p class="text-sm text-gray-500">SKU: <%= @product.sku || '-' %></p>
    </div>
    <div class="flex gap-3">
      <%= link_to 'Add Variant', new_admin_product_variant_path(@product), class: 'px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700' %>
      <%= link_to 'Edit', edit_admin_product_path(@product), class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700' %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Product Info -->
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Product Details</h2>
        <dl class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <dt class="text-gray-500">Category</dt>
            <dd class="font-medium text-gray-900"><%= @product.category&.name || '-' %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Status</dt>
            <dd>
              <span class="px-2 py-1 rounded-full text-xs font-medium <%= @product.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                <%= @product.active? ? 'Active' : 'Draft' %>
              </span>
              <% if @product.featured? %>
                <span class="px-2 py-1 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800 ml-1">Featured</span>
              <% end %>
            </dd>
          </div>
          <div>
            <dt class="text-gray-500">Base Price</dt>
            <dd class="font-medium text-gray-900">$<%= @product.price %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Rating</dt>
            <dd class="font-medium text-gray-900"><%= @product.average_rating %> (<%= @product.ratings_count %> reviews)</dd>
          </div>
        </dl>
        <% if @product.description.present? %>
          <div class="mt-6 pt-6 border-t border-gray-200">
            <h3 class="text-sm font-medium text-gray-900 mb-2">Description</h3>
            <p class="text-sm text-gray-600"><%= @product.description %></p>
          </div>
        <% end %>
      </div>

      <!-- Variants -->
      <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-gray-900">Variants (<%= @variants.count %>)</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">SKU</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Price</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Stock</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase whitespace-nowrap">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% @variants.each do |variant| %>
                <tr id="<%= dom_id(variant) %>" class="<%= variant.stock_quantity == 0 ? 'bg-red-50' : '' %>">
                  <td class="px-4 py-4 text-sm font-medium text-gray-900">
                    <div class="flex items-center gap-2">
                      <% if variant.image.attached? %>
                        <%= image_tag variant.image, class: 'h-8 w-8 rounded object-cover' %>
                      <% end %>
                      <%= variant.name %>
                    </div>
                  </td>
                  <td class="px-4 py-4 text-sm text-gray-500 font-mono"><%= variant.sku %></td>
                  <td class="px-4 py-4 text-sm text-gray-900 whitespace-nowrap">
                    <%= format_price(variant.price) %>
                    <% if variant.on_sale? %>
                      <span class="text-gray-400 line-through text-xs ml-1"><%= format_price(variant.compare_at_price) %></span>
                    <% end %>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap">
                    <% if variant.stock_quantity == 0 %>
                      <span class="px-2 py-1 text-xs font-medium rounded-full bg-red-100 text-red-800">Out of Stock</span>
                    <% elsif variant.stock_quantity < 10 %>
                      <span class="px-2 py-1 text-xs font-medium rounded-full bg-yellow-100 text-yellow-800"><%= variant.stock_quantity %> left</span>
                    <% else %>
                      <span class="text-sm text-gray-500"><%= variant.stock_quantity %></span>
                    <% end %>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap">
                    <span class="px-2 py-1 text-xs font-medium rounded-full <%= variant.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                      <%= variant.active? ? 'Active' : 'Inactive' %>
                    </span>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap text-right text-sm space-x-2">
                    <%= link_to 'Edit', edit_admin_product_variant_path(@product, variant), class: 'text-indigo-600 hover:text-indigo-900' %>
                    <%= button_to variant.active? ? 'Disable' : 'Enable', toggle_status_admin_product_variant_path(@product, variant), 
                        method: :patch, 
                        class: variant.active? ? 'text-yellow-600 hover:text-yellow-900' : 'text-green-600 hover:text-green-900',
                        form: { class: 'inline' } %>
                    <%= button_to 'Delete', admin_product_variant_path(@product, variant), 
                        method: :delete,
                        class: 'text-red-600 hover:text-red-900',
                        form: { class: 'inline', data: { turbo_confirm: 'Are you sure you want to delete this variant?' } } %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <% if @variants.empty? %>
          <div class="text-center py-8 text-gray-500">
            No variants yet. <%= link_to 'Add a variant', new_admin_product_variant_path(@product), class: 'text-indigo-600 hover:underline' %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Images & Reviews -->
    <div class="space-y-6">
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Images</h2>
        <% if @product.images.attached? %>
          <div class="grid grid-cols-2 gap-2">
            <% @product.images.each do |image| %>
              <div class="aspect-square bg-gray-100 rounded-lg overflow-hidden">
                <%= image_tag image, class: 'w-full h-full object-cover' %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 text-sm">No images uploaded</p>
        <% end %>
      </div>

      <div class="bg-white rounded-lg shadow-sm p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Recent Reviews</h2>
        <% if @reviews.any? %>
          <div class="space-y-4">
            <% @reviews.each do |review| %>
              <div class="text-sm">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-medium text-gray-900"><%= review.customer_name %></span>
                  <span class="text-yellow-500"><%= '★' * review.rating %></span>
                </div>
                <p class="text-gray-600"><%= truncate(review.body, length: 100) %></p>
              </div>
            <% end %>
          </div>
          <%= link_to 'View All Reviews', admin_reviews_path(product_id: @product.id), class: 'mt-4 inline-block text-sm text-indigo-600 hover:text-indigo-800' %>
        <% else %>
          <p class="text-gray-500 text-sm">No reviews yet</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
