<%# Dynamic attribute fields rendered based on category's attribute_config %>
<%# Locals: category (Category or nil), product (Product) %>

<% product_defs = category&.product_attribute_definitions || [] %>
<% variant_defs = category&.variant_attribute_definitions || [] %>

<!-- Product Attributes -->
<div id="dynamic-product-attributes">
  <% if product_defs.any? %>
    <div class="grid grid-cols-2 gap-4">
      <% product_defs.each do |defn| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            <%= defn[:label] %>
            <% if defn[:required] %><span class="text-red-500">*</span><% end %>
          </label>
          <%
            key = defn[:key]
            is_column = Category::PRODUCT_COLUMN_ATTRIBUTES.include?(key)
            current_value = is_column ? product.send(key) : product.properties&.dig(key)
            field_name = is_column ? "product[#{key}]" : "product[properties][#{key}]"
            options = defn[:options] || []
          %>
          <% if options.any? %>
            <select name="<%= field_name %>"
                    class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500"
                    <%= 'required' if defn[:required] %>>
              <option value="">Select <%= defn[:label].downcase %>...</option>
              <% options.each do |opt| %>
                <option value="<%= opt %>" <%= 'selected' if current_value == opt %>><%= opt %></option>
              <% end %>
            </select>
          <% else %>
            <input type="text" name="<%= field_name %>"
                   value="<%= current_value %>"
                   placeholder="<%= defn[:default] || '' %>"
                   class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500"
                   <%= 'required' if defn[:required] %>>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-gray-400 italic py-2">No product attributes configured for this category</p>
  <% end %>
</div>

<!-- Variant Attributes -->
<div id="dynamic-variant-attributes">
  <% if variant_defs.any? %>
    <div class="grid grid-cols-2 gap-4">
      <% variant_defs.each do |defn| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            <%= defn[:label] %>
          </label>
          <%
            key = defn[:key]
            is_column = Category::VARIANT_COLUMN_ATTRIBUTES.include?(key)
            # For the inline variant on product create, we use fields_for naming
            # but here we just provide the options data for reference
            variant = product.variants.first || product.variants.build
            current_value = is_column ? variant.send(key) : variant.properties&.dig(key)
            options = defn[:options] || []
          %>
          <% if options.any? %>
            <select name="product[variants_attributes][0][<%= is_column ? key : "properties][#{key}" %>]"
                    class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500">
              <option value="">Select <%= defn[:label].downcase %>...</option>
              <% options.each do |opt| %>
                <option value="<%= opt %>" <%= 'selected' if current_value == opt %>><%= opt %></option>
              <% end %>
            </select>
          <% else %>
            <input type="text"
                   name="product[variants_attributes][0][<%= is_column ? key : "properties][#{key}" %>]"
                   value="<%= current_value %>"
                   class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500">
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-gray-400 italic py-2">No variant attributes configured for this category</p>
  <% end %>
</div>
