<%= form_with model: [:admin, product], class: 'space-y-6' do |f| %>
  <% if product.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6" data-controller="multi-image-preview">
    <div class="lg:col-span-7">
      <div class="bg-white rounded-lg shadow-sm p-6 space-y-6">
        <div>
          <%= f.label :name, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :name, required: true, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
        </div>

        <div>
          <%= f.label :slug, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :slug, placeholder: 'Leave blank to auto-generate', class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
        </div>

        <div>
          <%= f.label :category_id, 'Category', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.collection_select :category_id, Category.active.ordered, :id, :name, { include_blank: 'Select category...' }, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
        </div>

        <div>
          <%= f.label :short_description, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_area :short_description, rows: 2, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
        </div>

        <div>
          <%= f.label :description, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_area :description, rows: 6, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :sku, 'SKU', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :sku, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <div>
            <%= f.label :price, 'Base Price', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.number_field :price, step: 0.01, min: 0, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
        </div>

        <div>
          <%= f.label :images, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.file_field :images,
                           multiple: true,
                           class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500',
                           accept: 'image/*',
                           data: { "multi-image-preview-target": "input", action: "change->multi-image-preview#change" } %>
          <p class="mt-1 text-xs text-gray-500">You can select multiple images</p>
        </div>

        <div class="flex items-center gap-6">
          <label class="flex items-center">
            <%= f.check_box :active, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
            <span class="ml-2 text-sm text-gray-700">Active</span>
          </label>
          <label class="flex items-center">
            <%= f.check_box :featured, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
            <span class="ml-2 text-sm text-gray-700">Featured</span>
          </label>
        </div>
      </div>
    </div>

    <div class="lg:col-span-5">
      <div class="bg-white rounded-lg shadow-sm p-6 lg:sticky lg:top-24">
        <div class="flex items-start justify-between">
          <h3 class="text-sm font-semibold text-gray-900">Storefront Preview</h3>
          <span class="text-xs text-gray-500">Primary image</span>
        </div>

        <div class="mt-4 aspect-square bg-stone-50 rounded-xl overflow-hidden border border-stone-200">
          <% preview_src = (product.persisted? && product.images.attached?) ? url_for(product.images.first) : '' %>
          <img src="<%= preview_src %>" class="w-full h-full object-cover <%= preview_src.present? ? '' : 'hidden' %>" data-multi-image-preview-target="main" alt="">
          <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-rose-50 to-amber-50 <%= preview_src.present? ? 'hidden' : '' %>" data-multi-image-preview-target="placeholder">
            <svg class="w-16 h-16 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
            </svg>
          </div>
        </div>

        <div class="mt-3 grid grid-cols-5 gap-2" data-multi-image-preview-target="thumbs">
          <% if product.persisted? && product.images.attached? %>
            <% product.images.each do |img| %>
              <button type="button"
                      class="aspect-square bg-stone-50 rounded-lg overflow-hidden border border-stone-200"
                      data-action="click->multi-image-preview#select"
                      data-url="<%= url_for(img) %>">
                <%= image_tag img, class: 'w-full h-full object-cover' %>
              </button>
            <% end %>
          <% end %>
        </div>

        <p class="mt-3 text-xs text-gray-500">Select multiple images — the first one is used on cards unless a variant image exists.</p>
      </div>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to 'Cancel', admin_products_path, class: 'px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50' %>
    <%= f.submit 'Save Product', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
  </div>
<% end %>
