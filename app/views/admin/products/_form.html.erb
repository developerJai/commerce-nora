<%= form_with model: [:admin, product], class: 'space-y-6',
             data: {
               controller: "multi-image-preview category-attributes",
               category_attributes_url_value: attribute_fields_admin_products_path,
               category_attributes_product_id_value: product.persisted? ? product.id : ""
             } do |f| %>
  <% if product.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <!-- ─── Left Column: Product details ─── -->
    <div class="lg:col-span-7 space-y-6">

      <!-- Basic Info -->
      <div class="bg-white rounded-lg shadow-sm p-6 space-y-6">
        <h3 class="text-base font-semibold text-gray-900 border-b border-gray-200 pb-3">Basic Information</h3>

        <div>
          <%= f.label :name, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :name, required: true, placeholder: 'e.g. Pearl Drop Earrings', class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
        </div>

        <div>
          <%= f.label :slug, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_field :slug, placeholder: 'Leave blank to auto-generate', class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :category_id, 'Category', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.select :category_id,
                grouped_options_for_select(
                  Category.tree.map { |parent|
                    children = parent.children.select(&:active?).sort_by { |c| [c.position, c.name] }
                    [parent.name, [[parent.name, parent.id]] + children.map { |c| [c.name, c.id] }]
                  },
                  product.category_id
                ),
                { include_blank: 'Select category...' },
                class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500',
                data: { category_attributes_target: "categorySelect", action: "change->category-attributes#categoryChanged" } %>
            <p class="mt-1 text-xs text-gray-500">Category determines which product attributes are shown below</p>
          </div>
          <div>
            <%= f.label :hsn_code_id, 'HSN Code', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.collection_select :hsn_code_id, HsnCode.active.ordered, :id, :display_name, { include_blank: 'Select HSN code...' }, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
        </div>

        <% if admin_role? && !vendor_context? %>
          <div>
            <%= f.label :vendor_id, 'Vendor', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.collection_select :vendor_id, Vendor.active.ordered, :id, :business_name, { include_blank: 'Select vendor...' }, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
        <% end %>

        <div>
          <%= f.label :short_description, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_area :short_description, rows: 2, placeholder: 'Brief product summary for cards and previews', class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
        </div>

        <div>
          <%= f.label :description, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_area :description, rows: 6, placeholder: 'Detailed product description shown on the product page', class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :sku, 'SKU', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :sku, placeholder: 'Auto-generated if blank', class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <div>
            <%= f.label :price, 'Base Price (₹)', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.number_field :price, step: 0.01, min: 0, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
            <p class="mt-1 text-xs text-gray-500">Reference price; actual selling price is set per variant</p>
          </div>
        </div>
      </div>

      <!-- Dynamic Product Attributes (loaded from category config) -->
      <div class="bg-white rounded-lg shadow-sm p-6 space-y-6">
        <h3 class="text-base font-semibold text-gray-900 border-b border-gray-200 pb-3">Product Attributes</h3>
        <div data-category-attributes-target="productAttributes">
          <% if product.category %>
            <% product.category.product_attribute_definitions.tap do |defs| %>
              <% if defs.any? %>
                <div class="grid grid-cols-2 gap-4">
                  <% defs.each do |defn| %>
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-1">
                        <%= defn[:label] %>
                        <% if defn[:required] %><span class="text-red-500">*</span><% end %>
                      </label>
                      <%
                        key = defn[:key]
                        is_column = Category::PRODUCT_COLUMN_ATTRIBUTES.include?(key)
                        current_value = is_column ? product.send(key) : product.properties&.dig(key)
                        field_name = is_column ? "product[#{key}]" : "product[properties][#{key}]"
                        options = defn[:options] || []
                      %>
                      <% if options.any? %>
                        <select name="<%= field_name %>"
                                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500"
                                <%= 'required' if defn[:required] %>>
                          <option value="">Select <%= defn[:label].downcase %>...</option>
                          <% options.each do |opt| %>
                            <option value="<%= opt %>" <%= 'selected' if current_value == opt %>><%= opt %></option>
                          <% end %>
                        </select>
                      <% else %>
                        <input type="text" name="<%= field_name %>"
                               value="<%= current_value %>"
                               placeholder="<%= defn[:default] || '' %>"
                               class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500"
                               <%= 'required' if defn[:required] %>>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="text-sm text-gray-400 italic py-2">No product attributes configured for this category</p>
              <% end %>
            <% end %>
          <% else %>
            <p class="text-sm text-gray-400 italic py-2">Select a category to see relevant product attributes</p>
          <% end %>
        </div>
      </div>

      <!-- Default Variant (inline on creation) -->
      <% if product.new_record? %>
        <div class="bg-white rounded-lg shadow-sm p-6 space-y-6 border-2 border-indigo-100">
          <div>
            <h3 class="text-base font-semibold text-gray-900 border-b border-gray-200 pb-3">
              Default Variant
              <span class="text-xs font-normal text-red-600 ml-2">* Required</span>
            </h3>
            <p class="mt-2 text-sm text-gray-500">
              Every product needs at least one variant with pricing and stock to appear on the storefront.
              You can add more variants later from the product page.
            </p>
          </div>

          <%= f.fields_for :variants do |vf| %>
            <!-- Dynamic variant attributes (color, size, etc. based on category) -->
            <div data-category-attributes-target="variantAttributes">
              <% if product.category %>
                <% product.category.variant_attribute_definitions.tap do |vdefs| %>
                  <% if vdefs.any? %>
                    <div class="grid grid-cols-2 gap-4">
                      <% vdefs.each do |defn| %>
                        <div>
                          <label class="block text-sm font-medium text-gray-700 mb-1"><%= defn[:label] %></label>
                          <%
                            key = defn[:key]
                            is_column = Category::VARIANT_COLUMN_ATTRIBUTES.include?(key)
                            options = defn[:options] || []
                          %>
                          <% if options.any? %>
                            <%= vf.select key.to_sym, options, { include_blank: "Select #{defn[:label].downcase}..." }, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' if is_column %>
                            <% unless is_column %>
                              <select name="product[variants_attributes][0][properties][<%= key %>]"
                                      class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500">
                                <option value="">Select <%= defn[:label].downcase %>...</option>
                                <% options.each do |opt| %>
                                  <option value="<%= opt %>"><%= opt %></option>
                                <% end %>
                              </select>
                            <% end %>
                          <% else %>
                            <% if is_column %>
                              <%= vf.text_field key.to_sym, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
                            <% else %>
                              <input type="text" name="product[variants_attributes][0][properties][<%= key %>]"
                                     class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500">
                            <% end %>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                <% end %>
              <% else %>
                <p class="text-sm text-gray-400 italic py-2">Select a category to see variant attributes (color, size, etc.)</p>
              <% end %>
            </div>

            <%# Display variant errors at the top of the variant section %>
            <% if vf.object.errors.any? %>
              <div class="rounded-md bg-red-50 p-3 mb-4">
                <ul class="text-sm text-red-700 list-disc list-inside">
                  <% vf.object.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div>
              <%= vf.label :name, 'Variant Name', class: 'block text-sm font-medium text-gray-700 mb-1' %>
              <%= vf.text_field :name, placeholder: 'Auto-generated from color/size if blank (e.g. "Gold / Free Size")', class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
            </div>

            <div class="grid grid-cols-2 gap-4" data-controller="price-validation" data-action="submit->price-validation#submit">
              <div>
                <%= vf.label :price, 'Selling Price (₹)', class: 'block text-sm font-medium text-gray-700 mb-1' %>
                <%= vf.number_field :price, step: 0.01, min: 0, required: true,
                    data: { "price-validation-target": "sellingPrice", action: "input->price-validation#validatePrices" },
                    class: "w-full px-4 py-2 border rounded-md focus:ring-indigo-500 focus:border-indigo-500 #{vf.object.errors[:price].any? ? 'border-red-500' : 'border-gray-300'}" %>
                <% if vf.object.errors[:price].any? %>
                  <p class="mt-1 text-sm text-red-600"><%= vf.object.errors[:price].join(", ") %></p>
                <% else %>
                  <p class="mt-1 text-xs text-gray-500">Customer-facing price shown on storefront</p>
                <% end %>
              </div>
              <div>
                <%= vf.label :compare_at_price, 'MRP / Compare Price (₹)', class: 'block text-sm font-medium text-gray-700 mb-1' %>
                <%= vf.number_field :compare_at_price, step: 0.01, min: 0,
                    data: { "price-validation-target": "mrp", action: "input->price-validation#validatePrices" },
                    class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
                <p class="mt-1 text-xs text-gray-500">Shown as struck-through if higher than selling price</p>
              </div>
              <div class="col-span-2 hidden" data-price-validation-target="errorMessage">
                <p class="text-sm text-red-600"></p>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <%= vf.label :stock_quantity, 'Stock Quantity', class: 'block text-sm font-medium text-gray-700 mb-1' %>
                <%= vf.number_field :stock_quantity, min: 0, required: true, value: vf.object.stock_quantity || 0, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
                <p class="mt-1 text-xs text-amber-600">Set to 0 to show as "Sold Out" on storefront</p>
              </div>
              <div>
                <%= vf.label :weight, 'Weight (g)', class: 'block text-sm font-medium text-gray-700 mb-1' %>
                <%= vf.number_field :weight, step: 0.01, min: 0, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
              </div>
            </div>

            <div>
              <%= vf.label :sku, 'Variant SKU', class: 'block text-sm font-medium text-gray-700 mb-1' %>
              <%= vf.text_field :sku, placeholder: 'Auto-generated if blank', class: "w-full px-4 py-2 border rounded-md focus:ring-indigo-500 focus:border-indigo-500 #{vf.object.errors[:sku].any? ? 'border-red-500' : 'border-gray-300'}" %>
              <% if vf.object.errors[:sku].any? %>
                <p class="mt-1 text-sm text-red-600"><%= vf.object.errors[:sku].join(", ") %></p>
              <% end %>
            </div>

            <!-- Inventory Management for inline variant -->
            <div class="border-t border-gray-200 pt-4 mt-4">
              <h4 class="text-sm font-semibold text-gray-900 mb-3">Inventory Management</h4>
              
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <%= vf.label :track_inventory, class: 'flex items-center' do %>
                    <%= vf.check_box :track_inventory, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
                    <span class="ml-2 text-sm text-gray-700">Track Inventory</span>
                  <% end %>
                  <p class="text-xs text-gray-500 ml-6 mt-1">Auto-adjust on orders</p>
                </div>
                <div>
                  <%= vf.label :reorder_point, 'Reorder Alert Level', class: 'block text-sm font-medium text-gray-700 mb-1' %>
                  <%= vf.number_field :reorder_point, min: 0, value: vf.object.reorder_point || 10, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
                </div>
              </div>
            </div>

            <div>
              <%= vf.label :image, 'Variant Image', class: 'block text-sm font-medium text-gray-700 mb-1' %>
              <%= vf.file_field :image, accept: 'image/*', class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
              <p class="mt-1 text-xs text-gray-500">Shown on product card. Falls back to product images if not set.</p>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Images -->
      <div class="bg-white rounded-lg shadow-sm p-6 space-y-4">
        <h3 class="text-base font-semibold text-gray-900 border-b border-gray-200 pb-3">Product Images</h3>

        <% if product.persisted? && product.images.attached? %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Current Images</label>
            <div class="grid grid-cols-5 gap-3">
              <% product.images.each do |image| %>
                <div class="relative group">
                  <%= image_tag image, class: 'w-full aspect-square object-cover rounded-lg border border-gray-200' %>
                  <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-40 transition-all rounded-lg flex items-center justify-center">
                    <label class="opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer">
                      <%= check_box_tag 'product[remove_image_ids][]', image.id, false, 
                          class: 'h-5 w-5 text-red-600 focus:ring-red-500 border-gray-300 rounded',
                          id: "remove_image_#{image.id}" %>
                      <span class="sr-only">Remove this image</span>
                    </label>
                  </div>
                  <div class="absolute top-1 right-1 opacity-0 group-hover:opacity-100 transition-opacity">
                    <label for="remove_image_<%= image.id %>" class="inline-flex items-center px-2 py-1 bg-red-600 text-white text-xs rounded cursor-pointer hover:bg-red-700">
                      Remove
                    </label>
                  </div>
                </div>
              <% end %>
            </div>
            <p class="mt-2 text-xs text-gray-500">Hover over images and click "Remove" to delete them</p>
          </div>
        <% end %>

        <div>
          <%= f.label :images, 'Add New Images', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.file_field :images,
                           multiple: true,
                           class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500',
                           accept: 'image/*',
                           data: { "multi-image-preview-target": "input", action: "change->multi-image-preview#change" } %>
          <p class="mt-1 text-xs text-gray-500">Select up to 15 images total. The first image is used on cards unless a variant image exists.</p>
          <div data-multi-image-preview-target="error" class="hidden mt-2 text-sm text-red-600"></div>
          <% if product.errors[:images].any? %>
            <p class="mt-1 text-sm text-red-600"><%= product.errors[:images].join(", ") %></p>
          <% end %>
        </div>

        <div class="flex items-center gap-6">
          <label class="flex items-center">
            <%= f.check_box :active, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
            <span class="ml-2 text-sm text-gray-700">Active</span>
          </label>
          <label class="flex items-center">
            <%= f.check_box :featured, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
            <span class="ml-2 text-sm text-gray-700">Featured</span>
          </label>
          <label class="flex items-center">
            <%= f.check_box :hot_selling, class: 'h-4 w-4 text-rose-600 focus:ring-rose-500 border-gray-300 rounded' %>
            <span class="ml-2 text-sm text-gray-700">Hot Selling</span>
          </label>
        </div>
      </div>
    </div>

    <!-- ─── Right Column: Preview ─── -->
    <div class="lg:col-span-5">
      <div class="bg-white rounded-lg shadow-sm p-6 lg:sticky lg:top-24">
        <div class="flex items-start justify-between">
          <h3 class="text-sm font-semibold text-gray-900">Storefront Preview</h3>
          <span class="text-xs text-gray-500">Primary image</span>
        </div>

        <div class="mt-4 aspect-square bg-stone-50 rounded-xl overflow-hidden border border-stone-200">
          <% preview_src = (product.persisted? && product.images.attached?) ? url_for(product.images.first) : '' %>
          <img src="<%= preview_src %>" class="w-full h-full object-cover <%= preview_src.present? ? '' : 'hidden' %>" data-multi-image-preview-target="main" alt="">
          <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-rose-50 to-amber-50 <%= preview_src.present? ? 'hidden' : '' %>" data-multi-image-preview-target="placeholder">
            <svg class="w-16 h-16 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
            </svg>
          </div>
        </div>

        <div class="mt-3 grid grid-cols-5 gap-2" data-multi-image-preview-target="thumbs">
          <% if product.persisted? && product.images.attached? %>
            <% product.images.each do |img| %>
              <button type="button"
                      class="aspect-square bg-stone-50 rounded-lg overflow-hidden border border-stone-200"
                      data-action="click->multi-image-preview#select"
                      data-url="<%= url_for(img) %>">
                <%= image_tag img, class: 'w-full h-full object-cover' %>
              </button>
            <% end %>
          <% end %>
        </div>

        <p class="mt-3 text-xs text-gray-500">Select multiple images — the first one is used on cards unless a variant image exists.</p>
      </div>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to 'Cancel', admin_products_path, class: 'px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50' %>
    <%= f.submit (product.new_record? ? 'Create Product' : 'Save Product'), class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
  </div>
<% end %>
