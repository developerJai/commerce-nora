<% content_for(:title) { "Products" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Products</h1>
    <%= link_to 'Add Product', new_admin_product_path, class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700' %>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-lg shadow-sm p-4">
    <%= form_with url: admin_products_path, method: :get, class: 'flex gap-4' do |f| %>
      <%= f.search_field :q, value: @q, placeholder: 'Search products...', 
          class: 'flex-1 px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
      <%= f.select :category_id, options_from_collection_for_select(@categories, :id, :name, @category_id), 
          { include_blank: 'All Categories' }, 
          class: 'px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
      <%= f.submit 'Filter', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
    <% end %>
  </div>

  <!-- Table -->
  <div class="bg-white rounded-lg shadow-sm overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Stock</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @products.each do |product| %>
          <tr>
            <td class="px-6 py-4">
              <div class="flex items-center">
                <div class="h-12 w-12 flex-shrink-0 bg-gray-100 rounded">
                  <% if product.images.attached? %>
                    <%= image_tag product.images.first, class: 'h-12 w-12 object-cover rounded' %>
                  <% end %>
                </div>
                <div class="ml-4">
                  <div class="text-sm font-medium text-gray-900"><%= product.name %></div>
                  <div class="text-sm text-gray-500"><%= product.variants.count %> variants</div>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= product.category&.name || '-' %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= format_price(product.min_price) %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= product.variants.sum(:stock_quantity) %></td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full <%= product.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                <%= product.active? ? 'Active' : 'Draft' %>
              </span>
              <% if product.featured? %>
                <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-indigo-100 text-indigo-800 ml-1">Featured</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= link_to 'View', admin_product_path(product), class: 'text-indigo-600 hover:text-indigo-900 mr-3' %>
              <%= link_to 'Edit', edit_admin_product_path(product), class: 'text-gray-600 hover:text-gray-900' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%== @pagy.series_nav if @pagy.last > 1 %>
</div>
