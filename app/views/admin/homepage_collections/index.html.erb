<% content_for(:title) { "Homepage Collections" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Homepage Collections</h1>
      <p class="mt-1 text-sm text-gray-500">Manage image collection sections displayed on the storefront homepage</p>
    </div>
    <%= link_to 'Add Collection', new_admin_homepage_collection_path, class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700' %>
  </div>

  <div class="bg-white rounded-lg shadow-sm overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Position</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Collection</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Layout</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Items</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Schedule</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @collections.each do |collection| %>
          <tr id="<%= dom_id(collection) %>">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= collection.position %>
            </td>
            <td class="px-6 py-4">
              <div class="text-sm font-medium text-gray-900"><%= collection.name %></div>
              <% if collection.subtitle.present? %>
                <div class="text-sm text-gray-500"><%= truncate(collection.subtitle, length: 60) %></div>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 py-1 text-xs font-medium rounded-full bg-indigo-100 text-indigo-800">
                <%= collection.layout_label %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= collection.items.size %> items
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= collection.starts_at&.strftime('%b %d, %Y') || 'Always' %> -
              <%= collection.ends_at&.strftime('%b %d, %Y') || 'Forever' %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2 py-1 text-xs font-medium rounded-full <%= collection.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                <%= collection.active? ? 'Active' : 'Inactive' %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
              <%= link_to 'Manage', admin_homepage_collection_path(collection), class: 'text-indigo-600 hover:text-indigo-900 mr-3' %>
              <%= link_to 'Edit', edit_admin_homepage_collection_path(collection), class: 'text-indigo-600 hover:text-indigo-900 mr-3' %>
              <%= button_to collection.active? ? 'Disable' : 'Enable', toggle_status_admin_homepage_collection_path(collection),
                  method: :patch,
                  class: collection.active? ? 'text-red-600 hover:text-red-900 mr-3' : 'text-green-600 hover:text-green-900 mr-3' %>
              <%= button_to 'Delete', admin_homepage_collection_path(collection), method: :delete,
                  class: 'text-red-600 hover:text-red-900',
                  form: { data: { turbo_confirm: 'Are you sure you want to delete this collection?' } } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%== @pagy.series_nav if @pagy.last > 1 %>
</div>
