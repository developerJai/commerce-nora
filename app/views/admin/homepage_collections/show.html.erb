<% content_for(:title) { @collection.name } %>

<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-3">
        <%= link_to admin_homepage_collections_path, class: "text-gray-400 hover:text-gray-600" do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        <% end %>
        <h1 class="text-2xl font-bold text-gray-900"><%= @collection.name %></h1>
        <span class="px-2 py-1 text-xs font-medium rounded-full <%= @collection.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
          <%= @collection.active? ? "Active" : "Inactive" %>
        </span>
      </div>
      <% if @collection.subtitle.present? %>
        <p class="mt-1 text-sm text-gray-500 ml-8"><%= @collection.subtitle %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Edit Collection", edit_admin_homepage_collection_path(@collection), class: "px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50" %>
      <%= link_to "Add Item", new_admin_homepage_collection_item_path(@collection), class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
    </div>
  </div>

  <!-- Collection Info -->
  <div class="bg-white rounded-lg shadow-sm p-6">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-6">
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase">Layout</p>
        <p class="mt-1 text-sm font-medium text-gray-900"><%= @collection.layout_label %></p>
      </div>
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase">Items</p>
        <p class="mt-1 text-sm font-medium text-gray-900">
          <%= @items.size %> / <%= @collection.min_items_for_layout %> recommended
        </p>
      </div>
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase">Schedule</p>
        <p class="mt-1 text-sm text-gray-900">
          <%= @collection.starts_at&.strftime("%b %d, %Y") || "Always" %> &ndash;
          <%= @collection.ends_at&.strftime("%b %d, %Y") || "Forever" %>
        </p>
      </div>
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase">Position</p>
        <p class="mt-1 text-sm font-medium text-gray-900">#<%= @collection.position %></p>
      </div>
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase">Max File Size</p>
        <p class="mt-1 text-sm font-medium text-gray-900">2 MB per image</p>
      </div>
    </div>

    <!-- Dimension guide for this layout -->
    <div class="mt-4 pt-4 border-t border-gray-100">
      <p class="text-xs font-semibold text-gray-700 mb-2">Recommended image dimensions</p>
      <div class="flex flex-wrap gap-3">
        <% seen = Set.new %>
        <% @collection.min_items_for_layout.times do |i| %>
          <% d = @collection.dimension_for_position(i) %>
          <% key = "#{d[:width]}x#{d[:height]}" %>
          <% next if seen.include?(key) %>
          <% seen << key %>
          <div class="px-3 py-1.5 bg-indigo-50 border border-indigo-100 rounded-md">
            <span class="text-xs font-medium text-indigo-800"><%= d[:label] %></span>
            <span class="text-xs text-indigo-600 ml-1"><%= d[:width] %> &times; <%= d[:height] %>px (<%= d[:ratio] %>)</span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- ═══ STOREFRONT PREVIEW ═══ -->
  <% if @items.any? %>
    <div class="bg-white rounded-lg shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <div>
          <h2 class="text-lg font-medium text-gray-900">Storefront Preview</h2>
          <p class="text-xs text-gray-500 mt-0.5">This is how the section will appear on the homepage</p>
        </div>
        <span class="text-xs text-gray-400 bg-gray-100 px-2 py-1 rounded">Read-only preview</span>
      </div>

      <!-- Preview area with storefront-like background -->
      <div class="bg-stone-50 p-6 sm:p-8">
        <!-- Section header preview -->
        <div class="text-center mb-6">
          <h3 class="text-xl sm:text-2xl font-serif font-semibold text-stone-900"><%= @collection.name %></h3>
          <% if @collection.subtitle.present? %>
            <p class="text-stone-500 text-sm mt-2 max-w-lg mx-auto"><%= @collection.subtitle %></p>
          <% end %>
          <div class="mt-3 flex justify-center">
            <div class="w-12 h-0.5 bg-rose-300 rounded-full"></div>
          </div>
        </div>

        <!-- Layout preview -->
        <%= render "admin/homepage_collections/preview_layouts/#{@collection.layout_type}", items: @items, collection: @collection %>
      </div>
    </div>
  <% end %>

  <!-- ═══ ITEMS MANAGEMENT ═══ -->
  <div class="bg-white rounded-lg shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-medium text-gray-900">Manage Items (<%= @items.size %>)</h2>
    </div>

    <% if @items.any? %>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 p-6">
        <% @items.each_with_index do |item, index| %>
          <% dims = @collection.dimension_for_position(item.position || index) %>
          <div class="relative group border border-gray-200 rounded-lg overflow-hidden">
            <% if item.image.attached? %>
              <%= image_tag item.image, class: "w-full aspect-square object-cover" %>
            <% else %>
              <div class="w-full aspect-square bg-gray-100 flex flex-col items-center justify-center gap-1">
                <svg class="w-10 h-10 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <span class="text-[10px] text-gray-400">No image</span>
                <span class="text-[10px] text-gray-400"><%= dims[:width] %>&times;<%= dims[:height] %>px</span>
              </div>
            <% end %>

            <!-- Hover overlay with actions -->
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors flex items-end">
              <div class="w-full p-3 translate-y-full group-hover:translate-y-0 transition-transform">
                <div class="flex gap-2">
                  <%= link_to "Edit", edit_admin_homepage_collection_item_path(@collection, item),
                      class: "flex-1 text-center px-3 py-1.5 bg-white text-gray-900 text-xs font-medium rounded hover:bg-gray-100 transition" %>
                  <%= button_to "Remove", admin_homepage_collection_item_path(@collection, item), method: :delete,
                      class: "flex-1 text-center px-3 py-1.5 bg-red-600 text-white text-xs font-medium rounded hover:bg-red-700 transition",
                      form: { data: { turbo_confirm: "Remove this item?" } } %>
                </div>
              </div>
            </div>

            <!-- Item Details -->
            <div class="p-3">
              <div class="flex items-center justify-between mb-1">
                <span class="text-xs text-gray-400">#<%= index + 1 %></span>
                <span class="text-xs text-gray-400">Pos: <%= item.position %></span>
              </div>
              <% if item.title.present? %>
                <p class="text-sm font-medium text-gray-900 truncate"><%= item.title %></p>
              <% end %>
              <% if item.subtitle.present? %>
                <p class="text-xs text-gray-500 truncate"><%= item.subtitle %></p>
              <% end %>
              <% if item.badge_text.present? %>
                <span class="inline-block mt-1 px-1.5 py-0.5 bg-rose-100 text-rose-700 text-xs rounded"><%= item.badge_text %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No items yet</h3>
        <p class="mt-1 text-sm text-gray-500">Add images to this collection to display on the homepage.</p>
        <div class="mt-6">
          <%= link_to "Add First Item", new_admin_homepage_collection_item_path(@collection), class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
