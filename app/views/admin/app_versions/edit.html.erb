<% content_for(:title) { "Edit App Version" } %>

<div class="max-w-2xl mx-auto space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Edit v<%= @app_version.version_number %> (<%= @app_version.platform.upcase %>)</h1>
    <p class="mt-1 text-sm text-gray-500">Update version details and release settings</p>
  </div>

  <%= render "form", app_version: @app_version %>
</div>
