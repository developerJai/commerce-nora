<div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Version</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Released</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Notes</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% versions.each do |version| %>
        <tr class="<%= version.active? ? '' : 'bg-gray-50 opacity-60' %>">
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="text-sm font-semibold text-gray-900">v<%= version.version_number %></span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <% if version.force_update? %>
              <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                Force Update
              </span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                Normal
              </span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <% if version.active? %>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                Active
              </span>
            <% else %>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                <span class="w-1.5 h-1.5 bg-gray-400 rounded-full"></span>
                Inactive
              </span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= version.released_at ? version.released_at.strftime("%b %d, %Y") : "—" %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500 max-w-xs truncate">
            <%= version.release_notes.present? ? truncate(version.release_notes, length: 60) : "—" %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
            <div class="flex items-center justify-end gap-2">
              <%= link_to edit_admin_app_version_path(version), class: "text-indigo-600 hover:text-indigo-900 font-medium" do %>
                Edit
              <% end %>
              <%= button_to toggle_status_admin_app_version_path(version), method: :patch, class: "text-sm font-medium #{version.active? ? 'text-amber-600 hover:text-amber-700' : 'text-green-600 hover:text-green-700'}" do %>
                <%= version.active? ? "Deactivate" : "Activate" %>
              <% end %>
              <%= button_to admin_app_version_path(version), method: :delete, data: { turbo_confirm: "Delete v#{version.version_number}? This cannot be undone." }, class: "text-red-600 hover:text-red-700 font-medium text-sm" do %>
                Delete
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
