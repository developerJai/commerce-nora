<% content_for(:title) { "Edit Homepage Settings" } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Edit Homepage Settings</h1>
    <%= link_to 'Cancel', admin_homepage_settings_path, class: 'px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50' %>
  </div>

  <%= form_with model: [:admin, @settings], url: admin_homepage_settings_path, class: 'space-y-6' do |f| %>
    <% if @settings.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <ul class="text-sm text-red-700 list-disc list-inside">
          <% @settings.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Flash Sale Section -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-rose-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
        Flash Sale Section
      </h2>
      
      <div class="space-y-4">
        <div class="flex items-center">
          <%= f.check_box :flash_sale_enabled, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
          <%= f.label :flash_sale_enabled, 'Enable Flash Sale Section', class: 'ml-2 text-sm text-gray-700' %>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :flash_sale_title, class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :flash_sale_title, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <div>
            <%= f.label :flash_sale_heading, class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :flash_sale_heading, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
        </div>
        
        <div>
          <%= f.label :flash_sale_description, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_area :flash_sale_description, rows: 2, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <%= f.label :flash_sale_discount, 'Discount Percentage', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.number_field :flash_sale_discount, min: 1, max: 100, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <div>
            <%= f.label :flash_sale_cta_text, 'CTA Button Text', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :flash_sale_cta_text, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <div>
            <%= f.label :flash_sale_cta_link, 'CTA Link', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :flash_sale_cta_link, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
        </div>
        
        <div>
          <%= f.label :flash_sale_ends_at, 'Sale Ends At (optional)', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.datetime_local_field :flash_sale_ends_at, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          <p class="mt-1 text-xs text-gray-500">Leave blank for no end date</p>
        </div>
      </div>
    </div>

    <!-- Promotional Banner Section -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
        </svg>
        Promotional Banner
      </h2>
      
      <div class="space-y-4">
        <div class="flex items-center">
          <%= f.check_box :promo_banner_enabled, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
          <%= f.label :promo_banner_enabled, 'Enable Promotional Banner', class: 'ml-2 text-sm text-gray-700' %>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :promo_banner_title, class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :promo_banner_title, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <div>
            <%= f.label :promo_banner_heading, class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :promo_banner_heading, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <%= f.label :promo_banner_code, 'Promo Code', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :promo_banner_code, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <div>
            <%= f.label :promo_banner_cta_text, 'CTA Button Text', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :promo_banner_cta_text, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <div>
            <%= f.label :promo_banner_cta_link, 'CTA Link', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :promo_banner_cta_link, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
        </div>
      </div>
    </div>

    <!-- Bundle Deals Section -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
        </svg>
        Bundle Deals Section
      </h2>
      
      <div class="space-y-4">
        <div class="flex items-center">
          <%= f.check_box :bundle_deals_enabled, class: 'h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
          <%= f.label :bundle_deals_enabled, 'Enable Bundle Deals Section', class: 'ml-2 text-sm text-gray-700' %>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :bundle_deals_title, class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :bundle_deals_title, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
          <div>
            <%= f.label :bundle_deals_heading, class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= f.text_field :bundle_deals_heading, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
          </div>
        </div>
        
        <div>
          <%= f.label :bundle_deals_description, class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= f.text_area :bundle_deals_description, rows: 2, class: 'w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500' %>
        </div>
      </div>
    </div>

    <!-- Homepage Section Toggles -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Homepage Sections Visibility
      </h2>
      <p class="text-sm text-gray-500 mb-4">Toggle sections on/off from the storefront homepage</p>
      
      <div class="space-y-4">
        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
          <div class="flex items-center gap-3">
            <span class="text-2xl">🎁</span>
            <div>
              <p class="font-medium text-gray-900">Perfect Presents</p>
              <p class="text-xs text-gray-500">Gifts & Celebrations</p>
            </div>
          </div>
          <%= f.check_box :gifts_section_enabled, class: 'h-5 w-5 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
        </div>

        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
          <div class="flex items-center gap-3">
            <span class="text-2xl">⚡</span>
            <div>
              <p class="font-medium text-gray-900">Flash Sale</p>
              <p class="text-xs text-gray-500">Discount Banner</p>
            </div>
          </div>
          <%= f.check_box :flash_sale_enabled, class: 'h-5 w-5 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
        </div>

        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
          <div class="flex items-center gap-3">
            <span class="text-2xl">💎</span>
            <div>
              <p class="font-medium text-gray-900">Handcrafted with Love</p>
              <p class="text-xs text-gray-500">Beautiful Jewellery Collection</p>
            </div>
          </div>
          <%= f.check_box :artisan_section_enabled, class: 'h-5 w-5 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
        </div>

        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
          <div class="flex items-center gap-3">
            <span class="text-2xl">👗</span>
            <div>
              <p class="font-medium text-gray-900">Ethnic Wear</p>
              <p class="text-xs text-gray-500">Collection</p>
            </div>
          </div>
          <%= f.check_box :ethnic_section_enabled, class: 'h-5 w-5 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded' %>
        </div>
      </div>
    </div>

    <div class="flex justify-end gap-3">
      <%= link_to 'Cancel', admin_homepage_settings_path, class: 'px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50' %>
      <%= f.submit 'Save Settings', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
    </div>
  <% end %>
</div>
