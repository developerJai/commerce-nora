<% content_for(:title) { "Payment Failed" } %>

<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4 py-12">
  <div class="max-w-md w-full">
    <!-- Main Card -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <!-- Header with Icon -->
      <div class="bg-red-50 px-8 py-10 text-center">
        <div class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4 ring-4 ring-red-50">
          <svg class="w-10 h-10 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 mb-2">Payment Failed</h1>
        <p class="text-red-700 text-sm">We couldn't process your payment</p>
      </div>

      <!-- Body -->
      <div class="px-8 py-6">
        <% if @error_description.present? %>
          <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <p class="text-sm text-red-800"><%= @error_description %></p>
            </div>
          </div>
        <% end %>

        <% if @orders.any? %>
          <div class="bg-gray-50 rounded-lg p-4 mb-6">
            <div class="flex items-center justify-between mb-3 pb-3 border-b border-gray-200">
              <span class="text-sm text-gray-600">Order ID</span>
              <span class="text-sm font-medium text-gray-900">#<%= @orders.first.order_number %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-600">Amount</span>
              <span class="text-lg font-bold text-gray-900"><%= number_to_currency(@total_amount, unit: "₹", precision: 2) %></span>
            </div>
          </div>
        <% end %>

        <!-- Action Buttons -->
        <div class="space-y-3">
          <%= link_to checkout_path, 
              class: "w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-rose-600 text-white font-semibold rounded-xl hover:bg-rose-700 transition shadow-lg shadow-rose-200" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            Try Again
          <% end %>

          <%= link_to cart_path, 
              class: "w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-white border-2 border-gray-300 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            Return to Cart
          <% end %>
        </div>

        <!-- Help Section -->
        <div class="mt-6 pt-6 border-t border-gray-200">
          <p class="text-center text-sm text-gray-500 mb-3">Need assistance?</p>
          <div class="flex justify-center gap-6 text-sm">
            <%= mail_to "support@noralooks.com", class: "text-rose-600 hover:text-rose-700 font-medium flex items-center gap-1" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Contact Us
            <% end %>
            <%= link_to orders_path, class: "text-gray-600 hover:text-gray-700 font-medium flex items-center gap-1" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
              My Orders
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Tips Card -->
    <div class="mt-6 bg-white rounded-xl shadow-md p-6">
      <h3 class="text-sm font-semibold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Troubleshooting Tips
      </h3>
      <ul class="space-y-2 text-sm text-gray-600">
        <li class="flex items-start gap-2">
          <span class="text-rose-500 mt-1">•</span>
          <span>Check if your card has sufficient balance</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-rose-500 mt-1">•</span>
          <span>Verify your bank hasn't blocked the transaction</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-rose-500 mt-1">•</span>
          <span>Try a different payment method (UPI/Card/Netbanking)</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-rose-500 mt-1">•</span>
          <span>Ensure stable internet connection</span>
        </li>
      </ul>
    </div>
  </div>
</div>
