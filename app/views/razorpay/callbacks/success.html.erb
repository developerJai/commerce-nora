<% content_for(:title) { "Payment Successful" } %>

<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4 py-12">
  <div class="max-w-lg w-full">
    <!-- Main Card -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <!-- Header with Success Animation -->
      <div class="bg-emerald-50 px-8 py-10 text-center">
        <div class="w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4 ring-4 ring-emerald-50">
          <svg class="w-10 h-10 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 mb-2">Payment Successful!</h1>
        <p class="text-emerald-700 text-sm">
          <% if @orders&.size&.> 1 %>
            <%= @orders.size %> orders have been confirmed
          <% else %>
            Your order has been confirmed
          <% end %>
        </p>
      </div>

      <!-- Body -->
      <div class="px-8 py-6">
        <!-- Checkout Session Details -->
        <% if @checkout_session %>
          <div class="bg-blue-50 rounded-xl p-5 mb-6 border border-blue-200">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-sm font-semibold text-blue-900">Payment Details</h3>
              <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded-full">
                <%= @checkout_session.payment_method.upcase %>
              </span>
            </div>
            <div class="text-xs text-blue-700 mb-2">
              Session ID: <%= @checkout_session.batch_id.first(16) %>
            </div>
            <% if @checkout_session.razorpay_payment_id %>
              <div class="text-xs text-blue-600">
                Transaction: <%= @checkout_session.razorpay_payment_id %>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- Multi-Vendor Order Details -->
        <% if @orders&.size&.> 1 %>
          <!-- Multiple Vendor Orders -->
          <div class="bg-gray-50 rounded-xl p-5 mb-6">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">Order Summary (<%= @orders.size %> Orders)</h3>
            
            <% @orders.each_with_index do |order, index| %>
              <div class="<%= index > 0 ? 'border-t border-gray-200 pt-3 mt-3' : '' %>">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm text-gray-600">Order #<%= order.order_number %></span>
                  <span class="text-sm font-medium text-gray-900"><%= number_to_currency(order.total_amount, unit: "₹", precision: 2) %></span>
                </div>
                <p class="text-xs text-gray-500">
                  <%= order.order_items.count %> item(s) from <%= order.vendor&.business_name || "Vendor ##{order.vendor_id}" %>
                </p>
                <% if order.vendor %>
                  <p class="text-xs text-gray-400 mt-1">
                    Vendor: <%= order.vendor.business_name %>
                  </p>
                <% end %>
              </div>
            <% end %>
            
            <div class="border-t-2 border-gray-300 pt-3 mt-3">
              <div class="flex items-center justify-between">
                <span class="text-sm font-semibold text-gray-900">Total Amount Paid</span>
                <span class="text-xl font-bold text-emerald-600">
                  <%= number_to_currency(@total_amount, unit: "₹", precision: 2) %>
                </span>
              </div>
              <p class="text-xs text-gray-500 mt-1 text-right">
                Paid on <%= Time.current.strftime("%B %d, %Y at %I:%M %p") %>
              </p>
            </div>
          </div>
        <% else %>
          <!-- Single Order -->
          <div class="bg-gray-50 rounded-xl p-5 mb-6">
            <div class="text-center mb-4">
              <p class="text-sm text-gray-500 mb-1">Order ID</p>
              <p class="text-xl font-bold text-gray-900">#<%= @orders&.first&.order_number || @order&.order_number %></p>
            </div>
            
            <div class="border-t border-gray-200 pt-4">
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm text-gray-600">Payment Method</span>
                <span class="text-sm font-medium text-gray-900">
                  <%= @checkout_session&.payment_method&.upcase || "Online Payment" %>
                </span>
              </div>
              <% if @checkout_session %>
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm text-gray-600">Transaction ID</span>
                  <span class="text-xs font-mono text-gray-900"><%= @checkout_session.razorpay_payment_id %></span>
                </div>
              <% end %>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-600">Total Amount</span>
                <span class="text-xl font-bold text-emerald-600">
                  <%= number_to_currency(@total_amount || @orders&.first&.total_amount || @order&.total_amount, unit: "₹", precision: 2) %>
                </span>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Delivery Info -->
        <div class="flex items-start gap-3 mb-6 p-4 bg-blue-50 rounded-lg">
          <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div>
            <p class="text-sm font-medium text-blue-900">What's Next?</p>
            <p class="text-sm text-blue-700 mt-1">
              We've sent a confirmation email to you. 
              <% if @orders&.size&.> 1 %>
                Each vendor will process and ship their items within 24-48 hours.
              <% else %>
                Your order will be processed and shipped within 24-48 hours.
              <% end %>
            </p>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="space-y-3">
          <% if @orders&.size == 1 %>
            <%= link_to order_path(@orders.first || @order), 
                class: "w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-emerald-600 text-white font-semibold rounded-xl hover:bg-emerald-700 transition shadow-lg shadow-emerald-200" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              View Order Details
            <% end %>
          <% else %>
            <%= link_to orders_path, 
                class: "w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-emerald-600 text-white font-semibold rounded-xl hover:bg-emerald-700 transition shadow-lg shadow-emerald-200" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
              View All Orders
            <% end %>
          <% end %>

          <%= link_to root_path, 
              class: "w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-white border-2 border-gray-300 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 transition" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            Continue Shopping
          <% end %>
        </div>

        <!-- Contact Info -->
        <div class="mt-6 pt-6 border-t border-gray-200 text-center">
          <p class="text-sm text-gray-500 mb-3">Need help with your order?</p>
          <div class="flex justify-center gap-6 text-sm">
            <%= mail_to "support@noralooks.com", class: "text-emerald-600 hover:text-emerald-700 font-medium flex items-center gap-1" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Contact Support
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="mt-6 grid grid-cols-3 gap-4">
      <%= link_to orders_path, class: "bg-white rounded-xl shadow-md p-4 text-center hover:shadow-lg transition" do %>
        <div class="w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center mx-auto mb-2">
          <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <p class="text-xs font-medium text-gray-700">My Orders</p>
      <% end %>

      <%= link_to account_path, class: "bg-white rounded-xl shadow-md p-4 text-center hover:shadow-lg transition" do %>
        <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-2">
          <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <p class="text-xs font-medium text-gray-700">My Account</p>
      <% end %>

      <%= link_to products_path, class: "bg-white rounded-xl shadow-md p-4 text-center hover:shadow-lg transition" do %>
        <div class="w-10 h-10 bg-rose-100 rounded-full flex items-center justify-center mx-auto mb-2">
          <svg class="w-5 h-5 text-rose-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
        </div>
        <p class="text-xs font-medium text-gray-700">Shop More</p>
      <% end %>
    </div>
  </div>
</div>
