<% content_for(:title) { "Payment Successful" } %>

<div class="min-h-[calc(100vh-4rem)] bg-stone-50 flex flex-col items-center justify-center px-4 py-8 sm:py-12">
  <div class="w-full max-w-md mx-auto">

    <!-- Success Icon + Message -->
    <div class="text-center mb-6 sm:mb-8">
      <div class="relative w-20 h-20 sm:w-24 sm:h-24 mx-auto mb-5">
        <div class="absolute inset-0 bg-emerald-100 rounded-full animate-ping opacity-20"></div>
        <div class="relative w-full h-full bg-gradient-to-br from-emerald-400 to-emerald-600 rounded-full flex items-center justify-center shadow-lg shadow-emerald-200">
          <svg class="w-10 h-10 sm:w-12 sm:h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
      </div>
      <h1 class="text-xl sm:text-2xl font-sans font-bold text-stone-900 mb-1.5">Payment Successful</h1>
      <p class="text-sm text-stone-500 font-sans">
        <% if @orders&.size&.> 1 %>
          <%= @orders.size %> orders have been placed successfully
        <% else %>
          Your order has been placed successfully
        <% end %>
      </p>
    </div>

    <!-- Order Card -->
    <div class="bg-white rounded-2xl border border-stone-200 shadow-sm overflow-hidden mb-4">
      <% if @orders&.size&.> 1 %>
        <!-- Multi-vendor orders -->
        <div class="px-4 sm:px-5 py-3.5 border-b border-stone-100 bg-stone-50/50">
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wider font-sans">Order Summary</p>
        </div>
        <div class="divide-y divide-stone-100">
          <% @orders.each do |order| %>
            <div class="px-4 sm:px-5 py-3.5">
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-semibold text-stone-900 font-sans">#<%= order.order_number %></span>
                <span class="text-sm font-bold text-stone-900 font-sans"><%= number_to_currency(order.total_amount, unit: "\u20B9", precision: 2) %></span>
              </div>
              <p class="text-xs text-stone-500 font-sans">
                <%= order.order_items.count %> item(s) from <%= order.vendor&.business_name || "Vendor" %>
              </p>
            </div>
          <% end %>
        </div>
        <div class="px-4 sm:px-5 py-3.5 bg-emerald-50/60 border-t border-emerald-100">
          <div class="flex items-center justify-between">
            <span class="text-sm font-semibold text-stone-700 font-sans">Total Paid</span>
            <span class="text-lg font-bold text-emerald-700 font-sans"><%= number_to_currency(@total_amount, unit: "\u20B9", precision: 2) %></span>
          </div>
        </div>
      <% else %>
        <!-- Single order -->
        <div class="px-4 sm:px-5 py-4 sm:py-5">
          <div class="flex items-center justify-between mb-3">
            <div>
              <p class="text-xs text-stone-400 font-sans mb-0.5">Order Number</p>
              <p class="text-base font-bold text-stone-900 font-sans">#<%= @orders&.first&.order_number || @order&.order_number %></p>
            </div>
            <div class="text-right">
              <p class="text-xs text-stone-400 font-sans mb-0.5">Amount Paid</p>
              <p class="text-base font-bold text-emerald-700 font-sans"><%= number_to_currency(@total_amount || @orders&.first&.total_amount || @order&.total_amount, unit: "\u20B9", precision: 2) %></p>
            </div>
          </div>

          <div class="flex items-center gap-2 pt-3 border-t border-stone-100">
            <% if @checkout_session&.payment_method %>
              <span class="inline-flex items-center gap-1 text-xs font-medium text-stone-600 bg-stone-100 px-2 py-1 rounded-md font-sans">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                </svg>
                <%= @checkout_session.payment_method.upcase %>
              </span>
            <% end %>
            <span class="text-xs text-stone-400 font-sans"><%= Time.current.strftime("%b %d, %Y \u00B7 %I:%M %p") %></span>
          </div>
        </div>
      <% end %>
    </div>

    <!-- What's Next -->
    <div class="bg-white rounded-2xl border border-stone-200 shadow-sm px-4 sm:px-5 py-4 mb-6 sm:mb-8">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-amber-50 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-stone-900 font-sans mb-0.5">What's next?</p>
          <p class="text-xs text-stone-500 leading-relaxed font-sans">
            We've sent a confirmation to your email.
            <% if @orders&.size&.> 1 %>
              Each vendor will process and ship their items within 24-48 hours.
            <% else %>
              Your order will be processed and shipped within 24-48 hours.
            <% end %>
          </p>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="space-y-2.5 mb-6 sm:mb-8">
      <% if @orders&.size == 1 %>
        <%= link_to order_path(@orders.first || @order),
            class: "w-full flex items-center justify-center gap-2 px-5 py-3 bg-stone-900 text-white text-sm font-semibold font-sans rounded-xl hover:bg-stone-800 transition shadow-sm" do %>
          View Order Details
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      <% else %>
        <%= link_to orders_path,
            class: "w-full flex items-center justify-center gap-2 px-5 py-3 bg-stone-900 text-white text-sm font-semibold font-sans rounded-xl hover:bg-stone-800 transition shadow-sm" do %>
          View All Orders
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      <% end %>

      <%= link_to products_path,
          class: "w-full flex items-center justify-center gap-2 px-5 py-3 bg-white border border-stone-200 text-stone-700 text-sm font-semibold font-sans rounded-xl hover:bg-stone-50 transition" do %>
        Continue Shopping
      <% end %>
    </div>

    <!-- Quick Links -->
    <div class="grid grid-cols-3 gap-2.5">
      <%= link_to orders_path, class: "bg-white rounded-xl border border-stone-200 p-3 sm:p-4 text-center hover:border-stone-300 hover:shadow-sm transition group" do %>
        <div class="w-9 h-9 sm:w-10 sm:h-10 mx-auto mb-1.5 bg-rose-50 rounded-xl flex items-center justify-center">
          <svg class="w-4 h-4 sm:w-5 sm:h-5 text-rose-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
        </div>
        <p class="text-[11px] sm:text-xs font-medium text-stone-600 font-sans">My Orders</p>
      <% end %>

      <%= link_to account_path, class: "bg-white rounded-xl border border-stone-200 p-3 sm:p-4 text-center hover:border-stone-300 hover:shadow-sm transition group" do %>
        <div class="w-9 h-9 sm:w-10 sm:h-10 mx-auto mb-1.5 bg-purple-50 rounded-xl flex items-center justify-center">
          <svg class="w-4 h-4 sm:w-5 sm:h-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <p class="text-[11px] sm:text-xs font-medium text-stone-600 font-sans">Account</p>
      <% end %>

      <%= link_to support_tickets_path, class: "bg-white rounded-xl border border-stone-200 p-3 sm:p-4 text-center hover:border-stone-300 hover:shadow-sm transition group" do %>
        <div class="w-9 h-9 sm:w-10 sm:h-10 mx-auto mb-1.5 bg-amber-50 rounded-xl flex items-center justify-center">
          <svg class="w-4 h-4 sm:w-5 sm:h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </div>
        <p class="text-[11px] sm:text-xs font-medium text-stone-600 font-sans">Support</p>
      <% end %>
    </div>

  </div>
</div>
